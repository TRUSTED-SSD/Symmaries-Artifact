digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = #r1, js1〉", ];
  "pc1_js1" [label="〈$i1 = this.read (r1, 0, $i0), js1〉\n\
tt", ];
  "pc2_js1" [label="〈return $i1, js1〉", ];
  "pc3_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><r1)' ∨ ¬this.><r1) ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S2 ∨ pc ⊔ level($i1) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(r1) ⊔ obj_level(r1)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{this.><this := if this.><r1 then this.><r1 ∨ this.><this else this.><this,\n\
 level($i1) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  
  }