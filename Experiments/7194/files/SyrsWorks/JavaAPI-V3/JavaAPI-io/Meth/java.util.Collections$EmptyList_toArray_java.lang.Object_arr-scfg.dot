digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = #r1, js1〉", ];
  "pc1_js1" [label="〈if ($i0 <= 0) goto label0, js1〉", ];
  "pc2_js1" [label="〈r1[0] = null, js1〉", ];
  "pc3_js1" [label="〈label0: return r1, js1〉", ];
  "pc3_js2" [label="〈label0: return r1, js2〉", ];
  "pc4_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(r1.><r1)' ∨ ¬r1.><r1) ∧ (ret(r1.><this)' ∨ ¬r1.><this) ∧ (ϕ ≠ S3 ∨ ret(~r1)' ∧ obj_level(r1) ⊑ ret(obj_level())' ∧ pc ⊔ level(r1) ⊑ ret(level())' ∧ (ret(.><r1)' ∨ ¬r1.><r1) ∧ (ret(r1.><)' ∨ ¬r1.><r1) ∧ (ret(this.><)' ∨ ¬r1.><this))",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(r1) ⊔ obj_level(r1)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($i0) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($i0) ⊑ pc,\n\
{r1.><r1' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then r1.><r1' else r1.><r1,\n\
 r1.><this' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then r1.><this' else r1.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($i0),\n\
 obj_level(r1)' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(r1)' else obj_level(r1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc3_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i0) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i0) ⊑ pc,\n\
{r1.><r1' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then r1.><r1' else r1.><r1,\n\
 r1.><this' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then r1.><this' else r1.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($i0),\n\
 obj_level(r1)' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then obj_level(r1)' else obj_level(r1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{obj_level(r1) := pc ⊔ obj_level(r1)}",
                          ];
  "pc3_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt,\n\
 r1.><r1 := r1.><r1',\n\
 r1.><this := r1.><this',\n\
 r1.><r1' := r1.><r1,\n\
 r1.><this' := r1.><this,\n\
 obj_level(r1) := obj_level(r1)',\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(r1)' := obj_level(r1),\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc3_js1" -> "pc3_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := ¬(υ ∧ hr = P1) ∧ (if hr = P1 then υ ∧ ¬(υ ∧ hr = P1) else υ),\n\
 pc := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then ⊥ else pc,\n\
 obj_level(r1) := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then obj_level(r1) ⊔ (if r1.><this then obj_level(this) else ⊥) else obj_level(r1),\n\
 hr := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc3_js2" -> "pc4_js1" [label="tt,\n\
{ϕ := S3}", ];
  
  }