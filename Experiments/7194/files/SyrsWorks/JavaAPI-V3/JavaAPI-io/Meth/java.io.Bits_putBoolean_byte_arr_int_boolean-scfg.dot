digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈if (z0 == 0) goto label0, js1〉", ];
  "pc1_js1" [label="〈$z1 = 1, js1〉", ];
  "pc2_js1" [label="〈goto label1, js1〉", ];
  "pc3_js1" [label="〈label0: $z1 = 0, js1〉", ];
