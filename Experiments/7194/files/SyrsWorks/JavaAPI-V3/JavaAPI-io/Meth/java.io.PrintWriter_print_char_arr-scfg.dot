digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈this.write (r1), js1〉\n\
pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) = ⊥",
             ];
  "pc1_js1" [label="〈return, js1〉", ];
  "pc2_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><r1)' ∨ ¬this.><r1) ∧ (ret(this.><this)' ∨ ¬this.><this)",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{this.><this := this.><r1 ∨ this.><this ∨ (if this.><r1 then this.><r1 ∨ this.><this else this.><this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{ϕ := S1}", ];
  
  }