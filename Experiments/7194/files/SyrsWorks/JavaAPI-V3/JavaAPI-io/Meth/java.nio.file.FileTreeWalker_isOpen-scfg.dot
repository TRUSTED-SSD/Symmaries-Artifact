digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$z0 = this.closed, js1〉", ];
  "pc1_js1" [label="〈if ($z0 != 0) goto label0, js1〉", ];
  "pc2_js1" [label="〈$z1 = 1, js1〉", ];
  "pc3_js1" [label="〈goto label1, js1〉", ];
  "pc4_js1" [label="〈label0: $z1 = 0, js1〉", ];
  "pc5_js1" [label="〈label1: return $z1, js1〉", ];
  "pc5_js2" [label="〈label1: return $z1, js2〉", ];
  "pc6_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S5 ∨ pc ⊔ level($z1) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($z0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($z0) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($z0) ⊑ pc,\n\
{this.><this' := if ¬(¬τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($z0),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc4_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($z0) ⊐ pc ∨ τ ∧ ¬υ ∧ level($z0) ⊑ pc,\n\
{this.><this' := if ¬(τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($z0),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($z0) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($z1) := pc ⊔ (if υ then level($z1) else ⊥)}",
                          ];
  "pc3_js1" -> "pc5_js1" [label="tt,\n\
{}", ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level($z1) := pc ⊔ (if υ then level($z1) else ⊥)}",
                          ];
  "pc5_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt,\n\
 this.><this := this.><this',\n\
 this.><this' := this.><this,\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc5_js1" -> "pc5_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := υ ∧ ¬(υ ∧ hr = P1),\n\
 pc := if υ ∧ hr = P1 then ⊥ else pc,\n\
 hr := if υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc5_js2" -> "pc6_js1" [label="tt,\n\
{ϕ := S5}", ];
  
  }