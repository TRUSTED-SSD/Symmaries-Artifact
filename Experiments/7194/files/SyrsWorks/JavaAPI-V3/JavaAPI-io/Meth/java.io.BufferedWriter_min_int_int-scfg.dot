digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈if (i0 >= i1) goto label0, js1〉", ];
  "pc1_js1" [label="〈return i0, js1〉", ];
  "pc2_js1" [label="〈label0: return i1, js1〉", ];
  "pc3_js1" [label="〈sink, js1〉", ];
  "pc3_js2" [label="〈sink, js2〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S1 ∨ pc ⊔ level(i0) ⊑ ret(level())') ∧ (ϕ ≠ S2 ∨ pc ⊔ level(i1) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊑ pc,\n\
{this.><this' := if ¬(¬τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level(i0) ⊔ level(i1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ¬ω then hr else P0}",
                          ];
  "pc0_js1" -> "pc2_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc ∨ τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊑ pc,\n\
{this.><this' := if ¬(τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level(i0) ⊔ level(i1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level(i0) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ω then hr else P0}",
                          ];
  "pc1_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S1}", ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  "pc3_js1" -> "pc0_js1" [label="¬υ ∧ hr = P0,\n\
{υ := tt,\n\
 this.><this := this.><this',\n\
 this.><this' := this.><this,\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc3_js1" -> "pc3_js2" [label="hr ≠ P0 ∨ υ ∧ hr = P0,\n\
{υ := υ ∧ ¬(υ ∧ hr = P0),\n\
 hr := if υ ∧ hr = P0 then P. else hr}",
                          ];
  
  }