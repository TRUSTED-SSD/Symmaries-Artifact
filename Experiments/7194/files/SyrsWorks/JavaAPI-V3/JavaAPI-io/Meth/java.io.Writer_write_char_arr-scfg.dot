digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = #r1, js1〉", ];
  "pc1_js1" [label="〈this.write (r1, 0, $i0), js1〉\n\
pc ⊔ level(this) ⊔ obj_level(this) ⊑ ⊥ ∧ level($i0) ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) ⊑ ⊥",
             ];
  "pc2_js1" [label="〈return, js1〉", ];
  "pc3_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><r1)' ∨ ¬this.><r1) ∧ (ret(this.><this)' ∨ ¬this.><this)",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(r1) ⊔ obj_level(r1)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{this.><this := this.><r1 ∨ this.><this ∨ (if this.><r1 then this.><r1 ∨ this.><this else this.><this),\n\
 obj_level(r1) := obj_level(r1) ⊔ (if this.><r1 then pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) else ⊥) ⊔ (if this.><r1 ∧ level(r1) = ⊥ ∧ level(this) = ⊥ ∧ obj_level(r1) = ⊥ ∧ obj_level(this) = ⊥ ∧ pc ⊔ level(r1) ⊔ obj_level(r1) = ⊥ then pc ⊔ level(this) ⊔ obj_level(this) else if if obj_level(this) = ⊤ then this.><r1 ∨ obj_level(r1) = ⊤ else obj_level(this) = ⊥ ∧ (obj_level(r1) = ⊤ ∨ (if level(this) = ⊤ then this.><r1 else level(this) = ⊥ ∧ (if level(r1) = ⊤ then this.><r1 else this.><r1 ∧ level(r1) = ⊥ ∧ pc ⊔ level(r1) ⊔ obj_level(r1) = ⊤))) then ⊤ else ⊥),\n\
 obj_level(this) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) ⊔ (if this.><r1 then obj_level(r1) ⊔ (if this.><r1 ∧ level(r1) = ⊥ ∧ level(this) = ⊥ ∧ obj_level(r1) = ⊥ ∧ obj_level(this) = ⊥ ∧ pc ⊔ level(r1) ⊔ obj_level(r1) = ⊥ then pc ⊔ level(this) ⊔ obj_level(this) else if if obj_level(this) = ⊤ then this.><r1 ∨ obj_level(r1) = ⊤ else obj_level(this) = ⊥ ∧ (obj_level(r1) = ⊤ ∨ (if level(this) = ⊤ then this.><r1 else level(this) = ⊥ ∧ (if level(r1) = ⊤ then this.><r1 else this.><r1 ∧ level(r1) = ⊥ ∧ pc ⊔ level(r1) ⊔ obj_level(r1) = ⊤))) then ⊤ else ⊥) else ⊥)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  
  }