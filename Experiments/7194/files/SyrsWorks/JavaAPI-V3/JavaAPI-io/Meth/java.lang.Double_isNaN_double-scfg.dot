digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$b0 = d0 cmpl d0, js1〉", ];
  "pc1_js1" [label="〈if ($b0 == 0) goto label0, js1〉", ];
  "pc2_js1" [label="〈$z0 = 1, js1〉", ];
  "pc3_js1" [label="〈goto label1, js1〉", ];
  "pc4_js1" [label="〈label0: $z0 = 0, js1〉", ];
  "pc5_js1" [label="〈label1: return $z0, js1〉", ];
  "pc5_js2" [label="〈label1: return $z0, js2〉", ];
  "pc6_js1" [label="〈sink, js1〉\n\
ϕ ≠ S5 ∨ pc ⊔ level($z0) ⊑ ret(level())'",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($b0) := pc ⊔ level(d0)}", ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($b0) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($b0) ⊑ pc,\n\
{pc := if ¬(¬τ ∧ ¬υ ∧ level($b0) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($b0),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($b0) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc4_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($b0) ⊐ pc ∨ τ ∧ ¬υ ∧ level($b0) ⊑ pc,\n\
{pc := if ¬(τ ∧ ¬υ ∧ level($b0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($b0),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($b0) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($z0) := pc ⊔ (if υ then level($z0) else ⊥)}",
                          ];
  "pc3_js1" -> "pc5_js1" [label="tt,\n\
{}", ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level($z0) := pc ⊔ (if υ then level($z0) else ⊥)}",
                          ];
  "pc5_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt}", ];
  "pc5_js1" -> "pc5_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := υ ∧ ¬(υ ∧ hr = P1),\n\
 pc := if υ ∧ hr = P1 then ⊥ else pc,\n\
 hr := if υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc5_js2" -> "pc6_js1" [label="tt,\n\
{ϕ := S5}", ];
  
  }