digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i1 = this.tail, js1〉", ];
  "pc1_js1" [label="〈$i0 = this.head, js1〉", ];
  "pc2_js1" [label="〈$i4 = $i1 - $i0, js1〉", ];
  "pc3_js1" [label="〈$r1 = this.elements, js1〉", ];
  "pc4_js1" [label="〈$i2 = #$r1, js1〉", ];
  "pc5_js1" [label="〈$i3 = $i2 - 1, js1〉", ];
  "pc6_js1" [label="〈$i5 = $i4 & $i3, js1〉", ];
  "pc7_js1" [label="〈return $i5, js1〉", ];
  "pc8_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S7 ∨ pc ⊔ level($i5) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i4) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{$r1.><$r1 := ff,\n\
 $r1.><this := this.><this,\n\
 this.><$r1 := tt,\n\
 level($r1) := pc ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level($r1) := obj_level(this)}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level($i2) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc5_js1" -> "pc6_js1" [label="tt,\n\
{level($i3) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc6_js1" -> "pc7_js1" [label="tt,\n\
{level($i5) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc7_js1" -> "pc8_js1" [label="tt,\n\
{ϕ := S7}", ];
  
  }