digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = this.count, js1〉", ];
  "pc1_js1" [label="〈return $i0, js1〉", ];
  "pc2_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S1 ∨ pc ⊔ level($i0) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{ϕ := S1}", ];
  
  }