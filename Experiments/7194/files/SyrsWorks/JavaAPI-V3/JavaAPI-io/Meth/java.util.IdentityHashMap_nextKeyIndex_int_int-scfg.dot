digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i2 = i0 + 2, js1〉", ];
  "pc1_js1" [label="〈if ($i2 >= i1) goto label0, js1〉", ];
  "pc2_js1" [label="〈$i3 = i0 + 2, js1〉", ];
  "pc3_js1" [label="〈goto label1, js1〉", ];
  "pc4_js1" [label="〈label0: $i3 = 0, js1〉", ];
  "pc5_js1" [label="〈label1: return $i3, js1〉", ];
  "pc5_js2" [label="〈label1: return $i3, js2〉", ];
  "pc6_js1" [label="〈sink, js1〉\n\
ϕ ≠ S5 ∨ pc ⊔ level($i3) ⊑ ret(level())'",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i2) := pc ⊔ level(i0)}", ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊑ pc,\n\
{pc := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($i2) ⊔ level(i1),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc4_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊑ pc,\n\
{pc := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($i2) ⊔ level(i1),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i1) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i3) := pc ⊔ (if υ then level($i3) else level(i0))}",
                          ];
  "pc3_js1" -> "pc5_js1" [label="tt,\n\
{}", ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level($i3) := pc ⊔ (if υ then level($i3) else ⊥)}",
                          ];
  "pc5_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt}", ];
  "pc5_js1" -> "pc5_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := υ ∧ ¬(υ ∧ hr = P1),\n\
 pc := if υ ∧ hr = P1 then ⊥ else pc,\n\
 hr := if υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc5_js2" -> "pc6_js1" [label="tt,\n\
{ϕ := S5}", ];
  
  }