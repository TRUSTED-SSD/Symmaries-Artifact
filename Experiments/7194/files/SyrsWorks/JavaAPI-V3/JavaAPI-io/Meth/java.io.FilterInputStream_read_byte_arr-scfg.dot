  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{this.><r1 := tt,\n\
 this.><this := tt,\n\
 level($i1) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this),\n\
 obj_level(r1) := p0 ⊔ p1 ⊔ pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) ⊔ (if this.><r1 then pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) ⊔ (if this.><r1 then p0 ⊔ p1 ⊔ level(this) ⊔ obj_level(this) else level(this) ⊔ obj_level(r1) ⊔ obj_level(this)) ⊔ (if this.><r1 then p0 ⊔ p1 ⊔ pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) else pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this)) else ⊥),\n\
 obj_level(this) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) ⊔ (if this.><r1 then p0 ⊔ p1 ⊔ level(this) ⊔ obj_level(this) else level(this) ⊔ obj_level(r1) ⊔ obj_level(this)) ⊔ (if this.><r1 then p0 ⊔ p1 ⊔ pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) else ⊥) ⊔ (if this.><r1 then p0 ⊔ p1 ⊔ pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) else pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this))}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  
