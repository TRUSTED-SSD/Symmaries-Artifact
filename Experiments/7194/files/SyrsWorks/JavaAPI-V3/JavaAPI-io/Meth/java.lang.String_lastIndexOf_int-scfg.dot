digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$r1 = this.value, js1〉", ];
  "pc1_js1" [label="〈$i1 = #$r1, js1〉", ];
  "pc2_js1" [label="〈$i2 = $i1 - 1, js1〉", ];
  "pc3_js1" [label="〈$i3 = this.lastIndexOf (i0, $i2), js1〉\n\
tt", ];
  "pc4_js1" [label="〈return $i3, js1〉", ];
  "pc5_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S4 ∨ pc ⊔ level($i3) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{this.><$r1 := tt,\n\
 level($r1) := pc ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level($r1) := obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i2) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{level($i3) := pc ⊔ level(i0) ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{ϕ := S4}", ];
  
  }