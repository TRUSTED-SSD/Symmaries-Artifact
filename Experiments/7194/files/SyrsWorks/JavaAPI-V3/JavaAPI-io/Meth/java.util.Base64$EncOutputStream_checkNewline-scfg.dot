  "pc2_js1" -> "pc7_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊑ pc,\n\
{$r2~this' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ω then $r2~this' else $r2~this,\n\
