digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = this.savedScannerPosition, js1〉", ];
  "pc1_js1" [label="〈this.position = $i0, js1〉", ];
  "pc2_js1" [label="〈this.savedScannerPosition = - 1, js1〉", ];
  "pc3_js1" [label="〈this.skipped = 0, js1〉", ];
  "pc4_js1" [label="〈return z0, js1〉", ];
  "pc5_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S4 ∨ pc ⊔ level(z0) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{obj_level(this) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{obj_level(this) := pc ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{obj_level(this) := pc ⊔ obj_level(this)}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{ϕ := S4}", ];
  
  }