digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = #r0, js1〉", ];
  "pc1_js1" [label="〈$r1 = java.nio.CharBuffer.wrap (r0, 0, $i0), js1〉\n\
pc ⊔ level($i0) ⊔ level(r0) ⊔ obj_level(r0) = ⊥",
             ];
  "pc2_js1" [label="〈return $r1, js1〉", ];
  "pc3_js1" [label="〈sink, js1〉\n\
obj_level(r0) ⊑ ret(obj_level(r0))' ∧ (ϕ ≠ S2 ∨ obj_level($r1) ⊑ ret(obj_level())' ∧ pc ⊔ level($r1) ⊑ ret(level())' ∧ (ret(r0.><)' ∨ ¬$r1.><r0))",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(r0) ⊔ obj_level(r0)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($r1) := pc,\n\
 obj_level($r1) := ⊤}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  
  }