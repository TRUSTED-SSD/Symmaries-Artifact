digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = this.modCount, js1〉", ];
  "pc1_js1" [label="〈$i1 = $i0 + 1, js1〉", ];
  "pc2_js1" [label="〈this.modCount = $i1, js1〉", ];
  "pc3_js1" [label="〈r1 = this.table, js1〉", ];
  "pc4_js1" [label="〈i3 = 0, js1〉", ];
  "pc5_js1" [label="〈label0: $i2 = #r1, js1〉", ];
  "pc6_js1" [label="〈if (i3 >= $i2) goto label1, js1〉", ];
  "pc7_js1" [label="〈r1[i3] = null, js1〉", ];
  "pc8_js1" [label="〈i3 = i3 + 1, js1〉", ];
  "pc9_js1" [label="〈goto label0, js1〉", ];
  "pc10_js1" [label="〈label1: this.size = 0, js1〉", ];
  "pc10_js2" [label="〈label1: this.size = 0, js2〉", ];
  "pc11_js1" [label="〈return, js1〉", ];
  "pc12_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this)",
              ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{obj_level(r1) := ⊥,\n\
 obj_level(this) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{r1.><r1 := ff,\n\
 r1.><this := this.><this,\n\
 this.><r1 := tt,\n\
 level(r1) := pc ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level(r1) := obj_level(this)}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level(i3) := pc}", ];
  "pc5_js1" -> "pc6_js1" [label="tt,\n\
{level($i2) := pc ⊔ (if υ then level($i2) else level(r1) ⊔ obj_level(r1))}",
                          ];
  "pc6_js1" -> "pc7_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊑ pc,\n\
{r1.><r1' := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then r1.><r1' else r1.><r1,\n\
 r1.><this' := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then r1.><this' else r1.><this,\n\
 this.><r1' := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then this.><r1' else this.><r1,\n\
 this.><this' := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($i2) ⊔ level(i3),\n\
 obj_level(r1)' := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(r1)' else obj_level(r1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ¬ω then hr else P6}",
                          ];
  "pc6_js1" -> "pc10_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊑ pc,\n\
{r1.><r1' := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then r1.><r1' else r1.><r1,\n\
 r1.><this' := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then r1.><this' else r1.><this,\n\
 this.><r1' := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then this.><r1' else this.><r1,\n\
 this.><this' := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($i2) ⊔ level(i3),\n\
 obj_level(r1)' := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then obj_level(r1)' else obj_level(r1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($i2) ⊔ level(i3) ⊐ pc) ∨ υ ∧ ω then hr else P6}",
                           ];
  "pc7_js1" -> "pc8_js1" [label="tt,\n\
{obj_level(r1) := pc ⊔ obj_level(r1) ⊔ (if υ then ⊥ else level(i3)),\n\
 obj_level(this) := obj_level(this) ⊔ (if this.><r1 then pc ⊔ (if υ then ⊥ else level(i3)) else ⊥)}",
                          ];
  "pc8_js1" -> "pc9_js1" [label="tt,\n\
{level(i3) := pc ⊔ level(i3)}", ];
  "pc9_js1" -> "pc5_js1" [label="tt,\n\
{}", ];
  "pc10_js1" -> "pc6_js1" [label="¬υ ∧ hr = P6,\n\
{υ := tt,\n\
 r1.><r1 := r1.><r1',\n\
 r1.><this := r1.><this',\n\
 this.><r1 := this.><r1',\n\
 this.><this := this.><this',\n\
 r1.><r1' := r1.><r1,\n\
 r1.><this' := r1.><this,\n\
 this.><r1' := this.><r1,\n\
 this.><this' := this.><this,\n\
 obj_level(r1) := obj_level(r1)',\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(r1)' := obj_level(r1),\n\
 obj_level(this)' := obj_level(this)}",
                           ];
  "pc10_js1" -> "pc10_js2" [label="hr ≠ P6 ∨ υ ∧ hr = P6,\n\
{υ := ¬(υ ∧ hr = P6) ∧ (if hr = P6 then υ ∧ ¬(υ ∧ hr = P6) else υ),\n\
 pc := if ¬(hr ≠ P6 ∨ ¬(υ ∧ hr = P6)) ∨ υ ∧ hr = P6 then ⊥ else pc,\n\
 obj_level(r1) := if ¬(hr ≠ P6 ∨ ¬(υ ∧ hr = P6)) ∨ υ ∧ hr = P6 then obj_level(r1) ⊔ (if r1.><this then obj_level(this) else ⊥) else obj_level(r1),\n\
 obj_level(this) := if ¬(hr ≠ P6 ∨ ¬(υ ∧ hr = P6)) ∨ υ ∧ hr = P6 then obj_level(this) ⊔ (if this.><r1 then obj_level(r1) else ⊥) else obj_level(this),\n\
 hr := if ¬(hr ≠ P6 ∨ ¬(υ ∧ hr = P6)) ∨ υ ∧ hr = P6 then P. else hr}",
                            ];
  "pc10_js2" -> "pc11_js1" [label="tt,\n\
{obj_level(r1) := obj_level(r1) ⊔ (if r1.><this then pc else ⊥),\n\
 obj_level(this) := pc ⊔ obj_level(this)}",
                            ];
  "pc11_js1" -> "pc12_js1" [label="tt,\n\
{ϕ := S11}", ];
  
  }