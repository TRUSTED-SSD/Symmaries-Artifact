digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$r3 = this.formatter, js1〉", ];
  "pc1_js1" [label="〈$r4 = $r3.format (r1, r2), js1〉\n\
pc ⊔ level($r3) ⊔ level(r1) ⊔ level(r2) ⊔ obj_level($r3) ⊔ obj_level(r1) ⊔ obj_level(r2) = ⊥",
             ];
  "pc2_js1" [label="〈$r4.flush (), js1〉\n\
pc ⊑ ⊥ ∧ level($r4) ⊔ obj_level($r4) ⊑ ⊥",
             ];
  "pc3_js1" [label="〈return this, js1〉", ];
  "pc4_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(r2) ⊑ ret(obj_level(r2))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(r1.><r1)' ∨ ¬r1.><r1) ∧ (ret(r1.><r2)' ∨ ¬r1.><r2) ∧ (ret(r1.><this)' ∨ ¬r1.><this) ∧ (ret(r2.><r1)' ∨ ¬r2.><r1) ∧ (ret(r2.><r2)' ∨ ¬r2.><r2) ∧ (ret(r2.><this)' ∨ ¬r2.><this) ∧ (ret(this.><r1)' ∨ ¬this.><r1) ∧ (ret(this.><r2)' ∨ ¬this.><r2) ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S3 ∨ ret(~this)' ∧ obj_level(this) ⊑ ret(obj_level())' ∧ pc ⊔ level(this) ⊑ ret(level())' ∧ (ret(.><r1)' ∨ ¬r1.><this) ∧ (ret(.><r2)' ∨ ¬r2.><this) ∧ (ret(.><this)' ∨ ¬this.><this) ∧ (ret(r1.><)' ∨ ¬this.><r1) ∧ (ret(r2.><)' ∨ ¬this.><r2) ∧ (ret(this.><)' ∨ ¬this.><this))",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{$r3~$r4 := ff,\n\
 $r3.><$r3 := ff,\n\
 $r3.><$r4 := ff,\n\
 $r3.><r1 := this.><r1,\n\
 $r3.><r2 := this.><r2,\n\
 $r3.><this := this.><this,\n\
 $r4.><$r3 := ff,\n\
 r1.><$r3 := r1.><this,\n\
 r2.><$r3 := r2.><this,\n\
 this.><$r3 := tt,\n\
 level($r3) := pc ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level($r3) := obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{$r3~$r4 := tt,\n\
 $r3.><$r3 := tt,\n\
 $r3.><$r4 := ff,\n\
 $r3.><r1 := tt,\n\
 $r3.><r2 := tt,\n\
 $r3.><this := tt,\n\
 $r4.><$r3 := ff,\n\
 $r4.><r1 := this.><r1,\n\
 $r4.><r2 := this.><r2,\n\
 $r4.><this := this.><this,\n\
 r1.><$r3 := tt,\n\
 r1.><$r4 := r1.><this,\n\
 r1.><r1 := tt,\n\
 r1.><r2 := tt,\n\
 r1.><this := tt,\n\
 r2.><$r3 := tt,\n\
 r2.><$r4 := r2.><this,\n\
 r2.><r1 := tt,\n\
 r2.><r2 := tt,\n\
 r2.><this := tt,\n\
 this.><$r3 := tt,\n\
 this.><$r4 := tt,\n\
 this.><r1 := tt,\n\
 this.><r2 := tt,\n\
 this.><this := tt,\n\
 level($r4) := ⊤,\n\
 obj_level($r3) := ⊤,\n\
 obj_level($r4) := ⊤,\n\
 obj_level(r1) := ⊤,\n\
 obj_level(r2) := ⊤,\n\
 obj_level(this) := ⊤}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{$r3.><$r3 := tt,\n\
 $r3.><$r4 := ff,\n\
 $r3.><r1 := tt,\n\
 $r3.><r2 := tt,\n\
 $r3.><this := tt,\n\
 $r4.><$r3 := ff,\n\
 r1.><$r3 := tt,\n\
 r1.><r1 := tt,\n\
 r1.><r2 := tt,\n\
 r1.><this := tt,\n\
 r2.><$r3 := tt,\n\
 r2.><r1 := tt,\n\
 r2.><r2 := tt,\n\
 r2.><this := tt,\n\
 this.><$r3 := tt,\n\
 this.><r1 := tt,\n\
 this.><r2 := tt,\n\
 this.><this := tt,\n\
 obj_level($r3) := ⊤,\n\
 obj_level($r4) := ⊤,\n\
 obj_level(r1) := ⊤,\n\
 obj_level(r2) := ⊤,\n\
 obj_level(this) := ⊤}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{ϕ := S3}", ];
  
  }