digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$r1 = this.next, js1〉", ];
  "pc1_js1" [label="〈if ($r1 == null) goto label0, js1〉", ];
  "pc2_js1" [label="〈$z0 = 1, js1〉", ];
