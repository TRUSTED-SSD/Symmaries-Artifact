  "pc5_js2" [label="〈label1: return $z0, js2〉", ];
  "pc6_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S5 ∨ pc ⊔ level($z0) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{$r1.><$r1 := ff,\n\
