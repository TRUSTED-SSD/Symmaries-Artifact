 this.><$r1 := tt,\n\
 level($r1) := pc ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level($r1) := obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($r1) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($r1) ⊑ pc,\n\
{$r1.><$r1' := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then $r1.><$r1' else $r1.><$r1,\n\
 $r1.><this' := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then $r1.><this' else $r1.><this,\n\
 this.><$r1' := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then this.><$r1' else this.><$r1,\n\
 this.><this' := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($r1),\n\
 obj_level($r1)' := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then obj_level($r1)' else obj_level($r1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc4_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($r1) ⊐ pc ∨ τ ∧ ¬υ ∧ level($r1) ⊑ pc,\n\
{$r1.><$r1' := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then $r1.><$r1' else $r1.><$r1,\n\
 $r1.><this' := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then $r1.><this' else $r1.><this,\n\
 this.><$r1' := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then this.><$r1' else this.><$r1,\n\
 this.><this' := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($r1),\n\
 obj_level($r1)' := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then obj_level($r1)' else obj_level($r1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($r1) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($z0) := pc ⊔ (if υ then level($z0) else ⊥)}",
