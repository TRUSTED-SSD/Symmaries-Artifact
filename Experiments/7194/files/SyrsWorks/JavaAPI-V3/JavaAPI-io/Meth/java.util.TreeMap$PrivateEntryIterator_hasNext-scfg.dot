{}", ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level($z0) := pc ⊔ (if υ then level($z0) else ⊥)}",
                          ];
  "pc5_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt,\n\
 $r1.><$r1 := $r1.><$r1',\n\
 $r1.><this := $r1.><this',\n\
 this.><$r1 := this.><$r1',\n\
 this.><this := this.><this',\n\
 $r1.><$r1' := $r1.><$r1,\n\
 $r1.><this' := $r1.><this,\n\
 this.><$r1' := this.><$r1,\n\
 this.><this' := this.><this,\n\
 obj_level($r1) := obj_level($r1)',\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level($r1)' := obj_level($r1),\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc5_js1" -> "pc5_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := υ ∧ ¬(υ ∧ hr = P1),\n\
 pc := if υ ∧ hr = P1 then ⊥ else pc,\n\
 obj_level($r1) := if υ ∧ hr = P1 then obj_level($r1) ⊔ (if $r1.><this then obj_level(this) else ⊥) else obj_level($r1),\n\
 obj_level(this) := if υ ∧ hr = P1 then obj_level(this) ⊔ (if this.><$r1 then obj_level($r1) else ⊥) else obj_level(this),\n\
 hr := if υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc5_js2" -> "pc6_js1" [label="tt,\n\
{ϕ := S5}", ];
  
