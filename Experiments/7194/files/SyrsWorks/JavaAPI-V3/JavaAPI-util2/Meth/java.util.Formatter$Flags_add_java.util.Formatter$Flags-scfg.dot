digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = this.flags, js1〉", ];
  "pc1_js1" [label="〈$i1 = r1.valueOf (), js1〉\n\
tt", ];
  "pc2_js1" [label="〈$i2 = $i0 | $i1, js1〉", ];
  "pc3_js1" [label="〈this.flags = $i2, js1〉", ];
  "pc4_js1" [label="〈return this, js1〉", ];
  "pc5_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ϕ ≠ S4 ∨ ret(~this)' ∧ obj_level(this) ⊑ ret(obj_level())' ∧ pc ⊔ level(this) ⊑ ret(level())' ∧ (ret(~r1)' ∨ ¬r1~this))",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(r1) ⊔ obj_level(r1)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i2) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{obj_level(r1) := obj_level(r1) ⊔ (if r1~this then pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) else ⊥),\n\
 obj_level(this) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this)}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{ϕ := S4}", ];
  
  }