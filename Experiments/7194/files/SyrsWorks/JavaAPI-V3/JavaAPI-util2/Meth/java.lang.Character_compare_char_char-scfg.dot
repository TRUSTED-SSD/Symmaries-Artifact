digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i2 = c0 - c1, js1〉", ];
  "pc1_js1" [label="〈return $i2, js1〉", ];
  "pc2_js1" [label="〈sink, js1〉\n\
