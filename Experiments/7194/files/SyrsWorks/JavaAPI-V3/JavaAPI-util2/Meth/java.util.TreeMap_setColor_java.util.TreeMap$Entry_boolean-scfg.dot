digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈if (r0 == null) goto label0, js1〉", ];
  "pc1_js1" [label="〈r0.color = z0, js1〉", ];
  "pc2_js1" [label="〈label0: return, js1〉", ];
  "pc2_js2" [label="〈label0: return, js2〉", ];
  "pc3_js1" [label="〈sink, js1〉\n\
obj_level(r0) ⊑ ret(obj_level(r0))' ∧ (ret(r0.><r0)' ∨ ¬r0.><r0)",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level(r0) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level(r0) ⊑ pc,\n\
{r0.><r0' := if ¬(¬τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ¬ω then r0.><r0' else r0.><r0,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level(r0),\n\
 obj_level(r0)' := if ¬(¬τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(r0)' else obj_level(r0),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ¬ω then hr else P0}",
                          ];
  "pc0_js1" -> "pc2_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level(r0) ⊐ pc ∨ τ ∧ ¬υ ∧ level(r0) ⊑ pc,\n\
{r0.><r0' := if ¬(τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ω then r0.><r0' else r0.><r0,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level(r0),\n\
 obj_level(r0)' := if ¬(τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ω then obj_level(r0)' else obj_level(r0),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level(r0) ⊐ pc) ∨ υ ∧ ω then hr else P0}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{obj_level(r0) := pc ⊔ obj_level(r0) ⊔ (if υ then ⊥ else level(z0))}",
                          ];
  "pc2_js1" -> "pc0_js1" [label="¬υ ∧ hr = P0,\n\
{υ := tt,\n\
 r0.><r0 := r0.><r0',\n\
 r0.><r0' := r0.><r0,\n\
 obj_level(r0) := obj_level(r0)',\n\
 obj_level(r0)' := obj_level(r0)}",
                          ];
  "pc2_js1" -> "pc2_js2" [label="hr ≠ P0 ∨ υ ∧ hr = P0,\n\
{υ := ¬(υ ∧ hr = P0) ∧ (if hr = P0 then υ ∧ ¬(υ ∧ hr = P0) else υ),\n\
 pc := if ¬(hr ≠ P0 ∨ ¬(υ ∧ hr = P0)) ∨ υ ∧ hr = P0 then ⊥ else pc,\n\
 hr := if ¬(hr ≠ P0 ∨ ¬(υ ∧ hr = P0)) ∨ υ ∧ hr = P0 then P. else hr}",
                          ];
  "pc2_js2" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  
  }