digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i1 = this.position (), js1〉\n\
tt", ];
  "pc1_js1" [label="〈$i2 = this.checkIndex (i0, 1), js1〉\n\
tt", ];
  "pc2_js1" [label="〈$i3 = $i1 + $i2, js1〉", ];
  "pc3_js1" [label="〈$c4 = this.get ($i3), js1〉\n\
tt", ];
  "pc4_js1" [label="〈return $c4, js1〉", ];
  "pc5_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S4 ∨ pc ⊔ level($c4) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i2) := pc ⊔ level(i0) ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i3) := pc ⊔ level(i0) ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{level($c4) := pc ⊔ level(i0) ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{ϕ := S4}", ];
  
  }