digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i0 = r0.size, js1〉", ];
  "pc1_js1" [label="〈$i1 = $i0 - 1, js1〉", ];
  "pc2_js1" [label="〈r0.size = $i1, js1〉", ];
  "pc3_js1" [label="〈return $i0, js1〉", ];
  "pc4_js1" [label="〈sink, js1〉\n\
obj_level(r0) ⊑ ret(obj_level(r0))' ∧ (ret(r0.><r0)' ∨ ¬r0.><r0) ∧ (ϕ ≠ S3 ∨ pc ⊔ level($i0) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(r0) ⊔ obj_level(r0)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(r0) ⊔ obj_level(r0)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{obj_level(r0) := pc ⊔ level(r0) ⊔ obj_level(r0)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{ϕ := S3}", ];
  
  }