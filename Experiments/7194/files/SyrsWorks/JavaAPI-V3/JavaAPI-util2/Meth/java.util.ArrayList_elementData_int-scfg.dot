 $r2.><$r1 := ff,\n\
 $r2.><$r2 := ff,\n\
 $r2.><this := this.><this,\n\
 this.><$r2 := tt,\n\
 level($r2) := pc ⊔ level(i0) ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level($r2) := obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{ϕ := S2}", ];
  
  }