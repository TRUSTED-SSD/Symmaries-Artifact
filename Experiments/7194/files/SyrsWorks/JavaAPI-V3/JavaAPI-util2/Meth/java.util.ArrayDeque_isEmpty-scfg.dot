digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i1 = this.head, js1〉", ];
  "pc1_js1" [label="〈$i0 = this.tail, js1〉", ];
  "pc2_js1" [label="〈if ($i1 != $i0) goto label0, js1〉", ];
  "pc3_js1" [label="〈$z0 = 1, js1〉", ];
  "pc4_js1" [label="〈goto label1, js1〉", ];
  "pc5_js1" [label="〈label0: $z0 = 0, js1〉", ];
  "pc6_js1" [label="〈label1: return $z0, js1〉", ];
  "pc6_js2" [label="〈label1: return $z0, js2〉", ];
  "pc7_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S6 ∨ pc ⊔ level($z0) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊑ pc,\n\
{this.><this' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($i0) ⊔ level($i1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then hr else P2}",
                          ];
  "pc2_js1" -> "pc5_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊑ pc,\n\
{this.><this' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($i0) ⊔ level($i1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($i0) ⊔ level($i1) ⊐ pc) ∨ υ ∧ ω then hr else P2}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{level($z0) := pc ⊔ (if υ then level($z0) else ⊥)}",
                          ];
  "pc4_js1" -> "pc6_js1" [label="tt,\n\
{}", ];
  "pc5_js1" -> "pc6_js1" [label="tt,\n\
{level($z0) := pc ⊔ (if υ then level($z0) else ⊥)}",
                          ];
  "pc6_js1" -> "pc2_js1" [label="¬υ ∧ hr = P2,\n\
{υ := tt,\n\
 this.><this := this.><this',\n\
 this.><this' := this.><this,\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc6_js1" -> "pc6_js2" [label="hr ≠ P2 ∨ υ ∧ hr = P2,\n\
{υ := υ ∧ ¬(υ ∧ hr = P2),\n\
 pc := if υ ∧ hr = P2 then ⊥ else pc,\n\
 hr := if υ ∧ hr = P2 then P. else hr}",
                          ];
  "pc6_js2" -> "pc7_js1" [label="tt,\n\
{ϕ := S6}", ];
  
