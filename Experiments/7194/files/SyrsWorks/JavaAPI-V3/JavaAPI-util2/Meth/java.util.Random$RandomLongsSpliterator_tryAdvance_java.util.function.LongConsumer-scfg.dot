 obj_level(this) := if υ ∧ (hr = P0 ∨ hr = P7) then obj_level(this) ⊔ (if this.><$r2 then obj_level($r2) else ⊥) ⊔ (if this.><r1 then obj_level(r1) else ⊥) else obj_level(this),\n\
 hr := if υ ∧ (hr = P0 ∨ hr = P7) then P. else hr}",
                            ];
  
