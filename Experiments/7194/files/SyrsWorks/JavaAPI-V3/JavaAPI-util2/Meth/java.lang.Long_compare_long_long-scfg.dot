{υ := tt}", ];
  "pc9_js1" -> "pc5_js1" [label="¬υ ∧ hr = P5,\n\
{υ := tt}", ];
  "pc9_js1" -> "pc9_js2" [label="¬(hr = P1 ∨ hr = P5) ∨ υ ∧ (hr = P1 ∨ hr = P5),\n\
