digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i1 = this.savedScannerPosition, js1〉", ];
  "pc1_js1" [label="〈if ($i1 == - 1) goto label0, js1〉", ];
  "pc2_js1" [label="〈$i2 = this.savedScannerPosition, js1〉", ];
  "pc3_js1" [label="〈$i3 = $i2 - i0, js1〉", ];
  "pc4_js1" [label="〈this.savedScannerPosition = $i3, js1〉", ];
  "pc5_js1" [label="〈label0: return, js1〉", ];
  "pc5_js2" [label="〈label0: return, js2〉", ];
  "pc6_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this)",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($i1) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($i1) ⊑ pc,\n\
{this.><this' := if ¬(¬τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($i1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc5_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i1) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i1) ⊑ pc,\n\
{this.><this' := if ¬(τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($i1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($i1) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i2) := pc ⊔ (if υ then level($i2) else level(this) ⊔ obj_level(this))}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{level($i3) := pc ⊔ (if υ then level($i3) else level($i2) ⊔ level(i0))}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{obj_level(this) := pc ⊔ obj_level(this) ⊔ (if υ then ⊥ else level($i3))}",
                          ];
  "pc5_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt,\n\
 this.><this := this.><this',\n\
 this.><this' := this.><this,\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc5_js1" -> "pc5_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := ¬(υ ∧ hr = P1) ∧ (if hr = P1 then υ ∧ ¬(υ ∧ hr = P1) else υ),\n\
 pc := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then ⊥ else pc,\n\
 hr := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc5_js2" -> "pc6_js1" [label="tt,\n\
{ϕ := S5}", ];
  
  }