digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$r1 = this.words, js1〉", ];
  "pc1_js1" [label="〈$i0 = #$r1, js1〉", ];
  "pc2_js1" [label="〈$i1 = $i0 * 64, js1〉", ];
  "pc3_js1" [label="〈return $i1, js1〉", ];
  "pc4_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S3 ∨ pc ⊔ level($i1) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{this.><$r1 := tt,\n\
 level($r1) := pc ⊔ level(this) ⊔ obj_level(this),\n\
 obj_level($r1) := obj_level(this)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i0) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{level($i1) := pc ⊔ level(this) ⊔ obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{ϕ := S3}", ];
  
  }