 obj_level(this) := if υ ∧ hr = P1 then obj_level(this) ⊔ (if this.><$r1 then obj_level($r1) else ⊥) ⊔ (if this.><$r2 then obj_level($r2) else ⊥) ⊔ (if this.><$r3 then obj_level($r3) else ⊥) ⊔ (if this.><$r4 then obj_level($r4) else ⊥) else obj_level(this),\n\
 hr := if υ ∧ hr = P1 then P. else hr}",
