                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{level($i2) := pc ⊔ (if υ then level($i2) else level(i0))}",
                          ];
  "pc2_js1" -> "pc4_js1" [label="tt,\n\
{}", ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{level($i2) := pc ⊔ (if υ then level($i2) else level(i1))}",
                          ];
  "pc4_js1" -> "pc0_js1" [label="¬υ ∧ hr = P0,\n\
{υ := tt}", ];
  "pc4_js1" -> "pc4_js2" [label="hr ≠ P0 ∨ υ ∧ hr = P0,\n\
{υ := υ ∧ ¬(υ ∧ hr = P0),\n\
 pc := if υ ∧ hr = P0 then ⊥ else pc,\n\
 hr := if υ ∧ hr = P0 then P. else hr}",
                          ];
  "pc4_js2" -> "pc5_js1" [label="tt,\n\
{ϕ := S4}", ];
  
