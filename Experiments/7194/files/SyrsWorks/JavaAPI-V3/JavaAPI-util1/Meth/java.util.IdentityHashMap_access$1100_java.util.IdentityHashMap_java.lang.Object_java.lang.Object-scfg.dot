             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{r0.><r0 := tt,\n\
 r0.><r1 := tt,\n\
 r0.><r2 := tt,\n\
 r1.><r0 := tt,\n\
