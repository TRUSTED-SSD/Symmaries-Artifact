 r2.><r2 := tt,\n\
 level($z0) := ⊤,\n\
 obj_level(r0) := ⊤,\n\
 obj_level(r1) := ⊤,\n\
 obj_level(r2) := ⊤}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{ϕ := S1}", ];
  
