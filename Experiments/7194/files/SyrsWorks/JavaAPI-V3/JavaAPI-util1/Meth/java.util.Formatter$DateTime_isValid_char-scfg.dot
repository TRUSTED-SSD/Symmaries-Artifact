             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level(c0) ⊐ pc ∨ τ ∧ ¬υ ∧ level(c0) ⊑ pc,\n\
{pc := if ¬(τ ∧ ¬υ ∧ level(c0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level(c0),\n\
