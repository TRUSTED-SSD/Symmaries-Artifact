digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈switch [c0] {58 cases & 1 default}, js1〉", ];
  "pc1_js1" [label="〈label0: return 1, js1〉", ];
  "pc2_js1" [label="〈label1: return 0, js1〉", ];
  "pc3_js1" [label="〈sink, js1〉", ];
  "pc3_js2" [label="〈sink, js2〉\n\
