digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$c0 = r0.zero, js1〉", ];
  "pc1_js1" [label="〈return $c0, js1〉", ];
  "pc2_js1" [label="〈sink, js1〉\n\
obj_level(r0) ⊑ ret(obj_level(r0))' ∧ (ret(r0.><r0)' ∨ ¬r0.><r0) ∧ (ϕ ≠ S1 ∨ pc ⊔ level($c0) ⊑ ret(level())')",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($c0) := pc ⊔ level(r0) ⊔ obj_level(r0)}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{ϕ := S1}", ];
  
  }