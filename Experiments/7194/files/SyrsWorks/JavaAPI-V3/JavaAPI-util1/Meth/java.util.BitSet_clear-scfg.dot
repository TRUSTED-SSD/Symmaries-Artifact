digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈label0: $i0 = this.wordsInUse, js1〉", ];
  "pc1_js1" [label="〈if ($i0 <= 0) goto label1, js1〉", ];
  "pc2_js1" [label="〈$r1 = this.words, js1〉", ];
  "pc3_js1" [label="〈$i1 = this.wordsInUse, js1〉", ];
  "pc4_js1" [label="〈$i2 = $i1 - 1, js1〉", ];
  "pc5_js1" [label="〈this.wordsInUse = $i2, js1〉", ];
  "pc6_js1" [label="〈$r1[$i2] = 0L, js1〉", ];
  "pc7_js1" [label="〈goto label0, js1〉", ];
  "pc8_js1" [label="〈label1: return, js1〉", ];
  "pc8_js2" [label="〈label1: return, js2〉", ];
  "pc9_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this)",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="tt,\n\
{level($i0) := pc ⊔ (if υ then level($i0) else level(this) ⊔ obj_level(this))}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level($i0) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level($i0) ⊑ pc,\n\
{this.><$r1' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then this.><$r1' else this.><$r1,\n\
 this.><this' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level($i0),\n\
 obj_level($r1)' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level($r1)' else obj_level($r1),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ¬ω then hr else P1}",
                          ];
  "pc1_js1" -> "pc8_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level($i0) ⊐ pc ∨ τ ∧ ¬υ ∧ level($i0) ⊑ pc,\n\
{this.><$r1' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then this.><$r1' else this.><$r1,\n\
 this.><this' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level($i0),\n\
 obj_level($r1)' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then obj_level($r1)' else obj_level($r1),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level($i0) ⊐ pc) ∨ υ ∧ ω then hr else P1}",
                          ];
  "pc2_js1" -> "pc3_js1" [label="tt,\n\
{this.><$r1 := tt,\n\
 level($r1) := pc ⊔ (if υ then level($r1) else level(this) ⊔ obj_level(this)),\n\
 obj_level($r1) := obj_level(this)}",
                          ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{level($i1) := pc ⊔ (if υ then level($i1) else level(this) ⊔ obj_level(this))}",
                          ];
  "pc4_js1" -> "pc5_js1" [label="tt,\n\
{level($i2) := pc ⊔ (if υ then level($i2) else level($i1))}",
                          ];
  "pc5_js1" -> "pc6_js1" [label="tt,\n\
{obj_level(this) := pc ⊔ obj_level(this) ⊔ (if υ then ⊥ else level($i2))}",
                          ];
  "pc6_js1" -> "pc7_js1" [label="tt,\n\
{obj_level($r1) := pc ⊔ obj_level($r1) ⊔ (if υ then ⊥ else level($i2)),\n\
 obj_level(this) := pc ⊔ obj_level(this) ⊔ (if υ then ⊥ else level($i2))}",
                          ];
  "pc7_js1" -> "pc0_js1" [label="tt,\n\
{}", ];
  "pc8_js1" -> "pc1_js1" [label="¬υ ∧ hr = P1,\n\
{υ := tt,\n\
 this.><$r1 := this.><$r1',\n\
 this.><this := this.><this',\n\
 this.><$r1' := this.><$r1,\n\
 this.><this' := this.><this,\n\
 obj_level($r1) := obj_level($r1)',\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level($r1)' := obj_level($r1),\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc8_js1" -> "pc8_js2" [label="hr ≠ P1 ∨ υ ∧ hr = P1,\n\
{υ := ¬(υ ∧ hr = P1) ∧ (if hr = P1 then υ ∧ ¬(υ ∧ hr = P1) else υ),\n\
 pc := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then ⊥ else pc,\n\
 obj_level(this) := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then obj_level(this) ⊔ (if this.><$r1 then obj_level($r1) else ⊥) else obj_level(this),\n\
 hr := if ¬(hr ≠ P1 ∨ ¬(υ ∧ hr = P1)) ∨ υ ∧ hr = P1 then P. else hr}",
                          ];
  "pc8_js2" -> "pc9_js1" [label="tt,\n\
{ϕ := S8}", ];
  
  }