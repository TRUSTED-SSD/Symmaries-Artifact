  "pc2_js1" [label="〈return $r2, js1〉", ];
  "pc3_js1" [label="〈sink, js1〉\n\
obj_level(r1) ⊑ ret(obj_level(r1))' ∧ obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><r1)' ∨ ¬this.><r1) ∧ (ret(this.><this)' ∨ ¬this.><this) ∧ (ϕ ≠ S2 ∨ obj_level($r2) ⊑ ret(obj_level())' ∧ pc ⊔ level($r2) ⊑ ret(level())' ∧ (ret(~this)' ∨ ¬$r2~this) ∧ (ret(.><this)' ∨ ¬this.><$r2) ∧ (ret(r1.><)' ∨ ¬$r2.><r1) ∧ (ret(this.><)' ∨ ¬$r2.><this))",
