 obj_level($r2) := pc ⊔ level(r1) ⊔ obj_level(r1) ⊔ (if this.><r1 then level(this) ⊔ obj_level(this) else level(this) ⊔ obj_level(this)),\n\
 obj_level(r1) := pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) ⊔ (if this.><r1 then if this.><r1 ∧ pc ⊔ level(r1) ⊔ obj_level(r1) = ⊥ ∧ level(this) ⊔ obj_level(this) = ⊥ then pc else if if pc ⊔ level(r1) ⊔ obj_level(r1) = ⊤ then this.><r1 ∨ obj_level(this) = ⊤ else pc ⊔ level(r1) ⊔ obj_level(r1) = ⊥ ∧ if this.><r1 then level(this) ⊔ obj_level(this) else obj_level(this) = ⊤ then ⊤ else ⊥ else ⊥),\n\
 obj_level(this) := obj_level(this) ⊔ (if this.><r1 then pc ⊔ level(r1) ⊔ level(this) ⊔ obj_level(r1) ⊔ obj_level(this) else ⊥) ⊔ (if this.><r1 ∧ pc ⊔ level(r1) ⊔ obj_level(r1) = ⊥ ∧ level(this) ⊔ obj_level(this) = ⊥ then pc else if if pc ⊔ level(r1) ⊔ obj_level(r1) = ⊤ then this.><r1 ∨ obj_level(this) = ⊤ else pc ⊔ level(r1) ⊔ obj_level(r1) = ⊥ ∧ if this.><r1 then level(this) ⊔ obj_level(this) else obj_level(this) = ⊤ then ⊤ else ⊥)}",
