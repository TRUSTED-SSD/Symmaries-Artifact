 obj_level($r2) := if υ ∧ hr = P2 then obj_level($r2) ⊔ (if $r2.><$r1 then obj_level($r1) else ⊥) ⊔ (if $r2.><this then obj_level(this) else ⊥) else obj_level($r2),\n\
 obj_level(this) := if υ ∧ hr = P2 then obj_level(this) ⊔ (if this.><$r1 then obj_level($r1) else ⊥) ⊔ (if this.><$r2 then obj_level($r2) else ⊥) ⊔ (if this.><$r3 then obj_level($r3) else ⊥) else obj_level(this),\n\
 hr := if υ ∧ hr = P2 then P. else hr}",
