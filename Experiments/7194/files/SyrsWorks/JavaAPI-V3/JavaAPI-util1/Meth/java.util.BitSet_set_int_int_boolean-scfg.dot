digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈if (z0 == 0) goto label0, js1〉", ];
  "pc1_js1" [label="〈this.set (i0, i1), js1〉\n\
pc ⊔ level(i0) ⊔ level(i1) ⊔ level(this) ⊔ obj_level(this) = ⊥",
             ];
  "pc2_js1" [label="〈goto label1, js1〉", ];
  "pc3_js1" [label="〈label0: this.clear (i0, i1), js1〉\n\
pc ⊔ level(i0) ⊔ level(i1) = ⊥",
             ];
  "pc4_js1" [label="〈label1: return, js1〉", ];
  "pc4_js2" [label="〈label1: return, js2〉", ];
  "pc5_js1" [label="〈sink, js1〉\n\
obj_level(this) ⊑ ret(obj_level(this))' ∧ (ret(this.><this)' ∨ ¬this.><this)",
             ];
  
  
  "pc0_js1" -> "pc1_js1" [label="υ ∧ ¬ω ∨ ¬τ ∧ ¬υ ∧ level(z0) ⊐ pc ∨ ¬τ ∧ ¬υ ∧ level(z0) ⊑ pc,\n\
{this.><this' := if ¬(¬τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ¬ω then this.><this' else this.><this,\n\
 pc := if ¬(¬τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ¬ω then pc else pc ⊔ level(z0),\n\
 obj_level(this)' := if ¬(¬τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ¬ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(¬τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ¬ω then hr else P0}",
                          ];
  "pc0_js1" -> "pc3_js1" [label="υ ∧ ω ∨ τ ∧ ¬υ ∧ level(z0) ⊐ pc ∨ τ ∧ ¬υ ∧ level(z0) ⊑ pc,\n\
{this.><this' := if ¬(τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ω then this.><this' else this.><this,\n\
 pc := if ¬(τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ω then pc else pc ⊔ level(z0),\n\
 obj_level(this)' := if ¬(τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ω then obj_level(this)' else obj_level(this),\n\
 hr := if ¬(τ ∧ ¬υ ∧ level(z0) ⊐ pc) ∨ υ ∧ ω then hr else P0}",
                          ];
  "pc1_js1" -> "pc2_js1" [label="tt,\n\
{obj_level(this) := obj_level(this) ⊔ (if pc ⊔ level(i0) ⊔ level(i1) ⊔ level(this) ⊔ obj_level(this) ⊑ if υ then pc else ⊤ then pc ⊔ level(i0) ⊔ level(i1) ⊔ level(this) ⊔ obj_level(this) else if υ then pc else ⊤)}",
                          ];
  "pc2_js1" -> "pc4_js1" [label="tt,\n\
{}", ];
  "pc3_js1" -> "pc4_js1" [label="tt,\n\
{obj_level(this) := obj_level(this) ⊔ (if level(this) ⊔ obj_level(this) ⊑ if υ then pc else ⊤ then level(this) ⊔ obj_level(this) else if υ then pc else ⊤)}",
                          ];
  "pc4_js1" -> "pc0_js1" [label="¬υ ∧ hr = P0,\n\
{υ := tt,\n\
 this.><this := this.><this',\n\
 this.><this' := this.><this,\n\
 obj_level(this) := obj_level(this)',\n\
 obj_level(this)' := obj_level(this)}",
                          ];
  "pc4_js1" -> "pc4_js2" [label="hr ≠ P0 ∨ υ ∧ hr = P0,\n\
{υ := υ ∧ ¬(υ ∧ hr = P0),\n\
 pc := if υ ∧ hr = P0 then ⊥ else pc,\n\
 hr := if υ ∧ hr = P0 then P. else hr}",
                          ];
  "pc4_js2" -> "pc5_js1" [label="tt,\n\
{ϕ := S4}", ];
  
  }