 obj_level($r2) := if υ ∧ (hr = P1 ∨ hr = P5) then obj_level($r2) ⊔ (if $r1~$r2 then obj_level($r1) else ⊥) ⊔ (if $r2~$r3 then obj_level($r3) else ⊥) ⊔ (if $r2~$r4 then obj_level($r4) else ⊥) else obj_level($r2),\n\
 obj_level($r3) := if υ ∧ (hr = P1 ∨ hr = P5) then obj_level($r3) ⊔ (if $r1~$r3 then obj_level($r1) else ⊥) ⊔ (if $r2~$r3 then obj_level($r2) else ⊥) ⊔ (if $r3~$r4 then obj_level($r4) else ⊥) else obj_level($r3),\n\
 obj_level($r4) := if υ ∧ (hr = P1 ∨ hr = P5) then obj_level($r4) ⊔ (if $r1~$r4 then obj_level($r1) else ⊥) ⊔ (if $r2~$r4 then obj_level($r2) else ⊥) ⊔ (if $r3~$r4 then obj_level($r3) else ⊥) else obj_level($r4),\n\
 obj_level(this) := if υ ∧ (hr = P1 ∨ hr = P5) then obj_level(this) ⊔ (if this.><$r1 then obj_level($r1) else ⊥) ⊔ (if this.><$r2 then obj_level($r2) else ⊥) ⊔ (if this.><$r3 then obj_level($r3) else ⊥) ⊔ (if this.><$r4 then obj_level($r4) else ⊥) else obj_level(this),\n\
 hr := if υ ∧ (hr = P1 ∨ hr = P5) then P. else hr}",
                            ];
  
