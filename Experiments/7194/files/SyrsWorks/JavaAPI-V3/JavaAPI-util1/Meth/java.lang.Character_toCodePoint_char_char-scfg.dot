digraph G {
  node [shape=box, ];
  "pc0_js1" [label="〈$i2 = c0 << 10, js1〉", ];
  "pc1_js1" [label="〈$i3 = $i2 + c1, js1〉", ];
  "pc2_js1" [label="〈$i4 = $i3 + - 56613888, js1〉", ];
  "pc3_js1" [label="〈return $i4, js1〉", ];
  "pc4_js1" [label="〈sink, js1〉\n\
