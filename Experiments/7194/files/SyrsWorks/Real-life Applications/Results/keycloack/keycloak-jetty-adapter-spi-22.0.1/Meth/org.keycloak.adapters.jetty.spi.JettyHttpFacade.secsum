org.keycloak.adapters.jetty.spi.JettyHttpFacade (org.eclipse.jetty.server.Request
                                                   request,
                                                 javax.servlet.http.HttpServletResponse
                                                   response) {
  guard = tt;
  ret(obj_level(request)) = pc ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(this);
  ret(obj_level(response)) = pc ⊔ level(this) ⊔ obj_level(response) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(request) ⊔ level(response) ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(response) ⊔ obj_level(this);
}