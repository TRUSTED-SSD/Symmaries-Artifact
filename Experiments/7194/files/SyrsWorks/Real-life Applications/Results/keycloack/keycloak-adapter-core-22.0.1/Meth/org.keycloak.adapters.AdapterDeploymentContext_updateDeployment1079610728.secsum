void org.keycloak.adapters.AdapterDeploymentContext:updateDeployment (
  org.keycloak.representations.adapters.config.AdapterConfig config) {
  guard = tt;
  ret(obj_level(config)) = pc ⊔ level(config) ⊔ level(this) ⊔ obj_level(config) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(config) ⊔ level(this) ⊔ obj_level(config) ⊔ obj_level(this);
}