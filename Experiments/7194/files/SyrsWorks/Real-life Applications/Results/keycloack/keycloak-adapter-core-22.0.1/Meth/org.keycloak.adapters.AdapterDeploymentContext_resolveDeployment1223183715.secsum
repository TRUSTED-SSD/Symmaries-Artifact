org.keycloak.adapters.KeycloakDeployment org.keycloak.adapters.AdapterDeploymentContext:resolveDeployment (
  org.keycloak.adapters.spi.HttpFacade facade) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(facade)) = pc ⊔ level(this) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(facade) ⊔ obj_level(this);
}