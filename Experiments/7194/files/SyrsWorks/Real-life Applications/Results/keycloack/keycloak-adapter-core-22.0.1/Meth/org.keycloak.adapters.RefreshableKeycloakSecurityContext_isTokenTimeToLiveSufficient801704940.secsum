boolean org.keycloak.adapters.RefreshableKeycloakSecurityContext:isTokenTimeToLiveSufficient (
  org.keycloak.representations.AccessToken token) {
  guard = tt;
  ret(level()) = pc ⊔ level(token) ⊔ obj_level(token);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ obj_level(token) = ⊤ then ⊤ else ⊥;
  ret(obj_level(token)) = obj_level(token);
}