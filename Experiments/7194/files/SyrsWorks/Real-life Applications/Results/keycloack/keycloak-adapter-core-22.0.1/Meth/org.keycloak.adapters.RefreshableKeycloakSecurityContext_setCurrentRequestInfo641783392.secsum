void org.keycloak.adapters.RefreshableKeycloakSecurityContext:setCurrentRequestInfo (
  org.keycloak.adapters.KeycloakDeployment deployment,
  org.keycloak.adapters.AdapterTokenStore tokenStore) {
  guard = tt;
  ret(obj_level(deployment)) = pc ⊔ level(deployment) ⊔ level(tokenStore) ⊔ obj_level(deployment) ⊔ obj_level(tokenStore);
  ret(obj_level(this)) = pc ⊔ level(deployment) ⊔ level(tokenStore) ⊔ obj_level(deployment) ⊔ obj_level(this) ⊔ obj_level(tokenStore);
  ret(obj_level(tokenStore)) = obj_level(tokenStore);
}