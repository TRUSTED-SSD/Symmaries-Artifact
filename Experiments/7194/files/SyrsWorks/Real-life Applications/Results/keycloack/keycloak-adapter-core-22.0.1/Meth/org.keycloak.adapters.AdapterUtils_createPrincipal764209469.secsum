static org.keycloak.KeycloakPrincipal org.keycloak.adapters.AdapterUtils:createPrincipal (
  org.keycloak.adapters.KeycloakDeployment deployment,
  org.keycloak.adapters.RefreshableKeycloakSecurityContext securityContext) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(securityContext) ⊔ obj_level(deployment) ⊔ obj_level(securityContext);
  ret(obj_level(deployment)) = pc ⊔ level(securityContext) ⊔ obj_level(deployment) ⊔ obj_level(securityContext);
  ret(obj_level(securityContext)) = pc ⊔ level(securityContext) ⊔ obj_level(deployment) ⊔ obj_level(securityContext);
}