org.keycloak.adapters.AuthenticatedActionsHandler (org.keycloak.adapters.KeycloakDeployment
                                                     deployment,
                                                   org.keycloak.adapters.OIDCHttpFacade
                                                     facade) {
  guard = tt;
  ret(obj_level(deployment)) = pc ⊔ level(deployment) ⊔ level(facade) ⊔ level(this) ⊔ obj_level(deployment) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(facade)) = pc ⊔ level(this) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(deployment) ⊔ level(facade) ⊔ level(this) ⊔ obj_level(deployment) ⊔ obj_level(facade) ⊔ obj_level(this);
}