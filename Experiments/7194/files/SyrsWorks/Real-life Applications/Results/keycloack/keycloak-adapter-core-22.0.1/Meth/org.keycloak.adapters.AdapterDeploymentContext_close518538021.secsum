void org.keycloak.adapters.AdapterDeploymentContext:close (org.apache.http.HttpResponse
                                                             response) {
  guard = tt;
  ret(obj_level(response)) = obj_level(response);
  ret(obj_level(this)) = if pc = ⊤ ∨ pc ⊔ obj_level(response) = ⊥ then obj_level(this) else if pc = ⊥ ∧ obj_level(response) = ⊤ then ⊤ else ⊥;
}