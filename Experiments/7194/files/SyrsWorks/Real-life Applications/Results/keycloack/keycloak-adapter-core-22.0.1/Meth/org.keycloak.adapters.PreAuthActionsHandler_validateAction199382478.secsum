boolean org.keycloak.adapters.PreAuthActionsHandler:validateAction (org.keycloak.representations.adapters.action.AdminAction
                                                                    action) {
  guard = pc ⊔ level(action) ⊔ obj_level(action) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(action)) = ⊥;
  ret(obj_level(this)) = ⊥;
}