void org.keycloak.adapters.NodesRegistrationManagement:sendRegistrationEvent (
  org.keycloak.adapters.KeycloakDeployment deployment) {
  guard = tt;
  ret(obj_level(deployment)) = pc ⊔ level(deployment) ⊔ level(this) ⊔ obj_level(deployment) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(deployment) ⊔ level(this) ⊔ obj_level(deployment) ⊔ obj_level(this);
}