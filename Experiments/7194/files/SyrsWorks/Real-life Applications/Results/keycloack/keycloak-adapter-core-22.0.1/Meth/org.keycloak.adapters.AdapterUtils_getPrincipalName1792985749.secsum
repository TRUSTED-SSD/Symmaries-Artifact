static java.lang.String org.keycloak.adapters.AdapterUtils:getPrincipalName (
  org.keycloak.adapters.KeycloakDeployment deployment,
  org.keycloak.representations.AccessToken token) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(token);
  ret(obj_level()) = pc ⊔ obj_level(token);
  ret(obj_level(deployment)) = if obj_level(deployment) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(deployment) = ⊥ ∧ obj_level(token) = ⊤ then ⊤ else ⊥;
  ret(obj_level(token)) = obj_level(token);
}