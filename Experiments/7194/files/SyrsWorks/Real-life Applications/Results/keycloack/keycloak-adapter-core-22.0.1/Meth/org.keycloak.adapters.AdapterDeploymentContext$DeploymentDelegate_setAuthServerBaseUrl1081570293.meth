void org.keycloak.adapters.AdapterDeploymentContext$DeploymentDelegate:setAuthServerBaseUrl(java.lang.String authServerBaseUrl)
{
org.keycloak.common.util.KeycloakUriBuilder serverBuilder;
  this.authServerBaseUrl=authServerBaseUrl;
 serverBuilder = org.keycloak.common.util.KeycloakUriBuilder.fromUri(authServerBaseUrl);
 this.resolveUrls(serverBuilder);
 return;
 } 

