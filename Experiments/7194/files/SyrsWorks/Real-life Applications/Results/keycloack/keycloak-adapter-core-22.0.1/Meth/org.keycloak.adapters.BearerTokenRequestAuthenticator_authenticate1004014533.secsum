org.keycloak.adapters.spi.AuthOutcome org.keycloak.adapters.BearerTokenRequestAuthenticator:authenticate (
  org.keycloak.adapters.spi.HttpFacade exchange) {
  guard = tt;
  ret(level()) = pc ⊔ level(exchange) ⊔ level(this) ⊔ obj_level(exchange) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(exchange) ⊔ level(this) ⊔ obj_level(exchange) ⊔ obj_level(this);
  ret(obj_level(exchange)) = pc ⊔ level(this) ⊔ obj_level(exchange) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(exchange) ⊔ obj_level(this);
}