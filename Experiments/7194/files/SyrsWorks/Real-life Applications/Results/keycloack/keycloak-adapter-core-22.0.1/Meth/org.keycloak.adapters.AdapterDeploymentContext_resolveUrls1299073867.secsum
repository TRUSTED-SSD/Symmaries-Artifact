org.keycloak.adapters.KeycloakDeployment org.keycloak.adapters.AdapterDeploymentContext:resolveUrls (
  org.keycloak.adapters.KeycloakDeployment @deployment,
  org.keycloak.adapters.spi.HttpFacade facade) {
  guard = tt;
  ret(level()) = pc ⊔ level(@deployment) ⊔ obj_level(@deployment);
  ret(obj_level()) = pc ⊔ level(@deployment) ⊔ level(this) ⊔ obj_level(@deployment) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(@deployment)) = pc ⊔ level(@deployment) ⊔ level(this) ⊔ obj_level(@deployment) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(facade)) = pc ⊔ level(@deployment) ⊔ level(this) ⊔ obj_level(@deployment) ⊔ obj_level(facade) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@deployment) ⊔ level(this) ⊔ obj_level(@deployment) ⊔ obj_level(facade) ⊔ obj_level(this);
}