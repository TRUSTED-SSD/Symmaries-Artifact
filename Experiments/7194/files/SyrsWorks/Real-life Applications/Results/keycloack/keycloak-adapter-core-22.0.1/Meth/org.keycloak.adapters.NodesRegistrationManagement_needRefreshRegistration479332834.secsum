boolean org.keycloak.adapters.NodesRegistrationManagement:needRefreshRegistration (
  java.lang.String registrationUri,
  org.keycloak.adapters.KeycloakDeployment resolvedDeployment) {
  guard = tt;
  ret(level()) = pc ⊔ level(registrationUri) ⊔ level(this) ⊔ obj_level(registrationUri) ⊔ obj_level(this);
  ret(obj_level(registrationUri)) = pc ⊔ level(registrationUri) ⊔ level(this) ⊔ obj_level(registrationUri) ⊔ obj_level(this);
  ret(obj_level(resolvedDeployment)) = pc ⊔ level(registrationUri) ⊔ level(this) ⊔ obj_level(registrationUri) ⊔ obj_level(resolvedDeployment) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(registrationUri) ⊔ level(this) ⊔ obj_level(registrationUri) ⊔ obj_level(this);
}