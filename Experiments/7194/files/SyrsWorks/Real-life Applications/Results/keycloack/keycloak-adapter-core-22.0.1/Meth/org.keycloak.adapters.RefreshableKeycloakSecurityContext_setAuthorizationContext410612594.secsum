void org.keycloak.adapters.RefreshableKeycloakSecurityContext:setAuthorizationContext (
  org.keycloak.AuthorizationContext authorizationContext) {
  guard = tt;
  ret(obj_level(authorizationContext)) = obj_level(authorizationContext);
  ret(obj_level(this)) = pc ⊔ level(authorizationContext) ⊔ obj_level(authorizationContext) ⊔ obj_level(this);
}