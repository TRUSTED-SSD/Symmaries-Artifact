void org.keycloak.adapters.KeycloakDeployment:setClient (org.apache.http.client.HttpClient
                                                           client) {
  guard = tt;
  ret(obj_level(client)) = pc ⊔ level(client) ⊔ level(this) ⊔ obj_level(client) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(client) ⊔ level(this) ⊔ obj_level(client) ⊔ obj_level(this);
}