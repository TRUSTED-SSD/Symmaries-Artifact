static org.keycloak.adapters.KeycloakDeployment org.keycloak.adapters.KeycloakDeploymentBuilder:build (
  org.keycloak.representations.adapters.config.AdapterConfig adapterConfig) {
  guard = tt;
  ret(level()) = pc ⊔ level(adapterConfig) ⊔ obj_level(adapterConfig);
  ret(obj_level()) = pc ⊔ level(adapterConfig) ⊔ obj_level(adapterConfig);
  ret(obj_level(adapterConfig)) = pc ⊔ level(adapterConfig) ⊔ obj_level(adapterConfig);
}