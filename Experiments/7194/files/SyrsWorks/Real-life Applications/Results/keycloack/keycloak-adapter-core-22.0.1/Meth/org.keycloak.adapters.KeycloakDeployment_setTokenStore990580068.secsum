void org.keycloak.adapters.KeycloakDeployment:setTokenStore (org.keycloak.enums.TokenStore
                                                               tokenStore) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(tokenStore) ⊔ obj_level(this) ⊔ obj_level(tokenStore);
  ret(obj_level(tokenStore)) = obj_level(tokenStore);
}