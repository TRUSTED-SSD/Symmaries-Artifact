boolean org.keycloak.adapters.spi.InMemorySessionIdMapper:hasSession (
  java.lang.String id) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(id) ⊔ obj_level(this);
  ret(obj_level(id)) = obj_level(id);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(id) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}