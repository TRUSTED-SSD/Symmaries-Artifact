static java.lang.String org.keycloak.jose.jws.crypto.HashUtils:oidcHash (
  java.lang.String @jwtAlgorithmName, java.lang.String input) {
  guard = tt;
  ret(level()) = pc ⊔ level(@jwtAlgorithmName) ⊔ level(input) ⊔ obj_level(input);
  ret(obj_level()) = pc ⊔ level(@jwtAlgorithmName) ⊔ level(input) ⊔ obj_level(input);
  ret(obj_level(@jwtAlgorithmName)) = pc ⊔ level(@jwtAlgorithmName) ⊔ level(input) ⊔ obj_level(input);
  ret(obj_level(input)) = pc ⊔ level(@jwtAlgorithmName) ⊔ level(input) ⊔ obj_level(input);
}