static org.keycloak.jose.JOSE org.keycloak.jose.JOSEParser:parse (java.lang.String
                                                                    jwt) {
  guard = tt;
  ret(level()) = pc ⊔ level(jwt) ⊔ obj_level(jwt);
  ret(obj_level()) = pc ⊔ level(jwt) ⊔ obj_level(jwt);
  ret(obj_level(jwt)) = pc ⊔ level(jwt) ⊔ obj_level(jwt);
