void org.keycloak.jose.jwe.enc.AesCbcHmacShaEncryptionProvider:encodeJwe (
  org.keycloak.jose.jwe.JWE jwe) {
  p0: '0 -> dummyClass ('0) -> level;
  guard = tt;
  ret(obj_level(jwe)) = p0 ⊔ pc ⊔ level(jwe) ⊔ level(this) ⊔ obj_level(jwe) ⊔ obj_level(this);
  ret(obj_level(this)) = p0 ⊔ pc ⊔ level(jwe) ⊔ level(this) ⊔ obj_level(jwe) ⊔ obj_level(this);
}