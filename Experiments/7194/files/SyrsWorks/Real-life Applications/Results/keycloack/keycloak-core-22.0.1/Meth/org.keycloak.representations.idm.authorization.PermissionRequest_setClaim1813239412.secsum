void org.keycloak.representations.idm.authorization.PermissionRequest:setClaim (
  java.lang.String name, java.lang.String[] value) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(name) ⊔ level(this) ⊔ level(value) ⊔ obj_level(name) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(this)) = pc ⊔ level(name) ⊔ level(this) ⊔ level(value) ⊔ obj_level(name) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(name) ⊔ level(this) ⊔ level(value) ⊔ obj_level(name) ⊔ obj_level(this) ⊔ obj_level(value);
}