void org.keycloak.representations.idm.RealmRepresentation:setRoles (org.keycloak.representations.idm.RolesRepresentation
                                                                    roles) {
  guard = tt;
  ret(obj_level(roles)) = pc ⊔ level(roles) ⊔ obj_level(roles);
  ret(obj_level(this)) = pc ⊔ level(roles) ⊔ obj_level(roles) ⊔ obj_level(this);
}