void org.keycloak.representations.idm.RealmRepresentation:addProtocolMapper (
  org.keycloak.representations.idm.ProtocolMapperRepresentation rep) {
  guard = tt;
  ret(obj_level(rep)) = pc ⊔ level(rep) ⊔ level(this) ⊔ obj_level(rep) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(rep) ⊔ level(this) ⊔ obj_level(rep) ⊔ obj_level(this);
}