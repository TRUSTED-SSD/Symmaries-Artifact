void org.keycloak.representations.idm.authorization.AuthorizationRequest:addPermission (
  java.lang.String resourceId, java.util.List scopes) {
  guard = tt;
  ret(obj_level(resourceId)) = pc ⊔ level(scopes) ⊔ level(this) ⊔ obj_level(resourceId) ⊔ obj_level(scopes) ⊔ obj_level(this);
  ret(obj_level(scopes)) = pc ⊔ level(scopes) ⊔ level(this) ⊔ obj_level(resourceId) ⊔ obj_level(scopes) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(scopes) ⊔ level(this) ⊔ obj_level(resourceId) ⊔ obj_level(scopes) ⊔ obj_level(this);
}