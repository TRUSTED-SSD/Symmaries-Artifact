org.keycloak.jose.jwk.JWKParser org.keycloak.jose.jwk.JWKParser:parse (
  java.lang.String jwk) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(jwk) ⊔ obj_level(jwk) ⊔ obj_level(this);
  ret(obj_level(jwk)) = obj_level(jwk);
  ret(obj_level(this)) = pc ⊔ level(jwk) ⊔ obj_level(jwk) ⊔ obj_level(this);
}