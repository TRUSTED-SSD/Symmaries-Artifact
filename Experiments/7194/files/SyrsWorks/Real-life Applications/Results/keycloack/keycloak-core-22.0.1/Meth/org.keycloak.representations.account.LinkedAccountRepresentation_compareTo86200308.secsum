int org.keycloak.representations.account.LinkedAccountRepresentation:compareTo (
  org.keycloak.representations.account.LinkedAccountRepresentation rep) {
  guard = tt;
  ret(level()) = pc ⊔ level(rep) ⊔ level(this) ⊔ obj_level(rep);
  ret(obj_level(rep)) = pc ⊔ level(rep) ⊔ level(this) ⊔ obj_level(rep);
  ret(obj_level(this)) = pc ⊔ level(rep) ⊔ level(this) ⊔ obj_level(rep);
}