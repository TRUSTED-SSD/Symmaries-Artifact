byte[] org.keycloak.crypto.AsymmetricSignatureSignerContext:sign (byte[]
                                                                    @data) {
  guard = tt;
  ret(level()) = pc ⊔ level(@data) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@data) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(@data)) = pc ⊔ level(@data) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@data) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
}