static org.keycloak.crypto.PublicKeysWrapper org.keycloak.util.JWKSUtils:getKeyWrappersForUse (
  org.keycloak.jose.jwk.JSONWebKeySet keySet,
  org.keycloak.jose.jwk.JWK$Use requestedUse) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(keySet) ⊔ obj_level(keySet) ⊔ obj_level(requestedUse);
  ret(obj_level(keySet)) = pc ⊔ level(keySet) ⊔ obj_level(keySet) ⊔ obj_level(requestedUse);
  ret(obj_level(requestedUse)) = pc ⊔ level(keySet) ⊔ obj_level(keySet) ⊔ obj_level(requestedUse);
}