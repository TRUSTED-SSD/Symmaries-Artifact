boolean org.keycloak.representations.idm.ClaimRepresentation:equals (
  java.lang.Object o) {
  guard = tt;
  ret(level()) = pc ⊔ level(o) ⊔ level(this) ⊔ obj_level(o);
  ret(obj_level(o)) = if obj_level(o) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(o) = ⊥ ∧ level(o) ⊔ level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = obj_level(o);
