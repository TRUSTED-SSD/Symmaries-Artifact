void org.keycloak.representations.provider.ScriptProviderDescriptor:addProvider (
  java.lang.String type, java.lang.String name, java.lang.String fileName,
  java.lang.String description) {
  guard = tt;
  ret(obj_level(description)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(description) ⊔ obj_level(this);
  ret(obj_level(fileName)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(fileName) ⊔ obj_level(this);
  ret(obj_level(name)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
}