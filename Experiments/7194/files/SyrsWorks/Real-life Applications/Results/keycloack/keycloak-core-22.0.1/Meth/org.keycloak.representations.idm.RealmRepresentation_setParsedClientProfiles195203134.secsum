void org.keycloak.representations.idm.RealmRepresentation:setParsedClientProfiles (
  org.keycloak.representations.idm.ClientProfilesRepresentation
    clientProfiles) {
  guard = tt;
  ret(obj_level(clientProfiles)) = pc ⊔ level(clientProfiles) ⊔ obj_level(clientProfiles);
  ret(obj_level(this)) = pc ⊔ level(clientProfiles) ⊔ obj_level(clientProfiles) ⊔ obj_level(this);
}