void org.keycloak.representations.idm.authorization.AuthorizationRequest:setPermissions (
  org.keycloak.representations.idm.authorization.PermissionTicketToken
    permissions) {
  guard = tt;
  ret(obj_level(permissions)) = pc ⊔ level(permissions) ⊔ obj_level(permissions);
  ret(obj_level(this)) = pc ⊔ level(permissions) ⊔ obj_level(permissions) ⊔ obj_level(this);
}