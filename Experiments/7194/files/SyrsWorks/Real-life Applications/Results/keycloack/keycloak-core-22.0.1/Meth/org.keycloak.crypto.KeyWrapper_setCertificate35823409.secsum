void org.keycloak.crypto.KeyWrapper:setCertificate (java.security.cert.X509Certificate
                                                      certificate) {
  guard = tt;
  ret(obj_level(certificate)) = pc ⊔ level(certificate) ⊔ obj_level(certificate);
  ret(obj_level(this)) = pc ⊔ level(certificate) ⊔ obj_level(certificate) ⊔ obj_level(this);
}