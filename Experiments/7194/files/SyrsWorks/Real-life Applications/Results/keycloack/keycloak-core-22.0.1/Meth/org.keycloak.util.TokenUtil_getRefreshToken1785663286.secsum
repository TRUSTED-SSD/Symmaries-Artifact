static org.keycloak.representations.RefreshToken org.keycloak.util.TokenUtil:getRefreshToken (
  byte[] decodedToken) {
  guard = tt;
  ret(level()) = pc ⊔ level(decodedToken) ⊔ obj_level(decodedToken);
  ret(obj_level()) = pc ⊔ level(decodedToken) ⊔ obj_level(decodedToken);
  ret(obj_level(decodedToken)) = obj_level(decodedToken);
}