org.keycloak.TokenVerifier (java.lang.String tokenString,
                            java.lang.Class clazz) {
  guard = tt;
  ret(obj_level(clazz)) = pc ⊔ level(clazz) ⊔ level(this) ⊔ level(tokenString) ⊔ obj_level(clazz) ⊔ obj_level(this) ⊔ obj_level(tokenString);
  ret(obj_level(this)) = pc ⊔ level(clazz) ⊔ level(this) ⊔ level(tokenString) ⊔ obj_level(clazz) ⊔ obj_level(this) ⊔ obj_level(tokenString);
  ret(obj_level(tokenString)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(tokenString);
}