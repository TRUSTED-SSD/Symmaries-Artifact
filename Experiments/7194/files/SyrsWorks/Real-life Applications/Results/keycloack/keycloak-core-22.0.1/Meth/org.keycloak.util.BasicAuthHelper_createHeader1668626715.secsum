static java.lang.String org.keycloak.util.BasicAuthHelper:createHeader (
  java.lang.String @username, java.lang.String password) {
  guard = tt;
  ret(level()) = pc ⊔ level(@username) ⊔ level(password) ⊔ obj_level(@username);
  ret(obj_level()) = pc ⊔ level(@username) ⊔ level(password) ⊔ obj_level(@username);
  ret(obj_level(@username)) = pc ⊔ level(@username) ⊔ level(password) ⊔ obj_level(@username);
  ret(obj_level(password)) = pc ⊔ level(@username) ⊔ level(password) ⊔ obj_level(@username);
}