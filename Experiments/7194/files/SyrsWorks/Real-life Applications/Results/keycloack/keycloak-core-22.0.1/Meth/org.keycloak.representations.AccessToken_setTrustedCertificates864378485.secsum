void org.keycloak.representations.AccessToken:setTrustedCertificates (
  java.util.Set trustedCertificates) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(trustedCertificates) ⊔ obj_level(this) ⊔ obj_level(trustedCertificates);
  ret(obj_level(trustedCertificates)) = pc ⊔ level(trustedCertificates) ⊔ obj_level(trustedCertificates);
}