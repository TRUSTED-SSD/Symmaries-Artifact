void org.keycloak.representations.idm.authorization.ResourceRepresentation:addScope (
  org.keycloak.representations.idm.authorization.ScopeRepresentation scope) {
  guard = tt;
  ret(obj_level(scope)) = pc ⊔ level(scope) ⊔ level(this) ⊔ obj_level(scope) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(scope) ⊔ level(this) ⊔ obj_level(scope) ⊔ obj_level(this);
}