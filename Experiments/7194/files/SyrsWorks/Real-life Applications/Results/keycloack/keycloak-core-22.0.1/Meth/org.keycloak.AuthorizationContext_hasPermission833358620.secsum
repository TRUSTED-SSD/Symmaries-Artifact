boolean org.keycloak.AuthorizationContext:hasPermission (java.lang.String
                                                           resourceName,
                                                         java.lang.String
                                                           @scopeName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@scopeName) ⊔ level(this) ⊔ obj_level(@scopeName) ⊔ obj_level(this);
  ret(obj_level(@scopeName)) = pc ⊔ level(@scopeName) ⊔ level(this) ⊔ obj_level(@scopeName) ⊔ obj_level(this);
  ret(obj_level(resourceName)) = pc ⊔ level(@scopeName) ⊔ level(this) ⊔ obj_level(@scopeName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@scopeName) ⊔ level(this) ⊔ obj_level(@scopeName) ⊔ obj_level(this);
}