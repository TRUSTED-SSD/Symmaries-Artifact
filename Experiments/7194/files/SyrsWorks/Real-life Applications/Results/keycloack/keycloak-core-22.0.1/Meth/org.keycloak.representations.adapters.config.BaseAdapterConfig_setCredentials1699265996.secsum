void org.keycloak.representations.adapters.config.BaseAdapterConfig:setCredentials (
  java.util.Map credentials) {
  guard = tt;
  ret(obj_level(credentials)) = pc ⊔ level(credentials) ⊔ obj_level(credentials);
  ret(obj_level(this)) = pc ⊔ level(credentials) ⊔ obj_level(credentials) ⊔ obj_level(this);
}