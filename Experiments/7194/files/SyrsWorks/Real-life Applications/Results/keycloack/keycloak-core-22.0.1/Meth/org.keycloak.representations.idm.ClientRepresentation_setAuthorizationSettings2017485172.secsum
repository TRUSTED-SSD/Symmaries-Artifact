void org.keycloak.representations.idm.ClientRepresentation:setAuthorizationSettings (
  org.keycloak.representations.idm.authorization.ResourceServerRepresentation
    authorizationSettings) {
  guard = tt;
  ret(obj_level(authorizationSettings)) = pc ⊔ level(authorizationSettings) ⊔ obj_level(authorizationSettings);
  ret(obj_level(this)) = pc ⊔ level(authorizationSettings) ⊔ obj_level(authorizationSettings) ⊔ obj_level(this);
}