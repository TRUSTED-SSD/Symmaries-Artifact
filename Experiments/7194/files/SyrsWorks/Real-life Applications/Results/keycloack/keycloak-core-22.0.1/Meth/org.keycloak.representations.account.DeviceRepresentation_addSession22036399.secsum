void org.keycloak.representations.account.DeviceRepresentation:addSession (
  org.keycloak.representations.account.SessionRepresentation sessionRep) {
  guard = tt;
  ret(obj_level(sessionRep)) = pc ⊔ level(sessionRep) ⊔ level(this) ⊔ obj_level(sessionRep) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(sessionRep) ⊔ level(this) ⊔ obj_level(sessionRep) ⊔ obj_level(this);
}