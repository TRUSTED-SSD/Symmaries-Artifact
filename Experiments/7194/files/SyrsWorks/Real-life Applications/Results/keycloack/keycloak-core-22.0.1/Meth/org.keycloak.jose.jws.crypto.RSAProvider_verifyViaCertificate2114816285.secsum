static boolean org.keycloak.jose.jws.crypto.RSAProvider:verifyViaCertificate (
  org.keycloak.jose.jws.JWSInput input, java.lang.String cert) {
  guard = tt;
  ret(level()) = pc ⊔ level(cert) ⊔ level(input) ⊔ obj_level(cert) ⊔ obj_level(input);
  ret(obj_level(cert)) = pc ⊔ level(cert) ⊔ level(input) ⊔ obj_level(cert) ⊔ obj_level(input);
  ret(obj_level(input)) = pc ⊔ level(cert) ⊔ level(input) ⊔ obj_level(cert) ⊔ obj_level(input);
}