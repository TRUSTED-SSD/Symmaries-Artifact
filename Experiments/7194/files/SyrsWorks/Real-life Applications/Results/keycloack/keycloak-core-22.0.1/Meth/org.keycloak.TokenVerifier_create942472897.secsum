  ret(obj_level()) = pc ⊔ level(clazz) ⊔ level(tokenString) ⊔ obj_level(clazz) ⊔ obj_level(tokenString);
  ret(obj_level(clazz)) = pc ⊔ level(clazz) ⊔ level(tokenString) ⊔ obj_level(clazz) ⊔ obj_level(tokenString);
