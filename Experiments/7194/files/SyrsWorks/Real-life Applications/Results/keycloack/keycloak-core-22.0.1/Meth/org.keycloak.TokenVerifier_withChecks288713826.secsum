org.keycloak.TokenVerifier org.keycloak.TokenVerifier:withChecks (org.keycloak.TokenVerifier$Predicate[]
                                                                    checks) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(checks) ⊔ level(this) ⊔ obj_level(checks) ⊔ obj_level(this);
  ret(obj_level(checks)) = pc ⊔ level(checks) ⊔ level(this) ⊔ obj_level(checks) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(checks) ⊔ level(this) ⊔ obj_level(checks) ⊔ obj_level(this);
}