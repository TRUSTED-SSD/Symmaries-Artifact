org.keycloak.RSATokenVerifier org.keycloak.RSATokenVerifier:checkTokenType (
  boolean checkTokenType) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(checkTokenType) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(checkTokenType) ⊔ level(this) ⊔ obj_level(this);
}