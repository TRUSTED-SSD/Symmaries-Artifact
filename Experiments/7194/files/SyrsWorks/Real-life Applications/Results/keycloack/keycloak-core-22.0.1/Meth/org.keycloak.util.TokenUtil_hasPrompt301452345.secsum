static boolean org.keycloak.util.TokenUtil:hasPrompt (java.lang.String
                                                        @promptParam,
                                                      java.lang.String
                                                        targetPrompt) {
  guard = tt;
  ret(level()) = pc ⊔ level(@promptParam) ⊔ level(targetPrompt) ⊔ obj_level(@promptParam);
  ret(obj_level(@promptParam)) = pc ⊔ level(@promptParam) ⊔ level(targetPrompt) ⊔ obj_level(@promptParam);
  ret(obj_level(targetPrompt)) = pc ⊔ level(@promptParam) ⊔ level(targetPrompt) ⊔ obj_level(@promptParam);
}