static boolean org.keycloak.util.TokenUtil:hasScope (java.lang.String
                                                       @scopeParam,
                                                     java.lang.String
                                                       targetScope) {
  guard = tt;
  ret(level()) = pc ⊔ level(@scopeParam) ⊔ level(targetScope) ⊔ obj_level(@scopeParam);
  ret(obj_level(@scopeParam)) = pc ⊔ level(@scopeParam) ⊔ level(targetScope) ⊔ obj_level(@scopeParam);
  ret(obj_level(targetScope)) = pc ⊔ level(@scopeParam) ⊔ level(targetScope) ⊔ obj_level(@scopeParam);
}