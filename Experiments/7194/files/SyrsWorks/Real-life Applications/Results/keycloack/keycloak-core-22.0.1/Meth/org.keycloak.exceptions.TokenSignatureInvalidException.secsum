org.keycloak.exceptions.TokenSignatureInvalidException (org.keycloak.representations.JsonWebToken
                                                          token) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(token) ⊔ obj_level(this) ⊔ obj_level(token);
  ret(obj_level(token)) = pc ⊔ level(this) ⊔ level(token) ⊔ obj_level(this) ⊔ obj_level(token);
}