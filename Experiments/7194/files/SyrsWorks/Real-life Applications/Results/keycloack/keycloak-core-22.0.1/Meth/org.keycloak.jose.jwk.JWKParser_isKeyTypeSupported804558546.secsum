boolean org.keycloak.jose.jwk.JWKParser:isKeyTypeSupported (java.lang.String
                                                              keyType) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(keyType);
  ret(obj_level(keyType)) = obj_level(keyType);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(keyType) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}