void org.keycloak.representations.adapters.action.GlobalRequestResult:addSuccessRequest (
  java.lang.String reqUri) {
  guard = tt;
  ret(obj_level(reqUri)) = pc ⊔ level(reqUri) ⊔ level(this) ⊔ obj_level(reqUri) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(reqUri) ⊔ level(this) ⊔ obj_level(reqUri) ⊔ obj_level(this);
}