void org.keycloak.representations.info.ServerInfoRepresentation:setProfileInfo (
  org.keycloak.representations.info.ProfileInfoRepresentation profileInfo) {
  guard = tt;
  ret(obj_level(profileInfo)) = pc ⊔ level(profileInfo) ⊔ obj_level(profileInfo);
  ret(obj_level(this)) = pc ⊔ level(profileInfo) ⊔ obj_level(profileInfo) ⊔ obj_level(this);
}