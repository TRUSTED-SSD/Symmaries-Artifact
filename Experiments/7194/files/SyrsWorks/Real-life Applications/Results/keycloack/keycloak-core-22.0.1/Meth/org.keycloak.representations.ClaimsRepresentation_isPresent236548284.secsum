boolean org.keycloak.representations.ClaimsRepresentation:isPresent (
  java.lang.String claimName,
  org.keycloak.representations.ClaimsRepresentation$ClaimContext ctx) {
  guard = tt;
  ret(level()) = pc ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(claimName) ⊔ obj_level(this);
  ret(obj_level(claimName)) = obj_level(claimName);
  ret(obj_level(ctx)) = if obj_level(ctx) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(claimName) = ⊤ ∧ obj_level(ctx) = ⊥ then ⊤ else ⊥;
  ret(obj_level(this)) = pc ⊔ level(ctx) ⊔ obj_level(claimName) ⊔ obj_level(this) ⊔ level(this) ⊓ obj_level(ctx);
}