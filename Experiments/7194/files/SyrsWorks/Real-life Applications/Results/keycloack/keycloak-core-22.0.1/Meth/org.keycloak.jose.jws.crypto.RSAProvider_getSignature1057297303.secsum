static java.security.Signature org.keycloak.jose.jws.crypto.RSAProvider:getSignature (
  org.keycloak.jose.jws.Algorithm alg) {
  guard = tt;
  ret(level()) = pc ⊔ level(alg) ⊔ obj_level(alg);
  ret(obj_level()) = pc ⊔ level(alg) ⊔ obj_level(alg);
  ret(obj_level(alg)) = pc ⊔ level(alg) ⊔ obj_level(alg);
}