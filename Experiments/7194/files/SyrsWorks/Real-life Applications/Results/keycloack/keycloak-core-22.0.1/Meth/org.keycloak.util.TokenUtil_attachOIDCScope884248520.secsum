static java.lang.String org.keycloak.util.TokenUtil:attachOIDCScope (
  java.lang.String @scopeParam) {
  guard = tt;
  ret(level()) = pc ⊔ level(@scopeParam) ⊔ obj_level(@scopeParam);
  ret(obj_level()) = pc ⊔ level(@scopeParam) ⊔ obj_level(@scopeParam);
  ret(obj_level(@scopeParam)) = pc ⊔ level(@scopeParam) ⊔ obj_level(@scopeParam);
}