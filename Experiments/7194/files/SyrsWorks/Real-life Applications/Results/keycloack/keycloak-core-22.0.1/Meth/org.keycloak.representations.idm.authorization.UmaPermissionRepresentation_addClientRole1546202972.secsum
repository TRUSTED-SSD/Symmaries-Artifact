void org.keycloak.representations.idm.authorization.UmaPermissionRepresentation:addClientRole (
  java.lang.String @clientId, java.lang.String roleName) {
  guard = tt;
  ret(obj_level(@clientId)) = pc ⊔ level(@clientId) ⊔ level(roleName) ⊔ level(this) ⊔ obj_level(@clientId) ⊔ obj_level(this);
  ret(obj_level(roleName)) = pc ⊔ level(@clientId) ⊔ level(roleName) ⊔ level(this) ⊔ obj_level(@clientId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@clientId) ⊔ level(roleName) ⊔ level(this) ⊔ obj_level(@clientId) ⊔ obj_level(this);
}