void org.keycloak.representations.account.ClientRepresentation:setConsent (
  org.keycloak.representations.account.ConsentRepresentation consent) {
  guard = tt;
  ret(obj_level(consent)) = pc ⊔ level(consent) ⊔ obj_level(consent);
  ret(obj_level(this)) = pc ⊔ level(consent) ⊔ obj_level(consent) ⊔ obj_level(this);
}