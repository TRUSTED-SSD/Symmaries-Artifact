static java.lang.String org.keycloak.util.TokenUtil:jweDirectEncode (
  java.security.Key aesKey, java.security.Key hmacKey,
  org.keycloak.representations.JsonWebToken jwt) {
  guard = tt;
  ret(level()) = pc ⊔ level(aesKey) ⊔ level(hmacKey) ⊔ level(jwt) ⊔ obj_level(aesKey) ⊔ obj_level(jwt);
  ret(obj_level()) = pc ⊔ level(aesKey) ⊔ level(hmacKey) ⊔ level(jwt) ⊔ obj_level(aesKey) ⊔ obj_level(jwt);
  ret(obj_level(aesKey)) = pc ⊔ level(jwt) ⊔ obj_level(aesKey) ⊔ obj_level(jwt);
  ret(obj_level(hmacKey)) = pc ⊔ level(jwt) ⊔ obj_level(hmacKey) ⊔ obj_level(jwt);
  ret(obj_level(jwt)) = pc ⊔ level(jwt) ⊔ obj_level(jwt);
}