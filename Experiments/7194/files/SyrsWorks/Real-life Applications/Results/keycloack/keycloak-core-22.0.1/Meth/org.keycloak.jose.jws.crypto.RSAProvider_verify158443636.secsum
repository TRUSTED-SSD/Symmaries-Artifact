boolean org.keycloak.jose.jws.crypto.RSAProvider:verify (org.keycloak.jose.jws.JWSInput
                                                           input,
                                                         java.lang.String key) {
  guard = tt;
  ret(level()) = pc ⊔ level(input) ⊔ level(key) ⊔ obj_level(input) ⊔ obj_level(key);
  ret(obj_level(input)) = pc ⊔ level(input) ⊔ level(key) ⊔ obj_level(input) ⊔ obj_level(key);
  ret(obj_level(key)) = pc ⊔ level(input) ⊔ level(key) ⊔ obj_level(input) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(input) ⊔ level(key) ⊔ obj_level(input) ⊔ obj_level(key) ⊔ obj_level(this);
}