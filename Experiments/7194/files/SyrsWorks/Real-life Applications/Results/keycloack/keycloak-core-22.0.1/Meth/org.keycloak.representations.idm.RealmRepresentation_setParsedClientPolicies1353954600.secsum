void org.keycloak.representations.idm.RealmRepresentation:setParsedClientPolicies (
  org.keycloak.representations.idm.ClientPoliciesRepresentation
    clientPolicies) {
  guard = tt;
  ret(obj_level(clientPolicies)) = pc ⊔ level(clientPolicies) ⊔ obj_level(clientPolicies);
  ret(obj_level(this)) = pc ⊔ level(clientPolicies) ⊔ obj_level(clientPolicies) ⊔ obj_level(this);
}