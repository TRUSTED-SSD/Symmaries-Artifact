static org.keycloak.representations.AccessToken org.keycloak.RSATokenVerifier:verifyToken (
  java.lang.String tokenString, java.security.PublicKey publicKey,
  java.lang.String realmUrl) {
  guard = tt;
  ret(level()) = pc ⊔ level(publicKey) ⊔ level(realmUrl) ⊔ level(tokenString) ⊔ obj_level(publicKey) ⊔ obj_level(realmUrl);
  ret(obj_level()) = pc ⊔ level(publicKey) ⊔ level(realmUrl) ⊔ level(tokenString) ⊔ obj_level(publicKey) ⊔ obj_level(realmUrl);
  ret(obj_level(publicKey)) = pc ⊔ level(publicKey) ⊔ level(realmUrl) ⊔ level(tokenString) ⊔ obj_level(publicKey) ⊔ obj_level(realmUrl);
  ret(obj_level(realmUrl)) = pc ⊔ level(publicKey) ⊔ level(realmUrl) ⊔ level(tokenString) ⊔ obj_level(publicKey) ⊔ obj_level(realmUrl);
  ret(obj_level(tokenString)) = pc ⊔ level(publicKey) ⊔ level(realmUrl) ⊔ level(tokenString) ⊔ obj_level(publicKey) ⊔ obj_level(realmUrl);
}