void org.keycloak.representations.idm.RealmRepresentation:addIdentityProvider (
  org.keycloak.representations.idm.IdentityProviderRepresentation
    identityProviderRepresentation) {
  guard = tt;
  ret(obj_level(identityProviderRepresentation)) = pc ⊔ level(identityProviderRepresentation) ⊔ level(this) ⊔ obj_level(identityProviderRepresentation) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(identityProviderRepresentation) ⊔ level(this) ⊔ obj_level(identityProviderRepresentation) ⊔ obj_level(this);
}