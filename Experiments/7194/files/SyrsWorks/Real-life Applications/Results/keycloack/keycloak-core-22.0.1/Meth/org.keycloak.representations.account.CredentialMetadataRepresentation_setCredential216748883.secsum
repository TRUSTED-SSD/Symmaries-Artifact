void org.keycloak.representations.account.CredentialMetadataRepresentation:setCredential (
  org.keycloak.representations.idm.CredentialRepresentation credential) {
  guard = tt;
  ret(obj_level(credential)) = obj_level(credential);
  ret(obj_level(this)) = pc ⊔ level(credential) ⊔ obj_level(credential) ⊔ obj_level(this);
}