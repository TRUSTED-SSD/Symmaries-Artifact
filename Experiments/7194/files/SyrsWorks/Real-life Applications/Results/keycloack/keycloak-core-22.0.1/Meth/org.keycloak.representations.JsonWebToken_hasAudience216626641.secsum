boolean org.keycloak.representations.JsonWebToken:hasAudience (java.lang.String
                                                                 audience) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(audience) ⊔ obj_level(this);
  ret(obj_level(audience)) = if obj_level(audience) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(audience) = ⊥ ∧ obj_level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(audience) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}