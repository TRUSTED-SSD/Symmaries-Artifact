javax.crypto.SecretKeyFactory org.keycloak.crypto.def.DefaultCryptoProvider:getSecretKeyFact (
  java.lang.String keyAlgorithm) {
  guard = tt;
  ret(level()) = pc ⊔ level(keyAlgorithm) ⊔ obj_level(keyAlgorithm);
  ret(obj_level()) = pc ⊔ level(keyAlgorithm) ⊔ obj_level(keyAlgorithm);
  ret(obj_level(keyAlgorithm)) = pc ⊔ level(keyAlgorithm) ⊔ obj_level(keyAlgorithm);
  ret(obj_level(this)) = pc ⊔ level(keyAlgorithm) ⊔ obj_level(keyAlgorithm) ⊔ obj_level(this);
}