javax.net.ssl.SSLSocketFactory org.keycloak.crypto.def.DefaultCryptoProvider:wrapFactoryForTruststore (
  javax.net.ssl.SSLSocketFactory delegate) {
  guard = tt;
  ret(level()) = pc ⊔ level(delegate);
  ret(obj_level()) = obj_level(delegate);
  ret(obj_level(delegate)) = obj_level(delegate);
  ret(obj_level(this)) = obj_level(this);
}