void org.keycloak.crypto.def.DefaultRsaKeyEncryptionJWEAlgorithmProvider:initCipher (
  javax.crypto.Cipher cipher, int mode, java.security.Key key) {
  guard = tt;
  ret(obj_level(cipher)) = pc ⊔ level(cipher) ⊔ level(key) ⊔ level(mode) ⊔ obj_level(cipher) ⊔ obj_level(key);
  ret(obj_level(key)) = pc ⊔ level(cipher) ⊔ level(key) ⊔ level(mode) ⊔ obj_level(cipher) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(cipher) ⊔ level(key) ⊔ level(mode) ⊔ obj_level(cipher) ⊔ obj_level(key) ⊔ obj_level(this);
}