static java.lang.Class org.keycloak.common.util.reflections.Types:getTemplateParameterOfInterface (
  java.lang.Class @base, java.lang.Class desiredInterface) {
  guard = tt;
  ret(level()) = pc ⊔ level(@base) ⊔ level(desiredInterface) ⊔ obj_level(@base);
  ret(obj_level()) = pc ⊔ level(@base) ⊔ level(desiredInterface) ⊔ obj_level(@base);
  ret(obj_level(@base)) = if obj_level(@base) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(@base) = ⊥ ∧ level(@base) ⊔ level(desiredInterface) = ⊤ then ⊤ else ⊥;
  ret(obj_level(desiredInterface)) = if obj_level(@base) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(@base) = ⊥ ∧ level(@base) ⊔ level(desiredInterface) = ⊤ then ⊤ else ⊥;
}