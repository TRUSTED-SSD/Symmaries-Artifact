static java.lang.reflect.Type[] org.keycloak.common.util.reflections.Types:extractTypeVariables (
  java.util.Map typeVarMap, java.lang.reflect.Type[] types) {
  guard = tt;
  ret(level()) = pc ⊔ level(types);
  ret(obj_level()) = pc ⊔ level(typeVarMap) ⊔ level(types) ⊔ obj_level(typeVarMap) ⊔ obj_level(types);
  ret(obj_level(typeVarMap)) = pc ⊔ level(typeVarMap) ⊔ level(types) ⊔ obj_level(typeVarMap) ⊔ obj_level(types);
  ret(obj_level(types)) = pc ⊔ level(typeVarMap) ⊔ level(types) ⊔ obj_level(typeVarMap) ⊔ obj_level(types);
}