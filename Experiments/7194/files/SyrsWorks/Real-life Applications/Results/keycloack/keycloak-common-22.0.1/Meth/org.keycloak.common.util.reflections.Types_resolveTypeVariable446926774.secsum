static java.lang.reflect.Type org.keycloak.common.util.reflections.Types:resolveTypeVariable (
  java.lang.Class root, java.lang.reflect.TypeVariable typeVariable) {
  guard = tt;
  ret(level()) = pc ⊔ level(root) ⊔ obj_level(root) ⊔ obj_level(typeVariable);
  ret(obj_level()) = pc ⊔ level(root) ⊔ obj_level(root) ⊔ obj_level(typeVariable);
  ret(obj_level(root)) = pc ⊔ level(root) ⊔ obj_level(root) ⊔ obj_level(typeVariable);
  ret(obj_level(typeVariable)) = pc ⊔ level(root) ⊔ obj_level(root) ⊔ obj_level(typeVariable);
}