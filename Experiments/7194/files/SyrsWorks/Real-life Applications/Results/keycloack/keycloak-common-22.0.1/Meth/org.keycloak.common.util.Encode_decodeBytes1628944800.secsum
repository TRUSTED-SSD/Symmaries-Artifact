static java.lang.String org.keycloak.common.util.Encode:decodeBytes (
  java.lang.String @enc, java.nio.charset.CharsetDecoder decoder) {
  guard = tt;
  ret(level()) = pc ⊔ level(@enc) ⊔ level(decoder) ⊔ obj_level(@enc) ⊔ obj_level(decoder);
  ret(obj_level()) = pc ⊔ level(@enc) ⊔ level(decoder) ⊔ obj_level(@enc) ⊔ obj_level(decoder);
  ret(obj_level(@enc)) = pc ⊔ level(@enc) ⊔ level(decoder) ⊔ obj_level(@enc) ⊔ obj_level(decoder);
  ret(obj_level(decoder)) = pc ⊔ level(@enc) ⊔ level(decoder) ⊔ obj_level(@enc) ⊔ obj_level(decoder);
}