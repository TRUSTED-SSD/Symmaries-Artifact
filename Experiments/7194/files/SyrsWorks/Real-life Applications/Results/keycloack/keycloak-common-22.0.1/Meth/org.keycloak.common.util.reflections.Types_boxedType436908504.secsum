static java.lang.reflect.Type org.keycloak.common.util.reflections.Types:boxedType (
  java.lang.reflect.Type type) {
  guard = tt;
  ret(level()) = pc ⊔ level(type) ⊔ obj_level(type);
  ret(obj_level()) = pc ⊔ level(type) ⊔ obj_level(type);
  ret(obj_level(type)) = if obj_level(type) = ⊤ ∨ pc ≠ ⊤ ∧ level(type) = ⊤ ∧ obj_level(type) = ⊥ then ⊤ else ⊥;
}