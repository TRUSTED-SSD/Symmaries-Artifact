void org.keycloak.common.util.ConcurrentMultivaluedHashMap:addAll (java.lang.Object
                                                                    key,
                                                                   java.lang.Object[]
                                                                    newValues) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ level(newValues) ⊔ level(this) ⊔ obj_level(key);
  ret(obj_level(newValues)) = pc ⊔ level(key) ⊔ level(newValues) ⊔ level(this) ⊔ obj_level(newValues);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ level(newValues) ⊔ level(this) ⊔ obj_level(newValues);
}