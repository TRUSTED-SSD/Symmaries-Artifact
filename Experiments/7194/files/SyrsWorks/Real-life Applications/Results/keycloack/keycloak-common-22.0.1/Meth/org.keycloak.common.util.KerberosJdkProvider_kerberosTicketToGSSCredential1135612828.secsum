org.ietf.jgss.GSSCredential org.keycloak.common.util.KerberosJdkProvider:kerberosTicketToGSSCredential (
  javax.security.auth.kerberos.KerberosTicket kerberosTicket) {
  guard = tt;
  ret(level()) = pc ⊔ level(kerberosTicket) ⊔ level(this) ⊔ obj_level(kerberosTicket) ⊔ obj_level(this);
  ret(obj_level()) = level(kerberosTicket) ⊔ level(this) ⊔ obj_level(kerberosTicket) ⊔ obj_level(this);
  ret(obj_level(kerberosTicket)) = obj_level(kerberosTicket);
  ret(obj_level(this)) = obj_level(this);
}