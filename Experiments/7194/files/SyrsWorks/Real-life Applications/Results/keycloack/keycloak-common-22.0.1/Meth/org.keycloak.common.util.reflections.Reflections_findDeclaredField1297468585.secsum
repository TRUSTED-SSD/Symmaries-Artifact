static java.lang.reflect.Field org.keycloak.common.util.reflections.Reflections:findDeclaredField (
  java.lang.Class @clazz, java.lang.String name) {
  guard = tt;
  ret(level()) = pc ⊔ level(@clazz) ⊔ level(name) ⊔ obj_level(@clazz) ⊔ obj_level(name);
  ret(obj_level()) = pc ⊔ level(@clazz) ⊔ level(name) ⊔ obj_level(@clazz) ⊔ obj_level(name);
  ret(obj_level(@clazz)) = pc ⊔ level(@clazz) ⊔ level(name) ⊔ obj_level(@clazz) ⊔ obj_level(name);
  ret(obj_level(name)) = pc ⊔ level(@clazz) ⊔ level(name) ⊔ obj_level(@clazz) ⊔ obj_level(name);
}