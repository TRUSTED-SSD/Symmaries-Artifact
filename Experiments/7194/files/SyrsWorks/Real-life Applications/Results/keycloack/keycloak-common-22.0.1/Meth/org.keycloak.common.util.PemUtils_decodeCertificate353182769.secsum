static java.security.cert.X509Certificate org.keycloak.common.util.PemUtils:decodeCertificate (
  java.lang.String cert) {
  guard = tt;
  ret(level()) = pc ⊔ level(cert) ⊔ obj_level(cert);
  ret(obj_level()) = pc ⊔ level(cert) ⊔ obj_level(cert);
  ret(obj_level(cert)) = pc ⊔ level(cert) ⊔ obj_level(cert);
}