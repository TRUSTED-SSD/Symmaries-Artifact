static org.keycloak.common.util.KeycloakUriBuilder org.keycloak.common.util.KeycloakUriBuilder:fromUri (
  java.net.URI uri) {
  guard = tt;
  ret(level()) = pc ⊔ level(uri) ⊔ obj_level(uri);
  ret(obj_level()) = pc ⊔ level(uri) ⊔ obj_level(uri);
  ret(obj_level(uri)) = pc ⊔ level(uri) ⊔ obj_level(uri);
}