static java.lang.reflect.Type[] org.keycloak.common.util.reflections.Types:findClassParameterizedTypes (
  java.lang.Class root, java.lang.reflect.ParameterizedType @rootType,
  java.lang.Class searchedForClass) {
  guard = tt;
  ret(level()) = pc ⊔ level(@rootType) ⊔ obj_level(@rootType) ⊔ obj_level(root);
  ret(obj_level()) = pc ⊔ level(@rootType) ⊔ obj_level(@rootType) ⊔ obj_level(root);
  ret(obj_level(@rootType)) = pc ⊔ level(@rootType) ⊔ obj_level(@rootType) ⊔ obj_level(root);
  ret(obj_level(root)) = pc ⊔ level(@rootType) ⊔ obj_level(@rootType) ⊔ obj_level(root);
  ret(obj_level(searchedForClass)) = pc ⊔ level(@rootType) ⊔ obj_level(@rootType) ⊔ obj_level(root);
}