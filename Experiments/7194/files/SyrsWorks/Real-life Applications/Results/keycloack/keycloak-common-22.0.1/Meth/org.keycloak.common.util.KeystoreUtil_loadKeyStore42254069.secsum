static java.security.KeyStore org.keycloak.common.util.KeystoreUtil:loadKeyStore (
  java.lang.String @filename, java.lang.String password) {
  guard = tt;
  ret(level()) = pc ⊔ level(@filename) ⊔ obj_level(@filename);
  ret(obj_level()) = pc ⊔ level(@filename) ⊔ obj_level(@filename);
  ret(obj_level(@filename)) = pc ⊔ level(@filename) ⊔ obj_level(@filename);
  ret(obj_level(password)) = pc ⊔ level(@filename) ⊔ obj_level(@filename);
}