byte[] org.keycloak.common.crypto.PemUtilsProvider:generateThumbprintBytes (
  java.lang.String[] certChain, java.lang.String @encoding) {
  guard = tt;
  ret(level()) = pc ⊔ level(@encoding) ⊔ level(certChain) ⊔ obj_level(@encoding) ⊔ obj_level(certChain);
  ret(obj_level()) = pc ⊔ level(@encoding) ⊔ level(certChain) ⊔ obj_level(@encoding) ⊔ obj_level(certChain);
  ret(obj_level(@encoding)) = pc ⊔ level(@encoding) ⊔ level(certChain) ⊔ obj_level(@encoding) ⊔ obj_level(certChain);
  ret(obj_level(certChain)) = pc ⊔ level(@encoding) ⊔ level(certChain) ⊔ obj_level(@encoding) ⊔ obj_level(certChain);
  ret(obj_level(this)) = pc ⊔ level(@encoding) ⊔ level(certChain) ⊔ obj_level(@encoding) ⊔ obj_level(certChain) ⊔ obj_level(this);
}