static java.lang.reflect.Type[] org.keycloak.common.util.reflections.Types:getActualTypeArgumentsOfAnInterface (
  java.lang.Class classToSearch, java.lang.Class interfaceToFind) {
  guard = tt;
  ret(level()) = pc ⊔ level(classToSearch) ⊔ level(interfaceToFind) ⊔ obj_level(classToSearch);
  ret(obj_level()) = pc ⊔ level(classToSearch) ⊔ level(interfaceToFind) ⊔ obj_level(classToSearch);
  ret(obj_level(classToSearch)) = pc ⊔ level(classToSearch) ⊔ level(interfaceToFind) ⊔ obj_level(classToSearch);
  ret(obj_level(interfaceToFind)) = pc ⊔ level(classToSearch) ⊔ level(interfaceToFind) ⊔ obj_level(classToSearch);
}