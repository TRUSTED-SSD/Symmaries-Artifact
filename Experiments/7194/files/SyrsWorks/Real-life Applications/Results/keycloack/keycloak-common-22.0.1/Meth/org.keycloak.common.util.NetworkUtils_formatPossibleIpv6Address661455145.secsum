static java.lang.String org.keycloak.common.util.NetworkUtils:formatPossibleIpv6Address (
  java.lang.String @address) {
  guard = tt;
  ret(level()) = pc ⊔ level(@address) ⊔ obj_level(@address);
  ret(obj_level()) = pc ⊔ level(@address) ⊔ obj_level(@address);
  ret(obj_level(@address)) = pc ⊔ level(@address) ⊔ obj_level(@address);
}