static java.lang.String org.keycloak.common.util.KerberosSerializationUtils:serializeCredential (
  javax.security.auth.kerberos.KerberosTicket @kerberosTicket,
  org.ietf.jgss.GSSCredential gssCredential) {
  guard = pc ⊔ level(@kerberosTicket) ⊔ level(gssCredential) ⊔ obj_level(@kerberosTicket) ⊔ obj_level(gssCredential) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(@kerberosTicket)) = ⊥;
  ret(obj_level(gssCredential)) = ⊥;
}