static java.lang.reflect.Type[] org.keycloak.common.util.reflections.Types:findParameterizedTypes (
  java.lang.Class root, java.lang.Class searchedFor) {
  guard = tt;
  ret(level()) = pc ⊔ level(root) ⊔ level(searchedFor) ⊔ obj_level(root);
  ret(obj_level()) = pc ⊔ level(root) ⊔ level(searchedFor) ⊔ obj_level(root);
  ret(obj_level(root)) = pc ⊔ obj_level(root);
  ret(obj_level(searchedFor)) = pc ⊔ obj_level(root);
}