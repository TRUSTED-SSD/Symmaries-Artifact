static java.lang.String org.keycloak.common.util.UriUtils:stripQueryParam (
  java.lang.String @url, java.lang.String @name) {
  guard = tt;
  ret(level()) = pc ⊔ level(@name) ⊔ level(@url) ⊔ obj_level(@name);
  ret(obj_level()) = pc ⊔ level(@name) ⊔ level(@url) ⊔ obj_level(@name);
  ret(obj_level(@name)) = pc ⊔ level(@name) ⊔ level(@url) ⊔ obj_level(@name);
  ret(obj_level(@url)) = pc ⊔ level(@name) ⊔ level(@url) ⊔ obj_level(@name);
}