static boolean org.keycloak.common.util.NetworkUtils:checkForPresence (
  java.lang.String @key, java.lang.String value) {
  guard = tt;
  ret(level()) = pc ⊔ level(@key) ⊔ level(value) ⊔ obj_level(@key);
  ret(obj_level(@key)) = pc ⊔ level(@key) ⊔ level(value) ⊔ obj_level(@key);
  ret(obj_level(value)) = pc ⊔ level(@key) ⊔ level(value) ⊔ obj_level(@key);
}