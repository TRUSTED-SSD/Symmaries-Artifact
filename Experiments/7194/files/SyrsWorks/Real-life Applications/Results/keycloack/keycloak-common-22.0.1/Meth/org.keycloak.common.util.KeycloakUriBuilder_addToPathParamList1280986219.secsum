void org.keycloak.common.util.KeycloakUriBuilder:addToPathParamList (
  java.util.List params, java.util.HashSet set, java.lang.String @string) {
  guard = tt;
  ret(obj_level(@string)) = pc ⊔ level(params) ⊔ level(set) ⊔ obj_level(@string) ⊔ obj_level(params) ⊔ obj_level(set);
  ret(obj_level(params)) = pc ⊔ level(params) ⊔ level(set) ⊔ obj_level(@string) ⊔ obj_level(params) ⊔ obj_level(set);
  ret(obj_level(set)) = pc ⊔ level(params) ⊔ level(set) ⊔ obj_level(@string) ⊔ obj_level(params) ⊔ obj_level(set);
