void org.keycloak.common.util.DelegatingSerializationFilter:setFilter (
  java.io.ObjectInputStream ois, java.lang.String filterPattern) {
  guard = tt;
  ret(obj_level(filterPattern)) = pc ⊔ level(filterPattern) ⊔ level(ois) ⊔ obj_level(filterPattern) ⊔ obj_level(ois);
  ret(obj_level(ois)) = pc ⊔ level(filterPattern) ⊔ level(ois) ⊔ obj_level(filterPattern) ⊔ obj_level(ois);
  ret(obj_level(this)) = pc ⊔ level(filterPattern) ⊔ level(ois) ⊔ obj_level(filterPattern) ⊔ obj_level(ois) ⊔ obj_level(this);
}