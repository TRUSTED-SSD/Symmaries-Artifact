static java.lang.reflect.Constructor org.keycloak.common.util.reflections.Reflections:findDeclaredConstructor (
  java.lang.Class @clazz, java.lang.Class[] args) {
  guard = tt;
  ret(level()) = pc ⊔ level(@clazz) ⊔ level(args) ⊔ obj_level(@clazz) ⊔ obj_level(args);
  ret(obj_level()) = pc ⊔ level(@clazz) ⊔ level(args) ⊔ obj_level(@clazz) ⊔ obj_level(args);
  ret(obj_level(@clazz)) = pc ⊔ level(@clazz) ⊔ level(args) ⊔ obj_level(@clazz) ⊔ obj_level(args);
  ret(obj_level(args)) = pc ⊔ level(@clazz) ⊔ level(args) ⊔ obj_level(@clazz) ⊔ obj_level(args);
}