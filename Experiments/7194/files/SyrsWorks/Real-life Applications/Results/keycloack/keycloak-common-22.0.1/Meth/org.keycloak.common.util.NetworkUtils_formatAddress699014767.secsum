static java.lang.String org.keycloak.common.util.NetworkUtils:formatAddress (
  java.net.InetAddress inet) {
  guard = tt;
  ret(level()) = pc ⊔ level(inet) ⊔ obj_level(inet);
  ret(obj_level()) = pc ⊔ level(inet) ⊔ obj_level(inet);
  ret(obj_level(inet)) = if obj_level(inet) = ⊤ ∨ pc ≠ ⊤ ∧ level(inet) = ⊤ ∧ obj_level(inet) = ⊥ then ⊤ else ⊥;
}