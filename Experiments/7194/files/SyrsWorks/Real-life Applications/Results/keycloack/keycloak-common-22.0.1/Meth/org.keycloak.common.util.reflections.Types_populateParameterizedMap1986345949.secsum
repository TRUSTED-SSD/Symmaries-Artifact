static java.util.Map org.keycloak.common.util.reflections.Types:populateParameterizedMap (
  java.lang.Class root, java.lang.reflect.ParameterizedType rootType) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(rootType) ⊔ obj_level(root) ⊔ obj_level(rootType);
  ret(obj_level(root)) = pc ⊔ level(rootType) ⊔ obj_level(root) ⊔ obj_level(rootType);
  ret(obj_level(rootType)) = pc ⊔ level(rootType) ⊔ obj_level(root) ⊔ obj_level(rootType);
}