static java.security.cert.X509Certificate org.keycloak.common.util.CertificateUtils:generateV1SelfSignedCertificate (
  java.security.KeyPair caKeyPair, java.lang.String subject) {
  guard = tt;
  ret(level()) = pc ⊔ level(caKeyPair) ⊔ level(subject) ⊔ obj_level(caKeyPair) ⊔ obj_level(subject);
  ret(obj_level()) = pc ⊔ level(caKeyPair) ⊔ level(subject) ⊔ obj_level(caKeyPair) ⊔ obj_level(subject);
  ret(obj_level(caKeyPair)) = obj_level(caKeyPair);
  ret(obj_level(subject)) = obj_level(subject);
}