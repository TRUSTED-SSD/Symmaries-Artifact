static void org.keycloak.common.util.UriUtils:checkUrl (org.keycloak.common.enums.SslRequired
                                                          sslRequired,
                                                        java.lang.String @url,
                                                        java.lang.String name) {
  guard = tt;
  ret(obj_level(@url)) = pc ⊔ level(@url) ⊔ level(name) ⊔ level(sslRequired) ⊔ obj_level(@url) ⊔ obj_level(sslRequired);
  ret(obj_level(name)) = pc ⊔ level(@url) ⊔ level(name) ⊔ level(sslRequired) ⊔ obj_level(@url) ⊔ obj_level(sslRequired);
  ret(obj_level(sslRequired)) = pc ⊔ level(@url) ⊔ level(name) ⊔ level(sslRequired) ⊔ obj_level(@url) ⊔ obj_level(sslRequired);
}