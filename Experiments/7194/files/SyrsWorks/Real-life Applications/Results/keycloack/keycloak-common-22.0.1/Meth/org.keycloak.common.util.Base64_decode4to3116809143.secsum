static int org.keycloak.common.util.Base64:decode4to3 (byte[] source,
                                                       int srcOffset,
                                                       byte[] destination,
                                                       int destOffset,
                                                       int options) {
  guard = tt;
  ret(level()) = pc ⊔ level(destOffset) ⊔ level(destination) ⊔ level(source) ⊔ level(srcOffset) ⊔ obj_level(destination);
  ret(obj_level(destination)) = pc ⊔ level(destOffset) ⊔ level(destination) ⊔ level(options) ⊔ level(source) ⊔ level(srcOffset) ⊔ obj_level(destination);
  ret(obj_level(source)) = pc ⊔ level(destOffset) ⊔ level(destination) ⊔ level(options) ⊔ level(source) ⊔ level(srcOffset) ⊔ obj_level(destination);
}