static boolean org.keycloak.common.util.reflections.Reflections:isTypeBounded (
  java.lang.reflect.Type type, java.lang.reflect.Type[] lowerBounds,
  java.lang.reflect.Type[] upperBounds) {
  guard = tt;
  ret(level()) = pc ⊔ level(lowerBounds) ⊔ level(type) ⊔ level(upperBounds) ⊔ obj_level(lowerBounds) ⊔ obj_level(type);
  ret(obj_level(lowerBounds)) = if obj_level(lowerBounds) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(lowerBounds) = ⊥ ∧ obj_level(type) = ⊤ then ⊤ else ⊥;
  ret(obj_level(type)) = if obj_level(type) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(lowerBounds) = ⊤ ∧ obj_level(type) = ⊥ then ⊤ else ⊥;
  ret(obj_level(upperBounds)) = if obj_level(lowerBounds) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(lowerBounds) = ⊥ ∧ obj_level(type) = ⊤ then ⊤ else ⊥;
}