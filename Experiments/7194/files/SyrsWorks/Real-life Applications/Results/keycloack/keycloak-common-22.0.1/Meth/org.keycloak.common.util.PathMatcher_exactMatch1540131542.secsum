boolean org.keycloak.common.util.PathMatcher:exactMatch (java.lang.String
                                                           @expectedUri,
                                                         java.lang.String
                                                           targetUri) {
  guard = tt;
  ret(level()) = pc ⊔ level(@expectedUri) ⊔ level(targetUri) ⊔ obj_level(@expectedUri);
  ret(obj_level(@expectedUri)) = pc ⊔ level(@expectedUri) ⊔ level(targetUri) ⊔ obj_level(@expectedUri);
  ret(obj_level(targetUri)) = pc ⊔ level(@expectedUri) ⊔ level(targetUri) ⊔ obj_level(@expectedUri);
  ret(obj_level(this)) = obj_level(this);
}