static java.lang.Object org.keycloak.common.util.reflections.Reflections:getFieldValue (
  java.lang.reflect.Field field, java.lang.Object @instance) {
  guard = tt;
  ret(level()) = pc ⊔ level(@instance) ⊔ level(field) ⊔ obj_level(@instance);
  ret(obj_level()) = pc ⊔ level(@instance) ⊔ level(field) ⊔ obj_level(@instance);
  ret(obj_level(@instance)) = obj_level(@instance);
  ret(obj_level(field)) = obj_level(field);
}