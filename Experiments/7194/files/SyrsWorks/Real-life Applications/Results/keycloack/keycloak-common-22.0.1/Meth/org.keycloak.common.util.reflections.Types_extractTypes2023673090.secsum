static java.lang.reflect.Type[] org.keycloak.common.util.reflections.Types:extractTypes (
  java.util.Map typeVarMap, java.lang.reflect.Type genericSub) {
  guard = tt;
  ret(level()) = pc ⊔ level(genericSub) ⊔ obj_level(genericSub);
  ret(obj_level()) = pc ⊔ level(genericSub) ⊔ level(typeVarMap) ⊔ obj_level(genericSub) ⊔ obj_level(typeVarMap);
  ret(obj_level(genericSub)) = pc ⊔ level(genericSub) ⊔ level(typeVarMap) ⊔ obj_level(genericSub) ⊔ obj_level(typeVarMap);
  ret(obj_level(typeVarMap)) = pc ⊔ level(genericSub) ⊔ level(typeVarMap) ⊔ obj_level(genericSub) ⊔ obj_level(typeVarMap);
}