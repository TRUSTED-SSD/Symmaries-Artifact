static boolean org.keycloak.common.util.reflections.Types:isCompatible (
  java.lang.reflect.Method method, java.lang.reflect.Method intfMethod) {
  guard = tt;
  ret(level()) = pc ⊔ level(intfMethod) ⊔ level(method) ⊔ obj_level(intfMethod);
  ret(obj_level(intfMethod)) = if obj_level(intfMethod) = ⊤ ∨ pc ≠ ⊤ ∧ (if level(method) = ⊤ then obj_level(intfMethod) = ⊥ else level(intfMethod) = ⊤ ∧ level(method) = ⊥ ∧ obj_level(intfMethod) = ⊥) then ⊤ else ⊥;
  ret(obj_level(method)) = if obj_level(intfMethod) = ⊤ ∨ pc ≠ ⊤ ∧ (if level(method) = ⊤ then obj_level(intfMethod) = ⊥ else level(intfMethod) = ⊤ ∧ level(method) = ⊥ ∧ obj_level(intfMethod) = ⊥) then ⊤ else ⊥;
}