java.lang.String org.keycloak.common.crypto.PemUtilsProvider:removeBeginEnd(java.lang.String @pem)
{
java.lang.String pem;
pem=@pem;
pem = pem.replaceAll("-----BEGIN (.*)-----","");
 pem = pem.replaceAll("-----END (.*)----","");
 pem = pem.replaceAll("\r\n","");
 pem = pem.replaceAll("\n","");
 pem = pem.trim();
 return  pem;
 } 

