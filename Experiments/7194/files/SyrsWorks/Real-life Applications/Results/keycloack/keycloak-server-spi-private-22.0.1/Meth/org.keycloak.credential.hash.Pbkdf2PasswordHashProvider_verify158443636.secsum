boolean org.keycloak.credential.hash.Pbkdf2PasswordHashProvider:verify (
  java.lang.String @rawPassword,
  org.keycloak.models.credential.PasswordCredentialModel credential) {
  guard = tt;
  ret(level()) = pc ⊔ level(@rawPassword) ⊔ level(this) ⊔ obj_level(@rawPassword) ⊔ obj_level(credential) ⊔ obj_level(this);
  ret(obj_level(@rawPassword)) = pc ⊔ level(@rawPassword) ⊔ level(this) ⊔ obj_level(@rawPassword) ⊔ obj_level(credential) ⊔ obj_level(this);
  ret(obj_level(credential)) = obj_level(credential);
  ret(obj_level(this)) = pc ⊔ level(@rawPassword) ⊔ level(this) ⊔ obj_level(@rawPassword) ⊔ obj_level(credential) ⊔ obj_level(this);
}