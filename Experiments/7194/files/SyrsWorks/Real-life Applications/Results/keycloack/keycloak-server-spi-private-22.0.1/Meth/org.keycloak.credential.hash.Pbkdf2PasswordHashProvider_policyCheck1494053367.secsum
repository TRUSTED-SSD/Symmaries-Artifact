boolean org.keycloak.credential.hash.Pbkdf2PasswordHashProvider:policyCheck (
  org.keycloak.models.PasswordPolicy policy,
  org.keycloak.models.credential.PasswordCredentialModel credential) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(credential) ⊔ obj_level(policy) ⊔ obj_level(this);
  ret(obj_level(credential)) = obj_level(credential);
  ret(obj_level(policy)) = obj_level(policy);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(credential) ⊔ obj_level(policy) ⊔ obj_level(this);
}