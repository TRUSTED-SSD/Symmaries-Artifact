org.eclipse.jetty.server.Request org.keycloak.adapters.jetty.KeycloakJettyAuthenticator:resolveRequest (
  javax.servlet.ServletRequest req) {
  guard = tt;
  ret(level()) = pc ⊔ level(req) ⊔ obj_level(req);
  ret(obj_level()) = pc ⊔ level(req) ⊔ obj_level(req);
  ret(obj_level(req)) = pc ⊔ level(req) ⊔ obj_level(req);
  ret(obj_level(this)) = obj_level(this);
}