static java.nio.ByteBuffer org.apache.kerby.kerberos.kerb.admin.message.KadminCode:encodeWrapMessage (
  org.apache.kerby.kerberos.kerb.admin.message.AdminMessage adminMessage,
  org.xnio.sasl.SaslWrapper sasl) {
  guard = tt;
  ret(level()) = pc ⊔ level(adminMessage) ⊔ level(sasl) ⊔ obj_level(adminMessage) ⊔ obj_level(sasl);
  ret(obj_level()) = ⊤;
  ret(obj_level(adminMessage)) = ⊤;
  ret(obj_level(sasl)) = pc ⊔ level(adminMessage) ⊔ level(sasl) ⊔ obj_level(adminMessage) ⊔ obj_level(sasl);
}