org.apache.kerby.asn1.Asn1Dumper org.apache.kerby.asn1.Asn1Dumper:append (
  java.lang.String string) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(string) ⊔ level(this) ⊔ obj_level(string) ⊔ obj_level(this);
  ret(obj_level(string)) = obj_level(string);
  ret(obj_level(this)) = pc ⊔ level(string) ⊔ level(this) ⊔ obj_level(string) ⊔ obj_level(this);
}