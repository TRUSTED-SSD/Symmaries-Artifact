org.apache.kerby.kerberos.kerb.crypto.cksum.ConfounderedDesCheckSum (
  org.apache.kerby.kerberos.kerb.crypto.cksum.HashProvider hashProvider,
  int computeSize, int outputSize) {
  guard = tt;
  ret(obj_level(hashProvider)) = pc ⊔ level(computeSize) ⊔ level(hashProvider) ⊔ level(outputSize) ⊔ level(this) ⊔ obj_level(hashProvider) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(computeSize) ⊔ level(hashProvider) ⊔ level(outputSize) ⊔ level(this) ⊔ obj_level(hashProvider) ⊔ obj_level(this);
}