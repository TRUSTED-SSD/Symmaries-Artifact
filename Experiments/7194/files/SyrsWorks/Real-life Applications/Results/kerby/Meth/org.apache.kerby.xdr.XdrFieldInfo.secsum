org.apache.kerby.xdr.XdrFieldInfo (int index,
                                   org.apache.kerby.xdr.XdrDataType dataType,
                                   java.lang.Object value) {
  guard = tt;
  ret(obj_level(dataType)) = pc ⊔ level(this) ⊔ obj_level(dataType);
  ret(obj_level(this)) = pc ⊔ level(dataType) ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(dataType);
  ret(obj_level(value)) = pc ⊔ level(dataType) ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(dataType);
}