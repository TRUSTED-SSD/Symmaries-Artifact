void org.apache.kerby.kerberos.kerb.KrbOutputStream:writeTime (org.apache.kerby.kerberos.kerb.type.KerberosTime
                                                                 ktime) {
  guard = pc ⊔ level(ktime) ⊔ level(this) ⊔ obj_level(ktime) ⊔ obj_level(this) = ⊥;
  ret(obj_level(ktime)) = ⊥;
  ret(obj_level(this)) = ⊥;
}