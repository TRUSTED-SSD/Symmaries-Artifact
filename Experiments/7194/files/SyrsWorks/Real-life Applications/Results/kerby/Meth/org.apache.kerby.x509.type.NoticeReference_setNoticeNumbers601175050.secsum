void org.apache.kerby.x509.type.NoticeReference:setNoticeNumbers (org.apache.kerby.x509.type.NoticeNumbers
                                                                    noticeNumbers) {
  guard = tt;
  ret(obj_level(noticeNumbers)) = pc ⊔ level(noticeNumbers) ⊔ level(this) ⊔ obj_level(noticeNumbers) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(noticeNumbers) ⊔ level(this) ⊔ obj_level(this);
}