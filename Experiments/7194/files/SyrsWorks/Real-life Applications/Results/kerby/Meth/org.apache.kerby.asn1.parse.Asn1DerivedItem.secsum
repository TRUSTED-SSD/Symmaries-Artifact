org.apache.kerby.asn1.parse.Asn1DerivedItem (org.apache.kerby.asn1.Tag newTag,
                                             org.apache.kerby.asn1.parse.Asn1Container
                                               container) {
  guard = tt;
  ret(obj_level(container)) = pc ⊔ level(container) ⊔ level(newTag) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(newTag) ⊔ obj_level(this);
  ret(obj_level(newTag)) = pc ⊔ level(container) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(newTag) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(container) ⊔ level(newTag) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(newTag) ⊔ obj_level(this);
}