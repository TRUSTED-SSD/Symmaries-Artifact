void org.apache.kerby.cms.type.SignerInfo:setSignedAttributes (org.apache.kerby.cms.type.SignedAttributes
                                                                 signedAttributes) {
  guard = tt;
  ret(obj_level(signedAttributes)) = pc ⊔ level(signedAttributes) ⊔ level(this) ⊔ obj_level(signedAttributes) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signedAttributes) ⊔ level(this) ⊔ obj_level(this);
}