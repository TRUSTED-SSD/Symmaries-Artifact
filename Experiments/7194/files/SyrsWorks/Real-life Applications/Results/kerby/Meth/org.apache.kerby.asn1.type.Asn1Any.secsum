org.apache.kerby.asn1.type.Asn1Any (org.apache.kerby.asn1.type.Asn1Type
                                      anyValue) {
  guard = tt;
  ret(obj_level(anyValue)) = pc ⊔ level(anyValue) ⊔ level(this) ⊔ obj_level(anyValue);
  ret(obj_level(this)) = pc ⊔ level(anyValue) ⊔ level(this) ⊔ obj_level(this);
}