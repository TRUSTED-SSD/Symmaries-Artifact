static org.apache.kerby.kerberos.kerb.type.base.EncryptionKey org.apache.kerby.kerberos.kerb.crypto.fast.FastUtil:makeArmorKey (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey @subkey,
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey ticketKey) {
  guard = tt;
  ret(level()) = pc ⊔ level(@subkey) ⊔ level(ticketKey) ⊔ obj_level(@subkey);
  ret(obj_level()) = pc ⊔ level(@subkey) ⊔ level(ticketKey) ⊔ obj_level(@subkey);
  ret(obj_level(@subkey)) = obj_level(@subkey);
  ret(obj_level(ticketKey)) = obj_level(ticketKey);
}