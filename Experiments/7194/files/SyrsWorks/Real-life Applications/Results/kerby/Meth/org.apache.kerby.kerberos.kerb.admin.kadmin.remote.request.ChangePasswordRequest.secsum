org.apache.kerby.kerberos.kerb.admin.kadmin.remote.request.ChangePasswordRequest (
  java.lang.String principal, java.lang.String newPassword) {
  guard = tt;
  ret(obj_level(newPassword)) = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
  ret(obj_level(principal)) = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(newPassword) ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
}