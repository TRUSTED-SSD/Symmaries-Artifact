void org.apache.kerby.kerberos.kerb.type.ad.ADIntendedForServer:setIntendedServer (
  org.apache.kerby.kerberos.kerb.type.ad.PrincipalList principals) {
  guard = tt;
  ret(obj_level(principals)) = pc ⊔ level(principals) ⊔ level(this) ⊔ obj_level(principals) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(principals) ⊔ level(this) ⊔ obj_level(principals) ⊔ obj_level(this);
}