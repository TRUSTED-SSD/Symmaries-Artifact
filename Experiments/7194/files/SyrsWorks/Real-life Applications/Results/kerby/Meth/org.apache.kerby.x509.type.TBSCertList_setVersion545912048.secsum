void org.apache.kerby.x509.type.TBSCertList:setVersion (org.apache.kerby.asn1.type.Asn1Integer
                                                          version) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(version) ⊔ obj_level(this);
  ret(obj_level(version)) = pc ⊔ level(this) ⊔ level(version) ⊔ obj_level(this) ⊔ obj_level(version);
}