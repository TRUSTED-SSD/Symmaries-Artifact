void org.apache.kerby.kerberos.kerb.common.Krb5Parser:insertSections (
  java.lang.String @line, java.io.BufferedReader br, java.util.Map items) {
  p0: '0 -> dummyClass ('0) -> level;
  p1: java.io.BufferedReader () -> level;
  guard = tt;
  ret(obj_level(@line)) = p0 ⊔ p1 ⊔ pc ⊔ level(@line) ⊔ level(items) ⊔ obj_level(@line) ⊔ obj_level(br) ⊔ obj_level(items) ⊔ obj_level(this);
  ret(obj_level(br)) = p0 ⊔ p1 ⊔ pc ⊔ level(@line) ⊔ level(items) ⊔ obj_level(@line) ⊔ obj_level(br) ⊔ obj_level(items) ⊔ obj_level(this);
  ret(obj_level(items)) = p0 ⊔ p1 ⊔ pc ⊔ level(@line) ⊔ level(items) ⊔ obj_level(@line) ⊔ obj_level(br) ⊔ obj_level(items) ⊔ obj_level(this);
  ret(obj_level(this)) = p0 ⊔ p1 ⊔ pc ⊔ level(@line) ⊔ level(items) ⊔ obj_level(@line) ⊔ obj_level(br) ⊔ obj_level(items) ⊔ obj_level(this);
}