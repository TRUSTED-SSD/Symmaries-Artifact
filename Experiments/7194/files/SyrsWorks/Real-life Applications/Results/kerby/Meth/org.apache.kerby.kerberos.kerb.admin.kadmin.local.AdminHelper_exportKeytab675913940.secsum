static void org.apache.kerby.kerberos.kerb.admin.kadmin.local.AdminHelper:exportKeytab (
  java.io.File keytabFile,
  org.apache.kerby.kerberos.kerb.request.KrbIdentity identity) {
  guard = pc ⊔ level(identity) ⊔ level(keytabFile) ⊔ obj_level(identity) ⊔ obj_level(keytabFile) = ⊥;
  ret(obj_level(identity)) = ⊥;
  ret(obj_level(keytabFile)) = ⊥;
}