void org.apache.kerby.kerberos.kerb.type.kdc.KdcReqBody:setCname (org.apache.kerby.kerberos.kerb.type.base.PrincipalName
                                                                    cname) {
  guard = tt;
  ret(obj_level(cname)) = pc ⊔ level(cname) ⊔ level(this) ⊔ obj_level(cname) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cname) ⊔ level(this) ⊔ obj_level(this);
}