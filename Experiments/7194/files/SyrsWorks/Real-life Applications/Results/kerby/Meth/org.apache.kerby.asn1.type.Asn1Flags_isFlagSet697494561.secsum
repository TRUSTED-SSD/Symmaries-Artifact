boolean org.apache.kerby.asn1.type.Asn1Flags:isFlagSet (org.apache.kerby.asn1.EnumType
                                                          flag) {
  guard = tt;
  ret(level()) = pc ⊔ level(flag) ⊔ level(this) ⊔ obj_level(flag) ⊔ obj_level(this);
  ret(obj_level(flag)) = pc ⊔ level(flag) ⊔ obj_level(flag);
  ret(obj_level(this)) = pc ⊔ level(flag) ⊔ obj_level(flag) ⊔ obj_level(this);
}