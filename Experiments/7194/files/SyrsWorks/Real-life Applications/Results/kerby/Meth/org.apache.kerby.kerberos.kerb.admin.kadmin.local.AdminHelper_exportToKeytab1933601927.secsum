static void org.apache.kerby.kerberos.kerb.admin.kadmin.local.AdminHelper:exportToKeytab (
  org.apache.kerby.kerberos.kerb.keytab.Keytab keytab,
  org.apache.kerby.kerberos.kerb.request.KrbIdentity identity) {
  guard = tt;
  ret(obj_level(identity)) = pc ⊔ level(identity) ⊔ level(keytab) ⊔ obj_level(identity) ⊔ obj_level(keytab);
  ret(obj_level(keytab)) = pc ⊔ level(identity) ⊔ level(keytab) ⊔ obj_level(identity) ⊔ obj_level(keytab);
}