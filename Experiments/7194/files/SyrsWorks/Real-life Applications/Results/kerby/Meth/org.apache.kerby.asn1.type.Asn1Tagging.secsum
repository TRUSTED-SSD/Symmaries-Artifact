org.apache.kerby.asn1.type.Asn1Tagging (int tagNo,
                                        org.apache.kerby.asn1.type.Asn1Type
                                          value,
                                        boolean isAppSpecific,
                                        boolean isImplicit) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(isAppSpecific) ⊔ level(isImplicit) ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
  ret(obj_level(value)) = pc ⊔ level(isAppSpecific) ⊔ level(isImplicit) ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
}