void org.apache.kerby.kerberos.kerb.request.KrbIdentity:setExpireTime (
  org.apache.kerby.kerberos.kerb.type.KerberosTime expireTime) {
  guard = tt;
  ret(obj_level(expireTime)) = pc ⊔ level(expireTime) ⊔ obj_level(expireTime);
  ret(obj_level(this)) = pc ⊔ level(expireTime) ⊔ obj_level(expireTime) ⊔ obj_level(this);
}