void org.apache.kerby.x509.type.OtherName:setTypeId (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                       algorithm) {
  guard = tt;
  ret(obj_level(algorithm)) = pc ⊔ level(algorithm) ⊔ level(this) ⊔ obj_level(algorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(algorithm) ⊔ level(this) ⊔ obj_level(this);
}