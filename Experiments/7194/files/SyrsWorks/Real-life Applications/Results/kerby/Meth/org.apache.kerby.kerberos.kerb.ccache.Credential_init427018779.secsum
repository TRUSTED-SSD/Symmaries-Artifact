void org.apache.kerby.kerberos.kerb.ccache.Credential:init (org.apache.kerby.kerberos.kerb.type.ticket.KrbTicket
                                                              tkt,
                                                            org.apache.kerby.kerberos.kerb.type.base.PrincipalName
                                                              clientPrincipal) {
  guard = tt;
  ret(obj_level(clientPrincipal)) = pc ⊔ level(clientPrincipal) ⊔ level(this) ⊔ level(tkt) ⊔ obj_level(clientPrincipal) ⊔ obj_level(this) ⊔ obj_level(tkt);
  ret(obj_level(this)) = pc ⊔ level(clientPrincipal) ⊔ level(this) ⊔ level(tkt) ⊔ obj_level(clientPrincipal) ⊔ obj_level(this) ⊔ obj_level(tkt);
  ret(obj_level(tkt)) = pc ⊔ level(clientPrincipal) ⊔ level(this) ⊔ level(tkt) ⊔ obj_level(clientPrincipal) ⊔ obj_level(this) ⊔ obj_level(tkt);
}