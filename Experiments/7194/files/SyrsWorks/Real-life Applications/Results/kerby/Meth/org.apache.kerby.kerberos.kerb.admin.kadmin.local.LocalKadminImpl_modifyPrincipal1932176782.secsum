void org.apache.kerby.kerberos.kerb.admin.kadmin.local.LocalKadminImpl:modifyPrincipal (
  java.lang.String @principal, org.apache.kerby.KOptions kOptions) {
  guard = pc ⊔ level(@principal) ⊔ level(kOptions) ⊔ level(this) ⊔ obj_level(@principal) ⊔ obj_level(kOptions) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@principal)) = ⊥;
  ret(obj_level(kOptions)) = ⊥;
  ret(obj_level(this)) = ⊥;
}