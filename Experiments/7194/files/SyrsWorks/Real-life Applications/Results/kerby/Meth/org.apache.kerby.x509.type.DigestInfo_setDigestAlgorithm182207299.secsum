void org.apache.kerby.x509.type.DigestInfo:setDigestAlgorithm (org.apache.kerby.x509.type.AlgorithmIdentifier
                                                                 digestAlgorithm) {
  guard = tt;
  ret(obj_level(digestAlgorithm)) = pc ⊔ level(digestAlgorithm) ⊔ level(this) ⊔ obj_level(digestAlgorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(digestAlgorithm) ⊔ level(this) ⊔ obj_level(this);
}