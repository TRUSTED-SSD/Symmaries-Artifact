void org.apache.kerby.kerberos.kerb.auth.AuthContext:setKey (org.apache.kerby.kerberos.kerb.type.base.EncryptionKey
                                                               key) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ obj_level(key) ⊔ obj_level(this);
}