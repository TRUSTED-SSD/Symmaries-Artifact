  java.lang.String remoteRealm) {
  guard = tt;
  ret(level()) = pc ⊔ level(remoteRealm) ⊔ level(this) ⊔ obj_level(remoteRealm) ⊔ obj_level(this);
  ret(obj_level(remoteRealm)) = pc ⊔ level(remoteRealm) ⊔ level(this) ⊔ obj_level(remoteRealm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(remoteRealm) ⊔ level(this) ⊔ obj_level(remoteRealm) ⊔ obj_level(this);
}