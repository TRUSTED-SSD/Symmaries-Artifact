void org.apache.kerby.asn1.type.Asn1CollectionType:setAnyFieldValueType (
  org.apache.kerby.asn1.EnumType index, java.lang.Class valueType) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(valueType) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(valueType);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(valueType) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(valueType);
  ret(obj_level(valueType)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(valueType) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(valueType);
}