void org.apache.kerby.cms.type.EncryptedContentInfo:setContentType (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                                    contentType) {
  guard = tt;
  ret(obj_level(contentType)) = pc ⊔ level(contentType) ⊔ level(this) ⊔ obj_level(contentType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(contentType) ⊔ level(this) ⊔ obj_level(this);
}