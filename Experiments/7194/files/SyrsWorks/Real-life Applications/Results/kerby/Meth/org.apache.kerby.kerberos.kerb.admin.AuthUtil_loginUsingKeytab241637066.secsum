static javax.security.auth.Subject org.apache.kerby.kerberos.kerb.admin.AuthUtil:loginUsingKeytab (
  java.lang.String principal, java.io.File keytabFile) {
  guard = pc ⊔ level(keytabFile) ⊔ level(principal) ⊔ obj_level(keytabFile) ⊔ obj_level(principal) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(keytabFile)) = ⊥;
  ret(obj_level(principal)) = ⊥;
}