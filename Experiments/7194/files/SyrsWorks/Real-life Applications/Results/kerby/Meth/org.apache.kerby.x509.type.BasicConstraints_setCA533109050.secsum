void org.apache.kerby.x509.type.BasicConstraints:setCA (org.apache.kerby.asn1.type.Asn1Boolean
                                                          isCA) {
  guard = tt;
  ret(obj_level(isCA)) = pc ⊔ level(isCA) ⊔ level(this) ⊔ obj_level(isCA) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(isCA) ⊔ level(this) ⊔ obj_level(this);
}