void org.apache.kerby.cms.type.SignerInfo:setSignatureAlgorithmIdentifier (
  org.apache.kerby.cms.type.SignatureAlgorithmIdentifier
    signatureAlgorithmIdentifier) {
  guard = tt;
  ret(obj_level(signatureAlgorithmIdentifier)) = pc ⊔ level(signatureAlgorithmIdentifier) ⊔ level(this) ⊔ obj_level(signatureAlgorithmIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signatureAlgorithmIdentifier) ⊔ level(this) ⊔ obj_level(this);
}