void org.apache.kerby.config.XmlConfigLoader:loadConfig (org.apache.kerby.config.ConfigImpl
                                                           config,
                                                         org.w3c.dom.Element
                                                           @element) {
  guard = tt;
  ret(obj_level(@element)) = pc ⊔ obj_level(@element);
  ret(obj_level(config)) = pc ⊔ obj_level(@element) ⊔ obj_level(config);
  ret(obj_level(this)) = pc ⊔ obj_level(@element) ⊔ obj_level(this);
}