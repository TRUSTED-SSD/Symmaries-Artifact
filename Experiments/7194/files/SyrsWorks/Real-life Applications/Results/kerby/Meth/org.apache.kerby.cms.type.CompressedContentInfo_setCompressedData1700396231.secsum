void org.apache.kerby.cms.type.CompressedContentInfo:setCompressedData (
  org.apache.kerby.cms.type.CompressedData signedData) {
  guard = tt;
  ret(obj_level(signedData)) = pc ⊔ level(signedData) ⊔ level(this) ⊔ obj_level(signedData) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signedData) ⊔ level(this) ⊔ obj_level(this);
}