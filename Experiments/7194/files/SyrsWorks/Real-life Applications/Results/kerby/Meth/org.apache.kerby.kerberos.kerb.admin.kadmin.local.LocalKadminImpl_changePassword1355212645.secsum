void org.apache.kerby.kerberos.kerb.admin.kadmin.local.LocalKadminImpl:changePassword (
  java.lang.String @principal, java.lang.String newPassword) {
  guard = pc ⊔ level(@principal) ⊔ level(newPassword) ⊔ level(this) ⊔ obj_level(@principal) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@principal)) = ⊥;
  ret(obj_level(newPassword)) = ⊥;
  ret(obj_level(this)) = ⊥;
}