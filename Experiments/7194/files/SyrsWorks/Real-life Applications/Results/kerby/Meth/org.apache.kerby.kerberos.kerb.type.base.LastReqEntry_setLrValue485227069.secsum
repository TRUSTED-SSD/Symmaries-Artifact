void org.apache.kerby.kerberos.kerb.type.base.LastReqEntry:setLrValue (
  org.apache.kerby.kerberos.kerb.type.KerberosTime lrValue) {
  guard = tt;
  ret(obj_level(lrValue)) = pc ⊔ level(lrValue) ⊔ level(this) ⊔ obj_level(lrValue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(lrValue) ⊔ level(this) ⊔ obj_level(this);
}