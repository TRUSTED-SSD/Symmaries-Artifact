org.w3c.dom.Element org.apache.kerby.config.XmlConfigLoader:loadResourceDocument (
  org.apache.kerby.config.Resource resource) {
  guard = tt;
  ret(level()) = pc ⊔ level(resource) ⊔ obj_level(resource);
  ret(obj_level()) = pc ⊔ level(resource) ⊔ obj_level(resource) ⊔ obj_level(this);
  ret(obj_level(resource)) = pc ⊔ level(resource) ⊔ obj_level(resource) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(resource) ⊔ obj_level(resource) ⊔ obj_level(this);
}