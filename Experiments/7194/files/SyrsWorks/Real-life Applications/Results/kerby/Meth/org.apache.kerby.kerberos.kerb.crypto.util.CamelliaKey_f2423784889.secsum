void org.apache.kerby.kerberos.kerb.crypto.util.CamelliaKey:f2 (int[] s,
                                                                int[] skey,
                                                                int keyoff) {
  guard = tt;
  ret(obj_level(s)) = pc ⊔ level(keyoff) ⊔ level(s) ⊔ level(skey) ⊔ obj_level(s);
  ret(obj_level(skey)) = pc ⊔ level(keyoff) ⊔ level(s) ⊔ level(skey) ⊔ obj_level(s);
  ret(obj_level(this)) = pc ⊔ level(keyoff) ⊔ level(s) ⊔ level(skey) ⊔ obj_level(s) ⊔ obj_level(this);
}