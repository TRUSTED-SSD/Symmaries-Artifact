void org.apache.kerby.kerberos.kerb.type.base.LastReqEntry:setLrType (
  org.apache.kerby.kerberos.kerb.type.base.LastReqType lrType) {
  guard = tt;
  ret(obj_level(lrType)) = pc ⊔ level(lrType) ⊔ level(this) ⊔ obj_level(lrType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(lrType) ⊔ level(this) ⊔ obj_level(lrType) ⊔ obj_level(this);
}