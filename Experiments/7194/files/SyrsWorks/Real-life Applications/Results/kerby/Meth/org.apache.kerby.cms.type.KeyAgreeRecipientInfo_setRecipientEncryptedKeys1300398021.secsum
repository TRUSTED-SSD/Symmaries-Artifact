void org.apache.kerby.cms.type.KeyAgreeRecipientInfo:setRecipientEncryptedKeys (
  org.apache.kerby.cms.type.RecipientEncryptedKeys recipientEncryptedKeys) {
  guard = tt;
  ret(obj_level(recipientEncryptedKeys)) = pc ⊔ level(recipientEncryptedKeys) ⊔ level(this) ⊔ obj_level(recipientEncryptedKeys) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(recipientEncryptedKeys) ⊔ level(this) ⊔ obj_level(this);
}