void org.apache.kerby.kerberos.kerb.admin.kadmin.remote.impl.DefaultAdminHandler:sendMessage (
  org.apache.kerby.kerberos.kerb.admin.kadmin.remote.request.AdminRequest
    adminRequest,
  java.nio.ByteBuffer requestMessage) {
  guard = pc ⊔ level(adminRequest) ⊔ level(requestMessage) ⊔ obj_level(adminRequest) ⊔ obj_level(requestMessage) = ⊥;
  ret(obj_level(adminRequest)) = ⊥;
  ret(obj_level(requestMessage)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}