void org.apache.kerby.cms.type.EncryptedContentInfo:setEncryptedContent (
  org.apache.kerby.asn1.type.Asn1OctetString encryptedContent) {
  guard = tt;
  ret(obj_level(encryptedContent)) = pc ⊔ level(encryptedContent) ⊔ level(this) ⊔ obj_level(encryptedContent) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(encryptedContent) ⊔ level(this) ⊔ obj_level(this);
}