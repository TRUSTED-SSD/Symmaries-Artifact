                                                                elements) {
  guard = tt;
  ret(obj_level(elements)) = pc ⊔ level(elements) ⊔ level(this) ⊔ obj_level(elements) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(elements) ⊔ level(this) ⊔ obj_level(elements) ⊔ obj_level(this);
}