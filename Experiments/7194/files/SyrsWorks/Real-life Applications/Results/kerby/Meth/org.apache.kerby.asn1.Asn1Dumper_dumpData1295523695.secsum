org.apache.kerby.asn1.Asn1Dumper org.apache.kerby.asn1.Asn1Dumper:dumpData (
  java.lang.String @hexData) {
  guard = pc ⊔ level(@hexData) ⊔ obj_level(@hexData) = ⊥;
  ret(level()) = level(this);
  ret(obj_level()) = obj_level(this);
  ret(obj_level(@hexData)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}