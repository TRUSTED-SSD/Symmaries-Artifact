void org.apache.kerby.kerberos.kerb.type.ad.ADKdcIssued:dumpWith (org.apache.kerby.asn1.Asn1Dumper
                                                                    dumper,
                                                                  int indents) {
  guard = tt;
  ret(obj_level(dumper)) = pc ⊔ level(dumper) ⊔ level(indents) ⊔ level(this) ⊔ obj_level(dumper) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(dumper) ⊔ level(indents) ⊔ level(this) ⊔ obj_level(dumper) ⊔ obj_level(this);
}