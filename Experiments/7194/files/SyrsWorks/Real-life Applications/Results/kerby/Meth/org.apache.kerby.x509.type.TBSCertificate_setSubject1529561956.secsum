void org.apache.kerby.x509.type.TBSCertificate:setSubject (org.apache.kerby.x500.type.Name
                                                             subject) {
  guard = tt;
  ret(obj_level(subject)) = pc ⊔ level(subject) ⊔ level(this) ⊔ obj_level(subject) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(subject) ⊔ level(this) ⊔ obj_level(this);
}