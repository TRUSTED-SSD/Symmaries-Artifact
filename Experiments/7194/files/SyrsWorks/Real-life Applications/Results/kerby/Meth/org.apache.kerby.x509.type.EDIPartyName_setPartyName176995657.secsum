void org.apache.kerby.x509.type.EDIPartyName:setPartyName (org.apache.kerby.x509.type.DirectoryString
                                                             partyName) {
  guard = tt;
  ret(obj_level(partyName)) = pc ⊔ level(partyName) ⊔ level(this) ⊔ obj_level(partyName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(partyName) ⊔ level(this) ⊔ obj_level(this);
}