void org.apache.kerby.x500.type.AttributeTypeAndValue:setType (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                                 type) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this);
  ret(obj_level(type)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
}