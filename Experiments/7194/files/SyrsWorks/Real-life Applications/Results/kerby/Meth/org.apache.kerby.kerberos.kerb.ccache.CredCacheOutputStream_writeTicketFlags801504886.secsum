void org.apache.kerby.kerberos.kerb.ccache.CredCacheOutputStream:writeTicketFlags (
  org.apache.kerby.kerberos.kerb.type.ticket.TicketFlags ticketFlags) {
  guard = pc ⊔ level(this) ⊔ level(ticketFlags) ⊔ obj_level(this) ⊔ obj_level(ticketFlags) = ⊥;
  ret(obj_level(this)) = ⊥;
  ret(obj_level(ticketFlags)) = ⊥;
}