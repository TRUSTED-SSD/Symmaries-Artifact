void org.apache.kerby.kerberos.kerb.type.ap.Authenticator:setSubKey (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey subKey) {
  guard = tt;
  ret(obj_level(subKey)) = pc ⊔ level(subKey) ⊔ level(this) ⊔ obj_level(subKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(subKey) ⊔ level(this) ⊔ obj_level(this);
}