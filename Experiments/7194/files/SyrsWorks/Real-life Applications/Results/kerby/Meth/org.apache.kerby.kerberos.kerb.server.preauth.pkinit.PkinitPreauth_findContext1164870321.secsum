org.apache.kerby.kerberos.kerb.server.preauth.pkinit.PkinitKdcContext org.apache.kerby.kerberos.kerb.server.preauth.pkinit.PkinitPreauth:findContext (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName principal) {
  guard = tt;
  ret(level()) = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
  ret(obj_level(principal)) = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this);
}