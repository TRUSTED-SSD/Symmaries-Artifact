void org.apache.kerby.cms.type.SignerInfo:setDigestAlgorithmIdentifier (
  org.apache.kerby.cms.type.DigestAlgorithmIdentifier
    digestAlgorithmIdentifier) {
  guard = tt;
  ret(obj_level(digestAlgorithmIdentifier)) = pc ⊔ level(digestAlgorithmIdentifier) ⊔ level(this) ⊔ obj_level(digestAlgorithmIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(digestAlgorithmIdentifier) ⊔ level(this) ⊔ obj_level(this);
}