void org.apache.kerby.cms.type.RevocationInfoChoice:setCRL (org.apache.kerby.x509.type.CertificateList
                                                              crl) {
  guard = tt;
  ret(obj_level(crl)) = pc ⊔ level(crl) ⊔ level(this) ⊔ obj_level(crl) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(crl) ⊔ level(this) ⊔ obj_level(this);
}