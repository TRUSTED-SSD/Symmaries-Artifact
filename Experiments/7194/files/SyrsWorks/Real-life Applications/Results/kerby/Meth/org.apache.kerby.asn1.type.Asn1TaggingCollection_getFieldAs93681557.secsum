org.apache.kerby.asn1.type.Asn1Type org.apache.kerby.asn1.type.Asn1TaggingCollection:getFieldAs (
  org.apache.kerby.asn1.EnumType index, java.lang.Class t) {
  guard = tt;
  ret(level()) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ obj_level(index) ⊔ obj_level(t) ⊔ obj_level(this);
  ret(obj_level(t)) = pc ⊔ level(index) ⊔ obj_level(index) ⊔ obj_level(t) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ obj_level(index) ⊔ obj_level(t) ⊔ obj_level(this);
}