void org.apache.kerby.x509.type.IssuerSerial:setSerial (org.apache.kerby.x509.type.CertificateSerialNumber
                                                          serial) {
  guard = tt;
  ret(obj_level(serial)) = pc ⊔ level(serial) ⊔ level(this) ⊔ obj_level(serial) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(serial) ⊔ level(this) ⊔ obj_level(this);
}