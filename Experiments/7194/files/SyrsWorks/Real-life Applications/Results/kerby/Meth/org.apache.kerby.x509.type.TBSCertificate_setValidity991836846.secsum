void org.apache.kerby.x509.type.TBSCertificate:setValidity (org.apache.kerby.x509.type.AttCertValidityPeriod
                                                              validity) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(validity) ⊔ obj_level(this);
  ret(obj_level(validity)) = pc ⊔ level(this) ⊔ level(validity) ⊔ obj_level(this) ⊔ obj_level(validity);
}