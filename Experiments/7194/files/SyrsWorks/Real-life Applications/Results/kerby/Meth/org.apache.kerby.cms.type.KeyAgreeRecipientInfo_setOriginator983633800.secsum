void org.apache.kerby.cms.type.KeyAgreeRecipientInfo:setOriginator (org.apache.kerby.cms.type.OriginatorIdentifierOrKey
                                                                    originator) {
  guard = tt;
  ret(obj_level(originator)) = pc ⊔ level(originator) ⊔ level(this) ⊔ obj_level(originator) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(originator) ⊔ level(this) ⊔ obj_level(this);
}