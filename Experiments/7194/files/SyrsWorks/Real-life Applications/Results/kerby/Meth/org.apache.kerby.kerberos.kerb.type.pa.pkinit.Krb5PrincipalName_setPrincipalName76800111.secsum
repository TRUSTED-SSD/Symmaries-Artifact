void org.apache.kerby.kerberos.kerb.type.pa.pkinit.Krb5PrincipalName:setPrincipalName (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName principalName) {
  guard = tt;
  ret(obj_level(principalName)) = pc ⊔ level(principalName) ⊔ level(this) ⊔ obj_level(principalName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(principalName) ⊔ level(this) ⊔ obj_level(this);
}