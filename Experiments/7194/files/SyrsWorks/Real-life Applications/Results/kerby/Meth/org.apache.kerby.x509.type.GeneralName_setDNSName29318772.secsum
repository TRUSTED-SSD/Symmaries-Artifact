void org.apache.kerby.x509.type.GeneralName:setDNSName (org.apache.kerby.asn1.type.Asn1IA5String
                                                          dnsName) {
  guard = tt;
  ret(obj_level(dnsName)) = pc ⊔ level(dnsName) ⊔ level(this) ⊔ obj_level(dnsName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(dnsName) ⊔ level(this) ⊔ obj_level(this);
}