void org.apache.kerby.cms.type.SignerInfo:setSignatureValue (org.apache.kerby.cms.type.SignatureValue
                                                               signatureValue) {
  guard = tt;
  ret(obj_level(signatureValue)) = pc ⊔ level(signatureValue) ⊔ level(this) ⊔ obj_level(signatureValue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signatureValue) ⊔ level(this) ⊔ obj_level(this);
}