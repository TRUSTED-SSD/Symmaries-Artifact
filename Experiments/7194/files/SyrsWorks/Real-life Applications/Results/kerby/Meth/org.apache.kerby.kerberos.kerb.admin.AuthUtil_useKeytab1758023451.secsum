static javax.security.auth.login.Configuration org.apache.kerby.kerberos.kerb.admin.AuthUtil:useKeytab (
  java.lang.String principal, java.io.File keytabFile) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(keytabFile) ⊔ level(principal) ⊔ obj_level(keytabFile) ⊔ obj_level(principal);
  ret(obj_level(keytabFile)) = pc ⊔ level(keytabFile) ⊔ level(principal) ⊔ obj_level(keytabFile) ⊔ obj_level(principal);
  ret(obj_level(principal)) = pc ⊔ level(keytabFile) ⊔ level(principal) ⊔ obj_level(keytabFile) ⊔ obj_level(principal);
}