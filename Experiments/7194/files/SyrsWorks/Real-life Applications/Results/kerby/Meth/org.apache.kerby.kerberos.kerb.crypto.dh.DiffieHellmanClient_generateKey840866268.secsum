org.apache.kerby.kerberos.kerb.type.base.EncryptionKey org.apache.kerby.kerberos.kerb.crypto.dh.DiffieHellmanClient:generateKey (
  byte[] @clientDhNonce, byte[] serverDhNonce,
  org.apache.kerby.kerberos.kerb.type.base.EncryptionType type) {
  guard = tt;
  ret(level()) = pc ⊔ level(@clientDhNonce) ⊔ level(serverDhNonce) ⊔ level(this) ⊔ obj_level(@clientDhNonce) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@clientDhNonce) ⊔ level(serverDhNonce) ⊔ level(this) ⊔ obj_level(@clientDhNonce) ⊔ obj_level(this);
  ret(obj_level(@clientDhNonce)) = pc ⊔ level(@clientDhNonce) ⊔ level(serverDhNonce) ⊔ level(this) ⊔ obj_level(@clientDhNonce) ⊔ obj_level(this);
  ret(obj_level(serverDhNonce)) = pc ⊔ level(@clientDhNonce) ⊔ level(serverDhNonce) ⊔ level(this) ⊔ obj_level(@clientDhNonce) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@clientDhNonce) ⊔ level(serverDhNonce) ⊔ level(this) ⊔ obj_level(@clientDhNonce) ⊔ obj_level(this);
  ret(obj_level(type)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(type);
}