void org.apache.kerby.cms.type.OtherRecipientInfo:setOriType (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                                oriType) {
  guard = tt;
  ret(obj_level(oriType)) = pc ⊔ level(oriType) ⊔ level(this) ⊔ obj_level(oriType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(oriType) ⊔ level(this) ⊔ obj_level(this);
}