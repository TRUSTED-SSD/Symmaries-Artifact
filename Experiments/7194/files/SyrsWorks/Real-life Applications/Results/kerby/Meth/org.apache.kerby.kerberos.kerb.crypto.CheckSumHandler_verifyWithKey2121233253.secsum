static boolean org.apache.kerby.kerberos.kerb.crypto.CheckSumHandler:verifyWithKey (
  org.apache.kerby.kerberos.kerb.type.base.CheckSum checkSum, byte[] bytes,
  byte[] key, org.apache.kerby.kerberos.kerb.type.base.KeyUsage usage) {
  guard = tt;
  ret(level()) = pc ⊔ level(bytes) ⊔ level(checkSum) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(bytes) ⊔ obj_level(checkSum) ⊔ obj_level(usage);
  ret(obj_level(bytes)) = pc ⊔ level(bytes) ⊔ level(checkSum) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(bytes) ⊔ obj_level(checkSum) ⊔ obj_level(usage);
  ret(obj_level(checkSum)) = pc ⊔ level(bytes) ⊔ level(checkSum) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(bytes) ⊔ obj_level(checkSum) ⊔ obj_level(usage);
  ret(obj_level(key)) = pc ⊔ level(bytes) ⊔ level(checkSum) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(bytes) ⊔ obj_level(checkSum) ⊔ obj_level(usage);
  ret(obj_level(usage)) = pc ⊔ level(bytes) ⊔ level(checkSum) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(bytes) ⊔ obj_level(checkSum) ⊔ obj_level(usage);
}