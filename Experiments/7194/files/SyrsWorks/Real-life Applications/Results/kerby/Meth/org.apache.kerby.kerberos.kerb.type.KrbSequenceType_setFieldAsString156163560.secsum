void org.apache.kerby.kerberos.kerb.type.KrbSequenceType:setFieldAsString (
  org.apache.kerby.asn1.EnumType index, java.lang.String value) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(value);
}