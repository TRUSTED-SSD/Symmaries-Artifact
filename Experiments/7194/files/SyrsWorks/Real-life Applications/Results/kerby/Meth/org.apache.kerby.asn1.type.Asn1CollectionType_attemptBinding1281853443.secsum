void org.apache.kerby.asn1.type.Asn1CollectionType:attemptBinding (org.apache.kerby.asn1.parse.Asn1ParseResult
                                                                    parseItem,
                                                                   int
                                                                    foundPos) {
  guard = tt;
  ret(obj_level(parseItem)) = pc ⊔ level(foundPos) ⊔ level(parseItem) ⊔ level(this) ⊔ obj_level(parseItem) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(foundPos) ⊔ level(parseItem) ⊔ level(this) ⊔ obj_level(parseItem) ⊔ obj_level(this);
}