org.apache.kerby.kerberos.kerb.crypto.cksum.CmacKcCheckSum (org.apache.kerby.kerberos.kerb.crypto.enc.EncryptProvider
                                                              encProvider,
                                                            int computeSize,
                                                            int outputSize) {
  guard = tt;
  ret(obj_level(encProvider)) = pc ⊔ level(computeSize) ⊔ level(encProvider) ⊔ level(outputSize) ⊔ level(this) ⊔ obj_level(encProvider) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(computeSize) ⊔ level(encProvider) ⊔ level(outputSize) ⊔ level(this) ⊔ obj_level(encProvider) ⊔ obj_level(this);
}