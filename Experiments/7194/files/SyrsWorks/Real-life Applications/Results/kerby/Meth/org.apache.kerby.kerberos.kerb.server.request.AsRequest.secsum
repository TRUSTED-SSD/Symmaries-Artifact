org.apache.kerby.kerberos.kerb.server.request.AsRequest (org.apache.kerby.kerberos.kerb.type.kdc.AsReq
                                                           asReq,
                                                         org.apache.kerby.kerberos.kerb.server.KdcContext
                                                           kdcContext) {
  guard = tt;
  ret(obj_level(asReq)) = pc ⊔ level(asReq) ⊔ level(kdcContext) ⊔ level(this) ⊔ obj_level(asReq) ⊔ obj_level(kdcContext) ⊔ obj_level(this);
  ret(obj_level(kdcContext)) = pc ⊔ level(asReq) ⊔ level(kdcContext) ⊔ level(this) ⊔ obj_level(asReq) ⊔ obj_level(kdcContext) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(asReq) ⊔ level(kdcContext) ⊔ level(this) ⊔ obj_level(asReq) ⊔ obj_level(kdcContext) ⊔ obj_level(this);
}