void org.apache.kerby.cms.type.CertificateChoices:setV2AttrCert (org.apache.kerby.cms.type.AttributeCertificateV2
                                                                   v2AttrCert) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(v2AttrCert) ⊔ obj_level(this);
  ret(obj_level(v2AttrCert)) = pc ⊔ level(this) ⊔ level(v2AttrCert) ⊔ obj_level(this) ⊔ obj_level(v2AttrCert);
}