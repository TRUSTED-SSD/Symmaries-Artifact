void org.apache.kerby.cms.type.SignedData:setDigestAlgorithms (org.apache.kerby.cms.type.DigestAlgorithmIdentifiers
                                                                 digestAlgorithms) {
  guard = tt;
  ret(obj_level(digestAlgorithms)) = pc ⊔ level(digestAlgorithms) ⊔ level(this) ⊔ obj_level(digestAlgorithms) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(digestAlgorithms) ⊔ level(this) ⊔ obj_level(this);
}