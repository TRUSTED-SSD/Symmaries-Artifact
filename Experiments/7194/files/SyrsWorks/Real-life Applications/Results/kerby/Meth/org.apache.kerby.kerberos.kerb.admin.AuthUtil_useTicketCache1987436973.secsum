static javax.security.auth.login.Configuration org.apache.kerby.kerberos.kerb.admin.AuthUtil:useTicketCache (
  java.lang.String principal, java.io.File credentialFile) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(credentialFile) ⊔ level(principal) ⊔ obj_level(credentialFile) ⊔ obj_level(principal);
  ret(obj_level(credentialFile)) = pc ⊔ level(credentialFile) ⊔ level(principal) ⊔ obj_level(credentialFile) ⊔ obj_level(principal);
  ret(obj_level(principal)) = pc ⊔ level(credentialFile) ⊔ level(principal) ⊔ obj_level(credentialFile) ⊔ obj_level(principal);
}