void org.apache.kerby.x509.type.GeneralSubtree:setBase (org.apache.kerby.x509.type.GeneralName
                                                          base) {
  guard = tt;
  ret(obj_level(base)) = pc ⊔ level(base) ⊔ level(this) ⊔ obj_level(base) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(base) ⊔ level(this) ⊔ obj_level(this);
}