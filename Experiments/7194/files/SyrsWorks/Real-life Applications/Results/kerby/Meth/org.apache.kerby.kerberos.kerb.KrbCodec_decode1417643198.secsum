static org.apache.kerby.asn1.type.Asn1Type org.apache.kerby.kerberos.kerb.KrbCodec:decode (
  byte[] content, java.lang.Class krbType) {
  guard = tt;
  ret(level()) = pc ⊔ level(content) ⊔ level(krbType) ⊔ obj_level(content) ⊔ obj_level(krbType);
  ret(obj_level()) = pc ⊔ level(content) ⊔ level(krbType) ⊔ obj_level(content) ⊔ obj_level(krbType);
  ret(obj_level(content)) = pc ⊔ level(content) ⊔ obj_level(content);
  ret(obj_level(krbType)) = pc ⊔ level(content) ⊔ obj_level(content) ⊔ obj_level(krbType);
}