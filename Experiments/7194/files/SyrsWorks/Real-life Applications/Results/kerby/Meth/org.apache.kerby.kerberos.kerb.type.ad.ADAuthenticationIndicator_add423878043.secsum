void org.apache.kerby.kerberos.kerb.type.ad.ADAuthenticationIndicator:add (
  org.apache.kerby.asn1.type.Asn1Utf8String indicator) {
  guard = tt;
  ret(obj_level(indicator)) = pc ⊔ level(indicator) ⊔ level(this) ⊔ obj_level(indicator) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(indicator) ⊔ level(this) ⊔ obj_level(indicator) ⊔ obj_level(this);
}