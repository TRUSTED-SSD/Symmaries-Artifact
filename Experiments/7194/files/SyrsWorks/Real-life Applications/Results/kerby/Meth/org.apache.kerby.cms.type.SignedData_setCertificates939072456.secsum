void org.apache.kerby.cms.type.SignedData:setCertificates (org.apache.kerby.cms.type.CertificateSet
                                                             certificates) {
  guard = tt;
  ret(obj_level(certificates)) = pc ⊔ level(certificates) ⊔ level(this) ⊔ obj_level(certificates) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(certificates) ⊔ level(this) ⊔ obj_level(this);
}