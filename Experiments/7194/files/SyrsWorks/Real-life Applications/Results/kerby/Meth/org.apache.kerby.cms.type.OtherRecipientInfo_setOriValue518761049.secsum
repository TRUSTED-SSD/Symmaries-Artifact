void org.apache.kerby.cms.type.OtherRecipientInfo:setOriValue (org.apache.kerby.asn1.type.Asn1BitString
                                                                 oriValue) {
  guard = tt;
  ret(obj_level(oriValue)) = pc ⊔ level(oriValue) ⊔ level(this) ⊔ obj_level(oriValue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(oriValue) ⊔ level(this) ⊔ obj_level(this);
}