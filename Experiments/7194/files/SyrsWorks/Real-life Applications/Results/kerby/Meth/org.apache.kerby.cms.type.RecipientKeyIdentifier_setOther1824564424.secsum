void org.apache.kerby.cms.type.RecipientKeyIdentifier:setOther (org.apache.kerby.cms.type.OtherKeyAttribute
                                                                  other) {
  guard = tt;
  ret(obj_level(other)) = pc ⊔ level(other) ⊔ level(this) ⊔ obj_level(other) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(other) ⊔ level(this) ⊔ obj_level(this);
}