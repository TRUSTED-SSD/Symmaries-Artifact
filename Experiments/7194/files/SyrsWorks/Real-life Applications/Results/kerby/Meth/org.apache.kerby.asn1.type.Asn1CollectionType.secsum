org.apache.kerby.asn1.type.Asn1CollectionType (org.apache.kerby.asn1.UniversalTag
                                                 universalTag,
                                               org.apache.kerby.asn1.Asn1FieldInfo[]
                                                 fieldInfos) {
  guard = tt;
  ret(obj_level(fieldInfos)) = pc ⊔ level(fieldInfos) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fieldInfos) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(this);
  ret(obj_level(universalTag)) = pc ⊔ level(fieldInfos) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(this) ⊔ obj_level(universalTag);
}