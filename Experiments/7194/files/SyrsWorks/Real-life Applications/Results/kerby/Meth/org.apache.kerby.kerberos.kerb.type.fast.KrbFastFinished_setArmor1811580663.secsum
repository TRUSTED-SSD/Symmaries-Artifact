void org.apache.kerby.kerberos.kerb.type.fast.KrbFastFinished:setArmor (
  org.apache.kerby.kerberos.kerb.type.fast.KrbFastArmor armor) {
  guard = tt;
  ret(obj_level(armor)) = pc ⊔ level(armor) ⊔ level(this) ⊔ obj_level(armor) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(armor) ⊔ level(this) ⊔ obj_level(this);
}