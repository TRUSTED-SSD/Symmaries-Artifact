void org.apache.kerby.x509.type.AttCertIssuer:setV1Form (org.apache.kerby.x509.type.GeneralNames
                                                           v1Form) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(v1Form) ⊔ obj_level(this);
  ret(obj_level(v1Form)) = pc ⊔ level(this) ⊔ level(v1Form) ⊔ obj_level(this) ⊔ obj_level(v1Form);
}