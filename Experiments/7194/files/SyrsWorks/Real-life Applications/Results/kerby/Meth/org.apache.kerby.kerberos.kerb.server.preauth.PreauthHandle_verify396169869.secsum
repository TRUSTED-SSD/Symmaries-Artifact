void org.apache.kerby.kerberos.kerb.server.preauth.PreauthHandle:verify (
  org.apache.kerby.kerberos.kerb.server.request.KdcRequest kdcRequest,
  org.apache.kerby.kerberos.kerb.type.pa.PaDataEntry paData) {
  guard = pc ⊔ level(kdcRequest) ⊔ level(paData) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(paData) ⊔ obj_level(this) = ⊥;
  ret(obj_level(kdcRequest)) = ⊤;
  ret(obj_level(paData)) = ⊤;
  ret(obj_level(this)) = ⊤;
}