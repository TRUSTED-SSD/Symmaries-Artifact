void org.apache.kerby.x509.type.AttributeCertificateInfo:setHolder (org.apache.kerby.x509.type.Holder
                                                                    holder) {
  guard = tt;
  ret(obj_level(holder)) = pc ⊔ level(holder) ⊔ level(this) ⊔ obj_level(holder) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(holder) ⊔ level(this) ⊔ obj_level(this);
}