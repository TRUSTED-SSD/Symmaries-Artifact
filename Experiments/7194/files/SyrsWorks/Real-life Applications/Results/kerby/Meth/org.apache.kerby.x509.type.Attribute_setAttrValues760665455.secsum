void org.apache.kerby.x509.type.Attribute:setAttrValues (org.apache.kerby.x509.type.AttributeValues
                                                           attrValues) {
  guard = tt;
  ret(obj_level(attrValues)) = pc ⊔ level(attrValues) ⊔ level(this) ⊔ obj_level(attrValues) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(attrValues) ⊔ level(this) ⊔ obj_level(this);
}