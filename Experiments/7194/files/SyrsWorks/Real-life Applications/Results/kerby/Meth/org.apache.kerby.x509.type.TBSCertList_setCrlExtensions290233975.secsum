void org.apache.kerby.x509.type.TBSCertList:setCrlExtensions (org.apache.kerby.x509.type.Extensions
                                                                crlExtensions) {
  guard = tt;
  ret(obj_level(crlExtensions)) = pc ⊔ level(crlExtensions) ⊔ level(this) ⊔ obj_level(crlExtensions) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(crlExtensions) ⊔ level(this) ⊔ obj_level(this);
}