void org.apache.kerby.kerberos.kerb.admin.kadmin.local.LocalKadminImpl:renamePrincipal (
  java.lang.String @oldPrincipalName, java.lang.String @newPrincipalName) {
  guard = pc ⊔ level(@newPrincipalName) ⊔ level(@oldPrincipalName) ⊔ level(this) ⊔ obj_level(@newPrincipalName) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@newPrincipalName)) = ⊥;
  ret(obj_level(@oldPrincipalName)) = ⊥;
  ret(obj_level(this)) = ⊥;
}