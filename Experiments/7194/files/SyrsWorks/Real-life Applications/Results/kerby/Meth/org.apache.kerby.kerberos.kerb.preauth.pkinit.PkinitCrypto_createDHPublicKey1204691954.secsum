static javax.crypto.interfaces.DHPublicKey org.apache.kerby.kerberos.kerb.preauth.pkinit.PkinitCrypto:createDHPublicKey (
  java.math.BigInteger p, java.math.BigInteger g, java.math.BigInteger y) {
  guard = tt;
  ret(level()) = pc ⊔ level(g) ⊔ level(p) ⊔ level(y) ⊔ obj_level(g);
  ret(obj_level()) = pc ⊔ level(g) ⊔ level(p) ⊔ level(y) ⊔ obj_level(g);
  ret(obj_level(g)) = pc ⊔ level(g) ⊔ level(p) ⊔ level(y) ⊔ obj_level(g);
  ret(obj_level(p)) = pc ⊔ level(g) ⊔ level(p) ⊔ level(y) ⊔ obj_level(g);
  ret(obj_level(y)) = pc ⊔ level(g) ⊔ level(p) ⊔ level(y) ⊔ obj_level(g);
}