static boolean org.apache.kerby.kerberos.kerb.preauth.pkinit.PkinitCrypto:pkinitCheckDhParams (
  javax.crypto.spec.DHParameterSpec dh1,
  org.apache.kerby.x509.type.DhParameter dh2) {
  guard = pc ⊔ level(dh2) ⊔ obj_level(dh1) ⊔ obj_level(dh2) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(dh1)) = ⊥;
  ret(obj_level(dh2)) = ⊥;
}