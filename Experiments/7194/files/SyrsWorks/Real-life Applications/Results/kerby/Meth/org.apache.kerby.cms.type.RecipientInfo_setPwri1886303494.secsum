void org.apache.kerby.cms.type.RecipientInfo:setPwri (org.apache.kerby.cms.type.PasswordRecipientInfo
                                                        pwri) {
  guard = tt;
  ret(obj_level(pwri)) = pc ⊔ level(pwri) ⊔ level(this) ⊔ obj_level(pwri) ⊔ obj_level(this);
