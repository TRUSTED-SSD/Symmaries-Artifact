void org.apache.kerby.kerberos.kerb.type.pa.pkinit.AuthPack:setClientPublicValue (
  org.apache.kerby.x509.type.SubjectPublicKeyInfo clientPublicValue) {
  guard = tt;
  ret(obj_level(clientPublicValue)) = pc ⊔ level(clientPublicValue) ⊔ level(this) ⊔ obj_level(clientPublicValue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(clientPublicValue) ⊔ level(this) ⊔ obj_level(this);
}