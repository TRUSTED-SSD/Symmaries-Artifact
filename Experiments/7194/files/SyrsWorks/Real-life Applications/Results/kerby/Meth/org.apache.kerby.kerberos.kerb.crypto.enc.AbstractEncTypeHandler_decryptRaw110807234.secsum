byte[] org.apache.kerby.kerberos.kerb.crypto.enc.AbstractEncTypeHandler:decryptRaw (
  byte[] @cipher, byte[] key, int usage) {
  guard = tt;
  ret(level()) = pc ⊔ level(@cipher) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@cipher) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@cipher) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@cipher) ⊔ obj_level(this);
  ret(obj_level(@cipher)) = obj_level(@cipher);
  ret(obj_level(key)) = obj_level(key);
  ret(obj_level(this)) = obj_level(this);
}