static void org.apache.kerby.asn1.Asn1Binder:bind (org.apache.kerby.asn1.parse.Asn1ParseResult
                                                     parseResult,
                                                   org.apache.kerby.asn1.type.Asn1Type
                                                     value) {
  guard = tt;
  ret(obj_level(parseResult)) = pc ⊔ level(parseResult) ⊔ level(value) ⊔ obj_level(parseResult) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(parseResult) ⊔ level(value) ⊔ obj_level(parseResult) ⊔ obj_level(value);
}