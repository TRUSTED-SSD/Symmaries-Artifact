void org.apache.kerby.x509.type.NameConstraints:setPermittedSubtrees (
  org.apache.kerby.x509.type.GeneralSubtrees permittedSubtrees) {
  guard = tt;
  ret(obj_level(permittedSubtrees)) = pc ⊔ level(permittedSubtrees) ⊔ level(this) ⊔ obj_level(permittedSubtrees) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(permittedSubtrees) ⊔ level(this) ⊔ obj_level(this);
}