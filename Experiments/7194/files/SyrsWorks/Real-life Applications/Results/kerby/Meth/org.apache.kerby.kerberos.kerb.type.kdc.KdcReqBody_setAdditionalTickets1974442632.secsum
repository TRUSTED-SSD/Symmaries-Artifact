void org.apache.kerby.kerberos.kerb.type.kdc.KdcReqBody:setAdditionalTickets (
  org.apache.kerby.kerberos.kerb.type.ticket.Tickets additionalTickets) {
  guard = tt;
  ret(obj_level(additionalTickets)) = pc ⊔ level(additionalTickets) ⊔ level(this) ⊔ obj_level(additionalTickets) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(additionalTickets) ⊔ level(this) ⊔ obj_level(this);
}