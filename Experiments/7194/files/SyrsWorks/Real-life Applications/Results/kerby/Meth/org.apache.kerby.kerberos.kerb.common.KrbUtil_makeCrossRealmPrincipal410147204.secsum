static org.apache.kerby.kerberos.kerb.type.base.PrincipalName org.apache.kerby.kerberos.kerb.common.KrbUtil:makeCrossRealmPrincipal (
  java.lang.String @localRealm, java.lang.String remoteRealm) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc;
  ret(obj_level(@localRealm)) = pc ⊔ level(@localRealm) ⊔ level(remoteRealm) ⊔ obj_level(@localRealm);
  ret(obj_level(remoteRealm)) = pc ⊔ level(@localRealm) ⊔ obj_level(@localRealm);
}