org.apache.kerby.asn1.type.AbstractAsn1Type (org.apache.kerby.asn1.Tag tag,
                                             java.lang.Object value) {
  guard = tt;
  ret(obj_level(tag)) = pc ⊔ level(this) ⊔ obj_level(tag);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(value) ⊔ obj_level(tag);
  ret(obj_level(value)) = pc ⊔ level(this) ⊔ level(value) ⊔ obj_level(tag);
}