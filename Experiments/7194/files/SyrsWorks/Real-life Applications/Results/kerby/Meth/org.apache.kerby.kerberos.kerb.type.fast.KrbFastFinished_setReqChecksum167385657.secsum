void org.apache.kerby.kerberos.kerb.type.fast.KrbFastFinished:setReqChecksum (
  org.apache.kerby.kerberos.kerb.type.base.CheckSum checkSum) {
  guard = tt;
  ret(obj_level(checkSum)) = pc ⊔ level(checkSum) ⊔ level(this) ⊔ obj_level(checkSum) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(checkSum) ⊔ level(this) ⊔ obj_level(this);
}