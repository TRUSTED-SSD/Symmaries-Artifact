  org.apache.kerby.asn1.type.Asn1IA5String uniformResourceIdentifier) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(uniformResourceIdentifier) ⊔ obj_level(this);
  ret(obj_level(uniformResourceIdentifier)) = pc ⊔ level(this) ⊔ level(uniformResourceIdentifier) ⊔ obj_level(this) ⊔ obj_level(uniformResourceIdentifier);
