static byte[] org.apache.kerby.kerberos.kerb.common.EncryptionUtil:encrypt (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey key,
  byte[] @plaintext, org.apache.kerby.kerberos.kerb.type.base.KeyUsage usage) {
  guard = tt;
  ret(level()) = pc ⊔ level(@plaintext) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(@plaintext) ⊔ obj_level(key) ⊔ obj_level(usage);
  ret(obj_level()) = pc ⊔ level(@plaintext) ⊔ level(key) ⊔ level(usage) ⊔ obj_level(@plaintext) ⊔ obj_level(key) ⊔ obj_level(usage);
  ret(obj_level(@plaintext)) = pc ⊔ level(key) ⊔ obj_level(@plaintext) ⊔ obj_level(key);
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ obj_level(key);
  ret(obj_level(usage)) = pc ⊔ level(key) ⊔ obj_level(key) ⊔ obj_level(usage);
}