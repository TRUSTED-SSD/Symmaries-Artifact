void org.apache.kerby.asn1.type.Asn1TaggingCollection:setFieldAsInt (
  org.apache.kerby.asn1.EnumType index, int value) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this);
}