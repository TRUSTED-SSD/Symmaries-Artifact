void org.apache.kerby.x509.type.PolicyQualifierInfo:setQualifier (org.apache.kerby.asn1.type.Asn1Type
                                                                    qualifier) {
  guard = tt;
  ret(obj_level(qualifier)) = pc ⊔ level(qualifier) ⊔ level(this) ⊔ obj_level(qualifier);
  ret(obj_level(this)) = pc ⊔ level(qualifier) ⊔ level(this) ⊔ obj_level(this);
}