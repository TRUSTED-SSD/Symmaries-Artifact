void org.apache.kerby.x509.type.RevokedCertificate:setCrlEntryExtensions (
  org.apache.kerby.x509.type.Extensions crlEntryExtensions) {
  guard = tt;
  ret(obj_level(crlEntryExtensions)) = pc ⊔ level(crlEntryExtensions) ⊔ level(this) ⊔ obj_level(crlEntryExtensions) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(crlEntryExtensions) ⊔ level(this) ⊔ obj_level(this);
}