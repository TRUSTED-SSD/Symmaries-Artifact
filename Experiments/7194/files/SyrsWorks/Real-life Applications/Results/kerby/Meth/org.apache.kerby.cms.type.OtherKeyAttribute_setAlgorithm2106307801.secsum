void org.apache.kerby.cms.type.OtherKeyAttribute:setAlgorithm (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                                 keyAttrId) {
  guard = tt;
  ret(obj_level(keyAttrId)) = pc ⊔ level(keyAttrId) ⊔ level(this) ⊔ obj_level(keyAttrId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(keyAttrId) ⊔ level(this) ⊔ obj_level(this);
}