void org.apache.kerby.asn1.type.Asn1Choice:dumpWith (org.apache.kerby.asn1.Asn1Dumper
                                                       dumper,
                                                     int indents) {
  guard = tt;
  ret(obj_level(dumper)) = pc ⊔ level(dumper) ⊔ level(indents) ⊔ obj_level(dumper);
  ret(obj_level(this)) = pc ⊔ level(dumper) ⊔ level(indents) ⊔ obj_level(dumper) ⊔ obj_level(this);
}