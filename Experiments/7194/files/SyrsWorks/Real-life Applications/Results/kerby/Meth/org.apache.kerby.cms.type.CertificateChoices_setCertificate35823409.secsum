void org.apache.kerby.cms.type.CertificateChoices:setCertificate (org.apache.kerby.x509.type.Certificate
                                                                    certificate) {
  guard = tt;
  ret(obj_level(certificate)) = pc ⊔ level(certificate) ⊔ level(this) ⊔ obj_level(certificate) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(certificate) ⊔ level(this) ⊔ obj_level(this);
}