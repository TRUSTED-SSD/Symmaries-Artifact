org.apache.kerby.asn1.Asn1Dumper org.apache.kerby.asn1.Asn1Dumper:indent (
  int numSpaces) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(numSpaces) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(numSpaces) ⊔ level(this) ⊔ obj_level(this);
}