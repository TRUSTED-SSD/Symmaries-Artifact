void org.apache.kerby.x509.type.DirectoryString:setUtf8String (org.apache.kerby.asn1.type.Asn1Utf8String
                                                                 utf8String) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(utf8String) ⊔ obj_level(this);
  ret(obj_level(utf8String)) = pc ⊔ level(this) ⊔ level(utf8String) ⊔ obj_level(this) ⊔ obj_level(utf8String);
}