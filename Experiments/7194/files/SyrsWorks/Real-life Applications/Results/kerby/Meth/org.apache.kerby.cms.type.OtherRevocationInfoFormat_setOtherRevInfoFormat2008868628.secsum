void org.apache.kerby.cms.type.OtherRevocationInfoFormat:setOtherRevInfoFormat (
  org.apache.kerby.asn1.type.Asn1ObjectIdentifier otherRevInfoFormat) {
  guard = tt;
  ret(obj_level(otherRevInfoFormat)) = pc ⊔ level(otherRevInfoFormat) ⊔ level(this) ⊔ obj_level(otherRevInfoFormat) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(otherRevInfoFormat) ⊔ level(this) ⊔ obj_level(this);
}