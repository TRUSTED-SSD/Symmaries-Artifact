org.apache.kerby.kerberos.kerb.response.ApResponse (org.apache.kerby.kerberos.kerb.type.ap.ApReq
                                                      apReq,
                                                    org.apache.kerby.kerberos.kerb.type.base.EncryptionKey
                                                      encryptionKey) {
  guard = tt;
  ret(obj_level(apReq)) = pc ⊔ level(apReq) ⊔ level(encryptionKey) ⊔ level(this) ⊔ obj_level(apReq) ⊔ obj_level(encryptionKey) ⊔ obj_level(this);
  ret(obj_level(encryptionKey)) = pc ⊔ level(apReq) ⊔ level(encryptionKey) ⊔ level(this) ⊔ obj_level(apReq) ⊔ obj_level(encryptionKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(apReq) ⊔ level(encryptionKey) ⊔ level(this) ⊔ obj_level(apReq) ⊔ obj_level(encryptionKey) ⊔ obj_level(this);
}