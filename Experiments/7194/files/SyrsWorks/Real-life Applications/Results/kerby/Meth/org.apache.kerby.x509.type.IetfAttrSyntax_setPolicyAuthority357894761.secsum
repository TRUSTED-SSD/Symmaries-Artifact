void org.apache.kerby.x509.type.IetfAttrSyntax:setPolicyAuthority (org.apache.kerby.x509.type.GeneralNames
                                                                    policyAuthority) {
  guard = tt;
  ret(obj_level(policyAuthority)) = pc ⊔ level(policyAuthority) ⊔ level(this) ⊔ obj_level(policyAuthority) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(policyAuthority) ⊔ level(this) ⊔ obj_level(this);
}