void org.apache.kerby.kerberos.kerb.type.base.EncryptedData:setEType (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionType eType) {
  guard = tt;
  ret(obj_level(eType)) = pc ⊔ level(eType) ⊔ level(this) ⊔ obj_level(eType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(eType) ⊔ level(this) ⊔ obj_level(eType) ⊔ obj_level(this);
}