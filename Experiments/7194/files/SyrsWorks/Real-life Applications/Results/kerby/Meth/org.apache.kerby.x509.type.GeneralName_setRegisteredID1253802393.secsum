void org.apache.kerby.x509.type.GeneralName:setRegisteredID (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                               registeredID) {
  guard = tt;
  ret(obj_level(registeredID)) = pc ⊔ level(registeredID) ⊔ level(this) ⊔ obj_level(registeredID) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(registeredID) ⊔ level(this) ⊔ obj_level(this);
}