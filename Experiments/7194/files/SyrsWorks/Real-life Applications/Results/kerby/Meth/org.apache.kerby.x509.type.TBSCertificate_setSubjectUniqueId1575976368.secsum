void org.apache.kerby.x509.type.TBSCertificate:setSubjectUniqueId (byte[]
                                                                    issuerUniqueId) {
  guard = tt;
  ret(obj_level(issuerUniqueId)) = pc ⊔ level(this) ⊔ obj_level(issuerUniqueId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(this);
}