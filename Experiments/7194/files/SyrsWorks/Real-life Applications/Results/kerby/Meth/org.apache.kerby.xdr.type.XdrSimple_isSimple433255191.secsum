static boolean org.apache.kerby.xdr.type.XdrSimple:isSimple (org.apache.kerby.xdr.XdrDataType
                                                               dataType) {
  guard = tt;
  ret(level()) = pc ⊔ level(dataType) ⊔ obj_level(dataType);
  ret(obj_level(dataType)) = pc ⊔ level(dataType) ⊔ obj_level(dataType);
}