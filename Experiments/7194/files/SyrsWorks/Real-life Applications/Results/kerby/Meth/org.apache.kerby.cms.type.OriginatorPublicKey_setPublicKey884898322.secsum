void org.apache.kerby.cms.type.OriginatorPublicKey:setPublicKey (org.apache.kerby.asn1.type.Asn1BitString
                                                                   publicKey) {
  guard = tt;
  ret(obj_level(publicKey)) = pc ⊔ level(publicKey) ⊔ level(this) ⊔ obj_level(publicKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(publicKey) ⊔ level(this) ⊔ obj_level(this);
}