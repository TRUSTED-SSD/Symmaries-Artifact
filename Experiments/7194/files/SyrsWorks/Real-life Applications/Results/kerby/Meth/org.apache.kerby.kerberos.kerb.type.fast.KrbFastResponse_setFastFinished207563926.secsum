  org.apache.kerby.kerberos.kerb.type.fast.KrbFastFinished fastFinished) {
  guard = tt;
  ret(obj_level(fastFinished)) = pc ⊔ level(fastFinished) ⊔ level(this) ⊔ obj_level(fastFinished) ⊔ obj_level(this);
