void org.apache.kerby.config.ConfigLoader:setResource (org.apache.kerby.config.Resource
                                                         resource) {
  guard = tt;
  ret(obj_level(resource)) = pc ⊔ level(resource) ⊔ obj_level(resource);
  ret(obj_level(this)) = pc ⊔ level(resource) ⊔ obj_level(resource) ⊔ obj_level(this);
}