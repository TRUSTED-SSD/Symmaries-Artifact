void org.apache.kerby.kerberos.kerb.type.base.EtypeInfo2Entry:setEtype (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionType etype) {
  guard = tt;
  ret(obj_level(etype)) = pc ⊔ level(etype) ⊔ level(this) ⊔ obj_level(etype) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(etype) ⊔ level(this) ⊔ obj_level(this);
}