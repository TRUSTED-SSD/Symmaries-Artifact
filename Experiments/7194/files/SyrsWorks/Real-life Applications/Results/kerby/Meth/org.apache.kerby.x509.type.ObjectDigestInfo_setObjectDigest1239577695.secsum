void org.apache.kerby.x509.type.ObjectDigestInfo:setObjectDigest (org.apache.kerby.asn1.type.Asn1BitString
                                                                    objectDigest) {
  guard = tt;
  ret(obj_level(objectDigest)) = pc ⊔ level(objectDigest) ⊔ level(this) ⊔ obj_level(objectDigest) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(objectDigest) ⊔ level(this) ⊔ obj_level(this);
}