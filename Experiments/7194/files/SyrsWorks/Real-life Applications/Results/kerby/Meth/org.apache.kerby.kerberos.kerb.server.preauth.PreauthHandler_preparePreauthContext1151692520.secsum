org.apache.kerby.kerberos.kerb.server.preauth.PreauthContext org.apache.kerby.kerberos.kerb.server.preauth.PreauthHandler:preparePreauthContext (
  org.apache.kerby.kerberos.kerb.server.request.KdcRequest kdcRequest) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
  ret(obj_level(kdcRequest)) = pc ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
}