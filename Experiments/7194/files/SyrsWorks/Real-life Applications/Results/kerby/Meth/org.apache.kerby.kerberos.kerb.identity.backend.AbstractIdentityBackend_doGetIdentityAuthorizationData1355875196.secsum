org.apache.kerby.kerberos.kerb.type.ad.AuthorizationData org.apache.kerby.kerberos.kerb.identity.backend.AbstractIdentityBackend:doGetIdentityAuthorizationData (
  org.apache.kerby.kerberos.kerb.request.KdcClientRequest kdcClientRequest,
  org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart encTicketPart) {
  guard = tt;
  ret(level()) = pc ⊔ level(kdcClientRequest) ⊔ obj_level(kdcClientRequest);
  ret(obj_level()) = ⊤;
  ret(obj_level(encTicketPart)) = ⊤;
  ret(obj_level(kdcClientRequest)) = ⊤;
  ret(obj_level(this)) = ⊤;
}