void org.apache.kerby.kerberos.kerb.ccache.CredentialCache:writeTag (
  org.apache.kerby.kerberos.kerb.ccache.CredCacheOutputStream ccos,
  org.apache.kerby.kerberos.kerb.ccache.Tag tag) {
  guard = pc ⊔ level(ccos) ⊔ level(tag) ⊔ obj_level(ccos) ⊔ obj_level(tag) = ⊥;
  ret(obj_level(ccos)) = ⊥;
  ret(obj_level(tag)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}