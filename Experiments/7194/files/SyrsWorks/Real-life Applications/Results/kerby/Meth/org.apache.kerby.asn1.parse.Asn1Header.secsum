org.apache.kerby.asn1.parse.Asn1Header (org.apache.kerby.asn1.Tag tag,
                                        int length) {
  guard = tt;
  ret(obj_level(tag)) = pc ⊔ level(this) ⊔ obj_level(tag) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(length) ⊔ level(tag) ⊔ level(this) ⊔ obj_level(tag) ⊔ obj_level(this);
}