void org.apache.kerby.kerberos.kerb.type.base.KrbError:setStime (org.apache.kerby.kerberos.kerb.type.KerberosTime
                                                                   stime) {
  guard = tt;
  ret(obj_level(stime)) = pc ⊔ level(stime) ⊔ level(this) ⊔ obj_level(stime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(stime) ⊔ level(this) ⊔ obj_level(this);
}