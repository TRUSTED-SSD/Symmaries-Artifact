void org.apache.kerby.kerberos.kerb.type.ad.CamMacVerifierChoice:setChoice (
  org.apache.kerby.asn1.EnumType type,
  org.apache.kerby.asn1.type.Asn1Type choice) {
  guard = tt;
  ret(obj_level(choice)) = pc ⊔ level(choice) ⊔ level(this) ⊔ level(type) ⊔ obj_level(choice) ⊔ obj_level(type);
  ret(obj_level(this)) = pc ⊔ level(choice) ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(choice) ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
}