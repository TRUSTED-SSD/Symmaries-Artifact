    innerClient,
  javax.security.auth.Subject subject) {
  guard = tt;
  ret(obj_level(innerClient)) = pc ⊔ level(innerClient) ⊔ level(subject) ⊔ level(this) ⊔ obj_level(innerClient) ⊔ obj_level(subject) ⊔ obj_level(this);
  ret(obj_level(subject)) = pc ⊔ level(innerClient) ⊔ level(subject) ⊔ level(this) ⊔ obj_level(innerClient) ⊔ obj_level(subject) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(innerClient) ⊔ level(subject) ⊔ level(this) ⊔ obj_level(innerClient) ⊔ obj_level(subject) ⊔ obj_level(this);
}