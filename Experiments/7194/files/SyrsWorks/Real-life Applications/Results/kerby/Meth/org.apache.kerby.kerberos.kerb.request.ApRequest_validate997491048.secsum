static void org.apache.kerby.kerberos.kerb.request.ApRequest:validate (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey @encKey,
  org.apache.kerby.kerberos.kerb.type.ap.ApReq apReq) {
  guard = tt;
  ret(obj_level(@encKey)) = pc ⊔ level(@encKey) ⊔ level(apReq) ⊔ obj_level(@encKey) ⊔ obj_level(apReq);
  ret(obj_level(apReq)) = pc ⊔ level(@encKey) ⊔ level(apReq) ⊔ obj_level(@encKey) ⊔ obj_level(apReq);
}