byte[] org.apache.kerby.kerberos.kerb.crypto.dh.DiffieHellmanClient:decrypt (
  byte[] @cipherText,
  org.apache.kerby.kerberos.kerb.type.base.KeyUsage usage) {
  guard = tt;
  ret(level()) = pc ⊔ level(@cipherText) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@cipherText) ⊔ obj_level(this) ⊔ obj_level(usage);
  ret(obj_level()) = pc ⊔ level(@cipherText) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@cipherText) ⊔ obj_level(this) ⊔ obj_level(usage);
  ret(obj_level(@cipherText)) = pc ⊔ level(this) ⊔ obj_level(@cipherText) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(usage)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(usage);
}