void org.apache.kerby.cms.type.KEKRecipientInfo:setEncryptedKey (org.apache.kerby.cms.type.EncryptedKey
                                                                   encryptedKey) {
  guard = tt;
  ret(obj_level(encryptedKey)) = pc ⊔ level(encryptedKey) ⊔ level(this) ⊔ obj_level(encryptedKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(encryptedKey) ⊔ level(this) ⊔ obj_level(this);
}