void org.apache.kerby.cms.type.ContentInfo:setContent (org.apache.kerby.asn1.type.Asn1Type
                                                         content) {
  guard = tt;
  ret(obj_level(content)) = pc ⊔ level(content) ⊔ level(this) ⊔ obj_level(content);
  ret(obj_level(this)) = pc ⊔ level(content) ⊔ level(this) ⊔ obj_level(this);
}