void org.apache.kerby.kerberos.kerb.type.fast.KrbFastArmor:setArmorType (
  org.apache.kerby.kerberos.kerb.type.fast.ArmorType armorType) {
  guard = tt;
  ret(obj_level(armorType)) = pc ⊔ level(armorType) ⊔ level(this) ⊔ obj_level(armorType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(armorType) ⊔ level(this) ⊔ obj_level(armorType) ⊔ obj_level(this);
}