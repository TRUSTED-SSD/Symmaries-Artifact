void org.apache.kerby.kerberos.kerb.type.KrbSequenceType:setField (org.apache.kerby.asn1.EnumType
                                                                    index,
                                                                   org.apache.kerby.asn1.EnumType
                                                                    value) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(value)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(value) ⊔ obj_level(index) ⊔ obj_level(this);
}