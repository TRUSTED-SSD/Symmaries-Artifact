void org.apache.kerby.x509.type.EDIPartyName:setNameAssigner (org.apache.kerby.x509.type.DirectoryString
                                                                nameAssigner) {
  guard = tt;
  ret(obj_level(nameAssigner)) = pc ⊔ level(nameAssigner) ⊔ level(this) ⊔ obj_level(nameAssigner) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(nameAssigner) ⊔ level(this) ⊔ obj_level(this);
}