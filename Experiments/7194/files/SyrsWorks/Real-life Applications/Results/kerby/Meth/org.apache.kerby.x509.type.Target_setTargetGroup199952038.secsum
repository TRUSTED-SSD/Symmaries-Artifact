void org.apache.kerby.x509.type.Target:setTargetGroup (org.apache.kerby.x509.type.GeneralName
                                                         targetGroup) {
  guard = tt;
  ret(obj_level(targetGroup)) = pc ⊔ level(targetGroup) ⊔ level(this) ⊔ obj_level(targetGroup) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(targetGroup) ⊔ level(this) ⊔ obj_level(this);
}