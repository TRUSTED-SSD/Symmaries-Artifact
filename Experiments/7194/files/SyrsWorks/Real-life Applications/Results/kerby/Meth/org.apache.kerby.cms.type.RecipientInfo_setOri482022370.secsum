void org.apache.kerby.cms.type.RecipientInfo:setOri (org.apache.kerby.cms.type.OtherRecipientInfo
                                                       ori) {
  guard = tt;
  ret(obj_level(ori)) = pc ⊔ level(ori) ⊔ level(this) ⊔ obj_level(ori) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ori) ⊔ level(this) ⊔ obj_level(this);
}