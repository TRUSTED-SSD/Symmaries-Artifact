void org.apache.kerby.x509.type.Attribute:setAttrType (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                         attrType) {
  guard = tt;
  ret(obj_level(attrType)) = pc ⊔ level(attrType) ⊔ level(this) ⊔ obj_level(attrType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(attrType) ⊔ level(this) ⊔ obj_level(this);
}