void org.apache.kerby.kerberos.kerb.type.ad.ADEnctypeNegotiation:add (
  org.apache.kerby.asn1.type.Asn1Integer element) {
  guard = tt;
  ret(obj_level(element)) = pc ⊔ level(element) ⊔ level(this) ⊔ obj_level(element) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(element) ⊔ level(this) ⊔ obj_level(element) ⊔ obj_level(this);
}