void org.apache.kerby.x509.type.DisplayText:setBmpString (org.apache.kerby.asn1.type.Asn1BmpString
                                                            bmpString) {
  guard = tt;
  ret(obj_level(bmpString)) = pc ⊔ level(bmpString) ⊔ level(this) ⊔ obj_level(bmpString) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bmpString) ⊔ level(this) ⊔ obj_level(this);
}