void org.apache.kerby.kerberos.kerb.type.pa.token.TokenInfo:setFlags (
  org.apache.kerby.kerberos.kerb.type.pa.token.TokenFlags flags) {
  guard = tt;
  ret(obj_level(flags)) = pc ⊔ level(flags) ⊔ level(this) ⊔ obj_level(flags) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(flags) ⊔ level(this) ⊔ obj_level(this);
}