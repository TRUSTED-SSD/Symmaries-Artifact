void org.apache.kerby.x509.type.IetfAttrSyntaxChoice:setUtf8 (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                                utf8) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(utf8) ⊔ obj_level(this);
  ret(obj_level(utf8)) = pc ⊔ level(this) ⊔ level(utf8) ⊔ obj_level(this) ⊔ obj_level(utf8);
}