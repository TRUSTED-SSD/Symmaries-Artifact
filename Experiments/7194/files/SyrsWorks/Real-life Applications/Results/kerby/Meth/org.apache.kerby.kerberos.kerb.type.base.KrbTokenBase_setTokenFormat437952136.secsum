void org.apache.kerby.kerberos.kerb.type.base.KrbTokenBase:setTokenFormat (
  org.apache.kerby.kerberos.kerb.type.base.TokenFormat tokenFormat) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(tokenFormat) ⊔ obj_level(this) ⊔ obj_level(tokenFormat);
  ret(obj_level(tokenFormat)) = pc ⊔ level(this) ⊔ level(tokenFormat) ⊔ obj_level(this) ⊔ obj_level(tokenFormat);
}