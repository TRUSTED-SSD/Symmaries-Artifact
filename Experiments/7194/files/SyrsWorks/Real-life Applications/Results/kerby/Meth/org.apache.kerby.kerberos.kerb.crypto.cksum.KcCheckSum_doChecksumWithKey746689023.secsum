byte[] org.apache.kerby.kerberos.kerb.crypto.cksum.KcCheckSum:doChecksumWithKey (
  byte[] @data, int start, int len, byte[] @key, int usage) {
  guard = tt;
  ret(level()) = pc ⊔ level(@data) ⊔ level(@key) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@key) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@data) ⊔ level(@key) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@key) ⊔ obj_level(this);
  ret(obj_level(@data)) = pc ⊔ level(usage) ⊔ obj_level(@data);
  ret(obj_level(@key)) = pc ⊔ level(usage) ⊔ obj_level(@key);
  ret(obj_level(this)) = pc ⊔ level(usage) ⊔ obj_level(this);
}