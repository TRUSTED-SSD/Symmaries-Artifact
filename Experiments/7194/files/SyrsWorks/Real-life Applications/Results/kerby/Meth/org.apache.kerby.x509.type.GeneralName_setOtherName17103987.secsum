void org.apache.kerby.x509.type.GeneralName:setOtherName (org.apache.kerby.x509.type.OtherName
                                                            otherName) {
  guard = tt;
  ret(obj_level(otherName)) = pc ⊔ level(otherName) ⊔ level(this) ⊔ obj_level(otherName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(otherName) ⊔ level(this) ⊔ obj_level(this);
}