org.apache.kerby.kerberos.kerb.crypto.cksum.provider.MessageDigestHashProvider (
  int hashSize, int blockSize, java.lang.String algorithm) {
  guard = tt;
  ret(obj_level(algorithm)) = pc ⊔ level(algorithm) ⊔ level(blockSize) ⊔ level(hashSize) ⊔ level(this) ⊔ obj_level(algorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(algorithm) ⊔ level(blockSize) ⊔ level(hashSize) ⊔ level(this) ⊔ obj_level(algorithm) ⊔ obj_level(this);
}