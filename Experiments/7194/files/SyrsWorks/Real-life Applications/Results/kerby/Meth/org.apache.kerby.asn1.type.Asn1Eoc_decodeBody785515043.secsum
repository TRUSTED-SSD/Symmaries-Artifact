void org.apache.kerby.asn1.type.Asn1Eoc:decodeBody (org.apache.kerby.asn1.parse.Asn1ParseResult
                                                      parseResult) {
  guard = tt;
  ret(obj_level(parseResult)) = pc ⊔ level(parseResult) ⊔ obj_level(parseResult);
  ret(obj_level(this)) = pc ⊔ level(parseResult) ⊔ obj_level(parseResult) ⊔ obj_level(this);
}