void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setEndTime (
  org.apache.kerby.kerberos.kerb.type.KerberosTime endTime) {
  guard = tt;
  ret(obj_level(endTime)) = pc ⊔ level(endTime) ⊔ level(this) ⊔ obj_level(endTime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(endTime) ⊔ level(this) ⊔ obj_level(this);
}