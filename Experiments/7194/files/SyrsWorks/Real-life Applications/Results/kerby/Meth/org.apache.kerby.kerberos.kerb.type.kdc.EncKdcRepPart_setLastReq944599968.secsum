void org.apache.kerby.kerberos.kerb.type.kdc.EncKdcRepPart:setLastReq (
  org.apache.kerby.kerberos.kerb.type.base.LastReq lastReq) {
  guard = tt;
  ret(obj_level(lastReq)) = pc ⊔ level(lastReq) ⊔ level(this) ⊔ obj_level(lastReq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(lastReq) ⊔ level(this) ⊔ obj_level(this);
}