void org.apache.kerby.kerberos.kerb.type.base.CheckSum:setCksumtype (
  org.apache.kerby.kerberos.kerb.type.base.CheckSumType cksumtype) {
  guard = tt;
  ret(obj_level(cksumtype)) = pc ⊔ level(cksumtype) ⊔ level(this) ⊔ obj_level(cksumtype) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cksumtype) ⊔ level(this) ⊔ obj_level(cksumtype) ⊔ obj_level(this);
}