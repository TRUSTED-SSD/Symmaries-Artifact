void org.apache.kerby.kerberos.kerb.keytab.Keytab:removeKeytabEntry (
  org.apache.kerby.kerberos.kerb.keytab.KeytabEntry entry) {
  guard = tt;
  ret(obj_level(entry)) = pc ⊔ level(entry) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entry) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
}