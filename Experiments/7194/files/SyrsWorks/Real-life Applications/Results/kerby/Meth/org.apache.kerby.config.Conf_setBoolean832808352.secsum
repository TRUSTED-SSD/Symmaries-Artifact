void org.apache.kerby.config.Conf:setBoolean (java.lang.String name,
                                              java.lang.Boolean value) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(value) ⊔ obj_level(name) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(this)) = pc ⊔ level(value) ⊔ obj_level(name) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(value) ⊔ obj_level(name) ⊔ obj_level(this) ⊔ obj_level(value);
}