void org.apache.kerby.x509.type.PolicyConstraints:setRequireExplicitPolicy (
  org.apache.kerby.asn1.type.Asn1Integer requireExplicitPolicy) {
  guard = tt;
  ret(obj_level(requireExplicitPolicy)) = pc ⊔ level(requireExplicitPolicy) ⊔ level(this) ⊔ obj_level(requireExplicitPolicy) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(requireExplicitPolicy) ⊔ level(this) ⊔ obj_level(this);
}