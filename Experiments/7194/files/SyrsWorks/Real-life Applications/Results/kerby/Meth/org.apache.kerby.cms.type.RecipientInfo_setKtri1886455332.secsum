void org.apache.kerby.cms.type.RecipientInfo:setKtri (org.apache.kerby.cms.type.KeyTransRecipientInfo
                                                        ktri) {
  guard = tt;
  ret(obj_level(ktri)) = pc ⊔ level(ktri) ⊔ level(this) ⊔ obj_level(ktri) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ktri) ⊔ level(this) ⊔ obj_level(this);
}