  ret(obj_level(errorCode)) = pc ⊔ level(@message) ⊔ level(errorCode) ⊔ level(this) ⊔ obj_level(@message) ⊔ obj_level(errorCode) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@message) ⊔ level(errorCode) ⊔ level(this) ⊔ obj_level(@message) ⊔ obj_level(errorCode) ⊔ obj_level(this);
