static byte[] org.apache.kerby.kerberos.kerb.crypto.util.Pbkdf:pbkdf2 (
  char[] secret, byte[] @salt, int count, int keySize) {
  guard = tt;
  ret(level()) = pc ⊔ level(@salt) ⊔ level(count) ⊔ level(keySize) ⊔ level(secret) ⊔ obj_level(@salt) ⊔ obj_level(secret);
  ret(obj_level()) = pc ⊔ level(@salt) ⊔ level(count) ⊔ level(keySize) ⊔ level(secret) ⊔ obj_level(@salt) ⊔ obj_level(secret);
  ret(obj_level(@salt)) = pc ⊔ level(@salt) ⊔ level(count) ⊔ level(keySize) ⊔ level(secret) ⊔ obj_level(@salt) ⊔ obj_level(secret);
  ret(obj_level(secret)) = pc ⊔ level(@salt) ⊔ level(count) ⊔ level(keySize) ⊔ level(secret) ⊔ obj_level(@salt) ⊔ obj_level(secret);
}