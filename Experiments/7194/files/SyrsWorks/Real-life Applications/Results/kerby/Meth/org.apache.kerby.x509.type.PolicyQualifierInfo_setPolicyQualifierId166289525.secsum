void org.apache.kerby.x509.type.PolicyQualifierInfo:setPolicyQualifierId (
  org.apache.kerby.x509.type.PolicyQualifierId policyQualifierId) {
  guard = tt;
  ret(obj_level(policyQualifierId)) = pc ⊔ level(policyQualifierId) ⊔ level(this) ⊔ obj_level(policyQualifierId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(policyQualifierId) ⊔ level(this) ⊔ obj_level(this);
}