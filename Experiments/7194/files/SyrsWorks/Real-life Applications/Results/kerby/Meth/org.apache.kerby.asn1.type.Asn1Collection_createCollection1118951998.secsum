static org.apache.kerby.asn1.type.Asn1Collection org.apache.kerby.asn1.type.Asn1Collection:createCollection (
  org.apache.kerby.asn1.Tag tag) {
  guard = tt;
  ret(level()) = pc ⊔ level(tag) ⊔ obj_level(tag);
  ret(obj_level()) = pc ⊔ level(tag) ⊔ obj_level(tag);
  ret(obj_level(tag)) = obj_level(tag);
}