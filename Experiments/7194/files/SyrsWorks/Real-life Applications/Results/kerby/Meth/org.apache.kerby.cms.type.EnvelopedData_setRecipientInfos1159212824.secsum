void org.apache.kerby.cms.type.EnvelopedData:setRecipientInfos (org.apache.kerby.cms.type.RecipientInfos
                                                                  recipientInfos) {
  guard = tt;
  ret(obj_level(recipientInfos)) = pc ⊔ level(recipientInfos) ⊔ level(this) ⊔ obj_level(recipientInfos) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(recipientInfos) ⊔ level(this) ⊔ obj_level(this);
}