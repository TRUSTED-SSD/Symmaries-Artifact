void org.apache.kerby.kerberos.kerb.type.pa.token.PaTokenRequest:setToken (
  org.apache.kerby.kerberos.kerb.type.base.KrbTokenBase token) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(token) ⊔ obj_level(this);
  ret(obj_level(token)) = pc ⊔ level(this) ⊔ level(token) ⊔ obj_level(this) ⊔ obj_level(token);
}