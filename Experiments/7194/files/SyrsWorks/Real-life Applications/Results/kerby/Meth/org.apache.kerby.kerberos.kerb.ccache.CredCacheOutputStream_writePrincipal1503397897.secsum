void org.apache.kerby.kerberos.kerb.ccache.CredCacheOutputStream:writePrincipal (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName principal,
  int version) {
  guard = pc ⊔ level(principal) ⊔ level(this) ⊔ level(version) ⊔ obj_level(principal) ⊔ obj_level(this) = ⊥;
  ret(obj_level(principal)) = ⊥;
  ret(obj_level(this)) = ⊥;
}