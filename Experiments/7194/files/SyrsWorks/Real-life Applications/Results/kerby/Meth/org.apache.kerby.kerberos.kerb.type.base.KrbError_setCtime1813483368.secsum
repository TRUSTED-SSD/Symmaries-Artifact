void org.apache.kerby.kerberos.kerb.type.base.KrbError:setCtime (org.apache.kerby.kerberos.kerb.type.KerberosTime
                                                                   ctime) {
  guard = tt;
  ret(obj_level(ctime)) = pc ⊔ level(ctime) ⊔ level(this) ⊔ obj_level(ctime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ctime) ⊔ level(this) ⊔ obj_level(this);
}