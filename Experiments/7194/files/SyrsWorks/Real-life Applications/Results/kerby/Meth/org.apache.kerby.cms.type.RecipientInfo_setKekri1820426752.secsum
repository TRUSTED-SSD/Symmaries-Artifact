void org.apache.kerby.cms.type.RecipientInfo:setKekri (org.apache.kerby.cms.type.KEKRecipientInfo
                                                         kekri) {
  guard = tt;
  ret(obj_level(kekri)) = pc ⊔ level(kekri) ⊔ level(this) ⊔ obj_level(kekri) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(kekri) ⊔ level(this) ⊔ obj_level(this);
}