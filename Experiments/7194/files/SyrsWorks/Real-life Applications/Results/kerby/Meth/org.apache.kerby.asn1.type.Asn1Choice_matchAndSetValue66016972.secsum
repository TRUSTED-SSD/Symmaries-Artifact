boolean org.apache.kerby.asn1.type.Asn1Choice:matchAndSetValue (org.apache.kerby.asn1.Tag
                                                                  tag) {
  guard = tt;
  ret(level()) = pc ⊔ level(tag) ⊔ level(this) ⊔ obj_level(tag) ⊔ obj_level(this);
  ret(obj_level(tag)) = pc ⊔ level(tag) ⊔ level(this) ⊔ obj_level(tag) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(tag) ⊔ level(this) ⊔ obj_level(tag) ⊔ obj_level(this);
}