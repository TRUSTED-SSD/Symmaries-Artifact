void org.apache.kerby.kerberos.kerb.type.ad.ADCamMac:setOtherVerifiers (
  org.apache.kerby.kerberos.kerb.type.ad.CamMacOtherVerifiers otherVerifiers) {
  guard = tt;
  ret(obj_level(otherVerifiers)) = pc ⊔ level(otherVerifiers) ⊔ level(this) ⊔ obj_level(otherVerifiers) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(otherVerifiers) ⊔ level(this) ⊔ obj_level(otherVerifiers) ⊔ obj_level(this);
}