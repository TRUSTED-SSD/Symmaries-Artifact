void org.apache.kerby.kerberos.kerb.type.kdc.EncKdcRepPart:setCaddr (
  org.apache.kerby.kerberos.kerb.type.base.HostAddresses caddr) {
  guard = tt;
  ret(obj_level(caddr)) = pc ⊔ level(caddr) ⊔ level(this) ⊔ obj_level(caddr) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(caddr) ⊔ level(this) ⊔ obj_level(this);
}