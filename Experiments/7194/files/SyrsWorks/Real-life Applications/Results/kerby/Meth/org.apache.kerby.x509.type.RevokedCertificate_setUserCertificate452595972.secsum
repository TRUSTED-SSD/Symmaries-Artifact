void org.apache.kerby.x509.type.RevokedCertificate:setUserCertificate (
  org.apache.kerby.x509.type.CertificateSerialNumber userCertificate) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(userCertificate) ⊔ obj_level(this);
  ret(obj_level(userCertificate)) = pc ⊔ level(this) ⊔ level(userCertificate) ⊔ obj_level(this) ⊔ obj_level(userCertificate);
}