org.apache.kerby.asn1.type.Asn1CollectionType org.apache.kerby.asn1.type.Asn1TaggingSet:createTaggedCollection (
  org.apache.kerby.asn1.Asn1FieldInfo[] tags) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(tags) ⊔ obj_level(tags);
  ret(obj_level(tags)) = pc ⊔ level(tags) ⊔ obj_level(tags);
  ret(obj_level(this)) = pc ⊔ level(tags) ⊔ obj_level(tags) ⊔ obj_level(this);
}