org.apache.kerby.kerberos.kerb.admin.kadmin.remote.request.RenamePrincipalRequest (
  java.lang.String oldPrincipalName, java.lang.String newPrincipalName) {
  guard = tt;
  ret(obj_level(newPrincipalName)) = pc ⊔ level(oldPrincipalName) ⊔ level(this) ⊔ obj_level(oldPrincipalName) ⊔ obj_level(this);
  ret(obj_level(oldPrincipalName)) = pc ⊔ level(oldPrincipalName) ⊔ level(this) ⊔ obj_level(oldPrincipalName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(newPrincipalName) ⊔ level(oldPrincipalName) ⊔ level(this) ⊔ obj_level(oldPrincipalName) ⊔ obj_level(this);
}