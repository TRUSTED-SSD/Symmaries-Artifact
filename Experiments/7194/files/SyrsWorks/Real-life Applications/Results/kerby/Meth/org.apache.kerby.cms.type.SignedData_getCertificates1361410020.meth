org.apache.kerby.cms.type.CertificateSet org.apache.kerby.cms.type.SignedData:getCertificates()
{
org.apache.kerby.cms.type.SignedData$SignedDataField $stack1;
  org.apache.kerby.asn1.type.Asn1Type $stack2;
  org.apache.kerby.cms.type.CertificateSet $stack3;
  $stack1=org.apache.kerby.cms.type.SignedData$SignedDataField.CERTIFICATES;
 $stack2 = this.getFieldAs((org.apache.kerby.asn1.EnumType)$stack1,org.apache.kerby.cms.type.CertificateSet);
 $stack3=(org.apache.kerby.cms.type.CertificateSet) $stack2;
 return  $stack3;
 } 

