void org.apache.kerby.x509.type.DistributionPoint:setReasons (org.apache.kerby.x509.type.ReasonFlags
                                                                reasons) {
  guard = tt;
  ret(obj_level(reasons)) = pc ⊔ level(reasons) ⊔ level(this) ⊔ obj_level(reasons) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(reasons) ⊔ level(this) ⊔ obj_level(this);
}