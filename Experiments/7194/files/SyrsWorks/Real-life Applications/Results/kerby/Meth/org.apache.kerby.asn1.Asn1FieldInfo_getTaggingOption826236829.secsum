org.apache.kerby.asn1.TaggingOption org.apache.kerby.asn1.Asn1FieldInfo:getTaggingOption () {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ level(this) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}