static org.apache.kerby.kerberos.kerb.type.base.EncryptionKey org.apache.kerby.kerberos.kerb.crypto.fast.FastUtil:makeArmorKey(org.apache.kerby.kerberos.kerb.type.base.EncryptionKey @subkey,org.apache.kerby.kerberos.kerb.type.base.EncryptionKey ticketKey)
{
org.apache.kerby.kerberos.kerb.type.base.EncryptionKey subkey;
subkey=@subkey;
subkey = org.apache.kerby.kerberos.kerb.crypto.fast.FastUtil.cf2(subkey,"subkeyarmor",ticketKey,"ticketarmor");
 return  subkey;
 } 

