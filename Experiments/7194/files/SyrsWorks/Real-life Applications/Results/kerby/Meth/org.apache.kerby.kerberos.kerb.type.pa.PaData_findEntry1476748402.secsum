org.apache.kerby.kerberos.kerb.type.pa.PaDataEntry org.apache.kerby.kerberos.kerb.type.pa.PaData:findEntry (
  org.apache.kerby.kerberos.kerb.type.pa.PaDataType paType) {
  guard = tt;
  ret(level()) = pc ⊔ level(paType) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(paType) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(paType)) = pc ⊔ level(paType) ⊔ level(this) ⊔ obj_level(paType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(paType) ⊔ level(this) ⊔ obj_level(this);
}