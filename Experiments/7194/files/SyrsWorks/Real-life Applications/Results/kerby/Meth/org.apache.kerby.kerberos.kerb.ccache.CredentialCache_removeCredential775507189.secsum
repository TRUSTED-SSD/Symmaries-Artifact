void org.apache.kerby.kerberos.kerb.ccache.CredentialCache:removeCredential (
  org.apache.kerby.kerberos.kerb.ccache.Credential credential) {
  guard = tt;
  ret(obj_level(credential)) = pc ⊔ level(credential) ⊔ level(this) ⊔ obj_level(credential) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(credential) ⊔ level(this) ⊔ obj_level(credential) ⊔ obj_level(this);
}