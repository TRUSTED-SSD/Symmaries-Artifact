void org.apache.kerby.asn1.type.Asn1Constructed:decodeBody (org.apache.kerby.asn1.parse.Asn1ParseResult
                                                              parseResult) {
  guard = tt;
  ret(obj_level(parseResult)) = pc ⊔ level(parseResult) ⊔ level(this) ⊔ obj_level(parseResult) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(parseResult) ⊔ level(this) ⊔ obj_level(parseResult) ⊔ obj_level(this);
}