void org.apache.kerby.kerberos.kerb.type.KrbPriv:setEncPart (org.apache.kerby.kerberos.kerb.type.EncKrbPrivPart
                                                               encPart) {
  guard = tt;
  ret(obj_level(encPart)) = pc ⊔ level(encPart) ⊔ obj_level(encPart);
  ret(obj_level(this)) = pc ⊔ level(encPart) ⊔ obj_level(encPart) ⊔ obj_level(this);
}