org.apache.kerby.kerberos.kerb.type.base.KrbToken (org.apache.kerby.kerberos.kerb.type.base.AuthToken
                                                     @authToken,
                                                   org.apache.kerby.kerberos.kerb.type.base.TokenFormat
                                                     format) {
  guard = tt;
  ret(obj_level(@authToken)) = pc ⊔ level(@authToken) ⊔ level(format) ⊔ level(this) ⊔ obj_level(@authToken) ⊔ obj_level(format);
  ret(obj_level(format)) = pc ⊔ level(@authToken) ⊔ level(format) ⊔ level(this) ⊔ obj_level(@authToken) ⊔ obj_level(format);
  ret(obj_level(this)) = pc ⊔ level(@authToken) ⊔ level(format) ⊔ level(this) ⊔ obj_level(@authToken) ⊔ obj_level(format);
}