void org.apache.kerby.x509.type.CertificateList:setSignatureAlgorithms (
  org.apache.kerby.x509.type.AlgorithmIdentifier signatureAlgorithms) {
  guard = tt;
  ret(obj_level(signatureAlgorithms)) = pc ⊔ level(signatureAlgorithms) ⊔ level(this) ⊔ obj_level(signatureAlgorithms) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signatureAlgorithms) ⊔ level(this) ⊔ obj_level(this);
}