boolean org.apache.kerby.kerberos.kerb.crypto.cksum.provider.AbstractUnkeyedCheckSumTypeHandler:verify (
  byte[] @data, int start, int len, byte[] checksum) {
  guard = tt;
  ret(level()) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(@data)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(checksum)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ obj_level(checksum) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
}