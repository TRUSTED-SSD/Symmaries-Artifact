void org.apache.kerby.kerberos.kerb.server.request.KdcRequest:setTicket (
  org.apache.kerby.kerberos.kerb.type.ticket.Ticket ticket) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(ticket) ⊔ obj_level(this) ⊔ obj_level(ticket);
  ret(obj_level(ticket)) = pc ⊔ level(ticket) ⊔ obj_level(ticket);
}