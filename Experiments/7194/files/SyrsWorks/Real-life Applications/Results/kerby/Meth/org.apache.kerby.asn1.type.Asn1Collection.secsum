org.apache.kerby.asn1.type.Asn1Collection (org.apache.kerby.asn1.UniversalTag
                                             universalTag) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(universalTag)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(universalTag);
}