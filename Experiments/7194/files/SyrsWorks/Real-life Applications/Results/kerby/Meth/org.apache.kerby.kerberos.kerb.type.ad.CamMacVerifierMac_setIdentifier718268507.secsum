void org.apache.kerby.kerberos.kerb.type.ad.CamMacVerifierMac:setIdentifier (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName identifier) {
  guard = tt;
  ret(obj_level(identifier)) = pc ⊔ level(identifier) ⊔ level(this) ⊔ obj_level(identifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(identifier) ⊔ level(this) ⊔ obj_level(this);
}