static void org.apache.kerby.kerberos.kerb.preauth.pkinit.PkinitCrypto:verifyCmsSignedData (
  org.apache.kerby.kerberos.kerb.preauth.pkinit.CmsMessageType cmsMsgType,
  org.apache.kerby.cms.type.SignedData signedData) {
  guard = pc ⊔ level(cmsMsgType) ⊔ level(signedData) ⊔ obj_level(cmsMsgType) ⊔ obj_level(signedData) = ⊥;
  ret(obj_level(cmsMsgType)) = ⊥;
  ret(obj_level(signedData)) = ⊥;
}