static javax.security.auth.Subject org.apache.kerby.kerberos.kerb.admin.AuthUtil:loginUsingTicketCache (
  java.lang.String principal, java.io.File cacheFile) {
  guard = pc ⊔ level(cacheFile) ⊔ level(principal) ⊔ obj_level(cacheFile) ⊔ obj_level(principal) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(cacheFile)) = ⊥;
  ret(obj_level(principal)) = ⊥;
}