void org.apache.kerby.cms.type.CertificateChoices:setExtendedCertificate (
  org.apache.kerby.cms.type.ExtendedCertificate extendedCertificate) {
  guard = tt;
  ret(obj_level(extendedCertificate)) = pc ⊔ level(extendedCertificate) ⊔ level(this) ⊔ obj_level(extendedCertificate) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(extendedCertificate) ⊔ level(this) ⊔ obj_level(this);
}