void org.apache.kerby.kerberos.kerb.server.preauth.PreauthHandler:provideEdata (
  org.apache.kerby.kerberos.kerb.server.request.KdcRequest kdcRequest,
  org.apache.kerby.kerberos.kerb.type.pa.PaData outPaData) {
  guard = tt;
  ret(obj_level(kdcRequest)) = pc ⊔ level(kdcRequest) ⊔ obj_level(kdcRequest);
  ret(obj_level(outPaData)) = pc ⊔ level(kdcRequest) ⊔ obj_level(kdcRequest) ⊔ obj_level(outPaData);
  ret(obj_level(this)) = pc ⊔ level(kdcRequest) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
}