static boolean org.apache.kerby.kerberos.kerb.preauth.pkinit.PkinitCrypto:checkDHWellknown (
  org.apache.kerby.kerberos.kerb.preauth.pkinit.PkinitPlgCryptoContext
    cryptoctx,
  org.apache.kerby.x509.type.DhParameter dhParameter, int dhPrimeBits) {
  guard = pc ⊔ level(dhParameter) ⊔ level(dhPrimeBits) ⊔ obj_level(dhParameter) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(cryptoctx)) = obj_level(cryptoctx);
  ret(obj_level(dhParameter)) = ⊥;
}