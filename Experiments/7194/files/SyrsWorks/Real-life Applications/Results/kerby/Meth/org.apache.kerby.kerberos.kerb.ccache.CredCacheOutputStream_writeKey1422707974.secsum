void org.apache.kerby.kerberos.kerb.ccache.CredCacheOutputStream:writeKey (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey key, int version) {
  guard = pc ⊔ level(key) ⊔ level(this) ⊔ level(version) ⊔ obj_level(key) ⊔ obj_level(this) = ⊥;
  ret(obj_level(key)) = ⊥;
  ret(obj_level(this)) = ⊥;
}