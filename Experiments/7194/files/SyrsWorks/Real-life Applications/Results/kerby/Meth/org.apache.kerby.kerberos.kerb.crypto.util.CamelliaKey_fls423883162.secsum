void org.apache.kerby.kerberos.kerb.crypto.util.CamelliaKey:fls (int[] s,
                                                                 int[] fkey,
                                                                 int keyoff) {
  guard = tt;
  ret(obj_level(fkey)) = pc ⊔ level(fkey) ⊔ level(keyoff) ⊔ level(s) ⊔ obj_level(fkey);
  ret(obj_level(s)) = pc ⊔ level(fkey) ⊔ level(keyoff) ⊔ level(s) ⊔ obj_level(fkey);
  ret(obj_level(this)) = pc ⊔ level(fkey) ⊔ level(keyoff) ⊔ level(s) ⊔ obj_level(fkey) ⊔ obj_level(this);
}