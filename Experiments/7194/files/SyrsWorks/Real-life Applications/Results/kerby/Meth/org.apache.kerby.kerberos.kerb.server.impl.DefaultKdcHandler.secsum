org.apache.kerby.kerberos.kerb.server.impl.DefaultKdcHandler (org.apache.kerby.kerberos.kerb.server.KdcContext
                                                                kdcContext,
                                                              org.apache.kerby.kerberos.kerb.transport.KrbTransport
                                                                transport) {
  guard = tt;
  ret(obj_level(kdcContext)) = pc ⊔ level(kdcContext) ⊔ level(this) ⊔ level(transport) ⊔ obj_level(kdcContext) ⊔ obj_level(this) ⊔ obj_level(transport);
  ret(obj_level(this)) = pc ⊔ level(kdcContext) ⊔ level(this) ⊔ level(transport) ⊔ obj_level(kdcContext) ⊔ obj_level(this) ⊔ obj_level(transport);
  ret(obj_level(transport)) = pc ⊔ level(kdcContext) ⊔ level(this) ⊔ level(transport) ⊔ obj_level(kdcContext) ⊔ obj_level(this) ⊔ obj_level(transport);
}