org.apache.kerby.kerberos.kerb.server.KdcRecoverableException (org.apache.kerby.kerberos.kerb.type.base.KrbError
                                                                 krbError) {
  guard = tt;
  ret(obj_level(krbError)) = pc ⊔ level(krbError) ⊔ obj_level(krbError) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(krbError) ⊔ obj_level(krbError) ⊔ obj_level(this);
}