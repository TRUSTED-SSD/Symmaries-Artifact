void org.apache.kerby.x509.type.RevokedCertificate:setRevocationData (
  org.apache.kerby.x509.type.Time revocationData) {
  guard = tt;
  ret(obj_level(revocationData)) = pc ⊔ level(revocationData) ⊔ level(this) ⊔ obj_level(revocationData) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(revocationData) ⊔ level(this) ⊔ obj_level(this);
}