void org.apache.kerby.x509.type.AttCertIssuer:setV2Form (org.apache.kerby.x509.type.V2Form
                                                           v2Form) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(v2Form) ⊔ obj_level(this);
  ret(obj_level(v2Form)) = pc ⊔ level(this) ⊔ level(v2Form) ⊔ obj_level(this) ⊔ obj_level(v2Form);
}