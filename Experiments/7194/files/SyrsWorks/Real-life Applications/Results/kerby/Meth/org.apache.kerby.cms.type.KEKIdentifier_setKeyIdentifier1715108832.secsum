void org.apache.kerby.cms.type.KEKIdentifier:setKeyIdentifier (org.apache.kerby.asn1.type.Asn1OctetString
                                                                 keyIdentifier) {
  guard = tt;
  ret(obj_level(keyIdentifier)) = pc ⊔ level(keyIdentifier) ⊔ level(this) ⊔ obj_level(keyIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(keyIdentifier) ⊔ level(this) ⊔ obj_level(this);
}