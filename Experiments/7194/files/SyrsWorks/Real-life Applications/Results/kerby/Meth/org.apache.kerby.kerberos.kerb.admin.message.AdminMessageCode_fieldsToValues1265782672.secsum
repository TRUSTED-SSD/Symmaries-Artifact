org.apache.kerby.xdr.type.XdrStructType org.apache.kerby.kerberos.kerb.admin.message.AdminMessageCode:fieldsToValues (
  org.apache.kerby.xdr.type.AbstractXdrType[] fields) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc;
  ret(obj_level(fields)) = pc ⊔ level(fields) ⊔ obj_level(fields);
  ret(obj_level(this)) = pc ⊔ level(fields) ⊔ obj_level(fields) ⊔ obj_level(this);
}