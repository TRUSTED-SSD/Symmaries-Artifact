void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setKey (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey key) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ level(this) ⊔ obj_level(key) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ level(this) ⊔ obj_level(this);
}