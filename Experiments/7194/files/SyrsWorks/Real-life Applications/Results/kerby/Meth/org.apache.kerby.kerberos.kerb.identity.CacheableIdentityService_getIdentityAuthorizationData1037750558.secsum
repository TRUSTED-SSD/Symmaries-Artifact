org.apache.kerby.kerberos.kerb.type.ad.AuthorizationData org.apache.kerby.kerberos.kerb.identity.CacheableIdentityService:getIdentityAuthorizationData (
  org.apache.kerby.kerberos.kerb.request.KdcClientRequest kdcClientRequest,
  org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart encTicketPart) {
  guard = pc ⊔ level(kdcClientRequest) ⊔ level(this) ⊔ obj_level(this) = ⊥;
  ret(level()) = obj_level(kdcClientRequest);
  ret(obj_level()) = ⊤;
  ret(obj_level(encTicketPart)) = ⊤;
  ret(obj_level(kdcClientRequest)) = ⊤;
  ret(obj_level(this)) = ⊤;
}