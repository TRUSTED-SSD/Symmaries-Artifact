void org.apache.kerby.cms.type.PasswordRecipientInfo:setKeyDerivationAlgorithmIdentifier (
  org.apache.kerby.cms.type.KeyDerivationAlgorithmIdentifier
    keyDerivationAlgorithmIdentifier) {
  guard = tt;
  ret(obj_level(keyDerivationAlgorithmIdentifier)) = pc ⊔ level(keyDerivationAlgorithmIdentifier) ⊔ level(this) ⊔ obj_level(keyDerivationAlgorithmIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(keyDerivationAlgorithmIdentifier) ⊔ level(this) ⊔ obj_level(this);
}