void org.apache.kerby.x509.type.PolicyInformation:setPolicyQualifiers (
  org.apache.kerby.x509.type.PolicyQualifierInfos policyQualifiers) {
  guard = tt;
  ret(obj_level(policyQualifiers)) = pc ⊔ level(policyQualifiers) ⊔ level(this) ⊔ obj_level(policyQualifiers) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(policyQualifiers) ⊔ level(this) ⊔ obj_level(this);
}