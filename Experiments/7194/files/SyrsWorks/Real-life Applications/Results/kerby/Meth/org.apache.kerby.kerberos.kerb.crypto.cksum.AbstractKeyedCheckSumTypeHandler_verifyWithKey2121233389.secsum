boolean org.apache.kerby.kerberos.kerb.crypto.cksum.AbstractKeyedCheckSumTypeHandler:verifyWithKey (
  byte[] @data, byte[] key, int usage, byte[] checksum) {
  guard = tt;
  ret(level()) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(@data)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(checksum)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(key)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(key) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@data) ⊔ level(checksum) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@data) ⊔ obj_level(this);
}