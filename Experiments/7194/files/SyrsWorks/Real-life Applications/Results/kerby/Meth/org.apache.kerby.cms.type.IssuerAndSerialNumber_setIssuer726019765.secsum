void org.apache.kerby.cms.type.IssuerAndSerialNumber:setIssuer (org.apache.kerby.x500.type.Name
                                                                  name) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(name) ⊔ level(this) ⊔ obj_level(this);
}