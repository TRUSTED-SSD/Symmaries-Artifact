void org.apache.kerby.cms.type.KeyAgreeRecipientInfo:setUkm (org.apache.kerby.asn1.type.Asn1OctetString
                                                               ukm) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(ukm) ⊔ obj_level(this);
  ret(obj_level(ukm)) = pc ⊔ level(this) ⊔ level(ukm) ⊔ obj_level(this) ⊔ obj_level(ukm);
}