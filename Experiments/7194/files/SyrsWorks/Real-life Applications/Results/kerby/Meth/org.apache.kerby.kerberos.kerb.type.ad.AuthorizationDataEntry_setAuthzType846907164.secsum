void org.apache.kerby.kerberos.kerb.type.ad.AuthorizationDataEntry:setAuthzType (
  org.apache.kerby.kerberos.kerb.type.ad.AuthorizationType authzType) {
  guard = tt;
  ret(obj_level(authzType)) = pc ⊔ level(authzType) ⊔ level(this) ⊔ obj_level(authzType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(authzType) ⊔ level(this) ⊔ obj_level(authzType) ⊔ obj_level(this);
}