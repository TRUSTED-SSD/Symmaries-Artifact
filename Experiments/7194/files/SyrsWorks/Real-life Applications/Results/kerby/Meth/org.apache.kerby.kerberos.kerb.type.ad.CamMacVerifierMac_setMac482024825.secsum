void org.apache.kerby.kerberos.kerb.type.ad.CamMacVerifierMac:setMac (
  org.apache.kerby.kerberos.kerb.type.base.CheckSum mac) {
  guard = tt;
  ret(obj_level(mac)) = pc ⊔ level(mac) ⊔ level(this) ⊔ obj_level(mac) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(mac) ⊔ level(this) ⊔ obj_level(this);
}