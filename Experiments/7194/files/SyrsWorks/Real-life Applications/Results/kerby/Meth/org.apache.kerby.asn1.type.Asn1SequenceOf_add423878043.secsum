void org.apache.kerby.asn1.type.Asn1SequenceOf:add (org.apache.kerby.asn1.type.Asn1Type
                                                      element) {
  guard = tt;
  ret(obj_level(element)) = pc ⊔ level(element) ⊔ level(this) ⊔ obj_level(element);
  ret(obj_level(this)) = pc ⊔ level(element) ⊔ level(this) ⊔ obj_level(element);
}