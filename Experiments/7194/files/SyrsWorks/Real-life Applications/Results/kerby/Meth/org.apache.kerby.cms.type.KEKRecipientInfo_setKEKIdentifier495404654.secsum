void org.apache.kerby.cms.type.KEKRecipientInfo:setKEKIdentifier (org.apache.kerby.cms.type.KEKIdentifier
                                                                    kekIdentifier) {
  guard = tt;
  ret(obj_level(kekIdentifier)) = pc ⊔ level(kekIdentifier) ⊔ level(this) ⊔ obj_level(kekIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(kekIdentifier) ⊔ level(this) ⊔ obj_level(this);
}