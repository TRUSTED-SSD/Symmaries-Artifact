void org.apache.kerby.cms.type.CertificateChoices:setV1AttrCert (org.apache.kerby.cms.type.AttributeCertificateV1
                                                                   v1AttrCert) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(v1AttrCert) ⊔ obj_level(this);
  ret(obj_level(v1AttrCert)) = pc ⊔ level(this) ⊔ level(v1AttrCert) ⊔ obj_level(this) ⊔ obj_level(v1AttrCert);
}