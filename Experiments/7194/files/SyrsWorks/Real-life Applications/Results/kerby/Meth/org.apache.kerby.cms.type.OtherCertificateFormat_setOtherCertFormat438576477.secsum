void org.apache.kerby.cms.type.OtherCertificateFormat:setOtherCertFormat (
  org.apache.kerby.asn1.type.Asn1ObjectIdentifier otherCertFormat) {
  guard = tt;
  ret(obj_level(otherCertFormat)) = pc ⊔ level(otherCertFormat) ⊔ level(this) ⊔ obj_level(otherCertFormat) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(otherCertFormat) ⊔ level(this) ⊔ obj_level(this);
}