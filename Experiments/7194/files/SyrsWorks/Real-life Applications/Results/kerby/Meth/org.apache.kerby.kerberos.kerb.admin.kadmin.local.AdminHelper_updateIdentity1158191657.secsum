static void org.apache.kerby.kerberos.kerb.admin.kadmin.local.AdminHelper:updateIdentity (
  org.apache.kerby.kerberos.kerb.request.KrbIdentity identity,
  org.apache.kerby.KOptions kOptions) {
  guard = tt;
  ret(obj_level(identity)) = pc ⊔ level(kOptions) ⊔ obj_level(identity) ⊔ obj_level(kOptions);
  ret(obj_level(kOptions)) = pc ⊔ level(kOptions) ⊔ obj_level(identity) ⊔ obj_level(kOptions);
}