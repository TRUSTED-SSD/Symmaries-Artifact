static void org.apache.kerby.kerberos.kerb.response.ApResponse:validate (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey encKey,
  org.apache.kerby.kerberos.kerb.type.ap.ApRep apRep,
  org.apache.kerby.kerberos.kerb.type.ap.ApReq apReqSent) {
  guard = tt;
  ret(obj_level(apRep)) = pc ⊔ level(apRep) ⊔ level(apReqSent) ⊔ level(encKey) ⊔ obj_level(apRep) ⊔ obj_level(apReqSent) ⊔ obj_level(encKey);
  ret(obj_level(apReqSent)) = pc ⊔ level(apRep) ⊔ level(apReqSent) ⊔ level(encKey) ⊔ obj_level(apRep) ⊔ obj_level(apReqSent) ⊔ obj_level(encKey);
  ret(obj_level(encKey)) = pc ⊔ level(apRep) ⊔ level(apReqSent) ⊔ level(encKey) ⊔ obj_level(apRep) ⊔ obj_level(apReqSent) ⊔ obj_level(encKey);
}