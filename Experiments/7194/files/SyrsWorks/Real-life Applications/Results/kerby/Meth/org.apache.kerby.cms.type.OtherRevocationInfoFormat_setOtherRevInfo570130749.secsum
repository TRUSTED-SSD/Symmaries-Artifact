void org.apache.kerby.cms.type.OtherRevocationInfoFormat:setOtherRevInfo (
  org.apache.kerby.asn1.type.Asn1Type otherRevInfo) {
  guard = tt;
  ret(obj_level(otherRevInfo)) = pc ⊔ level(otherRevInfo) ⊔ level(this) ⊔ obj_level(otherRevInfo);
  ret(obj_level(this)) = pc ⊔ level(otherRevInfo) ⊔ level(this) ⊔ obj_level(this);
}