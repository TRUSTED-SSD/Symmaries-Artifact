void org.apache.kerby.x509.type.IssuingDistributionPoint:setOnlySomeReasons (
  org.apache.kerby.x509.type.ReasonFlags onlySomeReasons) {
  guard = tt;
  ret(obj_level(onlySomeReasons)) = pc ⊔ level(onlySomeReasons) ⊔ level(this) ⊔ obj_level(onlySomeReasons) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(onlySomeReasons) ⊔ level(this) ⊔ obj_level(this);
}