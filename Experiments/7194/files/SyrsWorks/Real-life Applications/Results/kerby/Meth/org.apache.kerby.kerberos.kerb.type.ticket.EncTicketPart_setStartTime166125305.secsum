void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setStartTime (
  org.apache.kerby.kerberos.kerb.type.KerberosTime startTime) {
  guard = tt;
  ret(obj_level(startTime)) = pc ⊔ level(startTime) ⊔ level(this) ⊔ obj_level(startTime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(startTime) ⊔ level(this) ⊔ obj_level(this);
}