void org.apache.kerby.x509.type.TargetCert:setCerttDigestInfo (org.apache.kerby.x509.type.ObjectDigestInfo
                                                                 certDigestInfo) {
  guard = tt;
  ret(obj_level(certDigestInfo)) = pc ⊔ level(certDigestInfo) ⊔ level(this) ⊔ obj_level(certDigestInfo) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(certDigestInfo) ⊔ level(this) ⊔ obj_level(this);
}