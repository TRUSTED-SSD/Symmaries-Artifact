void org.apache.kerby.kerberos.kerb.type.fast.KrbFastReq:setFastOptions (
  org.apache.kerby.kerberos.kerb.type.fast.FastOptions fastOptions) {
  guard = tt;
  ret(obj_level(fastOptions)) = pc ⊔ level(fastOptions) ⊔ level(this) ⊔ obj_level(fastOptions) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fastOptions) ⊔ level(this) ⊔ obj_level(this);
}