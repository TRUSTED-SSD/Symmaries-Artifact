void org.apache.kerby.x509.type.PolicyInformation:setPolicyIdentifier (
  org.apache.kerby.x509.type.CertPolicyId policyIdentifier) {
  guard = tt;
  ret(obj_level(policyIdentifier)) = pc ⊔ level(policyIdentifier) ⊔ level(this) ⊔ obj_level(policyIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(policyIdentifier) ⊔ level(this) ⊔ obj_level(this);
}