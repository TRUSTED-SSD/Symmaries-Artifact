void org.apache.kerby.cms.type.OriginatorInfo:setCerts (org.apache.kerby.cms.type.CertificateSet
                                                          certs) {
  guard = tt;
  ret(obj_level(certs)) = pc ⊔ level(certs) ⊔ level(this) ⊔ obj_level(certs) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(certs) ⊔ level(this) ⊔ obj_level(this);
}