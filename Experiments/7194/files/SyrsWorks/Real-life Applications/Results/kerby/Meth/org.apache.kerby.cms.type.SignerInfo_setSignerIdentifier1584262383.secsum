void org.apache.kerby.cms.type.SignerInfo:setSignerIdentifier (org.apache.kerby.cms.type.SignerIdentifier
                                                                 signerIdentifier) {
  guard = tt;
  ret(obj_level(signerIdentifier)) = pc ⊔ level(signerIdentifier) ⊔ level(this) ⊔ obj_level(signerIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signerIdentifier) ⊔ level(this) ⊔ obj_level(this);
}