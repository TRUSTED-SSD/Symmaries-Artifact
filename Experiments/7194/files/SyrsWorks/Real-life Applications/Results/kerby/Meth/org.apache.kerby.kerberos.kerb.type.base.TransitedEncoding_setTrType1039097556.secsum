void org.apache.kerby.kerberos.kerb.type.base.TransitedEncoding:setTrType (
  org.apache.kerby.kerberos.kerb.type.base.TransitedEncodingType trType) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(trType) ⊔ obj_level(this);
  ret(obj_level(trType)) = pc ⊔ level(this) ⊔ level(trType) ⊔ obj_level(this) ⊔ obj_level(trType);
}