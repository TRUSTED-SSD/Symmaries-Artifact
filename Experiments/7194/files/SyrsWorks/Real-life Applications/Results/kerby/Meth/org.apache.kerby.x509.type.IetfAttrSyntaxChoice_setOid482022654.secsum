void org.apache.kerby.x509.type.IetfAttrSyntaxChoice:setOid (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                               oid) {
  guard = tt;
  ret(obj_level(oid)) = pc ⊔ level(oid) ⊔ level(this) ⊔ obj_level(oid) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(oid) ⊔ level(this) ⊔ obj_level(this);
}