void org.apache.kerby.x509.type.BasicConstraints:setPathLenConstraint (
  org.apache.kerby.asn1.type.Asn1Integer pathLenConstraint) {
  guard = tt;
  ret(obj_level(pathLenConstraint)) = pc ⊔ level(pathLenConstraint) ⊔ level(this) ⊔ obj_level(pathLenConstraint) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(pathLenConstraint) ⊔ level(this) ⊔ obj_level(this);
}