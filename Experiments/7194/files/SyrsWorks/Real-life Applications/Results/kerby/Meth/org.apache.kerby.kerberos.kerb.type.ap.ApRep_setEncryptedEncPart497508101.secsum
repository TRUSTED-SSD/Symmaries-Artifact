void org.apache.kerby.kerberos.kerb.type.ap.ApRep:setEncryptedEncPart (
  org.apache.kerby.kerberos.kerb.type.base.EncryptedData encPart) {
  guard = tt;
  ret(obj_level(encPart)) = pc ⊔ level(encPart) ⊔ level(this) ⊔ obj_level(encPart) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(encPart) ⊔ level(this) ⊔ obj_level(this);
}