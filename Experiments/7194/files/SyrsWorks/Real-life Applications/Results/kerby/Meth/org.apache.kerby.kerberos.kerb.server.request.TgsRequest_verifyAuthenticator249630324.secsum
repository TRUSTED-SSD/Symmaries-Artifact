void org.apache.kerby.kerberos.kerb.server.request.TgsRequest:verifyAuthenticator (
  org.apache.kerby.kerberos.kerb.type.pa.PaDataEntry paDataEntry) {
  guard = pc ⊔ level(paDataEntry) ⊔ level(this) ⊔ obj_level(paDataEntry) ⊔ obj_level(this) = ⊥;
  ret(obj_level(paDataEntry)) = ⊤;
  ret(obj_level(this)) = ⊤;
}