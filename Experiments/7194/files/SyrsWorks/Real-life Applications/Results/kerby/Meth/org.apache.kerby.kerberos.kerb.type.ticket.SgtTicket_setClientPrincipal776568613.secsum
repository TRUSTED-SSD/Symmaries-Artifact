void org.apache.kerby.kerberos.kerb.type.ticket.SgtTicket:setClientPrincipal (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName clientPrincipal) {
  guard = tt;
  ret(obj_level(clientPrincipal)) = pc ⊔ level(clientPrincipal) ⊔ obj_level(clientPrincipal);
  ret(obj_level(this)) = pc ⊔ level(clientPrincipal) ⊔ obj_level(clientPrincipal) ⊔ obj_level(this);
}