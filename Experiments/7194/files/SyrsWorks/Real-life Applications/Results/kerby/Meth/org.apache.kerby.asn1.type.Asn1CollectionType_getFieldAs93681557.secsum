org.apache.kerby.asn1.type.Asn1Type org.apache.kerby.asn1.type.Asn1CollectionType:getFieldAs (
  org.apache.kerby.asn1.EnumType index, java.lang.Class t) {
  guard = tt;
  ret(level()) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ obj_level(index);
  ret(obj_level(t)) = pc ⊔ level(index) ⊔ obj_level(index) ⊔ obj_level(t) ⊔ obj_level(this);
  ret(obj_level(this)) = if obj_level(index) = ⊥ ∧ obj_level(this) = ⊥ ∧ (if obj_level(t) = ⊥ then level(index) = ⊥ else obj_level(t) = ⊤ ∧ level(index) ⊔ level(this) = ⊥) then pc else obj_level(index) ⊔ obj_level(this) ⊔ (if obj_level(t) = ⊥ then level(index) else obj_level(t) ⊓ (level(index) ⊔ level(this)));
}