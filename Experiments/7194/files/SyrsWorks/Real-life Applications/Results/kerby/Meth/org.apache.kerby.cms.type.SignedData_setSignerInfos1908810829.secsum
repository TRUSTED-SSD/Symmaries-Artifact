void org.apache.kerby.cms.type.SignedData:setSignerInfos (org.apache.kerby.cms.type.SignerInfos
                                                            signerInfos) {
  guard = tt;
  ret(obj_level(signerInfos)) = pc ⊔ level(signerInfos) ⊔ level(this) ⊔ obj_level(signerInfos) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signerInfos) ⊔ level(this) ⊔ obj_level(this);
}