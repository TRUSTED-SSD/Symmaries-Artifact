void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setRenewtill (
  org.apache.kerby.kerberos.kerb.type.KerberosTime renewtill) {
  guard = tt;
  ret(obj_level(renewtill)) = pc ⊔ level(renewtill) ⊔ level(this) ⊔ obj_level(renewtill) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(renewtill) ⊔ level(this) ⊔ obj_level(this);
}