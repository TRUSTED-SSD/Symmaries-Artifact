void org.apache.kerby.cms.type.RecipientInfo:setKari (org.apache.kerby.cms.type.KeyAgreeRecipientInfo
                                                        kari) {
  guard = tt;
  ret(obj_level(kari)) = pc ⊔ level(kari) ⊔ level(this) ⊔ obj_level(kari) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(kari) ⊔ level(this) ⊔ obj_level(this);
}