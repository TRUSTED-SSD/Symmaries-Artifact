void org.apache.kerby.cms.type.CompressedData:setCompressionAlgorithm (
  org.apache.kerby.x509.type.AlgorithmIdentifier compressionAlgorithm) {
  guard = tt;
  ret(obj_level(compressionAlgorithm)) = pc ⊔ level(compressionAlgorithm) ⊔ level(this) ⊔ obj_level(compressionAlgorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(compressionAlgorithm) ⊔ level(this) ⊔ obj_level(this);
}