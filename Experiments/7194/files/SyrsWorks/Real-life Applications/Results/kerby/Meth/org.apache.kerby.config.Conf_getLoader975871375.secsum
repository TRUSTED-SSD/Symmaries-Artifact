static org.apache.kerby.config.ConfigLoader org.apache.kerby.config.Conf:getLoader (
  org.apache.kerby.config.Resource resource) {
  guard = tt;
  ret(level()) = pc ⊔ level(resource) ⊔ obj_level(resource);
  ret(obj_level()) = pc ⊔ level(resource) ⊔ obj_level(resource);
  ret(obj_level(resource)) = pc ⊔ level(resource) ⊔ obj_level(resource);
}