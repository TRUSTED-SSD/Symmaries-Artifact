void org.apache.kerby.cms.type.Subject:setSubjectName (org.apache.kerby.x509.type.GeneralNames
                                                         subjectName) {
  guard = tt;
  ret(obj_level(subjectName)) = pc ⊔ level(subjectName) ⊔ level(this) ⊔ obj_level(subjectName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(subjectName) ⊔ level(this) ⊔ obj_level(this);
}