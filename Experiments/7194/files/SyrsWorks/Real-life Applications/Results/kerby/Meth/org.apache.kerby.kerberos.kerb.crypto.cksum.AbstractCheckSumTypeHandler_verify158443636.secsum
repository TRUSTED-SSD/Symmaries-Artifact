boolean org.apache.kerby.kerberos.kerb.crypto.cksum.AbstractCheckSumTypeHandler:verify (
  byte[] data, byte[] checksum) {
  guard = tt;
  ret(level()) = pc ⊔ level(checksum) ⊔ level(data) ⊔ level(this) ⊔ obj_level(checksum) ⊔ obj_level(this);
  ret(obj_level(checksum)) = obj_level(checksum);
  ret(obj_level(data)) = obj_level(data);
  ret(obj_level(this)) = obj_level(this);
}