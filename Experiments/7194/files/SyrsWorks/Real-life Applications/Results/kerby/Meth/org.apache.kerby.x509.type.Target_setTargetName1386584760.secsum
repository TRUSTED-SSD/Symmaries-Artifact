void org.apache.kerby.x509.type.Target:setTargetName (org.apache.kerby.x509.type.GeneralName
                                                        targetName) {
  guard = tt;
  ret(obj_level(targetName)) = pc ⊔ level(targetName) ⊔ level(this) ⊔ obj_level(targetName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(targetName) ⊔ level(this) ⊔ obj_level(this);
}