                                                  msgType) {
  guard = tt;
  ret(obj_level(msgType)) = pc ⊔ level(msgType) ⊔ level(this) ⊔ obj_level(msgType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msgType) ⊔ level(this) ⊔ obj_level(msgType) ⊔ obj_level(this);
}