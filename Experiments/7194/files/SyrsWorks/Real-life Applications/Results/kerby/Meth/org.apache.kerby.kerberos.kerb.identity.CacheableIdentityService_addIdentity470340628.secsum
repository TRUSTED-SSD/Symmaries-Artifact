org.apache.kerby.kerberos.kerb.request.KrbIdentity org.apache.kerby.kerberos.kerb.identity.CacheableIdentityService:addIdentity (
  org.apache.kerby.kerberos.kerb.request.KrbIdentity @identity) {
  guard = pc ⊔ level(@identity) ⊔ level(this) ⊔ obj_level(@identity) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(@identity)) = ⊥;
  ret(obj_level(this)) = ⊥;
}