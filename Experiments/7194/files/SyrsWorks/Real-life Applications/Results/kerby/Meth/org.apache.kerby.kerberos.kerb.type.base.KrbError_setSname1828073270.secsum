void org.apache.kerby.kerberos.kerb.type.base.KrbError:setSname (org.apache.kerby.kerberos.kerb.type.base.PrincipalName
                                                                   sname) {
  guard = tt;
  ret(obj_level(sname)) = pc ⊔ level(sname) ⊔ level(this) ⊔ obj_level(sname) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(sname) ⊔ level(this) ⊔ obj_level(this);
}