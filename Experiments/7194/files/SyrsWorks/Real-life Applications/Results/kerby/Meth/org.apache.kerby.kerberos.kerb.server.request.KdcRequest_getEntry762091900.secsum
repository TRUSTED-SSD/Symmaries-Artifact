  guard = pc ⊔ level(principal) ⊔ level(this) ⊔ obj_level(principal) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(principal)) = ⊥;
