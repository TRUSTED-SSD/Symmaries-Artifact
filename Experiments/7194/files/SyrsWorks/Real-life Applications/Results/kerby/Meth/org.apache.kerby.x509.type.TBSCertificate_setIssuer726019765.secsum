void org.apache.kerby.x509.type.TBSCertificate:setIssuer (org.apache.kerby.x500.type.Name
                                                            attCertIssuer) {
  guard = tt;
  ret(obj_level(attCertIssuer)) = pc ⊔ level(attCertIssuer) ⊔ level(this) ⊔ obj_level(attCertIssuer) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(attCertIssuer) ⊔ level(this) ⊔ obj_level(this);
}