org.apache.kerby.asn1.type.Asn1TaggingSequence (int taggingTagNo,
                                                org.apache.kerby.asn1.Asn1FieldInfo[]
                                                  tags,
                                                boolean isAppSpecific,
                                                boolean isImplicit) {
  guard = tt;
  ret(obj_level(tags)) = pc ⊔ level(isAppSpecific) ⊔ level(isImplicit) ⊔ level(tags) ⊔ level(this) ⊔ obj_level(tags) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(isAppSpecific) ⊔ level(isImplicit) ⊔ level(tags) ⊔ level(this) ⊔ obj_level(tags) ⊔ obj_level(this);
}