void org.apache.kerby.x509.type.RoleSyntax:setRoleAuthority (org.apache.kerby.x509.type.GeneralNames
                                                               roleAuthority) {
  guard = tt;
  ret(obj_level(roleAuthority)) = pc ⊔ level(roleAuthority) ⊔ level(this) ⊔ obj_level(roleAuthority) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(roleAuthority) ⊔ level(this) ⊔ obj_level(this);
}