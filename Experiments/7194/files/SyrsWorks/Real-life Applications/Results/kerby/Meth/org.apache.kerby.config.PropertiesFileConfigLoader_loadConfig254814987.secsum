void org.apache.kerby.config.PropertiesFileConfigLoader:loadConfig (org.apache.kerby.config.ConfigImpl
                                                                    config,
                                                                    org.apache.kerby.config.Resource
                                                                    resource) {
  guard = tt;
  ret(obj_level(config)) = pc ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource);
  ret(obj_level(resource)) = pc ⊔ level(resource) ⊔ obj_level(resource);
  ret(obj_level(this)) = pc ⊔ level(resource) ⊔ obj_level(resource) ⊔ obj_level(this);
}