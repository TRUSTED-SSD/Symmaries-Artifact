static org.apache.kerby.asn1.type.Asn1Type org.apache.kerby.asn1.Asn1Converter:convertAs (
  org.apache.kerby.asn1.parse.Asn1ParseResult parseResult,
  java.lang.Class type) {
  guard = tt;
  ret(level()) = pc ⊔ level(type) ⊔ obj_level(type);
  ret(obj_level()) = pc ⊔ level(parseResult) ⊔ level(type) ⊔ obj_level(parseResult) ⊔ obj_level(type);
  ret(obj_level(parseResult)) = pc ⊔ level(parseResult) ⊔ level(type) ⊔ obj_level(parseResult) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(parseResult) ⊔ level(type) ⊔ obj_level(parseResult) ⊔ obj_level(type);
}