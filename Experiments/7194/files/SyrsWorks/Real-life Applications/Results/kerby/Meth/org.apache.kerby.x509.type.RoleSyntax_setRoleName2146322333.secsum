void org.apache.kerby.x509.type.RoleSyntax:setRoleName (org.apache.kerby.x509.type.GeneralName
                                                          roleName) {
  guard = tt;
  ret(obj_level(roleName)) = pc ⊔ level(roleName) ⊔ level(this) ⊔ obj_level(roleName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(roleName) ⊔ level(this) ⊔ obj_level(this);
}