void org.apache.kerby.x509.type.TBSCertList:setIssuer (org.apache.kerby.x500.type.Name
                                                         issuer) {
  guard = tt;
  ret(obj_level(issuer)) = pc ⊔ level(issuer) ⊔ level(this) ⊔ obj_level(issuer) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(issuer) ⊔ level(this) ⊔ obj_level(this);
}