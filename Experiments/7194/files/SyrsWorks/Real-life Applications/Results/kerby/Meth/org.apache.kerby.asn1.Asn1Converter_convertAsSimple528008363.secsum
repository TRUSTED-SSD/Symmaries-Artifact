static org.apache.kerby.asn1.type.Asn1Type org.apache.kerby.asn1.Asn1Converter:convertAsSimple (
  org.apache.kerby.asn1.parse.Asn1ParseResult parseResult) {
  guard = tt;
  ret(level()) = pc ⊔ level(parseResult) ⊔ obj_level(parseResult);
  ret(obj_level()) = pc ⊔ level(parseResult) ⊔ obj_level(parseResult);
  ret(obj_level(parseResult)) = pc ⊔ level(parseResult) ⊔ obj_level(parseResult);
}