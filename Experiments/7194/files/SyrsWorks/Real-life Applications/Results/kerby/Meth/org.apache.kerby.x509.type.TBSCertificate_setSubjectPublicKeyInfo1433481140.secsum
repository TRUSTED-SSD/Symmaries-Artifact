void org.apache.kerby.x509.type.TBSCertificate:setSubjectPublicKeyInfo (
  org.apache.kerby.x509.type.SubjectPublicKeyInfo subjectPublicKeyInfo) {
  guard = tt;
  ret(obj_level(subjectPublicKeyInfo)) = pc ⊔ level(subjectPublicKeyInfo) ⊔ level(this) ⊔ obj_level(subjectPublicKeyInfo) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(subjectPublicKeyInfo) ⊔ level(this) ⊔ obj_level(this);
}