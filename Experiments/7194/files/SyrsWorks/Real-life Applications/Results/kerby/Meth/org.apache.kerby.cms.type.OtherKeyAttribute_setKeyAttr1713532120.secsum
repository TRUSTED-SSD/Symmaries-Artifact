void org.apache.kerby.cms.type.OtherKeyAttribute:setKeyAttr (org.apache.kerby.asn1.type.Asn1Type
                                                               keyAttr) {
  guard = tt;
  ret(obj_level(keyAttr)) = pc ⊔ level(keyAttr) ⊔ level(this) ⊔ obj_level(keyAttr);
  ret(obj_level(this)) = pc ⊔ level(keyAttr) ⊔ level(this) ⊔ obj_level(this);
}