static boolean org.apache.kerby.kerberos.kerb.crypto.CheckSumHandler:verify (
  org.apache.kerby.kerberos.kerb.type.base.CheckSum checkSum, byte[] bytes) {
  guard = tt;
  ret(level()) = pc ⊔ level(bytes) ⊔ level(checkSum) ⊔ obj_level(checkSum);
  ret(obj_level(bytes)) = pc ⊔ level(checkSum) ⊔ obj_level(bytes) ⊔ obj_level(checkSum);
  ret(obj_level(checkSum)) = pc ⊔ level(checkSum) ⊔ obj_level(checkSum);
}