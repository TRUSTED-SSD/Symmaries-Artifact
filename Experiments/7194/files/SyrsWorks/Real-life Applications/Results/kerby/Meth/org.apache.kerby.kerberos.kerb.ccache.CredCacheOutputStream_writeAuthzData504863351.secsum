void org.apache.kerby.kerberos.kerb.ccache.CredCacheOutputStream:writeAuthzData (
  org.apache.kerby.kerberos.kerb.type.ad.AuthorizationData authData) {
  guard = pc ⊔ level(authData) ⊔ level(this) ⊔ obj_level(authData) ⊔ obj_level(this) = ⊥;
  ret(obj_level(authData)) = ⊥;
  ret(obj_level(this)) = ⊥;
}