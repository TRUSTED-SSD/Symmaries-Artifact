void org.apache.kerby.kerberos.kerb.type.KrbAppSequenceType:setField (
  org.apache.kerby.asn1.EnumType index,
  org.apache.kerby.asn1.EnumType krbEnum) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(krbEnum) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(krbEnum)) = pc ⊔ level(index) ⊔ level(krbEnum) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(krbEnum) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
}