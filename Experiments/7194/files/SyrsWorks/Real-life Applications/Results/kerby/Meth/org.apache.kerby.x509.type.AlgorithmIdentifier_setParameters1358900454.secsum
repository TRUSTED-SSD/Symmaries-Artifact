void org.apache.kerby.x509.type.AlgorithmIdentifier:setParameters (org.apache.kerby.asn1.type.Asn1Type
                                                                    parameters) {
  guard = tt;
  ret(obj_level(parameters)) = pc ⊔ level(parameters) ⊔ level(this) ⊔ obj_level(parameters);
  ret(obj_level(this)) = pc ⊔ level(parameters) ⊔ level(this) ⊔ obj_level(this);
}