void org.apache.kerby.x509.type.DirectoryString:setUniversalString (org.apache.kerby.asn1.type.Asn1UniversalString
                                                                    universalString) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(universalString) ⊔ obj_level(this);
  ret(obj_level(universalString)) = pc ⊔ level(this) ⊔ level(universalString) ⊔ obj_level(this) ⊔ obj_level(universalString);
}