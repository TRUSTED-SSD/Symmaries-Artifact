org.apache.kerby.kerberos.kerb.transport.KrbTransport org.apache.kerby.kerberos.kerb.transport.KrbNetwork:connect (
  org.apache.kerby.kerberos.kerb.transport.TransportPair tpair) {
  guard = tt;
  ret(level()) = pc ⊔ level(tpair) ⊔ obj_level(tpair);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(tpair) ⊔ obj_level(this) ⊔ obj_level(tpair);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(tpair) ⊔ obj_level(this) ⊔ obj_level(tpair);
  ret(obj_level(tpair)) = pc ⊔ level(this) ⊔ level(tpair) ⊔ obj_level(this) ⊔ obj_level(tpair);
}