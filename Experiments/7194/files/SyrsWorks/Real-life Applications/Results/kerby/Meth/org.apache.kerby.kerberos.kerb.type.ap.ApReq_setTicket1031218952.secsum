void org.apache.kerby.kerberos.kerb.type.ap.ApReq:setTicket (org.apache.kerby.kerberos.kerb.type.ticket.Ticket
                                                               ticket) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(ticket) ⊔ obj_level(this);
  ret(obj_level(ticket)) = pc ⊔ level(this) ⊔ level(ticket) ⊔ obj_level(this) ⊔ obj_level(ticket);
}