org.apache.kerby.kerberos.kerb.request.KrbIdentity org.apache.kerby.kerberos.kerb.identity.backend.AbstractIdentityBackend:getIdentity (
  java.lang.String principalName) {
  guard = pc ⊔ level(principalName) ⊔ obj_level(principalName) = ⊥;
  ret(level()) = level(this) ⊔ obj_level(this);
  ret(obj_level()) = level(this) ⊔ obj_level(this);
  ret(obj_level(principalName)) = level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = level(this) ⊔ obj_level(this);
}