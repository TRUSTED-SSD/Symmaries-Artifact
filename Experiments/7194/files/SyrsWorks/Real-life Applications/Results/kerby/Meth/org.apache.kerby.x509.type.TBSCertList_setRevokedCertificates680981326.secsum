void org.apache.kerby.x509.type.TBSCertList:setRevokedCertificates (org.apache.kerby.x509.type.RevokedCertificates
                                                                    revokedCertificates) {
  guard = tt;
  ret(obj_level(revokedCertificates)) = pc ⊔ level(revokedCertificates) ⊔ level(this) ⊔ obj_level(revokedCertificates) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(revokedCertificates) ⊔ level(this) ⊔ obj_level(this);
}