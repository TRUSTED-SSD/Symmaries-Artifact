static javax.security.auth.Subject org.apache.kerby.kerberos.kerb.admin.AuthUtil:loginUsingPassword (
  java.lang.String principal,
  javax.security.auth.callback.CallbackHandler handler) {
  guard = pc ⊔ level(handler) ⊔ level(principal) ⊔ obj_level(handler) ⊔ obj_level(principal) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(handler)) = ⊥;
  ret(obj_level(principal)) = ⊥;
}