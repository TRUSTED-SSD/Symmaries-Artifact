void org.apache.kerby.kerberos.kerb.keytab.Keytab:writeVersion (org.apache.kerby.kerberos.kerb.keytab.KeytabOutputStream
                                                                  kos) {
  guard = pc ⊔ level(kos) ⊔ level(this) ⊔ obj_level(kos) ⊔ obj_level(this) = ⊥;
  ret(obj_level(kos)) = ⊥;
  ret(obj_level(this)) = ⊥;
}