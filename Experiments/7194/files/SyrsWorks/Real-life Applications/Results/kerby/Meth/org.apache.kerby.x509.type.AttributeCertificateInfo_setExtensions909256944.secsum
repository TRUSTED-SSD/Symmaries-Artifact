void org.apache.kerby.x509.type.AttributeCertificateInfo:setExtensions (
  org.apache.kerby.x509.type.Extensions extensions) {
  guard = tt;
  ret(obj_level(extensions)) = pc ⊔ level(extensions) ⊔ level(this) ⊔ obj_level(extensions) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(extensions) ⊔ level(this) ⊔ obj_level(this);
}