void org.apache.kerby.cms.type.RecipientKeyIdentifier:setDate (org.apache.kerby.asn1.type.Asn1GeneralizedTime
                                                                 date) {
  guard = tt;
  ret(obj_level(date)) = pc ⊔ level(date) ⊔ level(this) ⊔ obj_level(date) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(date) ⊔ level(this) ⊔ obj_level(this);
}