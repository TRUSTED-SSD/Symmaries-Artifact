org.apache.kerby.kerberos.kerb.type.KrbSequenceType (org.apache.kerby.asn1.Asn1FieldInfo[]
                                                       fieldInfos) {
  guard = tt;
  ret(obj_level(fieldInfos)) = pc ⊔ level(fieldInfos) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fieldInfos) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(this);
}