static org.apache.kerby.kerberos.kerb.crypto.CheckSumTypeHandler org.apache.kerby.kerberos.kerb.crypto.CheckSumHandler:getCheckSumHandler (
  org.apache.kerby.kerberos.kerb.type.base.CheckSumType cksumType,
  boolean check) {
  guard = tt;
  ret(level()) = pc ⊔ level(check) ⊔ level(cksumType) ⊔ obj_level(cksumType);
  ret(obj_level()) = pc ⊔ level(check) ⊔ level(cksumType) ⊔ obj_level(cksumType);
  ret(obj_level(cksumType)) = pc ⊔ level(check) ⊔ level(cksumType) ⊔ obj_level(cksumType);
}