void org.apache.kerby.x509.type.AttributeCertificate:setAciInfo (org.apache.kerby.x509.type.AttributeCertificateInfo
                                                                   aciInfo) {
  guard = tt;
  ret(obj_level(aciInfo)) = pc ⊔ level(aciInfo) ⊔ level(this) ⊔ obj_level(aciInfo) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(aciInfo) ⊔ level(this) ⊔ obj_level(this);
}