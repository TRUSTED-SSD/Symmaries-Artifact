byte[] org.apache.kerby.kerberos.kerb.crypto.cksum.HmacKcCheckSum:mac (
  byte[] @kc, byte[] data, int start, int len) {
  guard = tt;
  ret(level()) = pc ⊔ level(@kc) ⊔ level(data) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ obj_level(@kc) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@kc) ⊔ level(data) ⊔ level(len) ⊔ level(start) ⊔ level(this) ⊔ obj_level(@kc) ⊔ obj_level(this);
  ret(obj_level(@kc)) = obj_level(@kc);
  ret(obj_level(data)) = obj_level(data);
  ret(obj_level(this)) = obj_level(this);
}