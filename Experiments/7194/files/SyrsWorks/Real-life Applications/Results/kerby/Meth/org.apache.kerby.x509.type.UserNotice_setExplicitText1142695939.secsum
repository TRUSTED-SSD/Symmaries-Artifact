void org.apache.kerby.x509.type.UserNotice:setExplicitText (org.apache.kerby.x509.type.DisplayText
                                                              explicitText) {
  guard = tt;
  ret(obj_level(explicitText)) = pc ⊔ level(explicitText) ⊔ level(this) ⊔ obj_level(explicitText) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(explicitText) ⊔ level(this) ⊔ obj_level(this);
}