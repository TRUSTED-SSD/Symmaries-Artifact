void org.apache.kerby.x509.type.AccessDescription:setAccessMethod (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                                    accessMethod) {
  guard = tt;
  ret(obj_level(accessMethod)) = pc ⊔ level(accessMethod) ⊔ level(this) ⊔ obj_level(accessMethod) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(accessMethod) ⊔ level(this) ⊔ obj_level(this);
}