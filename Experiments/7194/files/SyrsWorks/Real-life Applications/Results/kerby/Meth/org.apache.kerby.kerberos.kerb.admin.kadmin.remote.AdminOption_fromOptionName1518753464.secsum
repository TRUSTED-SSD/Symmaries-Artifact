  ret(obj_level()) = pc ⊔ level(optionName) ⊔ obj_level(optionName);
  ret(obj_level(optionName)) = if obj_level(optionName) = ⊤ ∨ pc ≠ ⊤ ∧ level(optionName) = ⊤ ∧ obj_level(optionName) = ⊥ then ⊤ else ⊥;
}