void org.apache.kerby.x509.type.CertificatePair:setForward (org.apache.kerby.x509.type.Certificate
                                                              forward) {
  guard = tt;
  ret(obj_level(forward)) = pc ⊔ level(forward) ⊔ level(this) ⊔ obj_level(forward) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(forward) ⊔ level(this) ⊔ obj_level(this);
}