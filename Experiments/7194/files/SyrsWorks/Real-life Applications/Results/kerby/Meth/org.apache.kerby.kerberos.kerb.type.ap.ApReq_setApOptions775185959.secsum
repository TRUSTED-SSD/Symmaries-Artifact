void org.apache.kerby.kerberos.kerb.type.ap.ApReq:setApOptions (org.apache.kerby.kerberos.kerb.type.ap.ApOptions
                                                                  apOptions) {
  guard = tt;
  ret(obj_level(apOptions)) = pc ⊔ level(apOptions) ⊔ level(this) ⊔ obj_level(apOptions) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(apOptions) ⊔ level(this) ⊔ obj_level(this);
}