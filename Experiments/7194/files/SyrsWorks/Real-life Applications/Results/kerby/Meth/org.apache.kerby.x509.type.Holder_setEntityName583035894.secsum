void org.apache.kerby.x509.type.Holder:setEntityName (org.apache.kerby.x509.type.GeneralNames
                                                        entityName) {
  guard = tt;
  ret(obj_level(entityName)) = pc ⊔ level(entityName) ⊔ level(this) ⊔ obj_level(entityName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entityName) ⊔ level(this) ⊔ obj_level(this);
}