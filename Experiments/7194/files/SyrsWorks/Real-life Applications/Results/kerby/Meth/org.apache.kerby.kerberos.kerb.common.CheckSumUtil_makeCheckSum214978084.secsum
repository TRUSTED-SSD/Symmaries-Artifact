static org.apache.kerby.kerberos.kerb.type.base.CheckSum org.apache.kerby.kerberos.kerb.common.CheckSumUtil:makeCheckSum (
  org.apache.kerby.kerberos.kerb.type.base.CheckSumType checkSumType,
  byte[] input) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(checkSumType) ⊔ level(input) ⊔ obj_level(checkSumType) ⊔ obj_level(input);
  ret(obj_level(checkSumType)) = pc ⊔ level(checkSumType) ⊔ level(input) ⊔ obj_level(checkSumType) ⊔ obj_level(input);
  ret(obj_level(input)) = pc ⊔ level(checkSumType) ⊔ level(input) ⊔ obj_level(checkSumType) ⊔ obj_level(input);
}