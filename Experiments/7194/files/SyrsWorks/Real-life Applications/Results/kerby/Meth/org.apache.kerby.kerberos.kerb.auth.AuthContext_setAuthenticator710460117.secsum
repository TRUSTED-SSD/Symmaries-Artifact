void org.apache.kerby.kerberos.kerb.auth.AuthContext:setAuthenticator (
  org.apache.kerby.kerberos.kerb.type.ap.Authenticator authenticator) {
  guard = tt;
  ret(obj_level(authenticator)) = pc ⊔ level(authenticator) ⊔ obj_level(authenticator);
  ret(obj_level(this)) = pc ⊔ level(authenticator) ⊔ obj_level(authenticator) ⊔ obj_level(this);
}