byte[] org.apache.kerby.kerberos.kerb.crypto.cksum.ConfounderedDesCheckSum:fixKey (
  byte[] key) {
  guard = tt;
  ret(level()) = pc ⊔ level(key);
  ret(obj_level()) = pc ⊔ level(key) ⊔ obj_level(key);
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ obj_level(key) ⊔ obj_level(this);
}