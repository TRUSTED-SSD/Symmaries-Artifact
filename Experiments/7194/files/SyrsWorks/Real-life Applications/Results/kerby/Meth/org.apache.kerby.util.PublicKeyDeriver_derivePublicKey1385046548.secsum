static java.security.PublicKey org.apache.kerby.util.PublicKeyDeriver:derivePublicKey (
  java.security.PrivateKey @key) {
  guard = tt;
  ret(level()) = pc ⊔ level(@key) ⊔ obj_level(@key);
  ret(obj_level()) = pc ⊔ level(@key) ⊔ obj_level(@key);
  ret(obj_level(@key)) = pc ⊔ level(@key) ⊔ obj_level(@key);
}