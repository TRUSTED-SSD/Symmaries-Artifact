void org.apache.kerby.asn1.type.Asn1CollectionType:setFieldAsOctets (
  org.apache.kerby.asn1.EnumType index, byte[] bytes) {
  guard = tt;
  ret(obj_level(bytes)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(bytes) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
}