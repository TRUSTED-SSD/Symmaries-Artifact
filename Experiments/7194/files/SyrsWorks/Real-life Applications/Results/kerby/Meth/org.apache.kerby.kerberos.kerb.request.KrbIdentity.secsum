org.apache.kerby.kerberos.kerb.request.KrbIdentity (java.lang.String
                                                      principalName) {
  guard = tt;
  ret(obj_level(principalName)) = pc ⊔ level(principalName) ⊔ level(this) ⊔ obj_level(principalName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(principalName) ⊔ level(this) ⊔ obj_level(principalName) ⊔ obj_level(this);
}