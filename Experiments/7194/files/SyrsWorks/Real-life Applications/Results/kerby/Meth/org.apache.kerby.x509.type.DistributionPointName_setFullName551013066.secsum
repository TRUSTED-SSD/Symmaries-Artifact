void org.apache.kerby.x509.type.DistributionPointName:setFullName (org.apache.kerby.x509.type.GeneralNames
                                                                    fullName) {
  guard = tt;
  ret(obj_level(fullName)) = pc ⊔ level(fullName) ⊔ level(this) ⊔ obj_level(fullName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fullName) ⊔ level(this) ⊔ obj_level(this);
}