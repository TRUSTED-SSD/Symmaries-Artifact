void org.apache.kerby.cms.type.EnvelopedData:setOriginatorInfo (org.apache.kerby.cms.type.OriginatorInfo
                                                                  originatorInfo) {
  guard = tt;
  ret(obj_level(originatorInfo)) = pc ⊔ level(originatorInfo) ⊔ level(this) ⊔ obj_level(originatorInfo) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(originatorInfo) ⊔ level(this) ⊔ obj_level(this);
}