void org.apache.kerby.kerberos.kerb.admin.kadmin.remote.request.AdminRequest:setTransport (
  org.apache.kerby.kerberos.kerb.transport.KrbTransport transport) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(transport) ⊔ obj_level(this) ⊔ obj_level(transport);
  ret(obj_level(transport)) = pc ⊔ level(transport) ⊔ obj_level(transport);
}