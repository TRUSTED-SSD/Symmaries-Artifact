void org.apache.kerby.x509.type.DistributionPoint:setCRLIssuer (org.apache.kerby.x509.type.GeneralNames
                                                                  crlIssuer) {
  guard = tt;
  ret(obj_level(crlIssuer)) = pc ⊔ level(crlIssuer) ⊔ level(this) ⊔ obj_level(crlIssuer) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(crlIssuer) ⊔ level(this) ⊔ obj_level(this);
}