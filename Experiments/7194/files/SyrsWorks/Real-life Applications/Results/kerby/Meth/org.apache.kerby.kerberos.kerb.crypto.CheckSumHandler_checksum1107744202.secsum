static org.apache.kerby.kerberos.kerb.type.base.CheckSum org.apache.kerby.kerberos.kerb.crypto.CheckSumHandler:checksum (
  org.apache.kerby.kerberos.kerb.type.base.CheckSumType checkSumType,
  byte[] @bytes) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@bytes) ⊔ level(checkSumType) ⊔ obj_level(@bytes) ⊔ obj_level(checkSumType);
  ret(obj_level(@bytes)) = pc ⊔ level(@bytes) ⊔ level(checkSumType) ⊔ obj_level(@bytes) ⊔ obj_level(checkSumType);
  ret(obj_level(checkSumType)) = pc ⊔ level(@bytes) ⊔ level(checkSumType) ⊔ obj_level(@bytes) ⊔ obj_level(checkSumType);
}