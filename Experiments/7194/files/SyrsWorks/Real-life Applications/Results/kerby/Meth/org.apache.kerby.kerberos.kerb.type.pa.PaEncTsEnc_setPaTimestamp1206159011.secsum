void org.apache.kerby.kerberos.kerb.type.pa.PaEncTsEnc:setPaTimestamp (
  org.apache.kerby.kerberos.kerb.type.KerberosTime paTimestamp) {
  guard = tt;
  ret(obj_level(paTimestamp)) = pc ⊔ level(paTimestamp) ⊔ level(this) ⊔ obj_level(paTimestamp) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(paTimestamp) ⊔ level(this) ⊔ obj_level(this);
}