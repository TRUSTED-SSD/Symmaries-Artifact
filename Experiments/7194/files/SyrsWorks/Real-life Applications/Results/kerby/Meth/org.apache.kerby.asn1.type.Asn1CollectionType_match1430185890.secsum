int org.apache.kerby.asn1.type.Asn1CollectionType:match (int lastPos,
                                                         org.apache.kerby.asn1.parse.Asn1ParseResult
                                                           parseItem) {
  guard = tt;
  ret(level()) = pc ⊔ level(lastPos) ⊔ level(parseItem) ⊔ level(this) ⊔ obj_level(parseItem) ⊔ obj_level(this);
  ret(obj_level(parseItem)) = pc ⊔ level(lastPos) ⊔ level(parseItem) ⊔ level(this) ⊔ obj_level(parseItem) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(lastPos) ⊔ level(parseItem) ⊔ level(this) ⊔ obj_level(parseItem) ⊔ obj_level(this);
}