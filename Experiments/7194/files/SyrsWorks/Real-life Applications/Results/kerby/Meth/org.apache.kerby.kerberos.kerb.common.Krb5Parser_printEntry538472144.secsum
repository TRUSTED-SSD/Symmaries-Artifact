void org.apache.kerby.kerberos.kerb.common.Krb5Parser:printEntry (java.util.Map
                                                                    @map,
                                                                  int count) {
  guard = pc ⊔ level(@map) ⊔ level(count) ⊔ obj_level(@map) = ⊥;
  ret(obj_level(@map)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}