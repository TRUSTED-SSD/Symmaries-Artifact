void org.apache.kerby.x509.type.NoticeReference:setOrganization (org.apache.kerby.x509.type.DisplayText
                                                                   organization) {
  guard = tt;
  ret(obj_level(organization)) = pc ⊔ level(organization) ⊔ level(this) ⊔ obj_level(organization) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(organization) ⊔ level(this) ⊔ obj_level(this);
}