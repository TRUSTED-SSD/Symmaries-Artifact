void org.apache.kerby.x509.type.AccessDescription:setAccessLocation (
  org.apache.kerby.x509.type.GeneralName accessLocation) {
  guard = tt;
  ret(obj_level(accessLocation)) = pc ⊔ level(accessLocation) ⊔ level(this) ⊔ obj_level(accessLocation) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(accessLocation) ⊔ level(this) ⊔ obj_level(this);
}