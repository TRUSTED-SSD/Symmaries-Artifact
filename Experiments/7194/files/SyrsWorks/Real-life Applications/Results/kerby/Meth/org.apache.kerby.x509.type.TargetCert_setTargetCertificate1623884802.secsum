void org.apache.kerby.x509.type.TargetCert:setTargetCertificate (org.apache.kerby.x509.type.IssuerSerial
                                                                   targetCertificate) {
  guard = tt;
  ret(obj_level(targetCertificate)) = pc ⊔ level(targetCertificate) ⊔ level(this) ⊔ obj_level(targetCertificate) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(targetCertificate) ⊔ level(this) ⊔ obj_level(this);
}