void org.apache.kerby.x509.type.Time:setUtcTime (org.apache.kerby.asn1.type.Asn1UtcTime
                                                   utcTime) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(utcTime) ⊔ obj_level(this);
  ret(obj_level(utcTime)) = pc ⊔ level(this) ⊔ level(utcTime) ⊔ obj_level(this) ⊔ obj_level(utcTime);
}