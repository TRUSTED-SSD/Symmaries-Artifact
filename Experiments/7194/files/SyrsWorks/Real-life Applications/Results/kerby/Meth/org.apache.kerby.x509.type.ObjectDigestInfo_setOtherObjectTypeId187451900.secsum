void org.apache.kerby.x509.type.ObjectDigestInfo:setOtherObjectTypeId (
  org.apache.kerby.asn1.type.Asn1ObjectIdentifier otherObjectTypeID) {
  guard = tt;
  ret(obj_level(otherObjectTypeID)) = pc ⊔ level(otherObjectTypeID) ⊔ level(this) ⊔ obj_level(otherObjectTypeID) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(otherObjectTypeID) ⊔ level(this) ⊔ obj_level(this);
}