void org.apache.kerby.kerberos.kerb.type.ap.Authenticator:setCksum (org.apache.kerby.kerberos.kerb.type.base.CheckSum
                                                                    cksum) {
  guard = tt;
  ret(obj_level(cksum)) = pc ⊔ level(cksum) ⊔ level(this) ⊔ obj_level(cksum) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cksum) ⊔ level(this) ⊔ obj_level(this);
}