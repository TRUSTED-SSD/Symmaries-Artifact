static void org.apache.kerby.kerberos.kerb.request.ApRequest:unsealAuthenticator (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey encKey,
  org.apache.kerby.kerberos.kerb.type.ap.ApReq apReq) {
  guard = tt;
  ret(obj_level(apReq)) = pc ⊔ level(apReq) ⊔ level(encKey) ⊔ obj_level(apReq) ⊔ obj_level(encKey);
  ret(obj_level(encKey)) = pc ⊔ level(apReq) ⊔ level(encKey) ⊔ obj_level(apReq) ⊔ obj_level(encKey);
}