void org.apache.kerby.x509.type.Certificate:setSignatureAlgorithm (org.apache.kerby.x509.type.AlgorithmIdentifier
                                                                    signatureAlgorithm) {
  guard = tt;
  ret(obj_level(signatureAlgorithm)) = pc ⊔ level(signatureAlgorithm) ⊔ level(this) ⊔ obj_level(signatureAlgorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signatureAlgorithm) ⊔ level(this) ⊔ obj_level(this);
}