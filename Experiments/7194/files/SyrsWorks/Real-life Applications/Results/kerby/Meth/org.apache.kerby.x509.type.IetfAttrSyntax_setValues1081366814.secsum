void org.apache.kerby.x509.type.IetfAttrSyntax:setValues (org.apache.kerby.x509.type.IetfAttrSyntaxChoices
                                                            values) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(values) ⊔ obj_level(this);
  ret(obj_level(values)) = pc ⊔ level(this) ⊔ level(values) ⊔ obj_level(this) ⊔ obj_level(values);
}