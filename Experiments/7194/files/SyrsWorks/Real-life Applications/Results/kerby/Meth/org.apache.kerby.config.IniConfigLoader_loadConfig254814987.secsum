void org.apache.kerby.config.IniConfigLoader:loadConfig (org.apache.kerby.config.ConfigImpl
                                                           config,
                                                         org.apache.kerby.config.Resource
                                                           resource) {
  p0: '0 -> dummyClass ('0) -> level;
  guard = tt;
  ret(obj_level(config)) = p0 ⊔ pc ⊔ level(config) ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource);
  ret(obj_level(resource)) = p0 ⊔ pc ⊔ level(config) ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource);
  ret(obj_level(this)) = p0 ⊔ pc ⊔ level(config) ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource) ⊔ obj_level(this);
}