void org.apache.kerby.kerberos.kerb.request.KrbIdentity:setCreatedTime (
  org.apache.kerby.kerberos.kerb.type.KerberosTime createdTime) {
  guard = tt;
  ret(obj_level(createdTime)) = pc ⊔ level(createdTime) ⊔ obj_level(createdTime);
  ret(obj_level(this)) = pc ⊔ level(createdTime) ⊔ obj_level(createdTime) ⊔ obj_level(this);
}