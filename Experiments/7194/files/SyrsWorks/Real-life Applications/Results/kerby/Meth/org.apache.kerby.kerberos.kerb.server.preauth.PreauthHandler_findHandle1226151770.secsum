org.apache.kerby.kerberos.kerb.server.preauth.PreauthHandle org.apache.kerby.kerberos.kerb.server.preauth.PreauthHandler:findHandle (
  org.apache.kerby.kerberos.kerb.server.request.KdcRequest kdcRequest,
  org.apache.kerby.kerberos.kerb.type.pa.PaDataType paType) {
  guard = tt;
  ret(level()) = pc ⊔ level(kdcRequest) ⊔ level(paType) ⊔ obj_level(kdcRequest);
  ret(obj_level()) = pc ⊔ level(kdcRequest) ⊔ level(paType) ⊔ obj_level(kdcRequest);
  ret(obj_level(kdcRequest)) = pc ⊔ level(kdcRequest) ⊔ level(paType) ⊔ obj_level(kdcRequest);
  ret(obj_level(paType)) = pc ⊔ level(kdcRequest) ⊔ level(paType) ⊔ obj_level(kdcRequest) ⊔ obj_level(paType);
  ret(obj_level(this)) = pc ⊔ level(kdcRequest) ⊔ level(paType) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
}