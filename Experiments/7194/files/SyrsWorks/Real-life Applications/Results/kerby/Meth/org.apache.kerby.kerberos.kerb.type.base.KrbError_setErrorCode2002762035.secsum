void org.apache.kerby.kerberos.kerb.type.base.KrbError:setErrorCode (
  org.apache.kerby.kerberos.kerb.KrbErrorCode errorCode) {
  guard = tt;
  ret(obj_level(errorCode)) = pc ⊔ level(errorCode) ⊔ level(this) ⊔ obj_level(errorCode) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(errorCode) ⊔ level(this) ⊔ obj_level(errorCode) ⊔ obj_level(this);
}