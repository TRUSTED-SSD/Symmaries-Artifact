byte[] org.apache.kerby.kerberos.kerb.crypto.key.DesKeyMaker:str2key (
  java.lang.String string, java.lang.String salt, byte[] @param) {
  guard = tt;
  ret(level()) = pc ⊔ level(@param) ⊔ level(salt) ⊔ level(string) ⊔ level(this) ⊔ obj_level(@param) ⊔ obj_level(salt) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@param) ⊔ level(salt) ⊔ level(string) ⊔ level(this) ⊔ obj_level(@param) ⊔ obj_level(salt) ⊔ obj_level(this);
  ret(obj_level(@param)) = if obj_level(@param) = ⊤ ∨ pc ≠ ⊤ ∧ level(@param) = ⊤ ∧ obj_level(@param) = ⊥ then ⊤ else ⊥;
  ret(obj_level(salt)) = if obj_level(salt) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(salt) = ⊥ ∧ level(@param) ⊔ obj_level(@param) = ⊤ then ⊤ else ⊥;
  ret(obj_level(string)) = if obj_level(string) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(string) = ⊥ ∧ level(@param) ⊔ obj_level(@param) = ⊤ then ⊤ else ⊥;
