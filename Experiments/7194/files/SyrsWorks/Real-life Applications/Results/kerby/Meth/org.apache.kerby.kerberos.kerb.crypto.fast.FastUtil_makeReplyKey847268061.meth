static org.apache.kerby.kerberos.kerb.type.base.EncryptionKey org.apache.kerby.kerberos.kerb.crypto.fast.FastUtil:makeReplyKey(org.apache.kerby.kerberos.kerb.type.base.EncryptionKey @strengthenKey,org.apache.kerby.kerberos.kerb.type.base.EncryptionKey existingKey)
{
org.apache.kerby.kerberos.kerb.type.base.EncryptionKey strengthenKey;
strengthenKey=@strengthenKey;
strengthenKey = org.apache.kerby.kerberos.kerb.crypto.fast.FastUtil.cf2(strengthenKey,"strengthenkey",existingKey,"replykey");
 return  strengthenKey;
 } 

