void org.apache.kerby.kerberos.kerb.request.KrbIdentity:addKey (org.apache.kerby.kerberos.kerb.type.base.EncryptionKey
                                                                  encKey) {
  guard = tt;
  ret(obj_level(encKey)) = pc ⊔ level(encKey) ⊔ level(this) ⊔ obj_level(encKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(encKey) ⊔ level(this) ⊔ obj_level(encKey) ⊔ obj_level(this);
}