byte[] org.apache.kerby.kerberos.kerb.crypto.enc.Rc4HmacEnc:makeEncKey (
  byte[] @usageKey, byte[] checksum) {
  guard = tt;
  ret(level()) = pc ⊔ level(@usageKey) ⊔ level(checksum) ⊔ level(this) ⊔ obj_level(@usageKey) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@usageKey) ⊔ level(checksum) ⊔ level(this) ⊔ obj_level(@usageKey) ⊔ obj_level(this);
  ret(obj_level(@usageKey)) = pc ⊔ level(this) ⊔ obj_level(@usageKey) ⊔ obj_level(this);
  ret(obj_level(checksum)) = pc ⊔ level(this) ⊔ obj_level(checksum) ⊔ obj_level(this);
