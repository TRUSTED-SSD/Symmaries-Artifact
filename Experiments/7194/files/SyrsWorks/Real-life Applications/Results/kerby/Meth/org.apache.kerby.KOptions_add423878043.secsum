void org.apache.kerby.KOptions:add (org.apache.kerby.KOption option,
                                    java.lang.Object optionValue) {
  guard = tt;
  ret(obj_level(option)) = pc ⊔ level(option) ⊔ level(optionValue) ⊔ obj_level(option);
  ret(obj_level(optionValue)) = pc ⊔ level(option) ⊔ level(optionValue) ⊔ obj_level(option);
  ret(obj_level(this)) = pc ⊔ level(option) ⊔ level(optionValue) ⊔ obj_level(option);
}