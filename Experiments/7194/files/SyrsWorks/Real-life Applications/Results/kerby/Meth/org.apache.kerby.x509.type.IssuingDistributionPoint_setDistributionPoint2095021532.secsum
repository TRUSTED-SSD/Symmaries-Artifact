void org.apache.kerby.x509.type.IssuingDistributionPoint:setDistributionPoint (
  org.apache.kerby.x509.type.DistributionPointName distributionPoint) {
  guard = tt;
  ret(obj_level(distributionPoint)) = pc ⊔ level(distributionPoint) ⊔ level(this) ⊔ obj_level(distributionPoint) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(distributionPoint) ⊔ level(this) ⊔ obj_level(this);
}