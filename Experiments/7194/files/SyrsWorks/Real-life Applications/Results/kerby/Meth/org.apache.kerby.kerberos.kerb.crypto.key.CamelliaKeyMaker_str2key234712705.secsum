byte[] org.apache.kerby.kerberos.kerb.crypto.key.CamelliaKeyMaker:str2key (
  java.lang.String string, java.lang.String salt, byte[] @param) {
  guard = tt;
  ret(level()) = pc ⊔ level(@param) ⊔ level(salt) ⊔ level(this) ⊔ obj_level(@param) ⊔ obj_level(salt) ⊔ obj_level(this);
