void org.apache.kerby.kerberos.kerb.transport.KdcUdpTransport:onRecvMessage (
  java.nio.ByteBuffer message) {
  guard = tt;
  ret(obj_level(message)) = pc ⊔ level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
}