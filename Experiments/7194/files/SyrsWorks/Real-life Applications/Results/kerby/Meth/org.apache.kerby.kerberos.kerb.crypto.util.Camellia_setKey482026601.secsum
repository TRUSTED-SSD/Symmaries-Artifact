void org.apache.kerby.kerberos.kerb.crypto.util.Camellia:setKey (boolean
                                                                   forEncryption,
                                                                 byte[] key) {
  guard = tt;
  ret(obj_level(key)) = obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(forEncryption) ⊔ level(key) ⊔ obj_level(key) ⊔ obj_level(this);
}