void org.apache.kerby.kerberos.kerb.auth.AuthContext:setFlags (org.apache.kerby.asn1.type.Asn1Flags
                                                                 flags) {
  guard = tt;
  ret(obj_level(flags)) = pc ⊔ level(flags) ⊔ obj_level(flags);
  ret(obj_level(this)) = pc ⊔ level(flags) ⊔ obj_level(flags) ⊔ obj_level(this);
}