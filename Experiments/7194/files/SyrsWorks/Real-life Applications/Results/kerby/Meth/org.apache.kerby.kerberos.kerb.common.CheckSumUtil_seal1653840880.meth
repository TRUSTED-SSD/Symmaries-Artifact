static org.apache.kerby.kerberos.kerb.type.base.CheckSum org.apache.kerby.kerberos.kerb.common.CheckSumUtil:seal(org.apache.kerby.asn1.type.Asn1Encodeable asn1Object,org.apache.kerby.kerberos.kerb.type.base.CheckSumType checkSumType)
{
