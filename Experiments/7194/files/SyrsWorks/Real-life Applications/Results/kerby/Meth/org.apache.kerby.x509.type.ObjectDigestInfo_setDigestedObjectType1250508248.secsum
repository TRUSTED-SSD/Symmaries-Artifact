void org.apache.kerby.x509.type.ObjectDigestInfo:setDigestedObjectType (
  org.apache.kerby.x509.type.DigestedObjectType digestedObjectType) {
  guard = tt;
  ret(obj_level(digestedObjectType)) = pc ⊔ level(digestedObjectType) ⊔ level(this) ⊔ obj_level(digestedObjectType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(digestedObjectType) ⊔ level(this) ⊔ obj_level(this);
}