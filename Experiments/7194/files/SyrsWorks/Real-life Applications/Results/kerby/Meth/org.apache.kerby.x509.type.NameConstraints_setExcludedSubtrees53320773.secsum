void org.apache.kerby.x509.type.NameConstraints:setExcludedSubtrees (
  org.apache.kerby.x509.type.GeneralSubtrees excludedSubtrees) {
  guard = tt;
  ret(obj_level(excludedSubtrees)) = pc ⊔ level(excludedSubtrees) ⊔ level(this) ⊔ obj_level(excludedSubtrees) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(excludedSubtrees) ⊔ level(this) ⊔ obj_level(this);
}