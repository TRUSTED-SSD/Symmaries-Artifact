void org.apache.kerby.kerberos.kerb.server.preauth.PreauthHandler:providePaData (
  org.apache.kerby.kerberos.kerb.server.request.KdcRequest kdcRequest,
  org.apache.kerby.kerberos.kerb.type.pa.PaData paData) {
  guard = tt;
  ret(obj_level(kdcRequest)) = pc ⊔ level(kdcRequest) ⊔ obj_level(kdcRequest);
  ret(obj_level(paData)) = pc ⊔ level(kdcRequest) ⊔ obj_level(kdcRequest) ⊔ obj_level(paData);
  ret(obj_level(this)) = pc ⊔ level(kdcRequest) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
}