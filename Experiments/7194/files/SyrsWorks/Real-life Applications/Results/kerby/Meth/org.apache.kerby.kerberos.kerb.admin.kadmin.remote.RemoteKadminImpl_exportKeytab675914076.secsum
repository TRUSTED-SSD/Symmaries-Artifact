void org.apache.kerby.kerberos.kerb.admin.kadmin.remote.RemoteKadminImpl:exportKeytab (
  java.io.File keytabFile, java.lang.String principal) {
  guard = tt;
  ret(obj_level(keytabFile)) = pc ⊔ level(principal) ⊔ obj_level(keytabFile) ⊔ obj_level(principal);
  ret(obj_level(principal)) = pc ⊔ level(principal) ⊔ obj_level(principal);
  ret(obj_level(this)) = pc ⊔ level(principal) ⊔ obj_level(principal) ⊔ obj_level(this);
}