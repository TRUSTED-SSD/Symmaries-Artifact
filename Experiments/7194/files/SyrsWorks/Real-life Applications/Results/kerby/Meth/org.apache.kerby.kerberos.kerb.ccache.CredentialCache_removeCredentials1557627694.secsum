void org.apache.kerby.kerberos.kerb.ccache.CredentialCache:removeCredentials (
  java.util.List credentials) {
  guard = tt;
  ret(obj_level(credentials)) = pc ⊔ level(credentials) ⊔ level(this) ⊔ obj_level(credentials) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(credentials) ⊔ level(this) ⊔ obj_level(credentials) ⊔ obj_level(this);
}