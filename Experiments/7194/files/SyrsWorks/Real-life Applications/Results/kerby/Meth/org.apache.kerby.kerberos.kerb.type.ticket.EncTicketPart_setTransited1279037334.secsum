void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setTransited (
  org.apache.kerby.kerberos.kerb.type.base.TransitedEncoding transited) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(transited) ⊔ obj_level(this);
  ret(obj_level(transited)) = pc ⊔ level(this) ⊔ level(transited) ⊔ obj_level(this) ⊔ obj_level(transited);
}