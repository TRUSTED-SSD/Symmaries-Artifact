static void org.apache.kerby.kerberos.kerb.crypto.util.Cmac:encryptBlock (
  org.apache.kerby.kerberos.kerb.crypto.enc.EncryptProvider encProvider,
  byte[] key, byte[] @cipherState, byte[] block) {
  guard = tt;
  ret(obj_level(@cipherState)) = if obj_level(@cipherState) = ⊤ ∨ pc ≠ ⊤ ∧ (if obj_level(encProvider) = ⊥ then obj_level(@cipherState) = ⊥ ∧ level(@cipherState) ⊔ level(encProvider) = ⊤ else obj_level(@cipherState) = ⊥ ∧ obj_level(encProvider) = ⊤) then ⊤ else ⊥;
  ret(obj_level(block)) = if obj_level(block) = ⊤ ∨ pc ≠ ⊤ ∧ (if obj_level(encProvider) = ⊥ then obj_level(block) = ⊥ ∧ level(@cipherState) ⊔ level(encProvider) = ⊤ else obj_level(block) = ⊥ ∧ obj_level(encProvider) = ⊤) then ⊤ else ⊥;
  ret(obj_level(encProvider)) = obj_level(encProvider);
  ret(obj_level(key)) = if obj_level(key) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(key) = ⊥ ∧ level(@cipherState) ⊔ level(encProvider) ⊔ obj_level(encProvider) = ⊤ then ⊤ else ⊥;
}