void org.apache.kerby.cms.type.RecipientEncryptedKey:setRid (org.apache.kerby.cms.type.KeyAgreeRecipientIdentifier
                                                               rid) {
  guard = tt;
  ret(obj_level(rid)) = pc ⊔ level(rid) ⊔ level(this) ⊔ obj_level(rid) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(rid) ⊔ level(this) ⊔ obj_level(this);
}