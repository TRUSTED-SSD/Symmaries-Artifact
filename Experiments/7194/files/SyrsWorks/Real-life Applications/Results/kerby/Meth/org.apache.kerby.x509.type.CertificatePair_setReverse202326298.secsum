void org.apache.kerby.x509.type.CertificatePair:setReverse (org.apache.kerby.x509.type.Certificate
                                                              reverse) {
  guard = tt;
  ret(obj_level(reverse)) = pc ⊔ level(reverse) ⊔ level(this) ⊔ obj_level(reverse) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(reverse) ⊔ level(this) ⊔ obj_level(this);
}