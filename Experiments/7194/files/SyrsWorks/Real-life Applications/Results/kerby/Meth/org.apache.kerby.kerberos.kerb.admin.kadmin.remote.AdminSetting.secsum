org.apache.kerby.kerberos.kerb.admin.kadmin.remote.AdminSetting (org.apache.kerby.KOptions
                                                                   commonOptions,
                                                                 org.apache.kerby.kerberos.kerb.admin.kadmin.remote.AdminConfig
                                                                   config) {
  guard = tt;
  ret(obj_level(commonOptions)) = pc ⊔ level(commonOptions) ⊔ level(config) ⊔ level(this) ⊔ obj_level(commonOptions) ⊔ obj_level(config) ⊔ obj_level(this);
  ret(obj_level(config)) = pc ⊔ level(commonOptions) ⊔ level(config) ⊔ level(this) ⊔ obj_level(commonOptions) ⊔ obj_level(config) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(commonOptions) ⊔ level(config) ⊔ level(this) ⊔ obj_level(commonOptions) ⊔ obj_level(config) ⊔ obj_level(this);
}