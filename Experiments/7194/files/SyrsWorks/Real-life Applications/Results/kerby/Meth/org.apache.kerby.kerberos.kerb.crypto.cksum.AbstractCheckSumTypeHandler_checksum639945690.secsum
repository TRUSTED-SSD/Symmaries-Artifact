byte[] org.apache.kerby.kerberos.kerb.crypto.cksum.AbstractCheckSumTypeHandler:checksum (
  byte[] @data) {
  guard = tt;
  ret(level()) = pc ⊔ level(@data) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@data) ⊔ level(this) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(@data)) = obj_level(@data);
  ret(obj_level(this)) = obj_level(this);
}