static org.apache.kerby.kerberos.kerb.type.base.EncryptionType org.apache.kerby.kerberos.kerb.crypto.EncryptionHandler:getEncryptionType (
  java.lang.String eType) {
  guard = tt;
  ret(level()) = pc ⊔ level(eType) ⊔ obj_level(eType);
  ret(obj_level()) = pc ⊔ level(eType) ⊔ obj_level(eType);
  ret(obj_level(eType)) = if obj_level(eType) = ⊤ ∨ pc ≠ ⊤ ∧ level(eType) = ⊤ ∧ obj_level(eType) = ⊥ then ⊤ else ⊥;
}