static boolean org.apache.kerby.kerberos.kerb.common.KrbUtil:pricipalCompareIgnoreRealm (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName princ1,
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName princ2) {
  guard = tt;
  ret(level()) = pc ⊔ level(princ1) ⊔ level(princ2) ⊔ obj_level(princ1);
  ret(obj_level(princ1)) = pc ⊔ level(princ1) ⊔ level(princ2) ⊔ obj_level(princ1);
  ret(obj_level(princ2)) = pc ⊔ level(princ1) ⊔ level(princ2) ⊔ obj_level(princ1);
}