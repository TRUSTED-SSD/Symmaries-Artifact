org.apache.kerby.asn1.Asn1Dumper org.apache.kerby.asn1.Asn1Dumper:appendType (
  java.lang.Class cls) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ obj_level(cls) ⊔ obj_level(this);
  ret(obj_level(cls)) = pc ⊔ level(this) ⊔ obj_level(cls) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(cls) ⊔ obj_level(this);
}