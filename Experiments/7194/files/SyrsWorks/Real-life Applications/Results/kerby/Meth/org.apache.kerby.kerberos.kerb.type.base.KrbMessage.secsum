org.apache.kerby.kerberos.kerb.type.base.KrbMessage (org.apache.kerby.kerberos.kerb.type.base.KrbMessageType
                                                       msgType,
                                                     org.apache.kerby.asn1.Asn1FieldInfo[]
                                                       fieldInfos) {
  guard = tt;
  ret(obj_level(fieldInfos)) = pc ⊔ level(fieldInfos) ⊔ level(msgType) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(msgType) ⊔ obj_level(this);
  ret(obj_level(msgType)) = pc ⊔ level(fieldInfos) ⊔ level(msgType) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(msgType) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fieldInfos) ⊔ level(msgType) ⊔ level(this) ⊔ obj_level(fieldInfos) ⊔ obj_level(msgType) ⊔ obj_level(this);
}