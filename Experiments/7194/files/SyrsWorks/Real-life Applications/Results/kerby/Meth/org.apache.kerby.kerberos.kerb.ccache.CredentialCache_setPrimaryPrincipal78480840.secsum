void org.apache.kerby.kerberos.kerb.ccache.CredentialCache:setPrimaryPrincipal (
  org.apache.kerby.kerberos.kerb.type.base.PrincipalName principal) {
  guard = tt;
  ret(obj_level(principal)) = pc ⊔ level(principal) ⊔ obj_level(principal);
  ret(obj_level(this)) = pc ⊔ level(principal) ⊔ obj_level(principal) ⊔ obj_level(this);
}