void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setFlags (
  org.apache.kerby.kerberos.kerb.type.ticket.TicketFlags flags) {
  guard = tt;
  ret(obj_level(flags)) = pc ⊔ level(flags) ⊔ level(this) ⊔ obj_level(flags) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(flags) ⊔ level(this) ⊔ obj_level(this);
}