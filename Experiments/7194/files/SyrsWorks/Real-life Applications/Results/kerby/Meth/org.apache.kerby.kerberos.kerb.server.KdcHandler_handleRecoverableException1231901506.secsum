org.apache.kerby.kerberos.kerb.type.base.KrbMessage org.apache.kerby.kerberos.kerb.server.KdcHandler:handleRecoverableException (
  org.apache.kerby.kerberos.kerb.server.KdcRecoverableException e,
  org.apache.kerby.kerberos.kerb.server.request.KdcRequest kdcRequest) {
  guard = pc ⊔ obj_level(e) = ⊥;
  ret(level()) = level(e);
  ret(obj_level()) = level(e) ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
  ret(obj_level(e)) = level(e) ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
  ret(obj_level(kdcRequest)) = level(e) ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
  ret(obj_level(this)) = level(e) ⊔ level(kdcRequest) ⊔ level(this) ⊔ obj_level(kdcRequest) ⊔ obj_level(this);
}