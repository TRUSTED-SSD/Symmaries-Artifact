void org.apache.kerby.x509.type.Extension:setExtnId (org.apache.kerby.asn1.type.Asn1ObjectIdentifier
                                                       extnId) {
  guard = tt;
  ret(obj_level(extnId)) = pc ⊔ level(extnId) ⊔ level(this) ⊔ obj_level(extnId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(extnId) ⊔ level(this) ⊔ obj_level(this);
}