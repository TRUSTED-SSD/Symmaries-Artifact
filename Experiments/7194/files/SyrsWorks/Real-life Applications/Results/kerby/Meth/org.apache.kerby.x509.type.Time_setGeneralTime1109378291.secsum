void org.apache.kerby.x509.type.Time:setGeneralTime (org.apache.kerby.asn1.type.Asn1GeneralizedTime
                                                       generalTime) {
  guard = tt;
  ret(obj_level(generalTime)) = pc ⊔ level(generalTime) ⊔ level(this) ⊔ obj_level(generalTime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(generalTime) ⊔ level(this) ⊔ obj_level(this);
}