boolean org.apache.kerby.config.XmlConfigLoader:validateConfig (org.w3c.dom.Element
                                                                  root) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(root);
  ret(obj_level(root)) = obj_level(root);
  ret(obj_level(this)) = pc ⊔ obj_level(root) ⊔ obj_level(this);
}