void org.apache.kerby.cms.type.AttributeCertificateInfoV1:setAttributes (
  org.apache.kerby.x509.type.Attributes attributes) {
  guard = tt;
  ret(obj_level(attributes)) = pc ⊔ level(attributes) ⊔ level(this) ⊔ obj_level(attributes) ⊔ obj_level(this);
