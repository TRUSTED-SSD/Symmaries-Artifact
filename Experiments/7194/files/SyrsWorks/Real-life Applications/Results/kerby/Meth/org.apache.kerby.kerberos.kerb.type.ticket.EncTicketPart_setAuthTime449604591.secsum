void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setAuthTime (
  org.apache.kerby.kerberos.kerb.type.KerberosTime authTime) {
  guard = tt;
  ret(obj_level(authTime)) = pc ⊔ level(authTime) ⊔ level(this) ⊔ obj_level(authTime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(authTime) ⊔ level(this) ⊔ obj_level(this);
}