void org.apache.kerby.config.MapConfigLoader:loadConfig (org.apache.kerby.config.ConfigImpl
                                                           config,
                                                         org.apache.kerby.config.Resource
                                                           resource) {
  guard = tt;
  ret(obj_level(config)) = pc ⊔ level(config) ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource) ⊔ obj_level(this);
  ret(obj_level(resource)) = pc ⊔ level(config) ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(config) ⊔ level(resource) ⊔ obj_level(config) ⊔ obj_level(resource) ⊔ obj_level(this);
}