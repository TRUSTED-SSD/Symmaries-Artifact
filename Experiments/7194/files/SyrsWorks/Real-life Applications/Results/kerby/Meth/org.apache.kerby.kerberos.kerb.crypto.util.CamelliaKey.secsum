org.apache.kerby.kerberos.kerb.crypto.util.CamelliaKey (byte[] key,
                                                        boolean isEncrypt) {
  guard = tt;
  ret(obj_level(key)) = obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(isEncrypt) ⊔ level(key) ⊔ level(this) ⊔ obj_level(key) ⊔ obj_level(this);
}