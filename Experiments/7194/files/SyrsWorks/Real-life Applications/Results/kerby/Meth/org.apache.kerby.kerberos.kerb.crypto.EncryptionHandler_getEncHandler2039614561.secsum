static org.apache.kerby.kerberos.kerb.crypto.EncTypeHandler org.apache.kerby.kerberos.kerb.crypto.EncryptionHandler:getEncHandler (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionType eType,
  boolean check) {
  guard = tt;
  ret(level()) = pc ⊔ level(check) ⊔ level(eType) ⊔ obj_level(eType);
  ret(obj_level()) = pc ⊔ level(check) ⊔ level(eType) ⊔ obj_level(eType);
  ret(obj_level(eType)) = pc ⊔ level(check) ⊔ level(eType) ⊔ obj_level(eType);
}