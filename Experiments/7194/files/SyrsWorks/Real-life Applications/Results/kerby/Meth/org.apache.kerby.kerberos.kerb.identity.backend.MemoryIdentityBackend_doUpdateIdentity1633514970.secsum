org.apache.kerby.kerberos.kerb.request.KrbIdentity org.apache.kerby.kerberos.kerb.identity.backend.MemoryIdentityBackend:doUpdateIdentity (
  org.apache.kerby.kerberos.kerb.request.KrbIdentity @identity) {
  guard = tt;
  ret(level()) = pc ⊔ level(@identity) ⊔ level(this) ⊔ obj_level(@identity) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@identity) ⊔ level(this) ⊔ obj_level(@identity) ⊔ obj_level(this);
  ret(obj_level(@identity)) = pc ⊔ level(@identity) ⊔ level(this) ⊔ obj_level(@identity) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@identity) ⊔ level(this) ⊔ obj_level(@identity) ⊔ obj_level(this);
}