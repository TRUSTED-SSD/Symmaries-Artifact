byte[] org.apache.kerby.kerberos.kerb.crypto.cksum.AbstractCheckSumTypeHandler:checksumWithKey (
  byte[] @data, byte[] key, int usage) {
  guard = tt;
  ret(level()) = pc ⊔ level(@data) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@data) ⊔ level(key) ⊔ level(this) ⊔ level(usage) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(@data)) = obj_level(@data);
  ret(obj_level(key)) = obj_level(key);
  ret(obj_level(this)) = obj_level(this);
}