void org.apache.kerby.asn1.type.Asn1TaggingCollection:setFieldAsOctetBytes (
  org.apache.kerby.asn1.EnumType index, byte[] value) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(value);
}