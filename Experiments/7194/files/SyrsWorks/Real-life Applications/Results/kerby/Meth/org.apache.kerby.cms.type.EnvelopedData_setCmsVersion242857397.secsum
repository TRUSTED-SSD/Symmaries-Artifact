void org.apache.kerby.cms.type.EnvelopedData:setCmsVersion (org.apache.kerby.cms.type.CmsVersion
                                                              cmsVersion) {
  guard = tt;
  ret(obj_level(cmsVersion)) = pc ⊔ level(cmsVersion) ⊔ level(this) ⊔ obj_level(cmsVersion) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cmsVersion) ⊔ level(this) ⊔ obj_level(this);
}