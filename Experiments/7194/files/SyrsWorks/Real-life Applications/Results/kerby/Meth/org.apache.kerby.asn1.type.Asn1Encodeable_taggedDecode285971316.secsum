void org.apache.kerby.asn1.type.Asn1Encodeable:taggedDecode (org.apache.kerby.asn1.parse.Asn1ParseResult
                                                               parseResult,
                                                             org.apache.kerby.asn1.TaggingOption
                                                               taggingOption) {
  guard = tt;
  ret(obj_level(parseResult)) = pc ⊔ level(parseResult) ⊔ level(taggingOption) ⊔ level(this) ⊔ obj_level(parseResult) ⊔ obj_level(taggingOption) ⊔ obj_level(this);
  ret(obj_level(taggingOption)) = pc ⊔ level(parseResult) ⊔ level(taggingOption) ⊔ level(this) ⊔ obj_level(parseResult) ⊔ obj_level(taggingOption) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(parseResult) ⊔ level(taggingOption) ⊔ level(this) ⊔ obj_level(parseResult) ⊔ obj_level(taggingOption) ⊔ obj_level(this);
}