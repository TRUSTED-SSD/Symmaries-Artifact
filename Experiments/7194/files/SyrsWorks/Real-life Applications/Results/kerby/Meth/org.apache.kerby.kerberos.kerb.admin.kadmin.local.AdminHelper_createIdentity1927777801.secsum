static org.apache.kerby.kerberos.kerb.request.KrbIdentity org.apache.kerby.kerberos.kerb.admin.kadmin.local.AdminHelper:createIdentity (
  java.lang.String principal, org.apache.kerby.KOptions kOptions) {
  guard = tt;
