  ret(obj_level()) = pc ⊔ level(kOptions) ⊔ level(principal) ⊔ obj_level(kOptions) ⊔ obj_level(principal);
  ret(obj_level(kOptions)) = pc ⊔ level(kOptions) ⊔ level(principal) ⊔ obj_level(kOptions) ⊔ obj_level(principal);
