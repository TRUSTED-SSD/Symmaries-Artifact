void org.apache.kerby.cms.type.OriginatorIdentifierOrKey:setSubjectKeyIdentifier (
  org.apache.kerby.x509.type.SubjectKeyIdentifier subjectKeyIdentifier) {
  guard = tt;
  ret(obj_level(subjectKeyIdentifier)) = pc ⊔ level(subjectKeyIdentifier) ⊔ level(this) ⊔ obj_level(subjectKeyIdentifier) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(subjectKeyIdentifier) ⊔ level(this) ⊔ obj_level(this);
}