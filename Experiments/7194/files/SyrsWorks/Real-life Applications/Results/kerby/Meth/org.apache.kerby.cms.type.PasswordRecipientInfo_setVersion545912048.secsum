void org.apache.kerby.cms.type.PasswordRecipientInfo:setVersion (org.apache.kerby.cms.type.CmsVersion
                                                                   version) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(version) ⊔ obj_level(this);
