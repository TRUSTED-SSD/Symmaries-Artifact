int org.apache.kerby.asn1.type.Asn1Encodeable:taggedEncodingLength (org.apache.kerby.asn1.TaggingOption
                                                                    taggingOption) {
  guard = tt;
  ret(level()) = pc ⊔ level(taggingOption) ⊔ level(this) ⊔ obj_level(taggingOption) ⊔ obj_level(this);
  ret(obj_level(taggingOption)) = pc ⊔ level(taggingOption) ⊔ level(this) ⊔ obj_level(taggingOption) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(taggingOption) ⊔ level(this) ⊔ obj_level(taggingOption) ⊔ obj_level(this);
}