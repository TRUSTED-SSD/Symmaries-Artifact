void org.apache.kerby.cms.type.SignedData:setCrls (org.apache.kerby.cms.type.RevocationInfoChoices
                                                     crls) {
  guard = tt;
  ret(obj_level(crls)) = pc ⊔ level(crls) ⊔ level(this) ⊔ obj_level(crls) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(crls) ⊔ level(this) ⊔ obj_level(this);
}