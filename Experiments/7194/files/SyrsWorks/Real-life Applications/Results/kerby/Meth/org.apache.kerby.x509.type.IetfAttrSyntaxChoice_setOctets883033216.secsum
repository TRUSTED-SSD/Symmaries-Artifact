void org.apache.kerby.x509.type.IetfAttrSyntaxChoice:setOctets (org.apache.kerby.asn1.type.Asn1OctetString
                                                                  octets) {
  guard = tt;
  ret(obj_level(octets)) = pc ⊔ level(octets) ⊔ level(this) ⊔ obj_level(octets) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(octets) ⊔ level(this) ⊔ obj_level(this);
}