void org.apache.kerby.cms.type.OtherCertificateFormat:setOtherCert (org.apache.kerby.asn1.type.Asn1Type
                                                                    otherCert) {
  guard = tt;
  ret(obj_level(otherCert)) = pc ⊔ level(otherCert) ⊔ level(this) ⊔ obj_level(otherCert);
  ret(obj_level(this)) = pc ⊔ level(otherCert) ⊔ level(this) ⊔ obj_level(this);
}