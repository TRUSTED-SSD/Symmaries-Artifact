void org.apache.kerby.x509.type.Target:setTargetCert (org.apache.kerby.x509.type.TargetCert
                                                        targetCert) {
  guard = tt;
  ret(obj_level(targetCert)) = pc ⊔ level(targetCert) ⊔ level(this) ⊔ obj_level(targetCert) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(targetCert) ⊔ level(this) ⊔ obj_level(this);
}