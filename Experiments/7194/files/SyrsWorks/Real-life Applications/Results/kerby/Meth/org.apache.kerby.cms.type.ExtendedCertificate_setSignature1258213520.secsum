void org.apache.kerby.cms.type.ExtendedCertificate:setSignature (org.apache.kerby.cms.type.Signature
                                                                   signature) {
  guard = tt;
  ret(obj_level(signature)) = pc ⊔ level(signature) ⊔ level(this) ⊔ obj_level(signature) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(signature) ⊔ level(this) ⊔ obj_level(this);
}