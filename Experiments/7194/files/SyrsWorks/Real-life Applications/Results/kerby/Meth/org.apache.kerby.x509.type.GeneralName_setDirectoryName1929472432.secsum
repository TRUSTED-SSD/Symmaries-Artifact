void org.apache.kerby.x509.type.GeneralName:setDirectoryName (org.apache.kerby.x500.type.Name
                                                                directoryName) {
  guard = tt;
  ret(obj_level(directoryName)) = pc ⊔ level(directoryName) ⊔ level(this) ⊔ obj_level(directoryName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(directoryName) ⊔ level(this) ⊔ obj_level(this);
}