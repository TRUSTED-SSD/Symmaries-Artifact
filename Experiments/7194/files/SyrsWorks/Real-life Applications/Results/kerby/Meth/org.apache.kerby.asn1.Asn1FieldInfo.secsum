org.apache.kerby.asn1.Asn1FieldInfo (org.apache.kerby.asn1.EnumType index,
                                     java.lang.Class type) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(this) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(type) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(index) ⊔ level(this) ⊔ level(type) ⊔ obj_level(index) ⊔ obj_level(this) ⊔ obj_level(type);
}