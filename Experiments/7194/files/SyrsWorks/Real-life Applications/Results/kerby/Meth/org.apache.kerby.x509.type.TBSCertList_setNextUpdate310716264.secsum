void org.apache.kerby.x509.type.TBSCertList:setNextUpdate (org.apache.kerby.x509.type.Time
                                                             nextUpdate) {
  guard = tt;
  ret(obj_level(nextUpdate)) = pc ⊔ level(nextUpdate) ⊔ level(this) ⊔ obj_level(nextUpdate) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(nextUpdate) ⊔ level(this) ⊔ obj_level(this);
}