org.apache.kerby.kerberos.kerb.request.KrbIdentity org.apache.kerby.kerberos.kerb.identity.CacheableIdentityService:getIdentity (
  java.lang.String principalName) {
  guard = pc ⊔ level(principalName) ⊔ level(this) ⊔ obj_level(principalName) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(principalName)) = ⊥;
  ret(obj_level(this)) = ⊥;
}