void org.apache.kerby.config.Configured:setConfig (org.apache.kerby.config.Config
                                                     config) {
  guard = tt;
  ret(obj_level(config)) = pc ⊔ level(config) ⊔ obj_level(config);
  ret(obj_level(this)) = pc ⊔ level(config) ⊔ obj_level(config) ⊔ obj_level(this);
}