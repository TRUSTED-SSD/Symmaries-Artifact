void org.apache.kerby.kerberos.kerb.type.base.CheckSum:setChecksum (byte[]
                                                                    checksum) {
  guard = tt;
  ret(obj_level(checksum)) = pc ⊔ level(this) ⊔ obj_level(checksum) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(checksum) ⊔ obj_level(this);
}