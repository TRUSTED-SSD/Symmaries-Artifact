static void org.apache.kerby.kerberos.kerb.crypto.util.Cmac:makeSubkey (
  org.apache.kerby.kerberos.kerb.crypto.enc.EncryptProvider encProvider,
  byte[] @key, byte[] @k1, byte[] k2) {
  guard = tt;
  ret(obj_level(@k1)) = pc ⊔ level(@k1) ⊔ level(encProvider) ⊔ level(k2) ⊔ obj_level(@k1) ⊔ obj_level(encProvider);
  ret(obj_level(@key)) = pc ⊔ level(@k1) ⊔ level(encProvider) ⊔ level(k2) ⊔ obj_level(@k1) ⊔ obj_level(encProvider);
  ret(obj_level(encProvider)) = obj_level(encProvider);
  ret(obj_level(k2)) = pc ⊔ level(@k1) ⊔ level(encProvider) ⊔ level(k2) ⊔ obj_level(@k1) ⊔ obj_level(encProvider);
}