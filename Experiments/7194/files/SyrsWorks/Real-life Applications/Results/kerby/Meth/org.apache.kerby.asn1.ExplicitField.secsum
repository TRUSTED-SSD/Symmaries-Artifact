org.apache.kerby.asn1.ExplicitField (org.apache.kerby.asn1.EnumType index,
                                     java.lang.Class type) {
  guard = tt;
  ret(obj_level(index)) = pc ⊔ level(index) ⊔ obj_level(index);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ obj_level(index) ⊔ obj_level(this);
  ret(obj_level(type)) = pc ⊔ level(index) ⊔ obj_level(index) ⊔ obj_level(type);
}