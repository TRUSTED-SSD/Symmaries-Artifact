void org.apache.kerby.kerberos.kerb.type.EncKrbPrivPart:setTimeStamp (
  org.apache.kerby.kerberos.kerb.type.KerberosTime timeStamp) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(timeStamp) ⊔ obj_level(this);
  ret(obj_level(timeStamp)) = pc ⊔ level(this) ⊔ level(timeStamp) ⊔ obj_level(this) ⊔ obj_level(timeStamp);
}