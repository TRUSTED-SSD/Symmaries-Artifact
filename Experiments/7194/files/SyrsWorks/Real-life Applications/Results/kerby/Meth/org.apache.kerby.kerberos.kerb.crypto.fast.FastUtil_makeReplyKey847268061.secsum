static org.apache.kerby.kerberos.kerb.type.base.EncryptionKey org.apache.kerby.kerberos.kerb.crypto.fast.FastUtil:makeReplyKey (
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey @strengthenKey,
  org.apache.kerby.kerberos.kerb.type.base.EncryptionKey existingKey) {
  guard = tt;
  ret(level()) = pc ⊔ level(@strengthenKey) ⊔ level(existingKey) ⊔ obj_level(@strengthenKey);
  ret(obj_level()) = pc ⊔ level(@strengthenKey) ⊔ level(existingKey) ⊔ obj_level(@strengthenKey);
  ret(obj_level(@strengthenKey)) = obj_level(@strengthenKey);
  ret(obj_level(existingKey)) = obj_level(existingKey);
}