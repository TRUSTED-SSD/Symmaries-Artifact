void org.apache.kerby.x509.type.UserNotice:setNoticeRef (org.apache.kerby.x509.type.NoticeReference
                                                           noticeRef) {
  guard = tt;
  ret(obj_level(noticeRef)) = pc ⊔ level(noticeRef) ⊔ level(this) ⊔ obj_level(noticeRef) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(noticeRef) ⊔ level(this) ⊔ obj_level(this);
}