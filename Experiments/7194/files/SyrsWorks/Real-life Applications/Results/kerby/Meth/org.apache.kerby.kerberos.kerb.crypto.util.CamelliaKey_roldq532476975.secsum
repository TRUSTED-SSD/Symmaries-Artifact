static void org.apache.kerby.kerberos.kerb.crypto.util.CamelliaKey:roldq (
  int rot, int[] ki, int ioff, int[] ko, int ooff) {
  guard = tt;
  ret(obj_level(ki)) = pc ⊔ level(ioff) ⊔ level(ki) ⊔ level(ko) ⊔ level(ooff) ⊔ level(rot) ⊔ obj_level(ki);
  ret(obj_level(ko)) = pc ⊔ level(ioff) ⊔ level(ki) ⊔ level(ko) ⊔ level(ooff) ⊔ level(rot) ⊔ obj_level(ki);
}