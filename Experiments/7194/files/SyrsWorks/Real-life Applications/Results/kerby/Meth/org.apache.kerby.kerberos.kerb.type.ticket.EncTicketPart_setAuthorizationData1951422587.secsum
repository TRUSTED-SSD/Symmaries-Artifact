void org.apache.kerby.kerberos.kerb.type.ticket.EncTicketPart:setAuthorizationData (
  org.apache.kerby.kerberos.kerb.type.ad.AuthorizationData authorizationData) {
  guard = tt;
  ret(obj_level(authorizationData)) = pc ⊔ level(authorizationData) ⊔ level(this) ⊔ obj_level(authorizationData) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(authorizationData) ⊔ level(this) ⊔ obj_level(this);
}