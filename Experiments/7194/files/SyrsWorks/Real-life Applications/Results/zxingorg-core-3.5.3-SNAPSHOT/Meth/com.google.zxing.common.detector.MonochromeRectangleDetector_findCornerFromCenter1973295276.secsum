com.google.zxing.ResultPoint com.google.zxing.common.detector.MonochromeRectangleDetector:findCornerFromCenter (
  int centerX, int deltaX, int left, int right, int centerY, int deltaY,
  int top, int bottom, int maxWhiteRun) {
  guard = tt;
  ret(level()) = pc ⊔ level(bottom) ⊔ level(centerX) ⊔ level(centerY) ⊔ level(deltaX) ⊔ level(deltaY) ⊔ level(left) ⊔ level(maxWhiteRun) ⊔ level(right) ⊔ level(this) ⊔ level(top) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(bottom) ⊔ level(centerX) ⊔ level(centerY) ⊔ level(deltaX) ⊔ level(deltaY) ⊔ level(left) ⊔ level(maxWhiteRun) ⊔ level(right) ⊔ level(this) ⊔ level(top) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bottom) ⊔ level(centerX) ⊔ level(centerY) ⊔ level(deltaX) ⊔ level(deltaY) ⊔ level(left) ⊔ level(maxWhiteRun) ⊔ level(right) ⊔ level(this) ⊔ level(top) ⊔ obj_level(this);
}