static com.google.zxing.ResultPoint com.google.zxing.datamatrix.detector.Detector:shiftPoint (
  com.google.zxing.ResultPoint point, com.google.zxing.ResultPoint @to,
  int div) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@to) ⊔ level(div) ⊔ level(point) ⊔ obj_level(@to);
  ret(obj_level(@to)) = pc ⊔ level(@to) ⊔ level(div) ⊔ level(point) ⊔ obj_level(@to);
  ret(obj_level(point)) = pc ⊔ level(@to) ⊔ level(div) ⊔ level(point) ⊔ obj_level(@to);
}