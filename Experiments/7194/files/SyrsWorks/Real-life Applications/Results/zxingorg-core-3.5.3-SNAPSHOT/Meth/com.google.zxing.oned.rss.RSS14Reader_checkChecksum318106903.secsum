static boolean com.google.zxing.oned.rss.RSS14Reader:checkChecksum (com.google.zxing.oned.rss.Pair
                                                                    leftPair,
                                                                    com.google.zxing.oned.rss.Pair
                                                                    rightPair) {
  guard = tt;
  ret(level()) = pc ⊔ level(leftPair) ⊔ level(rightPair) ⊔ obj_level(leftPair);
  ret(obj_level(leftPair)) = obj_level(leftPair);
  ret(obj_level(rightPair)) = obj_level(leftPair);
}