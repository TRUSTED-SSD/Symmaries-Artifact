static char com.google.zxing.datamatrix.encoder.HighLevelEncoder:randomize253State(int codewordPosition)
{
char $stack6;
  codewordPosition=(149 * codewordPosition);
 codewordPosition=(codewordPosition%253);
 codewordPosition=(codewordPosition+1);
 codewordPosition=(129+codewordPosition);
 if (codewordPosition>254) goto label0;
 $stack6=(char) codewordPosition;
 return  $stack6;
 label0:codewordPosition=(codewordPosition-254);
 label1:$stack6=(char) codewordPosition;
