static com.google.zxing.pdf417.detector.PDF417DetectorResult com.google.zxing.pdf417.detector.Detector:detect (
  com.google.zxing.BinaryBitmap image, java.util.Map hints, boolean multiple) {
  guard = tt;
  ret(level()) = pc ⊔ level(image) ⊔ level(multiple) ⊔ obj_level(image);
  ret(obj_level()) = pc ⊔ level(image) ⊔ level(multiple) ⊔ obj_level(image);
  ret(obj_level(hints)) = pc ⊔ level(image) ⊔ level(multiple) ⊔ obj_level(hints) ⊔ obj_level(image);
  ret(obj_level(image)) = pc ⊔ level(image) ⊔ level(multiple) ⊔ obj_level(image);
}