com.google.zxing.oned.rss.Pair (int value, int checksumPortion,
                                com.google.zxing.oned.rss.FinderPattern
                                  finderPattern) {
  guard = tt;
  ret(obj_level(finderPattern)) = pc ⊔ level(checksumPortion) ⊔ level(this) ⊔ level(value) ⊔ obj_level(finderPattern) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(checksumPortion) ⊔ level(finderPattern) ⊔ level(this) ⊔ level(value) ⊔ obj_level(finderPattern) ⊔ obj_level(this);
}