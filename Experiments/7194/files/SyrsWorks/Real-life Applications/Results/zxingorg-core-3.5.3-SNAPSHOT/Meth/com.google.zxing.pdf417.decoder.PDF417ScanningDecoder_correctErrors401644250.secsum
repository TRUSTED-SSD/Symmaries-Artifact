static int com.google.zxing.pdf417.decoder.PDF417ScanningDecoder:correctErrors (
  int[] codewords, int[] erasures, int numECCodewords) {
  guard = tt;
  ret(level()) = pc ⊔ level(codewords) ⊔ level(erasures) ⊔ level(numECCodewords) ⊔ obj_level(codewords);
  ret(obj_level(codewords)) = obj_level(codewords);
  ret(obj_level(erasures)) = obj_level(codewords);
}