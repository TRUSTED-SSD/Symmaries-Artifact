static int com.google.zxing.oned.rss.AbstractRSSReader:parseFinderValue (
  int[] counters, int[][] finderPatterns) {
  guard = tt;
  ret(level()) = pc ⊔ level(counters) ⊔ level(finderPatterns) ⊔ obj_level(counters) ⊔ obj_level(finderPatterns);
  ret(obj_level(counters)) = if obj_level(counters) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(counters) = ⊥ ∧ obj_level(finderPatterns) = ⊤ then ⊤ else ⊥;
  ret(obj_level(finderPatterns)) = if obj_level(finderPatterns) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(counters) = ⊤ ∧ obj_level(finderPatterns) = ⊥ then ⊤ else ⊥;
}