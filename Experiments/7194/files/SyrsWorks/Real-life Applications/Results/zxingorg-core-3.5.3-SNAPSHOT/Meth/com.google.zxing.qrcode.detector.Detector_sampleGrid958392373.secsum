static com.google.zxing.common.BitMatrix com.google.zxing.qrcode.detector.Detector:sampleGrid (
  com.google.zxing.common.BitMatrix @image,
  com.google.zxing.common.PerspectiveTransform transform, int dimension) {
  guard = tt;
  ret(level()) = pc ⊔ level(@image) ⊔ level(dimension) ⊔ level(transform) ⊔ obj_level(@image) ⊔ obj_level(transform);
  ret(obj_level()) = pc ⊔ level(@image) ⊔ level(dimension) ⊔ level(transform) ⊔ obj_level(@image) ⊔ obj_level(transform);
  ret(obj_level(@image)) = obj_level(@image);
  ret(obj_level(transform)) = obj_level(transform);
}