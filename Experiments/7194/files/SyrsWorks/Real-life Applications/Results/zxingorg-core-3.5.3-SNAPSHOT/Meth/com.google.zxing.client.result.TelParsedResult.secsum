com.google.zxing.client.result.TelParsedResult (java.lang.String number,
                                                java.lang.String telURI,
                                                java.lang.String title) {
  guard = tt;
  ret(obj_level(number)) = pc ⊔ level(this) ⊔ obj_level(number) ⊔ obj_level(this);
  ret(obj_level(telURI)) = pc ⊔ level(this) ⊔ obj_level(telURI) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(number) ⊔ level(telURI) ⊔ level(this) ⊔ level(title) ⊔ obj_level(number) ⊔ obj_level(this);
  ret(obj_level(title)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(title);
}