static com.google.zxing.qrcode.decoder.Mode com.google.zxing.qrcode.encoder.Encoder:chooseMode (
  java.lang.String content) {
  guard = tt;
  ret(level()) = pc ⊔ level(content) ⊔ obj_level(content);
  ret(obj_level()) = if pc ≠ ⊤ ∧ level(content) ⊔ obj_level(content) = ⊤ then ⊤ else ⊥;
  ret(obj_level(content)) = pc ⊔ level(content) ⊔ obj_level(content);
}