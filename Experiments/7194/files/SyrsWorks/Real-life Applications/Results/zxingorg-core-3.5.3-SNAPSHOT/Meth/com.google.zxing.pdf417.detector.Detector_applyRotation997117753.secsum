static com.google.zxing.common.BitMatrix com.google.zxing.pdf417.detector.Detector:applyRotation (
  com.google.zxing.common.BitMatrix @matrix, int rotation) {
  guard = tt;
  ret(level()) = pc ⊔ level(@matrix) ⊔ level(rotation);
  ret(obj_level()) = pc ⊔ level(rotation) ⊔ obj_level(@matrix);
  ret(obj_level(@matrix)) = pc ⊔ level(rotation) ⊔ obj_level(@matrix);
}