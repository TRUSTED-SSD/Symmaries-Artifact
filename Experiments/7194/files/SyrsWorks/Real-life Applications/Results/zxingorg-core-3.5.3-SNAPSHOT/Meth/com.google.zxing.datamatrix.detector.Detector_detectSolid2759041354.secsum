com.google.zxing.ResultPoint[] com.google.zxing.datamatrix.detector.Detector:detectSolid2 (
  com.google.zxing.ResultPoint[] points) {
  guard = tt;
  ret(level()) = pc ⊔ level(points);
  ret(obj_level()) = pc ⊔ level(points) ⊔ level(this) ⊔ obj_level(points) ⊔ obj_level(this);
  ret(obj_level(points)) = pc ⊔ level(points) ⊔ level(this) ⊔ obj_level(points) ⊔ obj_level(this);
  ret(obj_level(this)) = obj_level(this);
}