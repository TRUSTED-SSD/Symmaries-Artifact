com.google.zxing.qrcode.detector.FinderPattern (float posX, float posY,
                                                float estimatedModuleSize,
                                                int count) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(count) ⊔ level(estimatedModuleSize) ⊔ level(posX) ⊔ level(posY) ⊔ level(this) ⊔ obj_level(this);
}