static com.google.zxing.common.BitMatrix com.google.zxing.datamatrix.DataMatrixWriter:encodeLowLevel (
  com.google.zxing.datamatrix.encoder.DefaultPlacement placement,
  com.google.zxing.datamatrix.encoder.SymbolInfo symbolInfo, int width,
  int height) {
  guard = tt;
  ret(level()) = pc ⊔ level(height) ⊔ level(placement) ⊔ level(symbolInfo) ⊔ level(width) ⊔ obj_level(placement) ⊔ obj_level(symbolInfo);
  ret(obj_level()) = pc ⊔ level(height) ⊔ level(placement) ⊔ level(symbolInfo) ⊔ level(width) ⊔ obj_level(placement) ⊔ obj_level(symbolInfo);
  ret(obj_level(placement)) = pc ⊔ level(placement) ⊔ level(symbolInfo) ⊔ obj_level(placement) ⊔ obj_level(symbolInfo);
  ret(obj_level(symbolInfo)) = obj_level(symbolInfo);
}