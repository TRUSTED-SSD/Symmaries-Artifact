boolean com.google.zxing.qrcode.detector.AlignmentPatternFinder:foundPatternCross (
  int[] stateCount) {
  guard = tt;
  ret(level()) = pc ⊔ level(stateCount) ⊔ level(this) ⊔ obj_level(stateCount) ⊔ obj_level(this);
  ret(obj_level(stateCount)) = obj_level(stateCount);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(stateCount) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}