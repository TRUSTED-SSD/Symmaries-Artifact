static com.google.zxing.ResultPoint[] com.google.zxing.aztec.detector.Detector:expandSquare (
  com.google.zxing.ResultPoint[] @cornerPoints, int oldSide, int newSide) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@cornerPoints) ⊔ level(newSide) ⊔ level(oldSide) ⊔ obj_level(@cornerPoints);
  ret(obj_level(@cornerPoints)) = pc ⊔ level(@cornerPoints) ⊔ level(newSide) ⊔ level(oldSide) ⊔ obj_level(@cornerPoints);
}