static char com.google.zxing.datamatrix.encoder.Base256Encoder:randomize255State(char ch,int codewordPosition)
{
codewordPosition=(149 * codewordPosition);
 codewordPosition=(codewordPosition%255);
 codewordPosition=(codewordPosition+1);
 codewordPosition=(ch+codewordPosition);
 if (codewordPosition>255) goto label0;
 ch=(char) codewordPosition;
 return  ch;
 label0:codewordPosition=(codewordPosition-256);
 ch=(char) codewordPosition;
 return  ch;
 } 

