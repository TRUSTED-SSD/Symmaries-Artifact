static com.google.zxing.common.BitArray com.google.zxing.aztec.encoder.Encoder:generateCheckWords (
  com.google.zxing.common.BitArray @bitArray, int totalBits, int wordSize) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@bitArray) ⊔ level(totalBits) ⊔ level(wordSize) ⊔ obj_level(@bitArray);
  ret(obj_level(@bitArray)) = pc ⊔ level(@bitArray) ⊔ level(totalBits) ⊔ level(wordSize) ⊔ obj_level(@bitArray);
}