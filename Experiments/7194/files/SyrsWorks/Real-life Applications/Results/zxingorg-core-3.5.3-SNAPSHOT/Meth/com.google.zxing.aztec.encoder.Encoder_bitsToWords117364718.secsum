static int[] com.google.zxing.aztec.encoder.Encoder:bitsToWords (com.google.zxing.common.BitArray
                                                                   stuffedBits,
                                                                 int wordSize,
                                                                 int
                                                                   totalWords) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(stuffedBits) ⊔ level(totalWords) ⊔ level(wordSize) ⊔ obj_level(stuffedBits);
