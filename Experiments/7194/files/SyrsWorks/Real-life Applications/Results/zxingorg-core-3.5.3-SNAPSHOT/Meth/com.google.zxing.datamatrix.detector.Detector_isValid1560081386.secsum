boolean com.google.zxing.datamatrix.detector.Detector:isValid (com.google.zxing.ResultPoint
                                                                 p) {
  guard = tt;
  ret(level()) = pc ⊔ level(p) ⊔ level(this) ⊔ obj_level(p) ⊔ obj_level(this);
  ret(obj_level(p)) = obj_level(p);
  ret(obj_level(this)) = obj_level(this);
}