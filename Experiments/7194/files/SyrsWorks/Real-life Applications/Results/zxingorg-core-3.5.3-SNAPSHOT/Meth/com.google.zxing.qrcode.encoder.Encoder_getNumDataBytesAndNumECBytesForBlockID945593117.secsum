static void com.google.zxing.qrcode.encoder.Encoder:getNumDataBytesAndNumECBytesForBlockID (
  int numTotalBytes, int numDataBytes, int numRSBlocks, int blockID,
  int[] numDataBytesInBlock, int[] numECBytesInBlock) {
  guard = tt;
  ret(obj_level(numDataBytesInBlock)) = pc ⊔ level(blockID) ⊔ level(numDataBytes) ⊔ level(numRSBlocks) ⊔ level(numTotalBytes) ⊔ obj_level(numDataBytesInBlock);
  ret(obj_level(numECBytesInBlock)) = pc ⊔ level(blockID) ⊔ level(numDataBytes) ⊔ level(numRSBlocks) ⊔ level(numTotalBytes) ⊔ obj_level(numECBytesInBlock);
}