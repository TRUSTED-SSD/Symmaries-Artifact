com.google.zxing.qrcode.encoder.BlockPair (byte[] data,
                                           byte[] errorCorrection) {
  guard = tt;
  ret(obj_level(data)) = pc ⊔ level(this) ⊔ obj_level(data) ⊔ obj_level(this);
  ret(obj_level(errorCorrection)) = pc ⊔ level(this) ⊔ obj_level(errorCorrection) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(data) ⊔ level(errorCorrection) ⊔ level(this) ⊔ obj_level(data) ⊔ obj_level(this);
}