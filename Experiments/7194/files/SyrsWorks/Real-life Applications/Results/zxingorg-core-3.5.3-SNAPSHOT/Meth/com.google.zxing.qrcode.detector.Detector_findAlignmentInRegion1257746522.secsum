com.google.zxing.qrcode.detector.AlignmentPattern com.google.zxing.qrcode.detector.Detector:findAlignmentInRegion (
  float overallEstModuleSize, int estAlignmentX, int estAlignmentY,
  float allowanceFactor) {
  guard = tt;
  ret(level()) = pc ⊔ level(allowanceFactor) ⊔ level(estAlignmentX) ⊔ level(estAlignmentY) ⊔ level(overallEstModuleSize) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(allowanceFactor) ⊔ level(estAlignmentX) ⊔ level(estAlignmentY) ⊔ level(overallEstModuleSize) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(allowanceFactor) ⊔ level(estAlignmentX) ⊔ level(estAlignmentY) ⊔ level(overallEstModuleSize) ⊔ level(this) ⊔ obj_level(this);
}