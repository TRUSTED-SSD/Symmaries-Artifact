static com.google.zxing.common.PerspectiveTransform com.google.zxing.common.PerspectiveTransform:quadrilateralToQuadrilateral (
  float x0, float y0, float x1, float y1, float x2, float y2, float x3,
  float y3, float x0p, float y0p, float x1p, float y1p, float x2p, float y2p,
  float x3p, float y3p) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(x0) ⊔ level(x0p) ⊔ level(x1) ⊔ level(x1p) ⊔ level(x2) ⊔ level(x2p) ⊔ level(x3) ⊔ level(x3p) ⊔ level(y0) ⊔ level(y0p) ⊔ level(y1) ⊔ level(y1p) ⊔ level(y2) ⊔ level(y2p) ⊔ level(y3) ⊔ level(y3p);
}