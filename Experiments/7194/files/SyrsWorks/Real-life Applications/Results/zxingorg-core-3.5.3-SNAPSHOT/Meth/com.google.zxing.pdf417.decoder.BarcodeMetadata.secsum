com.google.zxing.pdf417.decoder.BarcodeMetadata (int columnCount,
                                                 int rowCountUpperPart,
                                                 int rowCountLowerPart,
                                                 int errorCorrectionLevel) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(columnCount) ⊔ level(errorCorrectionLevel) ⊔ level(rowCountLowerPart) ⊔ level(rowCountUpperPart) ⊔ level(this) ⊔ obj_level(this);
}