static int com.google.zxing.pdf417.encoder.PDF417HighLevelEncoder:determineConsecutiveDigitCount (
  com.google.zxing.common.ECIInput input, int startpos) {
  guard = tt;
  ret(level()) = pc ⊔ level(input) ⊔ level(startpos) ⊔ obj_level(input);
  ret(obj_level(input)) = pc ⊔ level(input) ⊔ level(startpos) ⊔ obj_level(input);
}