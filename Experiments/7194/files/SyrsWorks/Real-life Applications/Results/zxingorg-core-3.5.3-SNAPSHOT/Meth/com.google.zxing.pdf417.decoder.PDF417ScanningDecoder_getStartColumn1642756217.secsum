static int com.google.zxing.pdf417.decoder.PDF417ScanningDecoder:getStartColumn (
  com.google.zxing.pdf417.decoder.DetectionResult detectionResult,
  int barcodeColumn, int imageRow, boolean leftToRight) {
  guard = tt;
  ret(level()) = pc ⊔ level(barcodeColumn) ⊔ level(detectionResult) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ obj_level(detectionResult);
  ret(obj_level(detectionResult)) = if obj_level(detectionResult) = ⊤ ∨ pc ≠ ⊤ ∧ (if level(leftToRight) = ⊤ then obj_level(detectionResult) = ⊥ else level(leftToRight) = ⊥ ∧ obj_level(detectionResult) = ⊥ ∧ level(barcodeColumn) ⊔ level(detectionResult) ⊔ level(imageRow) = ⊤) then ⊤ else ⊥;
}