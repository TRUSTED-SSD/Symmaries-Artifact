static com.google.zxing.qrcode.decoder.Version com.google.zxing.qrcode.encoder.Encoder:chooseVersion (
  int numInputBits,
  com.google.zxing.qrcode.decoder.ErrorCorrectionLevel ecLevel) {
  guard = tt;
  ret(level()) = pc ⊔ level(ecLevel) ⊔ level(numInputBits) ⊔ obj_level(ecLevel);
  ret(obj_level()) = pc ⊔ level(ecLevel) ⊔ level(numInputBits) ⊔ obj_level(ecLevel);
  ret(obj_level(ecLevel)) = pc ⊔ level(ecLevel) ⊔ level(numInputBits) ⊔ obj_level(ecLevel);
}