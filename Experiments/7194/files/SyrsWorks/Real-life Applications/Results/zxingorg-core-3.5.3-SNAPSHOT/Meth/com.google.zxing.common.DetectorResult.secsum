com.google.zxing.common.DetectorResult (com.google.zxing.common.BitMatrix
                                          bits,
                                        com.google.zxing.ResultPoint[] points) {
  guard = tt;
  ret(obj_level(bits)) = pc ⊔ level(this) ⊔ obj_level(bits) ⊔ obj_level(this);
  ret(obj_level(points)) = pc ⊔ level(this) ⊔ obj_level(points) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bits) ⊔ level(points) ⊔ level(this) ⊔ obj_level(bits) ⊔ obj_level(points) ⊔ obj_level(this);
}