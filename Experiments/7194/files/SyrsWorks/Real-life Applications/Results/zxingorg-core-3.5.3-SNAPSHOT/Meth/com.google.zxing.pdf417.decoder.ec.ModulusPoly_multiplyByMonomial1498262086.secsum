com.google.zxing.pdf417.decoder.ec.ModulusPoly com.google.zxing.pdf417.decoder.ec.ModulusPoly:multiplyByMonomial (
  int degree, int coefficient) {
  guard = tt;
  ret(level()) = pc ⊔ level(coefficient) ⊔ level(degree) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(coefficient) ⊔ level(degree) ⊔ obj_level(this);
