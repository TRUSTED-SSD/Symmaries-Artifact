com.google.zxing.Result com.google.zxing.oned.MultiFormatOneDReader:decodeRow (
  int rowNumber, com.google.zxing.common.BitArray row, java.util.Map hints) {
  guard = tt;
  ret(level()) = pc ⊔ level(hints) ⊔ level(row) ⊔ level(rowNumber) ⊔ level(this) ⊔ obj_level(hints) ⊔ obj_level(row) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(hints) ⊔ level(row) ⊔ level(rowNumber) ⊔ level(this) ⊔ obj_level(hints) ⊔ obj_level(row) ⊔ obj_level(this);
  ret(obj_level(hints)) = if obj_level(hints) = ⊤ ∨ pc ≠ ⊤ ∧ (if obj_level(this) = ⊤ then obj_level(hints) = ⊥ else level(this) = ⊤ ∧ obj_level(hints) = ⊥ ∧ obj_level(this) = ⊥) then ⊤ else ⊥;
  ret(obj_level(row)) = obj_level(row);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ level(this) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}