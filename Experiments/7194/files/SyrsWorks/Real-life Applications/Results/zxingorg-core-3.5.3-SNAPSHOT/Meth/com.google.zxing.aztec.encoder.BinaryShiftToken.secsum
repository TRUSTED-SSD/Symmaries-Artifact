  ret(obj_level(previous)) = pc ⊔ level(binaryShiftByteCount) ⊔ level(binaryShiftStart) ⊔ level(previous) ⊔ level(this) ⊔ obj_level(previous);
  ret(obj_level(this)) = pc ⊔ level(binaryShiftByteCount) ⊔ level(binaryShiftStart) ⊔ level(previous) ⊔ level(this) ⊔ obj_level(previous);
