static com.google.zxing.common.BitMatrix com.google.zxing.datamatrix.DataMatrixWriter:convertByteMatrixToBitMatrix (
  com.google.zxing.qrcode.encoder.ByteMatrix matrix, int reqWidth,
  int reqHeight) {
  guard = tt;
  ret(level()) = pc ⊔ level(matrix) ⊔ level(reqHeight) ⊔ level(reqWidth) ⊔ obj_level(matrix);
  ret(obj_level()) = pc ⊔ level(matrix) ⊔ level(reqHeight) ⊔ level(reqWidth) ⊔ obj_level(matrix);
  ret(obj_level(matrix)) = obj_level(matrix);
}