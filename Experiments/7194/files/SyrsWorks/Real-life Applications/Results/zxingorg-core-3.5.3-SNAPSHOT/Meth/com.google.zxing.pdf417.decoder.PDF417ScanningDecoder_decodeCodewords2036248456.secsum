static com.google.zxing.common.DecoderResult com.google.zxing.pdf417.decoder.PDF417ScanningDecoder:decodeCodewords (
  int[] codewords, int ecLevel, int[] erasures) {
  guard = tt;
  ret(level()) = pc ⊔ level(codewords) ⊔ level(ecLevel) ⊔ obj_level(codewords);
  ret(obj_level()) = pc ⊔ level(codewords) ⊔ level(ecLevel) ⊔ level(erasures) ⊔ obj_level(codewords);
  ret(obj_level(codewords)) = pc ⊔ level(codewords) ⊔ level(ecLevel) ⊔ level(erasures) ⊔ obj_level(codewords);
  ret(obj_level(erasures)) = pc ⊔ level(codewords) ⊔ level(ecLevel) ⊔ level(erasures) ⊔ obj_level(codewords);
}