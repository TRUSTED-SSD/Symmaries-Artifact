int[] com.google.zxing.common.reedsolomon.ReedSolomonDecoder:findErrorMagnitudes (
  com.google.zxing.common.reedsolomon.GenericGFPoly errorEvaluator,
  int[] errorLocations) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(errorEvaluator) ⊔ level(errorLocations) ⊔ level(this) ⊔ obj_level(errorEvaluator) ⊔ obj_level(errorLocations) ⊔ obj_level(this);
  ret(obj_level(errorEvaluator)) = pc ⊔ level(errorEvaluator) ⊔ level(errorLocations) ⊔ level(this) ⊔ obj_level(errorEvaluator) ⊔ obj_level(errorLocations) ⊔ obj_level(this);
  ret(obj_level(errorLocations)) = pc ⊔ level(errorEvaluator) ⊔ level(errorLocations) ⊔ level(this) ⊔ obj_level(errorEvaluator) ⊔ obj_level(errorLocations) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(errorEvaluator) ⊔ level(errorLocations) ⊔ level(this) ⊔ obj_level(errorEvaluator) ⊔ obj_level(errorLocations) ⊔ obj_level(this);
}