static void com.google.zxing.qrcode.encoder.MatrixUtil:makeTypeInfoBits (
  com.google.zxing.qrcode.decoder.ErrorCorrectionLevel ecLevel,
  int maskPattern, com.google.zxing.common.BitArray bits) {
  guard = tt;
  ret(obj_level(bits)) = pc ⊔ level(bits) ⊔ level(ecLevel) ⊔ level(maskPattern) ⊔ obj_level(bits) ⊔ obj_level(ecLevel);
  ret(obj_level(ecLevel)) = pc ⊔ level(bits) ⊔ level(ecLevel) ⊔ level(maskPattern) ⊔ obj_level(bits) ⊔ obj_level(ecLevel);
}