static com.google.zxing.qrcode.decoder.Mode com.google.zxing.qrcode.encoder.Encoder:chooseMode (
  java.lang.String content, java.nio.charset.Charset encoding) {
  guard = tt;
  ret(level()) = pc ⊔ level(content) ⊔ obj_level(content) ⊔ obj_level(encoding);
  ret(obj_level()) = if pc ≠ ⊤ ∧ level(content) ⊔ obj_level(content) ⊔ obj_level(encoding) = ⊤ then ⊤ else ⊥;
  ret(obj_level(content)) = pc ⊔ level(content) ⊔ obj_level(content) ⊔ obj_level(encoding);
  ret(obj_level(encoding)) = pc ⊔ level(content) ⊔ obj_level(content) ⊔ obj_level(encoding);
}