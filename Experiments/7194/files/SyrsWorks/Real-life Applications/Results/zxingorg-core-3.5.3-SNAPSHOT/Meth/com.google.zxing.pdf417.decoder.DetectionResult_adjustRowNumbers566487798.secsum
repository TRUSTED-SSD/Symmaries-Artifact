void com.google.zxing.pdf417.decoder.DetectionResult:adjustRowNumbers (
  int barcodeColumn, int codewordsRow,
  com.google.zxing.pdf417.decoder.Codeword[] @codewords) {
  guard = tt;
  ret(obj_level(@codewords)) = pc ⊔ level(@codewords) ⊔ level(barcodeColumn) ⊔ level(codewordsRow) ⊔ level(this) ⊔ obj_level(@codewords) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@codewords) ⊔ level(barcodeColumn) ⊔ level(codewordsRow) ⊔ level(this) ⊔ obj_level(@codewords) ⊔ obj_level(this);
}