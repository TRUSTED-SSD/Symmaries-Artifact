int[] com.google.zxing.common.reedsolomon.ReedSolomonDecoder:findErrorLocations (
  com.google.zxing.common.reedsolomon.GenericGFPoly errorLocator) {
  guard = tt;
  ret(level()) = pc ⊔ level(errorLocator) ⊔ level(this) ⊔ obj_level(errorLocator) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(errorLocator) ⊔ level(this) ⊔ obj_level(errorLocator) ⊔ obj_level(this);
  ret(obj_level(errorLocator)) = pc ⊔ level(errorLocator) ⊔ level(this) ⊔ obj_level(errorLocator) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(errorLocator) ⊔ level(this) ⊔ obj_level(errorLocator) ⊔ obj_level(this);
}