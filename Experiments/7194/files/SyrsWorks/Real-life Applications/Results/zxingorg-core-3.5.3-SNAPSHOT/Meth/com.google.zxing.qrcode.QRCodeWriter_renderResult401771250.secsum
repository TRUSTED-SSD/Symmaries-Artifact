static com.google.zxing.common.BitMatrix com.google.zxing.qrcode.QRCodeWriter:renderResult (
  com.google.zxing.qrcode.encoder.QRCode code, int width, int height,
  int quietZone) {
  guard = tt;
  ret(level()) = pc ⊔ level(code) ⊔ obj_level(code);
  ret(obj_level()) = pc ⊔ level(code) ⊔ level(height) ⊔ level(quietZone) ⊔ level(width) ⊔ obj_level(code);
  ret(obj_level(code)) = pc ⊔ level(code) ⊔ level(height) ⊔ level(quietZone) ⊔ level(width) ⊔ obj_level(code);
}