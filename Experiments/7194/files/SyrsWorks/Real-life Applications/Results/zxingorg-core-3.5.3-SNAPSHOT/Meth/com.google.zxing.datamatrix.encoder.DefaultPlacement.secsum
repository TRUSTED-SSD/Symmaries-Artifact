com.google.zxing.datamatrix.encoder.DefaultPlacement (java.lang.CharSequence
                                                        codewords,
                                                      int numcols,
                                                      int numrows) {
  guard = tt;
  ret(obj_level(codewords)) = pc ⊔ level(this) ⊔ obj_level(codewords) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(codewords) ⊔ level(numcols) ⊔ level(numrows) ⊔ level(this) ⊔ obj_level(codewords) ⊔ obj_level(this);
}