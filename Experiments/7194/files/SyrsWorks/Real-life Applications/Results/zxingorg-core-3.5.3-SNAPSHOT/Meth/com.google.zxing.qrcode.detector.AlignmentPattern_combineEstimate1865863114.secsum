com.google.zxing.qrcode.detector.AlignmentPattern com.google.zxing.qrcode.detector.AlignmentPattern:combineEstimate (
  float i, float j, float newModuleSize) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(i) ⊔ level(j) ⊔ level(newModuleSize) ⊔ level(this) ⊔ obj_level(this);
