static int com.google.zxing.datamatrix.decoder.DecodedBitStreamParser:unrandomize255State(int randomizedBase256Codeword,int base256CodewordPosition)
{
base256CodewordPosition=(149 * base256CodewordPosition);
 base256CodewordPosition=(base256CodewordPosition%255);
 base256CodewordPosition=(base256CodewordPosition+1);
 randomizedBase256Codeword=(randomizedBase256Codeword-base256CodewordPosition);
 if (randomizedBase256Codeword<0) goto label0;
 goto label1;
 label0:randomizedBase256Codeword=(randomizedBase256Codeword+256);
 label1:return  randomizedBase256Codeword;
 } 

