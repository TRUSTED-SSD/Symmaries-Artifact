  ret(level()) = pc ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxColumn) ⊔ level(minColumn) ⊔ level(startColumn) ⊔ obj_level(image);
  ret(obj_level()) = pc ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxColumn) ⊔ level(minColumn) ⊔ level(startColumn) ⊔ obj_level(image);
  ret(obj_level(image)) = pc ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxColumn) ⊔ level(minColumn) ⊔ level(startColumn) ⊔ obj_level(image);
