static int[] com.google.zxing.pdf417.decoder.PDF417ScanningDecoder:getModuleBitCount (
  com.google.zxing.common.BitMatrix image, int minColumn, int maxColumn,
  boolean leftToRight, int startColumn, int imageRow) {
