static int com.google.zxing.qrcode.detector.Detector:computeDimension (
  com.google.zxing.ResultPoint topLeft,
  com.google.zxing.ResultPoint topRight,
  com.google.zxing.ResultPoint bottomLeft, float moduleSize) {
  guard = tt;
  ret(level()) = pc ⊔ level(bottomLeft) ⊔ level(moduleSize) ⊔ level(topLeft) ⊔ level(topRight) ⊔ obj_level(bottomLeft);
  ret(obj_level(bottomLeft)) = obj_level(bottomLeft);
  ret(obj_level(topLeft)) = obj_level(bottomLeft);
  ret(obj_level(topRight)) = obj_level(bottomLeft);
}