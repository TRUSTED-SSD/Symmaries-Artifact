static void com.google.zxing.qrcode.decoder.DecodedBitStreamParser:decodeAlphanumericSegment (
  com.google.zxing.common.BitSource bits, java.lang.StringBuilder result,
  int count, boolean fc1InEffect) {
  guard = tt;
  ret(obj_level(bits)) = pc ⊔ level(bits) ⊔ level(count) ⊔ obj_level(bits);
  ret(obj_level(result)) = pc ⊔ level(bits) ⊔ level(count) ⊔ level(fc1InEffect) ⊔ level(result) ⊔ obj_level(bits) ⊔ obj_level(result);
}