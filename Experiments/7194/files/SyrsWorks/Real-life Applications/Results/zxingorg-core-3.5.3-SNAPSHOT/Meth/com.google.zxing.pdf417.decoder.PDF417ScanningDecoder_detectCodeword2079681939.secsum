static com.google.zxing.pdf417.decoder.Codeword com.google.zxing.pdf417.decoder.PDF417ScanningDecoder:detectCodeword (
  com.google.zxing.common.BitMatrix image, int minColumn, int maxColumn,
  boolean leftToRight, int startColumn, int imageRow, int minCodewordWidth,
  int maxCodewordWidth) {
  guard = tt;
  ret(level()) = pc ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxCodewordWidth) ⊔ level(maxColumn) ⊔ level(minCodewordWidth) ⊔ level(minColumn) ⊔ level(startColumn) ⊔ obj_level(image);
  ret(obj_level()) = pc ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxCodewordWidth) ⊔ level(maxColumn) ⊔ level(minCodewordWidth) ⊔ level(minColumn) ⊔ level(startColumn) ⊔ obj_level(image);
  ret(obj_level(image)) = pc ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxCodewordWidth) ⊔ level(maxColumn) ⊔ level(minCodewordWidth) ⊔ level(minColumn) ⊔ level(startColumn) ⊔ obj_level(image);
}