static int com.google.zxing.pdf417.encoder.PDF417HighLevelEncoder:determineConsecutiveBinaryCount (
  com.google.zxing.common.ECIInput input, int startpos,
  java.nio.charset.Charset encoding) {
  guard = tt;
  ret(level()) = pc ⊔ level(encoding) ⊔ level(input) ⊔ level(startpos) ⊔ obj_level(encoding) ⊔ obj_level(input);
  ret(obj_level(encoding)) = pc ⊔ level(encoding) ⊔ level(input) ⊔ level(startpos) ⊔ obj_level(encoding) ⊔ obj_level(input);
  ret(obj_level(input)) = pc ⊔ level(encoding) ⊔ level(input) ⊔ level(startpos) ⊔ obj_level(encoding) ⊔ obj_level(input);
}