com.google.zxing.pdf417.decoder.BarcodeMetadata(int columnCount,int rowCountUpperPart,int rowCountLowerPart,int errorCorrectionLevel)
{
this#java.lang.Object();
 this.columnCount=columnCount;
 this.errorCorrectionLevel=errorCorrectionLevel;
 this.rowCountUpperPart=rowCountUpperPart;
 this.rowCountLowerPart=rowCountLowerPart;
 columnCount=(rowCountUpperPart+rowCountLowerPart);
 this.rowCount=columnCount;
 return;
 } 

