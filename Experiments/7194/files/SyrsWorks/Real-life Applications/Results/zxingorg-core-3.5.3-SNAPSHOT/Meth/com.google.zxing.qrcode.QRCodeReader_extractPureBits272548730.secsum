static com.google.zxing.common.BitMatrix com.google.zxing.qrcode.QRCodeReader:extractPureBits (
  com.google.zxing.common.BitMatrix image) {
  guard = tt;
  ret(level()) = pc ⊔ level(image) ⊔ obj_level(image);
  ret(obj_level()) = pc ⊔ level(image) ⊔ obj_level(image);
  ret(obj_level(image)) = pc ⊔ level(image) ⊔ obj_level(image);
}