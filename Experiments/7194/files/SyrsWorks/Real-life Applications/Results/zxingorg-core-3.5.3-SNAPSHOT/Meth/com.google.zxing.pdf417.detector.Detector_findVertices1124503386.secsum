static com.google.zxing.ResultPoint[] com.google.zxing.pdf417.detector.Detector:findVertices (
  com.google.zxing.common.BitMatrix matrix, int startRow, int startColumn) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(matrix) ⊔ level(startColumn) ⊔ level(startRow) ⊔ obj_level(matrix);
  ret(obj_level(matrix)) = obj_level(matrix);
}