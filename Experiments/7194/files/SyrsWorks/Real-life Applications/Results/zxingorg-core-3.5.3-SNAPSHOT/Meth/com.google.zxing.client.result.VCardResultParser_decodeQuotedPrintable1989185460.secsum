static java.lang.String com.google.zxing.client.result.VCardResultParser:decodeQuotedPrintable (
  java.lang.CharSequence value, java.lang.String @charset) {
  guard = pc ⊔ level(@charset) ⊔ level(value) ⊔ obj_level(@charset) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(@charset)) = ⊥;
  ret(obj_level(value)) = ⊥;
}