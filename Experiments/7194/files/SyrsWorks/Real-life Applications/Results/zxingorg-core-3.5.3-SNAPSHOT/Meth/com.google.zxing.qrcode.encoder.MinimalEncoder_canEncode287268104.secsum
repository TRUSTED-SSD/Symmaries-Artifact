boolean com.google.zxing.qrcode.encoder.MinimalEncoder:canEncode (com.google.zxing.qrcode.decoder.Mode
                                                                    mode,
                                                                  char c) {
  guard = tt;
  ret(level()) = pc ⊔ level(c) ⊔ level(mode) ⊔ obj_level(mode);
  ret(obj_level(mode)) = pc ⊔ level(mode) ⊔ obj_level(mode);
  ret(obj_level(this)) = pc ⊔ level(mode) ⊔ obj_level(mode) ⊔ obj_level(this);
}