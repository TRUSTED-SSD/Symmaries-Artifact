static com.google.zxing.ResultPoint com.google.zxing.datamatrix.detector.Detector:moveAway (
  com.google.zxing.ResultPoint @point, float fromX, float fromY) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@point) ⊔ level(fromX) ⊔ level(fromY) ⊔ obj_level(@point);
  ret(obj_level(@point)) = pc ⊔ level(@point) ⊔ level(fromX) ⊔ level(fromY) ⊔ obj_level(@point);
}