                                                                    errorCorrectionCodeWords) {
  guard = tt;
  ret(level()) = pc ⊔ level(errorCorrectionCodeWords) ⊔ level(sourceCodeWords) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(errorCorrectionCodeWords) ⊔ level(sourceCodeWords) ⊔ level(this) ⊔ obj_level(this);
