static com.google.zxing.common.BitMatrix com.google.zxing.qrcode.detector.Detector:sampleGrid(com.google.zxing.common.BitMatrix @image,com.google.zxing.common.PerspectiveTransform transform,int dimension)
{
com.google.zxing.common.GridSampler sampler;
  com.google.zxing.common.BitMatrix image;
image=@image;
sampler = com.google.zxing.common.GridSampler.getInstance();
 image = sampler.sampleGrid(image,dimension,dimension,transform);
 return  image;
 } 

