com.google.zxing.Result[] com.google.zxing.multi.qrcode.QRCodeMultiReader:decodeMultiple (
  com.google.zxing.BinaryBitmap image) {
  guard = tt;
  ret(level()) = pc ⊔ level(image) ⊔ level(this) ⊔ obj_level(image) ⊔ obj_level(this);
  ret(obj_level()) = level(image) ⊔ level(this) ⊔ obj_level(image) ⊔ obj_level(this);
