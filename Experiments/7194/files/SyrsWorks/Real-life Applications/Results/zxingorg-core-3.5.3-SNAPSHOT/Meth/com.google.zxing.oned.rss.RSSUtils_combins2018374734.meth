static int com.google.zxing.oned.rss.RSSUtils:combins(int n,int r)
{
int minDenom;
  int val;
  int j;
  minDenom=(n-r);
 if (minDenom<=r) goto label0;
 minDenom=r;
 r=(n-r);
 goto label1;
 label0:minDenom=(n-r);
 label1:val=1;
 j=1;
 label2:if (n<=r) goto label3;
 val=(val * n);
 if (j>minDenom) goto label4;
 val=(val/j);
 j=(j+1);
 label4:n=(n+-1);
 goto label2;
 label3:if (j>minDenom) goto label5;
 val=(val/j);
 j=(j+1);
 goto label3;
 label5:return  val;
 } 

