com.google.zxing.multi.qrcode.detector.MultiFinderPatternFinder (com.google.zxing.common.BitMatrix
                                                                   image,
                                                                 com.google.zxing.ResultPointCallback
                                                                   resultPointCallback) {
  guard = tt;
  ret(obj_level(image)) = pc ⊔ level(image) ⊔ level(resultPointCallback) ⊔ level(this) ⊔ obj_level(image) ⊔ obj_level(resultPointCallback) ⊔ obj_level(this);
  ret(obj_level(resultPointCallback)) = pc ⊔ level(image) ⊔ level(resultPointCallback) ⊔ level(this) ⊔ obj_level(image) ⊔ obj_level(resultPointCallback) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(image) ⊔ level(resultPointCallback) ⊔ level(this) ⊔ obj_level(image) ⊔ obj_level(resultPointCallback) ⊔ obj_level(this);
