boolean com.google.zxing.qrcode.detector.FinderPatternFinder:crossCheckDiagonal (
  int centerI, int centerJ) {
  guard = tt;
  ret(level()) = pc ⊔ level(centerI) ⊔ level(centerJ) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(centerI) ⊔ level(centerJ) ⊔ level(this) ⊔ obj_level(this);
}