com.google.zxing.Binarizer com.google.zxing.common.HybridBinarizer:createBinarizer (
  com.google.zxing.LuminanceSource source) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(source) ⊔ obj_level(source);
  ret(obj_level(source)) = pc ⊔ level(source) ⊔ obj_level(source);
  ret(obj_level(this)) = pc ⊔ level(source) ⊔ obj_level(source) ⊔ obj_level(this);
}