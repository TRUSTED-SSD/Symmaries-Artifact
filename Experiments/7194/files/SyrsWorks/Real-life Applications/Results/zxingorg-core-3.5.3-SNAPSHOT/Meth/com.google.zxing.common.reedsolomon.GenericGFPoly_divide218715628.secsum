com.google.zxing.common.reedsolomon.GenericGFPoly[] com.google.zxing.common.reedsolomon.GenericGFPoly:divide (
  com.google.zxing.common.reedsolomon.GenericGFPoly other) {
  guard = tt;
  ret(level()) = pc ⊔ level(other) ⊔ obj_level(other);
  ret(obj_level()) = pc ⊔ level(other) ⊔ level(this) ⊔ obj_level(other);
  ret(obj_level(other)) = pc ⊔ level(other) ⊔ level(this) ⊔ obj_level(other);
  ret(obj_level(this)) = pc ⊔ level(other) ⊔ level(this) ⊔ obj_level(other);
}