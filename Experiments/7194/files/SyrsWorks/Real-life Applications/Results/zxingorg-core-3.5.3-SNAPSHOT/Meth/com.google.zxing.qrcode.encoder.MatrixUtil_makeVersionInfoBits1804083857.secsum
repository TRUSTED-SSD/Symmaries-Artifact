static void com.google.zxing.qrcode.encoder.MatrixUtil:makeVersionInfoBits (
  com.google.zxing.qrcode.decoder.Version version,
  com.google.zxing.common.BitArray bits) {
  guard = tt;
  ret(obj_level(bits)) = pc ⊔ level(bits) ⊔ level(version) ⊔ obj_level(bits) ⊔ obj_level(version);
  ret(obj_level(version)) = pc ⊔ level(bits) ⊔ level(version) ⊔ obj_level(bits) ⊔ obj_level(version);
}