com.google.zxing.common.GlobalHistogramBinarizer (com.google.zxing.LuminanceSource
                                                    source) {
  guard = tt;
  ret(obj_level(source)) = pc ⊔ level(source) ⊔ level(this) ⊔ obj_level(source) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(source) ⊔ level(this) ⊔ obj_level(source) ⊔ obj_level(this);
}