static int com.google.zxing.pdf417.decoder.PDF417ScanningDecoder:adjustCodewordStartColumn (
  com.google.zxing.common.BitMatrix image, int minColumn, int maxColumn,
  boolean leftToRight, int codewordStartColumn, int imageRow) {
  guard = tt;
  ret(level()) = pc ⊔ level(codewordStartColumn) ⊔ level(image) ⊔ level(imageRow) ⊔ level(leftToRight) ⊔ level(maxColumn) ⊔ level(minColumn) ⊔ obj_level(image);
  ret(obj_level(image)) = obj_level(image);
}