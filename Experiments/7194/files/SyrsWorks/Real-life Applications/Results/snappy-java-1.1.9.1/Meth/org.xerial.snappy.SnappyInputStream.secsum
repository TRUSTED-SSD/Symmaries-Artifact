org.xerial.snappy.SnappyInputStream (java.io.InputStream l1) {
  p0: '0 -> dummyClass ('0) -> level;
  p1: '0, '1, '2 -> java.io.InputStream ('0, '1, '2) -> level;
  guard = tt;
  ret(obj_level(l1)) = p0 ⊔ p1 ⊔ pc ⊔ level(l1) ⊔ level(this) ⊔ obj_level(l1);
  ret(obj_level(this)) = p0 ⊔ p1 ⊔ pc ⊔ level(l1) ⊔ level(this) ⊔ obj_level(l1);
}