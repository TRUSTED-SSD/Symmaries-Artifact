void org.apache.bookkeeper.stream.server.service.StorageService:doStart()
{
org.apache.bookkeeper.stream.storage.StorageContainerStoreBuilder $stack1;
  org.apache.bookkeeper.stream.storage.api.StorageContainerStore $stack2;
  $stack1=this.storeBuilder;
 $stack2 = $stack1.build();
 this.store=$stack2;
 $stack2=this.store;
 $stack2.start();
 return;
 } 

