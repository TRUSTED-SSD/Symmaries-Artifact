                                                            conf) {
  guard = tt;
  ret(obj_level(conf)) = obj_level(conf);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this);
}