static org.apache.bookkeeper.stream.server.grpc.GrpcServer org.apache.bookkeeper.stream.server.grpc.GrpcServer:build (
  org.apache.bookkeeper.stream.server.grpc.GrpcServerSpec spec) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(spec) ⊔ obj_level(spec);
  ret(obj_level(spec)) = pc ⊔ level(spec) ⊔ obj_level(spec);
}