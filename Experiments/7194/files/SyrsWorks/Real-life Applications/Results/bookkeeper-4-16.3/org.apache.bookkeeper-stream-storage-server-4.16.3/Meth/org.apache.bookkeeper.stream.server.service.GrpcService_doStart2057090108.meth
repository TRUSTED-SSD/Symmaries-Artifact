void org.apache.bookkeeper.stream.server.service.GrpcService:doStart()
{
org.apache.bookkeeper.stream.server.grpc.GrpcServerSpec $stack1;
  org.apache.bookkeeper.stream.server.grpc.GrpcServer $stack2;
  $stack1=this.spec;
 $stack2 = org.apache.bookkeeper.stream.server.grpc.GrpcServer.build($stack1);
 this.server=$stack2;
 $stack2=this.server;
 $stack2.start();
 return;
 } 

