static org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.stream.cluster.StreamCluster:newBookieConfiguration (
  org.apache.bookkeeper.common.net.ServiceURI serviceURI) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ obj_level(serviceURI);
  ret(obj_level(serviceURI)) = obj_level(serviceURI);
}