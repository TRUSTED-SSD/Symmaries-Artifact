org.apache.bookkeeper.stream.server.StreamStorageLifecycleComponent (
  org.apache.bookkeeper.server.conf.BookieConfiguration conf,
  org.apache.bookkeeper.stats.StatsLogger @statsLogger) {
  guard = tt;
  ret(obj_level(@statsLogger)) = pc ⊔ level(@statsLogger) ⊔ obj_level(@statsLogger);
  ret(obj_level(conf)) = obj_level(conf);
  ret(obj_level(this)) = pc ⊔ level(@statsLogger) ⊔ level(conf) ⊔ level(this) ⊔ obj_level(@statsLogger) ⊔ obj_level(conf) ⊔ obj_level(this);
}