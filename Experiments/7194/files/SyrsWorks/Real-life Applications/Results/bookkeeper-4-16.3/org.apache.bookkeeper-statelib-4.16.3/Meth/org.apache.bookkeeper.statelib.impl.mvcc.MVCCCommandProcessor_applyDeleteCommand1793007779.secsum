void org.apache.bookkeeper.statelib.impl.mvcc.MVCCCommandProcessor:applyDeleteCommand (
  long revision, org.apache.bookkeeper.stream.proto.kv.store.Command command,
  org.apache.bookkeeper.statelib.impl.mvcc.MVCCStoreImpl store) {
  guard = tt;
  ret(obj_level(command)) = pc ⊔ level(revision) ⊔ level(store) ⊔ obj_level(command) ⊔ obj_level(store);
  ret(obj_level(store)) = pc ⊔ level(revision) ⊔ level(store) ⊔ obj_level(command) ⊔ obj_level(store);
  ret(obj_level(this)) = pc ⊔ level(revision) ⊔ level(store) ⊔ obj_level(command) ⊔ obj_level(store) ⊔ obj_level(this);
}