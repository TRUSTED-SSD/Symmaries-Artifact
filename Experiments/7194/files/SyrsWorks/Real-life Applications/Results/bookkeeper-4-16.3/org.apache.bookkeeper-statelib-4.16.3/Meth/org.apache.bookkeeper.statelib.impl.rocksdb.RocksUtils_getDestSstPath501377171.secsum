static java.lang.String org.apache.bookkeeper.statelib.impl.rocksdb.RocksUtils:getDestSstPath (
  java.lang.String @dbPrefix, java.lang.String fileName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@dbPrefix) ⊔ level(fileName) ⊔ obj_level(@dbPrefix);
  ret(obj_level()) = pc ⊔ level(@dbPrefix) ⊔ level(fileName) ⊔ obj_level(@dbPrefix);
  ret(obj_level(@dbPrefix)) = pc ⊔ level(@dbPrefix) ⊔ level(fileName) ⊔ obj_level(@dbPrefix);
  ret(obj_level(fileName)) = pc ⊔ level(@dbPrefix) ⊔ level(fileName) ⊔ obj_level(@dbPrefix);
}