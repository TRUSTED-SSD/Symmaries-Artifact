void org.apache.bookkeeper.statelib.impl.rocksdb.ccheckpoint.CheckpointFile:copyToRemote (
  org.apache.bookkeeper.statelib.api.ccheckpoint.CheckpointStore
    checkpointStore,
  java.lang.String @dbPrefix, java.lang.String checkpointId) {
  guard = tt;
  ret(obj_level(@dbPrefix)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ level(checkpointStore) ⊔ level(this) ⊔ obj_level(@dbPrefix) ⊔ obj_level(checkpointStore) ⊔ obj_level(this);
  ret(obj_level(checkpointId)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ level(checkpointStore) ⊔ level(this) ⊔ obj_level(@dbPrefix) ⊔ obj_level(checkpointStore) ⊔ obj_level(this);
  ret(obj_level(checkpointStore)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ level(checkpointStore) ⊔ level(this) ⊔ obj_level(@dbPrefix) ⊔ obj_level(checkpointStore) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ level(checkpointStore) ⊔ level(this) ⊔ obj_level(@dbPrefix) ⊔ obj_level(checkpointStore) ⊔ obj_level(this);
}