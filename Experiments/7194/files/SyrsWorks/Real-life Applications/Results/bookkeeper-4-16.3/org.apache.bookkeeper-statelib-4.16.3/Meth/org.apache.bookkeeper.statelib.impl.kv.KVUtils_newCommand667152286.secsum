static org.apache.bookkeeper.proto.statestore.kv.Command org.apache.bookkeeper.statelib.impl.kv.KVUtils:newCommand (
  io.netty.buffer.ByteBuf cmdBuf) {
  guard = tt;
  ret(level()) = pc ⊔ level(cmdBuf) ⊔ obj_level(cmdBuf);
  ret(obj_level()) = pc ⊔ level(cmdBuf) ⊔ obj_level(cmdBuf);
  ret(obj_level(cmdBuf)) = pc ⊔ level(cmdBuf) ⊔ obj_level(cmdBuf);
}