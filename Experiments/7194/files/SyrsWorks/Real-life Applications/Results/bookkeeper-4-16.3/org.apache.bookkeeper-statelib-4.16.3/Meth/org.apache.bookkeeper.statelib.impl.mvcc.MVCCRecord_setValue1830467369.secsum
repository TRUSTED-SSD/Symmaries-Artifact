void org.apache.bookkeeper.statelib.impl.mvcc.MVCCRecord:setValue (io.netty.buffer.ByteBuf
                                                                    buf,
                                                                   org.apache.bookkeeper.stream.proto.kv.store.ValueType
                                                                    valueType) {
  guard = tt;
  ret(obj_level(buf)) = pc ⊔ level(buf) ⊔ level(this) ⊔ level(valueType) ⊔ obj_level(buf) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(buf) ⊔ level(this) ⊔ level(valueType) ⊔ obj_level(buf) ⊔ obj_level(this) ⊔ obj_level(valueType);
  ret(obj_level(valueType)) = obj_level(valueType);
}