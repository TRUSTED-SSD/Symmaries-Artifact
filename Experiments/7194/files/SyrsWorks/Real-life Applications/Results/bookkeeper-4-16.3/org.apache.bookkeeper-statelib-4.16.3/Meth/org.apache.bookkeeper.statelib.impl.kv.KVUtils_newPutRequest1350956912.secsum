static org.apache.bookkeeper.proto.statestore.kv.PutRequest org.apache.bookkeeper.statelib.impl.kv.KVUtils:newPutRequest (
  byte[] keyBytes, byte[] valBytes) {
  guard = tt;
  ret(level()) = pc ⊔ level(keyBytes) ⊔ level(valBytes) ⊔ obj_level(keyBytes);
  ret(obj_level()) = ⊥;
  ret(obj_level(keyBytes)) = pc ⊔ level(keyBytes) ⊔ level(valBytes) ⊔ obj_level(keyBytes);
  ret(obj_level(valBytes)) = pc ⊔ level(keyBytes) ⊔ level(valBytes) ⊔ obj_level(keyBytes);
}