static java.lang.String org.apache.bookkeeper.statelib.impl.rocksdb.RocksUtils:getDestTempSstPath (
  java.lang.String @dbPrefix, java.lang.String checkpointId,
  java.io.File file) {
  guard = tt;
  ret(level()) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix) ⊔ obj_level(file);
  ret(obj_level()) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix) ⊔ obj_level(file);
  ret(obj_level(@dbPrefix)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix) ⊔ obj_level(file);
  ret(obj_level(checkpointId)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix) ⊔ obj_level(file);
  ret(obj_level(file)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix) ⊔ obj_level(file);
}