static java.util.concurrent.CompletableFuture org.apache.bookkeeper.statelib.impl.mvcc.MVCCUtils:failWithCode (
  org.apache.bookkeeper.api.kv.result.Code code, java.lang.String msg) {
  guard = tt;
  ret(level()) = pc ⊔ level(code) ⊔ obj_level(code);
  ret(obj_level()) = pc ⊔ level(code) ⊔ obj_level(code);
  ret(obj_level(code)) = pc ⊔ level(code) ⊔ obj_level(code);
  ret(obj_level(msg)) = pc ⊔ level(code) ⊔ level(msg) ⊔ obj_level(code) ⊔ obj_level(msg);
}