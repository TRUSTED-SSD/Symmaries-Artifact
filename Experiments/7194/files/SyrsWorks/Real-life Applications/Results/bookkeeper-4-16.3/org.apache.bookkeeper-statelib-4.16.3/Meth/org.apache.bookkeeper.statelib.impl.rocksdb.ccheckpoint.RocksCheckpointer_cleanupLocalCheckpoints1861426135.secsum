static void org.apache.bookkeeper.statelib.impl.rocksdb.ccheckpoint.RocksCheckpointer:cleanupLocalCheckpoints (
  java.io.File @dbPath, java.lang.String checkpointToExclude) {
  guard = tt;
  ret(obj_level(@dbPath)) = pc ⊔ level(@dbPath) ⊔ obj_level(@dbPath) ⊔ obj_level(checkpointToExclude);
  ret(obj_level(checkpointToExclude)) = pc ⊔ level(@dbPath) ⊔ obj_level(@dbPath) ⊔ obj_level(checkpointToExclude);
}