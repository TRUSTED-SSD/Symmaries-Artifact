boolean org.apache.bookkeeper.statelib.impl.mvcc.MVCCStoreImpl:processCompares (
  org.apache.bookkeeper.api.kv.op.TxnOp op) {
  p0: io.netty.buffer.ByteBuf () -> level;
  guard = p0 ⊔ pc ⊔ level(op) ⊔ level(this) ⊔ obj_level(op) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(op)) = ⊥;
  ret(obj_level(this)) = ⊥;
}