boolean org.apache.bookkeeper.statelib.impl.mvcc.MVCCRecord:test (org.apache.bookkeeper.api.kv.options.RangeOption
                                                                    rangeOption) {
  guard = tt;
  ret(level()) = pc ⊔ level(rangeOption) ⊔ level(this) ⊔ obj_level(rangeOption) ⊔ obj_level(this);
  ret(obj_level(rangeOption)) = obj_level(rangeOption);
  ret(obj_level(this)) = obj_level(this);
}