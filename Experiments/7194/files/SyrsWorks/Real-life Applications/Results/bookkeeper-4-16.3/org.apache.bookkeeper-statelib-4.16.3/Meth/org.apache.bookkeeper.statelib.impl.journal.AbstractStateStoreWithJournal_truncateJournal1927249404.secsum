java.util.concurrent.CompletableFuture org.apache.bookkeeper.statelib.impl.journal.AbstractStateStoreWithJournal:truncateJournal (
  org.apache.distributedlog.DLSN dlsn) {
  guard = tt;
  ret(level()) = pc ⊔ level(dlsn) ⊔ level(this) ⊔ obj_level(dlsn) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(dlsn) ⊔ level(this) ⊔ obj_level(dlsn) ⊔ obj_level(this);
  ret(obj_level(dlsn)) = obj_level(dlsn);
  ret(obj_level(this)) = pc ⊔ level(dlsn) ⊔ level(this) ⊔ obj_level(dlsn) ⊔ obj_level(this);
}