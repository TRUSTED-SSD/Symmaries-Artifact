void org.apache.bookkeeper.statelib.impl.mvcc.op.proto.ProtoTxnOpImpl:setFailureOps (
  org.apache.bookkeeper.common.collections.RecyclableArrayList failureOps) {
  guard = tt;
  ret(obj_level(failureOps)) = obj_level(failureOps);
  ret(obj_level(this)) = pc ⊔ level(failureOps) ⊔ obj_level(failureOps) ⊔ obj_level(this);
}