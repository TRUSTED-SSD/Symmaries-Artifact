void org.apache.bookkeeper.statelib.impl.rocksdb.ccheckpoint.fs.FSCheckpointManager:rename (
  java.lang.String @srcPath, java.lang.String destPath) {
  guard = tt;
  ret(obj_level(@srcPath)) = pc ⊔ level(@srcPath) ⊔ level(destPath) ⊔ level(this) ⊔ obj_level(@srcPath) ⊔ obj_level(this);
  ret(obj_level(destPath)) = pc ⊔ level(@srcPath) ⊔ level(destPath) ⊔ level(this) ⊔ obj_level(@srcPath) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@srcPath) ⊔ level(destPath) ⊔ level(this) ⊔ obj_level(@srcPath) ⊔ obj_level(this);
}