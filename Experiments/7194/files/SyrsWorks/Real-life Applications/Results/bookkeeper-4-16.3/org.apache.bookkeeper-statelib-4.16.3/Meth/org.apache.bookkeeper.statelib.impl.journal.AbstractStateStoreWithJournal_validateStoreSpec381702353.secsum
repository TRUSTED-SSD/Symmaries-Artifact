void org.apache.bookkeeper.statelib.impl.journal.AbstractStateStoreWithJournal:validateStoreSpec (
  org.apache.bookkeeper.statelib.api.StateStoreSpec spec) {
  guard = tt;
  ret(obj_level(spec)) = pc ⊔ level(spec) ⊔ obj_level(spec);
  ret(obj_level(this)) = pc ⊔ level(spec) ⊔ obj_level(spec) ⊔ obj_level(this);
}