boolean org.apache.bookkeeper.statelib.impl.mvcc.MVCCStoreImpl:processCompareOp (
  org.apache.bookkeeper.api.kv.op.CompareOp op) {
  p0: io.netty.buffer.ByteBuf () -> level;
  guard = p0 ⊔ pc ⊔ level(op) ⊔ obj_level(op) = ⊥;
  ret(level()) = level(this) ⊔ obj_level(this);
  ret(obj_level(op)) = level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = level(this) ⊔ obj_level(this);
}