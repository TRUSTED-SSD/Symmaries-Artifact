static java.lang.String org.apache.bookkeeper.statelib.impl.rocksdb.RocksUtils:getDestCheckpointMetadataPath (
  java.lang.String @dbPrefix, java.lang.String checkpointId) {
  guard = tt;
  ret(level()) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix);
  ret(obj_level()) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix);
  ret(obj_level(@dbPrefix)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix);
  ret(obj_level(checkpointId)) = pc ⊔ level(@dbPrefix) ⊔ level(checkpointId) ⊔ obj_level(@dbPrefix);
}