static io.netty.buffer.ByteBuf org.apache.bookkeeper.statelib.impl.kv.KVUtils:serialize (
  io.netty.buffer.ByteBuf valBuf, long revision) {
  p1: io.netty.buffer.ByteBuf () -> level;
  guard = tt;
  ret(level()) = p1 ⊔ pc;
  ret(obj_level()) = p1 ⊔ pc ⊔ level(revision) ⊔ level(valBuf) ⊔ obj_level(valBuf);
  ret(obj_level(valBuf)) = p1 ⊔ pc ⊔ level(revision) ⊔ level(valBuf) ⊔ obj_level(valBuf);
}