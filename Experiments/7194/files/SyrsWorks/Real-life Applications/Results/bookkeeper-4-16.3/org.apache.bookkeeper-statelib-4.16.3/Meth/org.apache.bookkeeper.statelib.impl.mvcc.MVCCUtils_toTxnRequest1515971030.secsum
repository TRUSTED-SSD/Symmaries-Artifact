static org.apache.bookkeeper.stream.proto.kv.rpc.TxnRequest org.apache.bookkeeper.statelib.impl.mvcc.MVCCUtils:toTxnRequest (
  org.apache.bookkeeper.api.kv.op.TxnOp op) {
  guard = tt;
  ret(level()) = pc ⊔ level(op) ⊔ obj_level(op);
  ret(obj_level()) = pc ⊔ level(op) ⊔ obj_level(op);
  ret(obj_level(op)) = pc ⊔ level(op) ⊔ obj_level(op);
}