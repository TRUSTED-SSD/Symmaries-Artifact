org.apache.bookkeeper.statelib.impl.rocksdb.ccheckpoint.dlog.DLCheckpointStore (
  org.apache.distributedlog.api.namespace.Namespace namespace) {
  guard = tt;
  ret(obj_level(namespace)) = pc ⊔ level(this) ⊔ obj_level(namespace) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(namespace) ⊔ level(this) ⊔ obj_level(namespace) ⊔ obj_level(this);
}