org.apache.bookkeeper.statelib.impl.rocksdb.ccheckpoint.dlog.DLOutputStream (
  org.apache.distributedlog.api.DistributedLogManager dlm,
  org.apache.distributedlog.api.AsyncLogWriter writer) {
  guard = tt;
  ret(obj_level(dlm)) = pc ⊔ level(this) ⊔ obj_level(dlm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(dlm) ⊔ level(this) ⊔ level(writer) ⊔ obj_level(dlm) ⊔ obj_level(this) ⊔ obj_level(writer);
  ret(obj_level(writer)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(writer);
}