void org.apache.bookkeeper.statelib.impl.mvcc.MVCCStoreImpl:increment (
  java.lang.Object key, long amount, long revision) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(amount) ⊔ level(key) ⊔ level(revision) ⊔ level(this) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(amount) ⊔ level(key) ⊔ level(revision) ⊔ level(this) ⊔ obj_level(key);
}