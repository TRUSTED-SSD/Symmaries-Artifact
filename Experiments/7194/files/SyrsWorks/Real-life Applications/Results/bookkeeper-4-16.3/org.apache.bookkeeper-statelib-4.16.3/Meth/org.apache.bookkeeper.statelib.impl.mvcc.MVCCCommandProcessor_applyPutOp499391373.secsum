void org.apache.bookkeeper.statelib.impl.mvcc.MVCCCommandProcessor:applyPutOp (
  long revision, org.apache.bookkeeper.api.kv.op.PutOp op,
  boolean ignoreSmallerRevision,
  org.apache.bookkeeper.statelib.impl.mvcc.MVCCStoreImpl localStore) {
  guard = tt;
  ret(obj_level(localStore)) = pc ⊔ level(ignoreSmallerRevision) ⊔ level(localStore) ⊔ level(op) ⊔ level(revision) ⊔ obj_level(localStore) ⊔ obj_level(op);
  ret(obj_level(op)) = obj_level(op);
  ret(obj_level(this)) = obj_level(this);
}