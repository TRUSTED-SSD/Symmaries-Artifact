org.apache.bookkeeper.statelib.impl.rocksdb.ccheckpoint.RocksdbRestoreTask (
  java.lang.String dbName, java.io.File checkpointDir,
  org.apache.bookkeeper.statelib.api.ccheckpoint.CheckpointStore
    checkpointStore) {
  guard = tt;
  ret(obj_level(checkpointDir)) = obj_level(checkpointDir);
  ret(obj_level(checkpointStore)) = obj_level(checkpointStore);
  ret(obj_level(dbName)) = obj_level(dbName);
  ret(obj_level(this)) = obj_level(this);
}