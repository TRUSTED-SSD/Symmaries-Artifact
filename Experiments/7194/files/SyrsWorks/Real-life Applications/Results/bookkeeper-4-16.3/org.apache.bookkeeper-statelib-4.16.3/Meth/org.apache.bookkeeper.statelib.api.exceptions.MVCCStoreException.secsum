org.apache.bookkeeper.statelib.api.exceptions.MVCCStoreException (org.apache.bookkeeper.api.kv.result.Code
                                                                    code,
                                                                  java.lang.String
                                                                    @msg) {
  guard = tt;
  ret(obj_level(@msg)) = pc ⊔ level(@msg) ⊔ level(code) ⊔ obj_level(@msg) ⊔ obj_level(code);
  ret(obj_level(code)) = obj_level(code);
  ret(obj_level(this)) = pc ⊔ level(code) ⊔ obj_level(code) ⊔ obj_level(this);
}