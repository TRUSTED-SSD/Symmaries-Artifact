void org.apache.bookkeeper.statelib.impl.mvcc.op.proto.ProtoTxnOpImpl:setCompareOps (
  org.apache.bookkeeper.common.collections.RecyclableArrayList compareOps) {
  guard = tt;
  ret(obj_level(compareOps)) = obj_level(compareOps);
  ret(obj_level(this)) = pc ⊔ level(compareOps) ⊔ obj_level(compareOps) ⊔ obj_level(this);
}