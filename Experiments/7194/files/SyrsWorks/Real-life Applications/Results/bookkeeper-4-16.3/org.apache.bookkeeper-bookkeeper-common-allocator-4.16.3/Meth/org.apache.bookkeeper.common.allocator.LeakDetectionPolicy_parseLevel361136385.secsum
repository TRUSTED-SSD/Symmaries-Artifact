static org.apache.bookkeeper.common.allocator.LeakDetectionPolicy org.apache.bookkeeper.common.allocator.LeakDetectionPolicy:parseLevel (
  java.lang.String levelStr) {
  guard = pc ⊔ level(levelStr) ⊔ obj_level(levelStr) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(levelStr)) = ⊥;
}