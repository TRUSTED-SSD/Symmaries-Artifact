void org.apache.bookkeeper.stream.storage.impl.cluster.ZkClusterControllerLeaderSelectorListener:stateChanged (
  org.apache.curator.framework.CuratorFramework client,
  org.apache.curator.framework.state.ConnectionState newState) {
  guard = pc ⊔ level(newState) ⊔ obj_level(newState) = ⊥;
  ret(obj_level(client)) = obj_level(client);
  ret(obj_level(newState)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}