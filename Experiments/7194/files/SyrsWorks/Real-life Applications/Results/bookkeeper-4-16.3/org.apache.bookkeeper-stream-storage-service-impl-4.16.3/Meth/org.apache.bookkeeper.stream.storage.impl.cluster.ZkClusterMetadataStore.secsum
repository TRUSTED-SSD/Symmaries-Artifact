org.apache.bookkeeper.stream.storage.impl.cluster.ZkClusterMetadataStore (
  org.apache.curator.framework.CuratorFramework client,
  java.lang.String @zkServers, java.lang.String zkRootPath) {
  guard = tt;
  ret(obj_level(@zkServers)) = pc ⊔ level(this) ⊔ level(zkRootPath) ⊔ obj_level(@zkServers) ⊔ obj_level(this);
  ret(obj_level(client)) = pc ⊔ level(this) ⊔ obj_level(client) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@zkServers) ⊔ level(client) ⊔ level(this) ⊔ level(zkRootPath) ⊔ obj_level(@zkServers) ⊔ obj_level(client) ⊔ obj_level(this);
  ret(obj_level(zkRootPath)) = pc ⊔ level(this) ⊔ level(zkRootPath) ⊔ obj_level(this) ⊔ obj_level(zkRootPath);
}