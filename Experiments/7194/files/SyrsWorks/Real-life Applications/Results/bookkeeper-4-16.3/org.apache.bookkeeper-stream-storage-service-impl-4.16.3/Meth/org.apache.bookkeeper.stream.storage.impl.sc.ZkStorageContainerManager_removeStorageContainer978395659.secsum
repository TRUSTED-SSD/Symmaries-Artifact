void org.apache.bookkeeper.stream.storage.impl.sc.ZkStorageContainerManager:removeStorageContainer (
  long scId, org.apache.bookkeeper.stream.storage.api.sc.StorageContainer sc) {
  guard = pc ⊔ level(sc) ⊔ level(scId) ⊔ level(this) ⊔ obj_level(sc) ⊔ obj_level(this) = ⊥;
  ret(obj_level(sc)) = ⊥;
  ret(obj_level(this)) = ⊥;
}