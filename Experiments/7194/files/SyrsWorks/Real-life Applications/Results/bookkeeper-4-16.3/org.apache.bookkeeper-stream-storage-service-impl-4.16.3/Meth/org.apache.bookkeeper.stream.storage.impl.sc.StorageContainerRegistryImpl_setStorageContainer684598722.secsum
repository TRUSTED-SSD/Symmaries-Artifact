void org.apache.bookkeeper.stream.storage.impl.sc.StorageContainerRegistryImpl:setStorageContainer (
  long scId,
  org.apache.bookkeeper.stream.storage.api.sc.StorageContainer group) {
  guard = tt;
  ret(obj_level(group)) = pc ⊔ level(group) ⊔ level(scId) ⊔ level(this) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(group) ⊔ level(scId) ⊔ level(this) ⊔ obj_level(group) ⊔ obj_level(this);
}