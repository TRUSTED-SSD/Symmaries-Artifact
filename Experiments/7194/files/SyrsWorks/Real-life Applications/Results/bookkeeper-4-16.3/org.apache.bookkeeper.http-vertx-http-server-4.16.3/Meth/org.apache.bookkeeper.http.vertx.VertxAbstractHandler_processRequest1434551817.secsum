void org.apache.bookkeeper.http.vertx.VertxAbstractHandler:processRequest (
  org.apache.bookkeeper.http.service.HttpEndpointService httpEndpointService,
  io.vertx.ext.web.RoutingContext context) {
  guard = tt;
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ obj_level(context);
  ret(obj_level(httpEndpointService)) = pc ⊔ level(context) ⊔ level(httpEndpointService) ⊔ obj_level(context) ⊔ obj_level(httpEndpointService);
  ret(obj_level(this)) = pc ⊔ level(context) ⊔ obj_level(context) ⊔ obj_level(this);
}