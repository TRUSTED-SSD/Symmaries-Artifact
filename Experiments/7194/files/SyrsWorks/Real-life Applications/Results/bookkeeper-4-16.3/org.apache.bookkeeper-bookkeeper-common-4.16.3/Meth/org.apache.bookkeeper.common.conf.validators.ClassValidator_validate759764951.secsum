boolean org.apache.bookkeeper.common.conf.validators.ClassValidator:validate (
  java.lang.String @name, java.lang.Object value) {
  guard = pc ⊔ level(@name) ⊔ level(value) ⊔ obj_level(@name) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(@name)) = level(this);
  ret(obj_level(this)) = level(this);
  ret(obj_level(value)) = level(this);
}