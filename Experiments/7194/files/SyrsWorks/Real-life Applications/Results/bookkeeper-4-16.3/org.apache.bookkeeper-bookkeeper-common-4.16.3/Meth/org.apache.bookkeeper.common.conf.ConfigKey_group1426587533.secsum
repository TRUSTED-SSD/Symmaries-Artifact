org.apache.bookkeeper.common.conf.ConfigKey org.apache.bookkeeper.common.conf.ConfigKey:group (
  org.apache.bookkeeper.common.conf.ConfigKeyGroup group) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(group) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(group)) = pc ⊔ level(group) ⊔ obj_level(group);
  ret(obj_level(this)) = pc ⊔ level(group) ⊔ obj_level(group) ⊔ obj_level(this);
}