static java.lang.Object org.apache.bookkeeper.common.util.JsonUtil:fromJson (
  java.lang.String jsonStr, java.lang.Class valueType) {
  guard = tt;
  ret(level()) = pc ⊔ level(jsonStr) ⊔ level(valueType) ⊔ obj_level(jsonStr) ⊔ obj_level(valueType);
  ret(obj_level()) = pc ⊔ level(jsonStr) ⊔ level(valueType) ⊔ obj_level(jsonStr) ⊔ obj_level(valueType);
