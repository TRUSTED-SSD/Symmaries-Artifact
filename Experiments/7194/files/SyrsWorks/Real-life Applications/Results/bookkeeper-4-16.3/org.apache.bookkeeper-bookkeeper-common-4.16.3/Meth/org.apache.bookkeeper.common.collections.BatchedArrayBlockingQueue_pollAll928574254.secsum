int org.apache.bookkeeper.common.collections.BatchedArrayBlockingQueue:pollAll (
  java.lang.Object[] array, long timeout, java.util.concurrent.TimeUnit unit) {
  guard = tt;
  ret(level()) = pc ⊔ level(array) ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(array)) = pc ⊔ level(array) ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(this)) = pc ⊔ level(array) ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(unit)) = pc ⊔ level(array) ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
}