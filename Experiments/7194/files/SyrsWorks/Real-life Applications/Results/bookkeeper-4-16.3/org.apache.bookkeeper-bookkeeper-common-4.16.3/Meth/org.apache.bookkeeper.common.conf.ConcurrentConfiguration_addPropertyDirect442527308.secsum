void org.apache.bookkeeper.common.conf.ConcurrentConfiguration:addPropertyDirect (
  java.lang.String key, java.lang.Object value) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key);
  ret(obj_level(value)) = pc ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key);
}