boolean org.apache.bookkeeper.common.conf.validators.RangeValidator:validate (
  java.lang.String name, java.lang.Object value) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
  ret(obj_level(name)) = pc ⊔ level(this) ⊔ level(value) ⊔ obj_level(name);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
  ret(obj_level(value)) = pc ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
}