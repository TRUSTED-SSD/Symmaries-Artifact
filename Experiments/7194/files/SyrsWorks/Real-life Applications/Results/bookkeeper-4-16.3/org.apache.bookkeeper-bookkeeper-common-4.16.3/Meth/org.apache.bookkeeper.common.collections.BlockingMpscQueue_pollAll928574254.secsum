int org.apache.bookkeeper.common.collections.BlockingMpscQueue:pollAll (
  java.lang.Object[] array, long timeout, java.util.concurrent.TimeUnit unit) {
  guard = tt;
  ret(level()) = pc ⊔ level(array) ⊔ level(this) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(array)) = pc ⊔ level(array) ⊔ level(this) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(this)) = pc ⊔ level(array) ⊔ level(this) ⊔ obj_level(array) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(unit)) = if obj_level(unit) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(unit) = ⊥ ∧ level(array) ⊔ level(this) ⊔ obj_level(array) ⊔ obj_level(this) = ⊤ then ⊤ else ⊥;
}