org.apache.bookkeeper.common.stats.OpStatsListener (org.apache.bookkeeper.stats.OpStatsLogger
                                                      opStatsLogger,
                                                    com.google.common.base.Stopwatch
                                                      @stopwatch) {
  guard = tt;
  ret(obj_level(@stopwatch)) = pc ⊔ level(@stopwatch) ⊔ level(this) ⊔ obj_level(@stopwatch) ⊔ obj_level(this);
  ret(obj_level(opStatsLogger)) = pc ⊔ level(this) ⊔ obj_level(opStatsLogger) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@stopwatch) ⊔ level(opStatsLogger) ⊔ level(this) ⊔ obj_level(@stopwatch) ⊔ obj_level(opStatsLogger) ⊔ obj_level(this);
}