org.apache.bookkeeper.common.conf.validators.RangeValidator (java.lang.Number
                                                               min,
                                                             java.lang.Number
                                                               max) {
  guard = tt;
  ret(obj_level(max)) = pc ⊔ level(this) ⊔ obj_level(max) ⊔ obj_level(this);
  ret(obj_level(min)) = pc ⊔ level(this) ⊔ obj_level(min) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(max) ⊔ level(min) ⊔ level(this) ⊔ obj_level(max) ⊔ obj_level(this);
}