org.apache.bookkeeper.common.conf.ConfigKey org.apache.bookkeeper.common.conf.ConfigKey:type (
  org.apache.bookkeeper.common.conf.Type type) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(this)) = pc ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(type) ⊔ obj_level(type);
}