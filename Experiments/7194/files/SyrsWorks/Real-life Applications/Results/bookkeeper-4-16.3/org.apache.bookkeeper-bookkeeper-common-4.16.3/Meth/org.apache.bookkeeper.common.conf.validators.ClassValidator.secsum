org.apache.bookkeeper.common.conf.validators.ClassValidator (java.lang.Class
                                                               interfaceClass) {
  guard = tt;
  ret(obj_level(interfaceClass)) = pc ⊔ level(interfaceClass) ⊔ level(this) ⊔ obj_level(interfaceClass) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(interfaceClass) ⊔ level(this) ⊔ obj_level(interfaceClass) ⊔ obj_level(this);
}