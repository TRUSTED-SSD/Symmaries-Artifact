void org.apache.bookkeeper.common.conf.ConfigDef:writeConfigKeyGroup (
  java.io.PrintStream stream,
  org.apache.bookkeeper.common.conf.ConfigKeyGroup group) {
  guard = pc ⊔ level(group) ⊔ level(stream) ⊔ obj_level(group) ⊔ obj_level(stream) = ⊥;
  ret(obj_level(group)) = ⊥;
  ret(obj_level(stream)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}