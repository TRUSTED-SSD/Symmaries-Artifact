void org.apache.bookkeeper.common.component.ComponentInfoPublisher:publishProperty (
  java.lang.String @key, java.lang.String value) {
  guard = pc ⊔ level(@key) ⊔ level(value) ⊔ obj_level(@key) = ⊥;
  ret(obj_level(@key)) = level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = level(this) ⊔ obj_level(this);
  ret(obj_level(value)) = level(this) ⊔ obj_level(this);
}