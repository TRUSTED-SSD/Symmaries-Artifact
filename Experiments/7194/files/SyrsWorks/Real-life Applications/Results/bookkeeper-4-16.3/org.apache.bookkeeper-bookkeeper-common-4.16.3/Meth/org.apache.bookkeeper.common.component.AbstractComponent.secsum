org.apache.bookkeeper.common.component.AbstractComponent (java.lang.String
                                                            name,
                                                          org.apache.bookkeeper.common.conf.ComponentConfiguration
                                                            conf) {
  guard = tt;
  ret(obj_level(conf)) = pc ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(name)) = pc ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(name) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(name) ⊔ obj_level(this);
}