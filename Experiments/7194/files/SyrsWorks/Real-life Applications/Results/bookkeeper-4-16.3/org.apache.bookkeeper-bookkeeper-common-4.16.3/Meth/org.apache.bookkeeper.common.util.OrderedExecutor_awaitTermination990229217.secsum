boolean org.apache.bookkeeper.common.util.OrderedExecutor:awaitTermination (
  long timeout, java.util.concurrent.TimeUnit unit) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(this) ⊔ obj_level(unit);
  ret(obj_level(unit)) = pc ⊔ level(this) ⊔ level(timeout) ⊔ level(unit) ⊔ obj_level(this) ⊔ obj_level(unit);
}