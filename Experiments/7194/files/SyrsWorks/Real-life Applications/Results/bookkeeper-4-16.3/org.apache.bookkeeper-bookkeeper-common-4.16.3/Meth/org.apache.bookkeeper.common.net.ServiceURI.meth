org.apache.bookkeeper.common.net.ServiceURI(java.lang.String serviceName,java.lang.String[] serviceInfos,java.lang.String serviceUser,java.lang.String[] serviceHosts,java.lang.String servicePath,java.net.URI uri)
{
this#java.lang.Object();
 this.serviceName=serviceName;
 this.serviceInfos=serviceInfos;
 this.serviceUser=serviceUser;
 this.serviceHosts=serviceHosts;
 this.servicePath=servicePath;
 this.uri=uri;
 return;
 } 

