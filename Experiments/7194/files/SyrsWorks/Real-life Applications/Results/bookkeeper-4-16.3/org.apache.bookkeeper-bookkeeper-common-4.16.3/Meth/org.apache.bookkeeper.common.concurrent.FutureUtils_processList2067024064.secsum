static java.util.concurrent.CompletableFuture org.apache.bookkeeper.common.concurrent.FutureUtils:processList (
  java.util.List collection, java.util.function.Function processFunc,
  java.util.concurrent.ExecutorService callbackExecutor) {
  guard = pc ⊔ level(callbackExecutor) ⊔ level(collection) ⊔ level(processFunc) ⊔ obj_level(callbackExecutor) ⊔ obj_level(collection) ⊔ obj_level(processFunc) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(callbackExecutor)) = ⊥;
