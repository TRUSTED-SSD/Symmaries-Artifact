static java.lang.String org.apache.bookkeeper.common.net.ServiceURI:validateHostName (
  java.lang.String @serviceName, java.lang.String hostname) {
  guard = tt;
  ret(level()) = pc ⊔ level(hostname) ⊔ obj_level(@serviceName);
  ret(obj_level()) = pc ⊔ level(hostname) ⊔ obj_level(@serviceName);
  ret(obj_level(@serviceName)) = pc ⊔ level(hostname) ⊔ obj_level(@serviceName);
  ret(obj_level(hostname)) = pc ⊔ level(hostname) ⊔ obj_level(@serviceName);
}