void org.apache.bookkeeper.common.conf.ConfigDef:validate (org.apache.commons.configuration.Configuration
                                                             conf) {
  guard = pc ⊔ level(conf) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this) = ⊥;
  ret(obj_level(conf)) = ⊥;
  ret(obj_level(this)) = ⊥;
}