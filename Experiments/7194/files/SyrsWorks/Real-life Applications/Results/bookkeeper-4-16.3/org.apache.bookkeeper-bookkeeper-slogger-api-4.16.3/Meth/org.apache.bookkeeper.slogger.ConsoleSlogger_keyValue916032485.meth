static void org.apache.bookkeeper.slogger.ConsoleSlogger:keyValue(java.lang.StringBuilder sb,java.lang.String key,java.lang.String value)
{
org.apache.bookkeeper.slogger.ConsoleSlogger.quotedAppend(sb,key);
 sb.append(":");
 org.apache.bookkeeper.slogger.ConsoleSlogger.quotedAppend(sb,value);
 return;
 } 

