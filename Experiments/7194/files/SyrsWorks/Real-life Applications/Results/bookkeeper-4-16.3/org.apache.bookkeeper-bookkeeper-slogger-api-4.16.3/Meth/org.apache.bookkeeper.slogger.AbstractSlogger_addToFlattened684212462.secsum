void org.apache.bookkeeper.slogger.AbstractSlogger:addToFlattened (java.lang.String
                                                                    key,
                                                                   java.lang.String
                                                                    value) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ level(value) ⊔ obj_level(key) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ level(value) ⊔ obj_level(key) ⊔ obj_level(this);
  ret(obj_level(value)) = pc ⊔ level(key) ⊔ level(value) ⊔ obj_level(key) ⊔ obj_level(this);
}