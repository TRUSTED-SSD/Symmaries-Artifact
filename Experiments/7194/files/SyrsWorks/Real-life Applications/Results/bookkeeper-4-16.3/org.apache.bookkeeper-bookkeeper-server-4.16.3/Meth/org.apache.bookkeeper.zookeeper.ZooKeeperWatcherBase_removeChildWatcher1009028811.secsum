org.apache.bookkeeper.zookeeper.ZooKeeperWatcherBase org.apache.bookkeeper.zookeeper.ZooKeeperWatcherBase:removeChildWatcher (
  org.apache.zookeeper.Watcher watcher) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this);
  ret(obj_level(watcher)) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this);
}