org.apache.bookkeeper.discover.ZKRegistrationManager (org.apache.bookkeeper.conf.ServerConfiguration
                                                        conf,
                                                      org.apache.zookeeper.ZooKeeper
                                                        zk) {
  guard = tt;
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(zk)) = pc ⊔ level(conf) ⊔ obj_level(conf) ⊔ obj_level(zk);
}