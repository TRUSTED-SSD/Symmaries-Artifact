org.apache.bookkeeper.client.UpdateLedgerOp (org.apache.bookkeeper.client.BookKeeper
                                               bkc,
                                             org.apache.bookkeeper.client.BookKeeperAdmin
                                               admin) {
  guard = tt;
  ret(obj_level(admin)) = pc ⊔ level(admin) ⊔ level(bkc) ⊔ level(this) ⊔ obj_level(admin) ⊔ obj_level(bkc) ⊔ obj_level(this);
  ret(obj_level(bkc)) = pc ⊔ level(admin) ⊔ level(bkc) ⊔ level(this) ⊔ obj_level(admin) ⊔ obj_level(bkc) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(admin) ⊔ level(bkc) ⊔ level(this) ⊔ obj_level(admin) ⊔ obj_level(bkc) ⊔ obj_level(this);
}