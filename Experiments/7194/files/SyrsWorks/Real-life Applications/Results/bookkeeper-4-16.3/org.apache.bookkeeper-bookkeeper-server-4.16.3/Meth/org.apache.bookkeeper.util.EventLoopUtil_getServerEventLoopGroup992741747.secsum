static io.netty.channel.EventLoopGroup org.apache.bookkeeper.util.EventLoopUtil:getServerEventLoopGroup (
  org.apache.bookkeeper.conf.ServerConfiguration conf,
  java.util.concurrent.ThreadFactory threadFactory) {
  guard = tt;
  ret(level()) = pc ⊔ level(conf) ⊔ level(threadFactory) ⊔ obj_level(conf) ⊔ obj_level(threadFactory);
  ret(obj_level()) = pc ⊔ level(conf) ⊔ level(threadFactory) ⊔ obj_level(conf) ⊔ obj_level(threadFactory);
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level(threadFactory)) = pc ⊔ level(conf) ⊔ obj_level(conf) ⊔ obj_level(threadFactory);
}