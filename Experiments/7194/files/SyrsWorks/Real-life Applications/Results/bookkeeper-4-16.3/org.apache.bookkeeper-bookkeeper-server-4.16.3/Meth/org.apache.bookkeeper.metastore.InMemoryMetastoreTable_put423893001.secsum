                                                                   cb,
                                                                 java.lang.Object
                                                                   ctx) {
  guard = tt;
  ret(obj_level(cb)) = pc ⊔ level(cb) ⊔ level(ctx) ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ level(version) ⊔ obj_level(key);
  ret(obj_level(ctx)) = pc ⊔ level(cb) ⊔ level(ctx) ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ level(version) ⊔ obj_level(key);
  ret(obj_level(key)) = pc ⊔ level(cb) ⊔ level(ctx) ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ level(version) ⊔ obj_level(key);
  ret(obj_level(this)) = pc ⊔ level(cb) ⊔ level(ctx) ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ level(version) ⊔ obj_level(key);
  ret(obj_level(value)) = pc ⊔ level(cb) ⊔ level(ctx) ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ level(version) ⊔ obj_level(key);
  ret(obj_level(version)) = pc ⊔ level(cb) ⊔ level(ctx) ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ level(version) ⊔ obj_level(version);
