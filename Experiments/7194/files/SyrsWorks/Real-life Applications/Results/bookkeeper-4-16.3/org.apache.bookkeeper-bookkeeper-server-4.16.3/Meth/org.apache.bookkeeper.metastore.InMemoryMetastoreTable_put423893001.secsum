void org.apache.bookkeeper.metastore.InMemoryMetastoreTable:put (java.lang.String
                                                                   key,
                                                                 org.apache.bookkeeper.metastore.Value
                                                                   value,
                                                                 org.apache.bookkeeper.versioning.Version
                                                                   version,
