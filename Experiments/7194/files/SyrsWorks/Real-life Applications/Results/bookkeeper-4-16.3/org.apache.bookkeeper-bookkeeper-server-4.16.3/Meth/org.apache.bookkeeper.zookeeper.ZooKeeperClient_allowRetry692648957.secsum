boolean org.apache.bookkeeper.zookeeper.ZooKeeperClient:allowRetry (org.apache.bookkeeper.zookeeper.ZooWorker
                                                                    worker,
                                                                    int rc) {
  guard = tt;
  ret(level()) = pc ⊔ level(rc) ⊔ level(worker) ⊔ obj_level(this) ⊔ obj_level(worker);
  ret(obj_level(this)) = pc ⊔ level(rc) ⊔ level(worker) ⊔ obj_level(this) ⊔ obj_level(worker);
  ret(obj_level(worker)) = pc ⊔ level(rc) ⊔ level(worker) ⊔ obj_level(worker);
}