org.apache.bookkeeper.zookeeper.ExponentialBackoffRetryPolicy (long
                                                                 baseBackoffTime,
                                                               int maxRetries) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(baseBackoffTime) ⊔ level(maxRetries) ⊔ level(this) ⊔ obj_level(this);
}