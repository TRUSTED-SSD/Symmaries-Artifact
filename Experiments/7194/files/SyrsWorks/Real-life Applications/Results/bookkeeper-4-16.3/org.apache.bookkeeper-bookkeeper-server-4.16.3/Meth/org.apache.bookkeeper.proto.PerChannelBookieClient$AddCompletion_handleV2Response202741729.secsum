void org.apache.bookkeeper.proto.PerChannelBookieClient$AddCompletion:handleV2Response (
  long ledgerId, long entryId,
  org.apache.bookkeeper.proto.BookkeeperProtocol$StatusCode status,
  org.apache.bookkeeper.proto.BookieProtocol$Response response) {
  guard = pc = ⊥;
  ret(obj_level(response)) = level(entryId) ⊔ level(ledgerId) ⊔ level(status) ⊔ level(this) ⊔ obj_level(response) ⊔ obj_level(status) ⊔ obj_level(this);
  ret(obj_level(status)) = level(entryId) ⊔ level(ledgerId) ⊔ level(status) ⊔ level(this) ⊔ obj_level(status) ⊔ obj_level(this);
  ret(obj_level(this)) = level(entryId) ⊔ level(ledgerId) ⊔ level(status) ⊔ level(this) ⊔ obj_level(status) ⊔ obj_level(this);
}