io.netty.buffer.ByteBuf org.apache.bookkeeper.bookie.BookieImpl:createExplicitLACEntry (
  long ledgerId, io.netty.buffer.ByteBuf explicitLac) {
  guard = tt;
  ret(level()) = pc ⊔ level(explicitLac) ⊔ level(this) ⊔ obj_level(explicitLac) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(explicitLac) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(explicitLac) ⊔ obj_level(this);
  ret(obj_level(explicitLac)) = pc ⊔ level(explicitLac) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(explicitLac) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(explicitLac) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(explicitLac) ⊔ obj_level(this);
}