boolean org.apache.bookkeeper.bookie.LedgerDirsManager:isDirWritableForNewIndexFile (
  java.io.File indexDir) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(indexDir) ⊔ obj_level(this);
  ret(obj_level(indexDir)) = obj_level(indexDir);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(indexDir) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}