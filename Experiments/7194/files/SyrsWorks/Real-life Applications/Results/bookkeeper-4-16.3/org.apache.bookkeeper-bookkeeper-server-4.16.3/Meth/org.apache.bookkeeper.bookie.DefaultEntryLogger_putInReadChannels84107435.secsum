org.apache.bookkeeper.bookie.BufferedReadChannel org.apache.bookkeeper.bookie.DefaultEntryLogger:putInReadChannels (
  long logId, org.apache.bookkeeper.bookie.BufferedReadChannel @bc) {
  guard = tt;
  ret(level()) = pc ⊔ level(@bc) ⊔ level(logId) ⊔ obj_level(@bc) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@bc) ⊔ level(logId) ⊔ obj_level(@bc) ⊔ obj_level(this);
  ret(obj_level(@bc)) = pc ⊔ level(@bc) ⊔ level(logId) ⊔ obj_level(@bc) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@bc) ⊔ level(logId) ⊔ obj_level(@bc) ⊔ obj_level(this);
}