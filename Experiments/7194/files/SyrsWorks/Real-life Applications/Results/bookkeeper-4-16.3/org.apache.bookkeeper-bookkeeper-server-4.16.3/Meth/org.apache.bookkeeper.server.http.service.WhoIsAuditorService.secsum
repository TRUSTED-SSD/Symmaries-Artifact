org.apache.bookkeeper.server.http.service.WhoIsAuditorService (org.apache.bookkeeper.conf.ServerConfiguration
                                                                 conf,
                                                               org.apache.bookkeeper.client.BookKeeperAdmin
                                                                 bka) {
  guard = tt;
  ret(obj_level(bka)) = pc ⊔ level(bka) ⊔ level(conf) ⊔ level(this) ⊔ obj_level(bka) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bka) ⊔ level(conf) ⊔ level(this) ⊔ obj_level(bka) ⊔ obj_level(conf) ⊔ obj_level(this);
}