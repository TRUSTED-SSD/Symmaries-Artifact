org.apache.bookkeeper.conf.AbstractConfiguration org.apache.bookkeeper.conf.AbstractConfiguration:setAllocatorPoolingConcurrenncy (
  int concurrency) {
  guard = tt;
  ret(level()) = pc ⊔ level(concurrency) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(concurrency) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(concurrency) ⊔ level(this) ⊔ obj_level(this);
}