org.apache.bookkeeper.auth.ClientAuthProvider org.apache.bookkeeper.sasl.SASLClientProviderFactory:newProvider (
  org.apache.bookkeeper.proto.ClientConnectionPeer addr,
  org.apache.bookkeeper.auth.AuthCallbacks$GenericCallback completeCb) {
  guard = pc ⊔ level(addr) ⊔ level(completeCb) ⊔ level(this) ⊔ obj_level(addr) ⊔ obj_level(completeCb) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(addr)) = ⊥;
  ret(obj_level(completeCb)) = ⊥;
  ret(obj_level(this)) = ⊥;
}