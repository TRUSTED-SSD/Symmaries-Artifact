org.apache.bookkeeper.auth.BookieAuthProvider org.apache.bookkeeper.sasl.SASLBookieAuthProviderFactory:newProvider (
  org.apache.bookkeeper.proto.BookieConnectionPeer addr,
  org.apache.bookkeeper.auth.AuthCallbacks$GenericCallback completeCb) {
  guard = pc ⊔ level(completeCb) ⊔ level(this) ⊔ obj_level(completeCb) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = obj_level(addr);
  ret(obj_level(addr)) = obj_level(addr);
  ret(obj_level(completeCb)) = obj_level(addr);
  ret(obj_level(this)) = obj_level(addr);
}