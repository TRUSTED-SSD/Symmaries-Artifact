static java.io.File org.apache.bookkeeper.bookie.DefaultEntryLogger:compactedLogFileFromCompacting (
  java.io.File @compactionLogFile, long compactingLogId) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(compactingLogId) ⊔ obj_level(@compactionLogFile);
  ret(obj_level(@compactionLogFile)) = pc ⊔ level(compactingLogId) ⊔ obj_level(@compactionLogFile);
}