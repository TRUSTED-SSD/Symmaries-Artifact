org.apache.bookkeeper.feature.FixedValueFeature (java.lang.String name,
                                                 int availability) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(availability) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
}