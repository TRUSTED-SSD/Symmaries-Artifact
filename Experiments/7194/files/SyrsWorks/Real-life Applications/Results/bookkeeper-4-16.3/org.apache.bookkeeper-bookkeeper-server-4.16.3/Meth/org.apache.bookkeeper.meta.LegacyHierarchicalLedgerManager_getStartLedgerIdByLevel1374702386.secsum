long org.apache.bookkeeper.meta.LegacyHierarchicalLedgerManager:getStartLedgerIdByLevel (
  java.lang.String level1, java.lang.String level2) {
  guard = tt;
  ret(level()) = pc ⊔ level(level1) ⊔ level(level2) ⊔ obj_level(level1);
  ret(obj_level(level1)) = pc ⊔ level(level1) ⊔ level(level2) ⊔ obj_level(level1) ⊔ obj_level(this);
  ret(obj_level(level2)) = pc ⊔ level(level1) ⊔ level(level2) ⊔ obj_level(level1) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(level1) ⊔ level(level2) ⊔ obj_level(level1) ⊔ obj_level(this);
}