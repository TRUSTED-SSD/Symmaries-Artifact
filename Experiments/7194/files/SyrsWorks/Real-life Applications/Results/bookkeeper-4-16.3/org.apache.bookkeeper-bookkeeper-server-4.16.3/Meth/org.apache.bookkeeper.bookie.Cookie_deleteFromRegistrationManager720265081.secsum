void org.apache.bookkeeper.bookie.Cookie:deleteFromRegistrationManager (
  org.apache.bookkeeper.discover.RegistrationManager rm,
  org.apache.bookkeeper.net.BookieId address,
  org.apache.bookkeeper.versioning.Version version) {
  guard = tt;
  ret(obj_level(address)) = pc ⊔ level(version) ⊔ obj_level(address) ⊔ obj_level(version);
  ret(obj_level(rm)) = pc ⊔ level(version) ⊔ obj_level(rm) ⊔ obj_level(version);
  ret(obj_level(this)) = pc ⊔ level(version) ⊔ obj_level(this) ⊔ obj_level(version);
  ret(obj_level(version)) = obj_level(version);
}