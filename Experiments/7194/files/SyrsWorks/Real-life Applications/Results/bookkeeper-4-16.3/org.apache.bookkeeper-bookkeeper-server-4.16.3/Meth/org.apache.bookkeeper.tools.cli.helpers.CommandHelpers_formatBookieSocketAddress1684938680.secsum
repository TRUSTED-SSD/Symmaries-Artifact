static java.lang.String org.apache.bookkeeper.tools.cli.helpers.CommandHelpers:formatBookieSocketAddress (
  org.apache.bookkeeper.net.BookieId bookieId, java.lang.String @ip,
  int port, java.lang.String hostName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@ip) ⊔ level(bookieId) ⊔ level(hostName) ⊔ level(port) ⊔ obj_level(@ip) ⊔ obj_level(bookieId);
  ret(obj_level()) = pc ⊔ level(@ip) ⊔ level(bookieId) ⊔ level(hostName) ⊔ level(port) ⊔ obj_level(@ip) ⊔ obj_level(bookieId);
  ret(obj_level(@ip)) = pc ⊔ level(@ip) ⊔ level(bookieId) ⊔ level(hostName) ⊔ level(port) ⊔ obj_level(@ip) ⊔ obj_level(bookieId);
  ret(obj_level(bookieId)) = pc ⊔ level(@ip) ⊔ level(bookieId) ⊔ level(hostName) ⊔ level(port) ⊔ obj_level(@ip) ⊔ obj_level(bookieId);
  ret(obj_level(hostName)) = pc ⊔ level(@ip) ⊔ level(bookieId) ⊔ level(hostName) ⊔ level(port) ⊔ obj_level(@ip) ⊔ obj_level(bookieId);
}