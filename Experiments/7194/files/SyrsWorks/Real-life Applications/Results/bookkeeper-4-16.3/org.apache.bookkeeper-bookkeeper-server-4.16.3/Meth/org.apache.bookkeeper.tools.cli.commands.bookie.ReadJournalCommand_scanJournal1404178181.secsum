void org.apache.bookkeeper.tools.cli.commands.bookie.ReadJournalCommand:scanJournal (
  org.apache.bookkeeper.bookie.Journal journal, long journalId,
  boolean printMsg) {
  guard = pc ⊔ level(journalId) = ⊥;
  ret(obj_level(journal)) = level(printMsg) ⊔ level(this) ⊔ obj_level(journal) ⊔ obj_level(this);
  ret(obj_level(this)) = level(printMsg) ⊔ level(this) ⊔ obj_level(this);
}