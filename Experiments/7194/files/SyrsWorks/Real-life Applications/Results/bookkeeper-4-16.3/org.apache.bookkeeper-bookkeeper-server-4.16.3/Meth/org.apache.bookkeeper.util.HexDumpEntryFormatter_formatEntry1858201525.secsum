void org.apache.bookkeeper.util.HexDumpEntryFormatter:formatEntry (byte[]
                                                                    data) {
  guard = tt;
  ret(obj_level(data)) = pc ⊔ level(data) ⊔ obj_level(data);
  ret(obj_level(this)) = pc ⊔ level(data) ⊔ obj_level(data) ⊔ obj_level(this);
}