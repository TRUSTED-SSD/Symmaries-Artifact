org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLoggerStats (
  org.apache.bookkeeper.stats.StatsLogger stats) {
  guard = tt;
  ret(obj_level(stats)) = pc ⊔ level(stats) ⊔ obj_level(stats);
  ret(obj_level(this)) = pc ⊔ level(stats) ⊔ level(this) ⊔ obj_level(stats) ⊔ obj_level(this);
}