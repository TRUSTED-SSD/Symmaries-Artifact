static org.apache.bookkeeper.client.ClientInternalConf org.apache.bookkeeper.client.ClientInternalConf:fromConfig(org.apache.bookkeeper.conf.ClientConfiguration conf)
{
org.apache.bookkeeper.feature.FeatureProvider $stack1;
  org.apache.bookkeeper.client.ClientInternalConf $stack2;
  $stack1=org.apache.bookkeeper.feature.SettableFeatureProvider.DISABLE_ALL;
 $stack2 = org.apache.bookkeeper.client.ClientInternalConf.fromConfigAndFeatureProvider(conf,$stack1);
 return  $stack2;
 } 

