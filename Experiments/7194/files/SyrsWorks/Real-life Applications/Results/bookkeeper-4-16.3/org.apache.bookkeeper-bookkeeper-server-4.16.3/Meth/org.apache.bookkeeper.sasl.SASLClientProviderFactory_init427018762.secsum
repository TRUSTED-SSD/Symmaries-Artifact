void org.apache.bookkeeper.sasl.SASLClientProviderFactory:init (org.apache.bookkeeper.conf.ClientConfiguration
                                                                  @conf) {
  guard = pc ⊔ level(@conf) ⊔ level(this) ⊔ obj_level(@conf) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@conf)) = ⊥;
  ret(obj_level(this)) = ⊥;
}