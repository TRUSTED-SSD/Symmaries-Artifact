boolean org.apache.bookkeeper.bookie.LedgerCacheImpl:waitForLastAddConfirmedUpdate (
  long ledgerId, long previousLAC,
  org.apache.bookkeeper.common.util.Watcher watcher) {
  guard = pc ⊔ level(ledgerId) ⊔ level(previousLAC) ⊔ level(this) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(this)) = ⊤;
  ret(obj_level(watcher)) = ⊤;
}