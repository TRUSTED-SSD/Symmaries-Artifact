byte[] org.apache.bookkeeper.sasl.SaslClientState:saslResponse (byte[]
                                                                  @saslTokenMessage) {
  guard = tt;
  ret(level()) = pc ⊔ level(@saslTokenMessage) ⊔ level(this) ⊔ obj_level(@saslTokenMessage) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@saslTokenMessage) ⊔ level(this) ⊔ obj_level(@saslTokenMessage) ⊔ obj_level(this);
  ret(obj_level(@saslTokenMessage)) = obj_level(@saslTokenMessage);
  ret(obj_level(this)) = pc ⊔ level(@saslTokenMessage) ⊔ level(this) ⊔ obj_level(@saslTokenMessage) ⊔ obj_level(this);
}