  org.apache.bookkeeper.bookie.LedgerCache$PageEntriesIterable pages) {
  guard = tt;
  ret(level()) = pc ⊔ level(isFenced) ⊔ level(ledgerId) ⊔ level(masterKey) ⊔ level(pages) ⊔ level(this) ⊔ obj_level(masterKey) ⊔ obj_level(pages) ⊔ obj_level(this);
  ret(obj_level(masterKey)) = pc ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(masterKey) ⊔ obj_level(this);
  ret(obj_level(pages)) = pc ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(pages) ⊔ obj_level(this);
