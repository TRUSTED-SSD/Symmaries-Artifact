boolean org.apache.bookkeeper.tools.cli.commands.bookies.RecoverCommand:bkRecoveryLedger (
  org.apache.bookkeeper.client.BookKeeperAdmin bkAdmin, long lid,
  java.util.Set bookieAddrs, boolean dryrun, boolean skipOpenLedgers,
  boolean removeCookies) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level(bkAdmin)) = if obj_level(bkAdmin) = ⊤ ∨ pc ≠ ⊤ ∧ level(removeCookies) = ⊤ ∧ (if obj_level(this) = ⊤ then obj_level(bkAdmin) = ⊥ else obj_level(bkAdmin) = ⊥ ∧ obj_level(bookieAddrs) = ⊤ ∧ obj_level(this) = ⊥) then ⊤ else ⊥;
  ret(obj_level(bookieAddrs)) = if obj_level(bookieAddrs) = ⊤ ∨ pc ≠ ⊤ ∧ level(removeCookies) = ⊤ ∧ (if obj_level(this) = ⊤ then obj_level(bookieAddrs) = ⊥ else obj_level(bkAdmin) = ⊤ ∧ obj_level(bookieAddrs) = ⊥ ∧ obj_level(this) = ⊥) then ⊤ else ⊥;
  ret(obj_level(this)) = obj_level(this);
}