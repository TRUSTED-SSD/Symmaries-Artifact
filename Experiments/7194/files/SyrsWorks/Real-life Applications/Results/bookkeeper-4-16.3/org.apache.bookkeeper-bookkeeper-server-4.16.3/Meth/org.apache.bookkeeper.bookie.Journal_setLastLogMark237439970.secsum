void org.apache.bookkeeper.bookie.Journal:setLastLogMark (java.lang.Long id,
                                                          long scanOffset) {
  guard = tt;
  ret(obj_level(id)) = pc ⊔ level(id) ⊔ level(scanOffset) ⊔ obj_level(id) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(id) ⊔ level(scanOffset) ⊔ obj_level(id) ⊔ obj_level(this);
}