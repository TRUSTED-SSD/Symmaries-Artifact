void org.apache.bookkeeper.proto.checksum.StandardCRC32Digest:update (
  io.netty.buffer.ByteBuf @buf, int offset, int len) {
  guard = tt;
  ret(obj_level(@buf)) = pc ⊔ level(@buf) ⊔ level(len) ⊔ level(offset) ⊔ obj_level(@buf);
  ret(obj_level(this)) = pc ⊔ level(@buf) ⊔ level(len) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(@buf) ⊔ obj_level(this);
}