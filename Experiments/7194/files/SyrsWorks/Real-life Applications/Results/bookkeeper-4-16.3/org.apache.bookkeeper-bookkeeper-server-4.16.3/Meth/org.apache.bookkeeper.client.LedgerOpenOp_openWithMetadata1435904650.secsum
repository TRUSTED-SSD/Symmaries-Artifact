void org.apache.bookkeeper.client.LedgerOpenOp:openWithMetadata (org.apache.bookkeeper.versioning.Versioned
                                                                   versionedMetadata) {
  guard = pc ⊔ level(this) ⊔ level(versionedMetadata) ⊔ obj_level(this) ⊔ obj_level(versionedMetadata) = ⊥;
  ret(obj_level(this)) = ⊥;
  ret(obj_level(versionedMetadata)) = ⊥;
}