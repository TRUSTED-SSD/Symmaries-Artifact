  ret(obj_level(metadata)) = pc ⊔ level(allocator) ⊔ level(metadata) ⊔ level(this) ⊔ level(writer) ⊔ obj_level(allocator) ⊔ obj_level(metadata) ⊔ obj_level(this) ⊔ obj_level(writer);
  ret(obj_level(this)) = pc ⊔ level(allocator) ⊔ level(metadata) ⊔ level(this) ⊔ level(writer) ⊔ obj_level(allocator) ⊔ obj_level(metadata) ⊔ obj_level(this) ⊔ obj_level(writer);
