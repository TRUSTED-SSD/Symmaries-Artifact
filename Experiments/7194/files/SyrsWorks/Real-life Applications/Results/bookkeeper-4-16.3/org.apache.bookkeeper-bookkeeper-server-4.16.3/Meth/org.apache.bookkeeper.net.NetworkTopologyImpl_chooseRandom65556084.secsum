org.apache.bookkeeper.net.Node org.apache.bookkeeper.net.NetworkTopologyImpl:chooseRandom (
  java.lang.String scope, java.lang.String @excludedScope) {
  guard = tt;
  ret(level()) = pc ⊔ level(@excludedScope) ⊔ level(scope) ⊔ level(this) ⊔ obj_level(@excludedScope) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@excludedScope) ⊔ level(scope) ⊔ level(this) ⊔ obj_level(@excludedScope) ⊔ obj_level(this);
  ret(obj_level(@excludedScope)) = pc ⊔ level(@excludedScope) ⊔ level(scope) ⊔ level(this) ⊔ obj_level(@excludedScope) ⊔ obj_level(this);
  ret(obj_level(scope)) = pc ⊔ level(@excludedScope) ⊔ level(scope) ⊔ level(this) ⊔ obj_level(@excludedScope) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@excludedScope) ⊔ level(scope) ⊔ level(this) ⊔ obj_level(@excludedScope) ⊔ obj_level(this);
}