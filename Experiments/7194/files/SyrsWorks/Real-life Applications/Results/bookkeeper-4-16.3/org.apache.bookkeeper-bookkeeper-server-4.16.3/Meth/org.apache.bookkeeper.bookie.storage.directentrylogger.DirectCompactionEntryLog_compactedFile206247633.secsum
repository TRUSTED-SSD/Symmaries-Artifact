static java.io.File org.apache.bookkeeper.bookie.storage.directentrylogger.DirectCompactionEntryLog:compactedFile (
  java.io.File directory, int newLogId, int compactedLogId) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(compactedLogId) ⊔ level(directory) ⊔ level(newLogId) ⊔ obj_level(directory);
  ret(obj_level(directory)) = pc ⊔ level(compactedLogId) ⊔ level(directory) ⊔ level(newLogId) ⊔ obj_level(directory);
}