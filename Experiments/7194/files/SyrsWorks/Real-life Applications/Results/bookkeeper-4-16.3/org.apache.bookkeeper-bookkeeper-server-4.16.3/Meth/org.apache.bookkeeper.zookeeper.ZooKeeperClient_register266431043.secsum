void org.apache.bookkeeper.zookeeper.ZooKeeperClient:register (org.apache.zookeeper.Watcher
                                                                 watcher) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this);
  ret(obj_level(watcher)) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this);
}