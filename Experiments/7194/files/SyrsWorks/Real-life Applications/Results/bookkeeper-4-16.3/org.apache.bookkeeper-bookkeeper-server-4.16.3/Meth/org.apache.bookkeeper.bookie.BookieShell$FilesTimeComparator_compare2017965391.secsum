int org.apache.bookkeeper.bookie.BookieShell$FilesTimeComparator:compare (
  java.io.File file1, java.io.File file2) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(file1);
  ret(obj_level(file1)) = pc ⊔ obj_level(file1);
  ret(obj_level(file2)) = pc ⊔ obj_level(file1);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(file1) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}