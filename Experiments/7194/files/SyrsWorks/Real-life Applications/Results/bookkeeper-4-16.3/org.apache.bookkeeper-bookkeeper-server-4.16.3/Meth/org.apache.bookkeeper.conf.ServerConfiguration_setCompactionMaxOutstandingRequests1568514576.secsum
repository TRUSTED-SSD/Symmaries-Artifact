org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setCompactionMaxOutstandingRequests (
  int maxOutstandingRequests) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(maxOutstandingRequests) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(maxOutstandingRequests) ⊔ level(this) ⊔ obj_level(this);
}