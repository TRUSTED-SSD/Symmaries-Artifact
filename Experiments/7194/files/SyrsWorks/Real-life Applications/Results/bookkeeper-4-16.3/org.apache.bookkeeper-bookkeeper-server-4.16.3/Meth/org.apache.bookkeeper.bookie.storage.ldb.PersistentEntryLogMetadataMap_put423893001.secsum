void org.apache.bookkeeper.bookie.storage.ldb.PersistentEntryLogMetadataMap:put (
  long entryLogId,
  org.apache.bookkeeper.bookie.EntryLogMetadata entryLogMeta) {
  guard = tt;
  ret(obj_level(entryLogMeta)) = pc ⊔ level(entryLogId) ⊔ obj_level(entryLogMeta) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entryLogId) ⊔ obj_level(this);
}