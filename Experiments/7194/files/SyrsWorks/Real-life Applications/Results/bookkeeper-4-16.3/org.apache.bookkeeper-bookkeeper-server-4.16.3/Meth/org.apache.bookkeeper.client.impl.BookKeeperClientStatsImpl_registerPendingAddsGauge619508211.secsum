void org.apache.bookkeeper.client.impl.BookKeeperClientStatsImpl:registerPendingAddsGauge (
  org.apache.bookkeeper.stats.Gauge gauge) {
  guard = tt;
  ret(obj_level(gauge)) = pc ⊔ level(gauge) ⊔ level(this) ⊔ obj_level(gauge) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(gauge) ⊔ level(this) ⊔ obj_level(gauge) ⊔ obj_level(this);
}