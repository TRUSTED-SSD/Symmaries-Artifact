static java.lang.String org.apache.bookkeeper.client.BookKeeperAdmin:formatEnsemble (
  java.util.List ensemble, java.util.Set bookiesSrc, char marker) {
  guard = tt;
  ret(level()) = pc ⊔ level(bookiesSrc) ⊔ level(ensemble) ⊔ level(marker) ⊔ obj_level(bookiesSrc) ⊔ obj_level(ensemble);
  ret(obj_level()) = pc ⊔ level(bookiesSrc) ⊔ level(ensemble) ⊔ level(marker) ⊔ obj_level(bookiesSrc) ⊔ obj_level(ensemble);
  ret(obj_level(bookiesSrc)) = pc ⊔ level(bookiesSrc) ⊔ level(ensemble) ⊔ level(marker) ⊔ obj_level(bookiesSrc) ⊔ obj_level(ensemble);
  ret(obj_level(ensemble)) = pc ⊔ level(bookiesSrc) ⊔ level(ensemble) ⊔ level(marker) ⊔ obj_level(bookiesSrc) ⊔ obj_level(ensemble);
}