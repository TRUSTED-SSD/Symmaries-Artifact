boolean org.apache.bookkeeper.tools.cli.helpers.ClientCommand:apply (
  org.apache.bookkeeper.conf.ServerConfiguration conf,
  org.apache.bookkeeper.tools.framework.CliFlags cmdFlags) {
  guard = ff;
  ret(level()) = ⊥;
  ret(obj_level(cmdFlags)) = ⊥;
  ret(obj_level(conf)) = ⊥;
  ret(obj_level(this)) = ⊥;
}