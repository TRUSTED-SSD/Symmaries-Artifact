boolean org.apache.bookkeeper.client.BookieWatcherImpl:isBookieUnavailable (
  org.apache.bookkeeper.net.BookieId id) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(id) ⊔ obj_level(this);
  ret(obj_level(id)) = obj_level(id);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(id) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}