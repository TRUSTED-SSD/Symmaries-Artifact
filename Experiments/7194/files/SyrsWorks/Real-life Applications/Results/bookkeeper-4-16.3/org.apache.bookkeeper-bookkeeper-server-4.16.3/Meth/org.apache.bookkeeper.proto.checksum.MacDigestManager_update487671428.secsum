int org.apache.bookkeeper.proto.checksum.MacDigestManager:update (int digest,
                                                                  io.netty.buffer.ByteBuf
                                                                    @data,
                                                                  int offset,
                                                                  int len) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level(@data)) = pc ⊔ level(@data) ⊔ level(len) ⊔ level(offset) ⊔ obj_level(@data) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@data) ⊔ level(len) ⊔ level(offset) ⊔ obj_level(@data) ⊔ obj_level(this);
}