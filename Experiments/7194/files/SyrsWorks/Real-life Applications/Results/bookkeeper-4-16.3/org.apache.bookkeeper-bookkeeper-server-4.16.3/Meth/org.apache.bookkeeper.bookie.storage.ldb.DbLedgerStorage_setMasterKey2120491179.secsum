void org.apache.bookkeeper.bookie.storage.ldb.DbLedgerStorage:setMasterKey (
  long ledgerId, byte[] masterKey) {
  guard = pc = ⊥;
  ret(obj_level(masterKey)) = level(ledgerId) ⊔ level(this) ⊔ obj_level(masterKey) ⊔ obj_level(this);
  ret(obj_level(this)) = level(ledgerId) ⊔ level(this) ⊔ obj_level(this);
}