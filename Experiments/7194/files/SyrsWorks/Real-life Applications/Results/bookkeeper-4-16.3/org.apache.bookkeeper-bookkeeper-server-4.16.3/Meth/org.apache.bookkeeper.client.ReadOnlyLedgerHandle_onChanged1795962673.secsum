void org.apache.bookkeeper.client.ReadOnlyLedgerHandle:onChanged (long lid,
                                                                  org.apache.bookkeeper.versioning.Versioned
                                                                    newMetadata) {
  guard = pc ⊔ level(lid) ⊔ level(newMetadata) ⊔ level(this) ⊔ obj_level(newMetadata) ⊔ obj_level(this) = ⊥;
  ret(obj_level(newMetadata)) = ⊥;
  ret(obj_level(this)) = ⊥;
}