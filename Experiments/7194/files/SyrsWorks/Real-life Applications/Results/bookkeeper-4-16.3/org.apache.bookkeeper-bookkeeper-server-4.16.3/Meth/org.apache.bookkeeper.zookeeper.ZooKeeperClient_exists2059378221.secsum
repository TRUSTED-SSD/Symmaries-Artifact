org.apache.zookeeper.data.Stat org.apache.bookkeeper.zookeeper.ZooKeeperClient:exists (
  java.lang.String path, org.apache.zookeeper.Watcher watcher) {
  guard = tt;
  ret(level()) = pc ⊔ level(path) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(path) ⊔ obj_level(watcher);
  ret(obj_level()) = pc ⊔ level(path) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(path) ⊔ obj_level(watcher);
  ret(obj_level(path)) = pc ⊔ level(path) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(path) ⊔ obj_level(watcher);
  ret(obj_level(this)) = pc ⊔ level(path) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(path) ⊔ obj_level(watcher);
