  java.lang.Long lastLedger, boolean lastInclusive) {
  guard = tt;
  ret(level()) = pc ⊔ level(firstInclusive) ⊔ level(firstLedger) ⊔ level(lastInclusive) ⊔ level(lastLedger) ⊔ obj_level(firstLedger);
  ret(obj_level()) = pc ⊔ level(firstInclusive) ⊔ level(firstLedger) ⊔ level(lastInclusive) ⊔ level(lastLedger) ⊔ obj_level(firstLedger);
