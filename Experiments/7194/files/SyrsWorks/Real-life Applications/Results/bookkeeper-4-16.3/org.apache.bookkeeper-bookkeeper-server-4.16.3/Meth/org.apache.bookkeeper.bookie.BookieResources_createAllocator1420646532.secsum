static org.apache.bookkeeper.common.allocator.ByteBufAllocatorWithOomHandler org.apache.bookkeeper.bookie.BookieResources:createAllocator (
  org.apache.bookkeeper.conf.ServerConfiguration conf) {
  guard = tt;
  ret(level()) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level()) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ obj_level(conf);
}