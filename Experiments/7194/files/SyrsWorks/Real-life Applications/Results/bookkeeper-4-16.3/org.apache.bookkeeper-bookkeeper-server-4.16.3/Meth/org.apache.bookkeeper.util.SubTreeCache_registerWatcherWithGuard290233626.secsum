org.apache.bookkeeper.util.SubTreeCache$WatchGuard org.apache.bookkeeper.util.SubTreeCache:registerWatcherWithGuard (
  org.apache.zookeeper.Watcher watcher) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this) ⊔ obj_level(watcher);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this) ⊔ obj_level(watcher);
  ret(obj_level(watcher)) = pc ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this) ⊔ obj_level(watcher);
}