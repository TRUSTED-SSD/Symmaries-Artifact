void org.apache.bookkeeper.replication.ReplicationWorker:logBKExceptionAndReleaseLedger (
  org.apache.bookkeeper.client.BKException e, long ledgerIdToReplicate) {
  guard = pc = ⊥;
  ret(obj_level(e)) = level(ledgerIdToReplicate) ⊔ level(this) ⊔ obj_level(e) ⊔ obj_level(this);
  ret(obj_level(this)) = level(ledgerIdToReplicate) ⊔ level(this) ⊔ obj_level(e) ⊔ obj_level(this);
}