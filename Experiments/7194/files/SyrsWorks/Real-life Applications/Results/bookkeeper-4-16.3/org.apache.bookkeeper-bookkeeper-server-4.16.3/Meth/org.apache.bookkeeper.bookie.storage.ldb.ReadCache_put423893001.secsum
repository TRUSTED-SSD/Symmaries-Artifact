void org.apache.bookkeeper.bookie.storage.ldb.ReadCache:put (long ledgerId,
                                                             long entryId,
                                                             io.netty.buffer.ByteBuf
                                                               entry) {
  p1: io.netty.buffer.ByteBuf () -> level;
  guard = tt;
  ret(obj_level(entry)) = p1 ⊔ pc ⊔ level(entry) ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
  ret(obj_level(this)) = p1 ⊔ pc ⊔ level(entry) ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
}