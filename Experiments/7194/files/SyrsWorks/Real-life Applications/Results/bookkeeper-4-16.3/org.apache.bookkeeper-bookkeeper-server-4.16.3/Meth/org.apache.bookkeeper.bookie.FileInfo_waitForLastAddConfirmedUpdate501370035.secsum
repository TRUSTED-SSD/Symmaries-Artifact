boolean org.apache.bookkeeper.bookie.FileInfo:waitForLastAddConfirmedUpdate (
  long previousLAC, org.apache.bookkeeper.common.util.Watcher watcher) {
  guard = pc ⊔ level(previousLAC) ⊔ level(this) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(this)) = level(watcher) ⊔ obj_level(watcher);
  ret(obj_level(watcher)) = level(watcher) ⊔ obj_level(watcher);
}