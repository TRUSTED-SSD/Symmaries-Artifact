void org.apache.bookkeeper.bookie.storage.ldb.SingleDirectoryDbLedgerStorage:recordSuccessfulEvent (
  org.apache.bookkeeper.stats.OpStatsLogger logger, long startTimeNanos) {
  guard = tt;
  ret(obj_level(logger)) = pc ⊔ level(logger) ⊔ level(startTimeNanos) ⊔ obj_level(logger);
  ret(obj_level(this)) = pc ⊔ level(logger) ⊔ level(startTimeNanos) ⊔ obj_level(logger) ⊔ obj_level(this);
}