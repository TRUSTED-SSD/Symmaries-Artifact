org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setMinUsableSizeForEntryLogCreation (
  long minUsableSizeForEntryLogCreation) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(minUsableSizeForEntryLogCreation) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(minUsableSizeForEntryLogCreation) ⊔ level(this) ⊔ obj_level(this);
}