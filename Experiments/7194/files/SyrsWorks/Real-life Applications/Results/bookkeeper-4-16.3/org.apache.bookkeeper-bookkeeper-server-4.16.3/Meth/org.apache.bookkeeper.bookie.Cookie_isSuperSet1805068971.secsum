boolean org.apache.bookkeeper.bookie.Cookie:isSuperSet (java.lang.String[]
                                                          superS,
                                                        java.lang.String[]
                                                          subS) {
  guard = tt;
  ret(level()) = pc ⊔ level(subS) ⊔ level(superS) ⊔ obj_level(subS);
  ret(obj_level(subS)) = pc ⊔ level(subS) ⊔ level(superS) ⊔ obj_level(subS);
  ret(obj_level(superS)) = pc ⊔ level(subS) ⊔ level(superS) ⊔ obj_level(subS);
  ret(obj_level(this)) = pc ⊔ level(subS) ⊔ level(superS) ⊔ obj_level(subS) ⊔ obj_level(this);
}