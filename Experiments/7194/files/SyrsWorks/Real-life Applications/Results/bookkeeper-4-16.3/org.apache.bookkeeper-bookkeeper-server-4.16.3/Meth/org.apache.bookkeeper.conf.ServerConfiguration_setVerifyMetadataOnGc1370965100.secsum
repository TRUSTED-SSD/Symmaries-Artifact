  boolean verifyMetadataOnGC) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(verifyMetadataOnGC) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(verifyMetadataOnGC) ⊔ obj_level(this);
