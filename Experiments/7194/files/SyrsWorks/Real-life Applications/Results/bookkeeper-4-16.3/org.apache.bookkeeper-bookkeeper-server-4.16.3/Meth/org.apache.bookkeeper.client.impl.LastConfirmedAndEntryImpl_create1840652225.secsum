static org.apache.bookkeeper.client.impl.LastConfirmedAndEntryImpl org.apache.bookkeeper.client.impl.LastConfirmedAndEntryImpl:create (
  long lac, org.apache.bookkeeper.client.LedgerEntry entry) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(entry) ⊔ level(lac) ⊔ obj_level(entry);
  ret(obj_level(entry)) = if obj_level(entry) = ⊤ ∨ pc ≠ ⊤ ∧ level(entry) = ⊤ ∧ obj_level(entry) = ⊥ then ⊤ else ⊥;
}