  ret(level()) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level()) = if pc ≠ ⊤ ∧ level(conf) ⊔ obj_level(conf) = ⊤ then ⊤ else ⊥;
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ obj_level(conf);
}