org.apache.bookkeeper.bookie.EntryLogMetadata org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLogger:getEntryLogMetadata (
  long entryLogId,
  org.apache.bookkeeper.bookie.AbstractLogCompactor$Throttler throttler) {
  guard = tt;
  ret(level()) = pc ⊔ level(entryLogId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(entryLogId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entryLogId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(throttler)) = pc ⊔ level(entryLogId) ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(throttler);
}