static void org.apache.bookkeeper.verifier.BookkeeperVerifierMain:printHelpAndExit (
  org.apache.commons.cli.Options options, java.lang.String header, int code) {
  guard = pc ⊔ level(header) ⊔ level(options) ⊔ obj_level(header) ⊔ obj_level(options) = ⊥;
  ret(obj_level(header)) = ⊥;
  ret(obj_level(options)) = ⊥;
}