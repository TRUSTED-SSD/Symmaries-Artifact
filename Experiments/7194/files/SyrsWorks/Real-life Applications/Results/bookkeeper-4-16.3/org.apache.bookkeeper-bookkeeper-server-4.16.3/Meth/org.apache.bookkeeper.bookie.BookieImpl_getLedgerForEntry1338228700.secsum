org.apache.bookkeeper.bookie.LedgerDescriptor org.apache.bookkeeper.bookie.BookieImpl:getLedgerForEntry (
  io.netty.buffer.ByteBuf entry, byte[] masterKey) {
  p0: java.util.concurrent.locks.StampedLock () -> level;
  guard = p0 ⊔ pc ⊔ level(entry) ⊔ level(masterKey) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(masterKey) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊤;
  ret(obj_level(entry)) = ⊤;
  ret(obj_level(masterKey)) = ⊤;
  ret(obj_level(this)) = ⊤;
}