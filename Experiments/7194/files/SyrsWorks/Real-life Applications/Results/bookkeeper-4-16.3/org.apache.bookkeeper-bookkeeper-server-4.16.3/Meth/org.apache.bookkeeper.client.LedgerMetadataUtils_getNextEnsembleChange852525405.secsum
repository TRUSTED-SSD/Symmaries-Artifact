static long org.apache.bookkeeper.client.LedgerMetadataUtils:getNextEnsembleChange (
  org.apache.bookkeeper.client.api.LedgerMetadata metadata, long entryId) {
  guard = tt;
  ret(level()) = pc ⊔ level(entryId) ⊔ level(metadata) ⊔ obj_level(metadata);
  ret(obj_level(metadata)) = pc ⊔ level(entryId) ⊔ level(metadata) ⊔ obj_level(metadata);
}