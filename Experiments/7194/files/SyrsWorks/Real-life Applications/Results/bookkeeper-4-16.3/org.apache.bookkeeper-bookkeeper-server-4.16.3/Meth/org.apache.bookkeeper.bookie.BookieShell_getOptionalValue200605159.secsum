static boolean org.apache.bookkeeper.bookie.BookieShell:getOptionalValue (
  java.lang.String optValue, java.lang.String optName) {
  guard = tt;
  ret(level()) = pc ⊔ level(optName) ⊔ level(optValue) ⊔ obj_level(optName);
  ret(obj_level(optName)) = pc ⊔ level(optName) ⊔ level(optValue) ⊔ obj_level(optName);
  ret(obj_level(optValue)) = pc ⊔ level(optName) ⊔ level(optValue) ⊔ obj_level(optName);
}