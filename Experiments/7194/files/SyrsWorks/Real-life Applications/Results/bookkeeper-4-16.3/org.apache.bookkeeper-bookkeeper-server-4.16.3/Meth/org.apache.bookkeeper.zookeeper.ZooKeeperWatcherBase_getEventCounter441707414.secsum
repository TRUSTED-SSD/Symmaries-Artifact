org.apache.bookkeeper.stats.Counter org.apache.bookkeeper.zookeeper.ZooKeeperWatcherBase:getEventCounter (
  org.apache.zookeeper.Watcher$Event$EventType type) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
}