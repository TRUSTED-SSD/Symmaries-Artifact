boolean org.apache.bookkeeper.bookie.Cookie:verifyIndexDirs (org.apache.bookkeeper.bookie.Cookie
                                                               c,
                                                             boolean
                                                               checkIfSuperSet) {
  guard = tt;
  ret(level()) = pc ⊔ level(c) ⊔ level(checkIfSuperSet) ⊔ level(this) ⊔ obj_level(c);
  ret(obj_level(c)) = pc ⊔ level(c) ⊔ level(checkIfSuperSet) ⊔ level(this) ⊔ obj_level(c);
  ret(obj_level(this)) = pc ⊔ level(c) ⊔ level(checkIfSuperSet) ⊔ level(this) ⊔ obj_level(c);
