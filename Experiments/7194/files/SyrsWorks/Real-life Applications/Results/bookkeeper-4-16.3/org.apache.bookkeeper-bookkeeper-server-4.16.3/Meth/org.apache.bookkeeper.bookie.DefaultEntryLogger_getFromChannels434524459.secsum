org.apache.bookkeeper.bookie.BufferedReadChannel org.apache.bookkeeper.bookie.DefaultEntryLogger:getFromChannels (
  long logId) {
  guard = tt;
  ret(level()) = pc ⊔ level(logId) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(logId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(logId) ⊔ obj_level(this);
}