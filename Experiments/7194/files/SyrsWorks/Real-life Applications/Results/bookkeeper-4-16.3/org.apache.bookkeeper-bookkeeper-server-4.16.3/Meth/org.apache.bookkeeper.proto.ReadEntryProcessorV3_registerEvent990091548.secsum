void org.apache.bookkeeper.proto.ReadEntryProcessorV3:registerEvent (
  boolean failed, org.apache.bookkeeper.stats.OpStatsLogger statsLogger,
  com.google.common.base.Stopwatch startTime) {
  guard = tt;
  ret(obj_level(startTime)) = pc ⊔ level(failed) ⊔ level(startTime) ⊔ obj_level(startTime);
  ret(obj_level(statsLogger)) = pc ⊔ level(failed) ⊔ level(startTime) ⊔ level(statsLogger) ⊔ obj_level(startTime) ⊔ obj_level(statsLogger);
  ret(obj_level(this)) = pc ⊔ level(failed) ⊔ level(startTime) ⊔ level(statsLogger) ⊔ obj_level(startTime) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
}