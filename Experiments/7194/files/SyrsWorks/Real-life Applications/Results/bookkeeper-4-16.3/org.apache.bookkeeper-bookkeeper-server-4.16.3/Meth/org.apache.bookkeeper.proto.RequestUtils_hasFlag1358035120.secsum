static boolean org.apache.bookkeeper.proto.RequestUtils:hasFlag (org.apache.bookkeeper.proto.BookkeeperProtocol$ReadRequest
                                                                   request,
                                                                 org.apache.bookkeeper.proto.BookkeeperProtocol$ReadRequest$Flag
                                                                   flag) {
  guard = tt;
  ret(level()) = pc ⊔ level(flag) ⊔ obj_level(request);
  ret(obj_level(flag)) = if obj_level(flag) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(flag) = ⊥ ∧ obj_level(request) = ⊤ then ⊤ else ⊥;
  ret(obj_level(request)) = obj_level(request);
}