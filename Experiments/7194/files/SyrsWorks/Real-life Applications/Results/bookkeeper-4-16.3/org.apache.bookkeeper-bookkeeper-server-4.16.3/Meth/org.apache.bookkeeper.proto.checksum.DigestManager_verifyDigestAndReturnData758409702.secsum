io.netty.buffer.ByteBuf org.apache.bookkeeper.proto.checksum.DigestManager:verifyDigestAndReturnData (
  long entryId, io.netty.buffer.ByteBuf dataReceived) {
  guard = tt;
  ret(level()) = pc ⊔ level(dataReceived);
  ret(obj_level()) = pc ⊔ level(dataReceived) ⊔ level(this) ⊔ obj_level(dataReceived) ⊔ obj_level(this);
  ret(obj_level(dataReceived)) = pc ⊔ level(dataReceived) ⊔ level(this) ⊔ obj_level(dataReceived) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(dataReceived) ⊔ level(this) ⊔ obj_level(dataReceived) ⊔ obj_level(this);
}