org.apache.bookkeeper.feature.SettableFeatureProvider (java.lang.String scope,
                                                       int availability) {
  guard = tt;
  ret(obj_level(scope)) = pc ⊔ level(scope) ⊔ level(this) ⊔ obj_level(scope) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(availability) ⊔ level(scope) ⊔ level(this) ⊔ obj_level(scope) ⊔ obj_level(this);
}