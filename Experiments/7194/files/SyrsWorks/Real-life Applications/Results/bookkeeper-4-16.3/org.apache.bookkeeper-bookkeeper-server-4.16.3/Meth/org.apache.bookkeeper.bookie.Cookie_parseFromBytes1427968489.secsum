static org.apache.bookkeeper.bookie.Cookie org.apache.bookkeeper.bookie.Cookie:parseFromBytes (
  byte[] bytes) {
  p0: '0 -> dummyClass ('0) -> level;
  p1: java.io.BufferedReader () -> level;
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc;
  ret(obj_level(bytes)) = p0 ⊔ p1 ⊔ pc ⊔ level(bytes) ⊔ obj_level(bytes);
}