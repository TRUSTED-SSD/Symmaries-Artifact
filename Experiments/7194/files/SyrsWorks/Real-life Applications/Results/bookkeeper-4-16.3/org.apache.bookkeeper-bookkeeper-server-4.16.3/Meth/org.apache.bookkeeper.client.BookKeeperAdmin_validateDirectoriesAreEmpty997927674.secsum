static boolean org.apache.bookkeeper.client.BookKeeperAdmin:validateDirectoriesAreEmpty (
  java.io.File[] dirs, java.lang.String typeOfDir) {
  guard = pc ⊔ level(dirs) ⊔ level(typeOfDir) ⊔ obj_level(dirs) ⊔ obj_level(typeOfDir) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(dirs)) = ⊥;
  ret(obj_level(typeOfDir)) = ⊥;
}