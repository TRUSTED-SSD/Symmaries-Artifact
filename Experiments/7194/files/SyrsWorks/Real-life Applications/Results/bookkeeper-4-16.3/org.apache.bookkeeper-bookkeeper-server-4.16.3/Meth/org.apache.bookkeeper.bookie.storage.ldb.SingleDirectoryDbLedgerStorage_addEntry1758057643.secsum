long org.apache.bookkeeper.bookie.storage.ldb.SingleDirectoryDbLedgerStorage:addEntry (
  io.netty.buffer.ByteBuf entry) {
  p1: io.netty.buffer.ByteBuf () -> level;
  p2: java.util.concurrent.locks.StampedLock () -> level;
  guard = pc = ⊥;
  ret(level()) = level(entry) ⊔ obj_level(entry);
  ret(obj_level(entry)) = p1 ⊔ p2 ⊔ level(entry) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
  ret(obj_level(this)) = p1 ⊔ p2 ⊔ level(entry) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
}