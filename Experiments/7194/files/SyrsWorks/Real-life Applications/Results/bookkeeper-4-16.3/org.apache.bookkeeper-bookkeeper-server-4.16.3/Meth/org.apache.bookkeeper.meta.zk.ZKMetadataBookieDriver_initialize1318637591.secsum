org.apache.bookkeeper.meta.MetadataBookieDriver org.apache.bookkeeper.meta.zk.ZKMetadataBookieDriver:initialize (
  org.apache.bookkeeper.conf.ServerConfiguration conf,
  org.apache.bookkeeper.stats.StatsLogger statsLogger) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(conf) ⊔ level(statsLogger) ⊔ obj_level(conf) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level(statsLogger)) = pc ⊔ level(statsLogger) ⊔ obj_level(statsLogger);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(statsLogger) ⊔ obj_level(conf) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
}