org.apache.bookkeeper.bookie.storage.ldb.PersistentEntryLogMetadataMap (
  java.lang.String @metadataPath,
  org.apache.bookkeeper.conf.ServerConfiguration conf) {
  guard = pc = ⊥;
  ret(obj_level(@metadataPath)) = level(@metadataPath) ⊔ level(this) ⊔ obj_level(@metadataPath) ⊔ obj_level(this);
  ret(obj_level(conf)) = level(@metadataPath) ⊔ level(this) ⊔ obj_level(@metadataPath) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(this)) = level(@metadataPath) ⊔ level(conf) ⊔ level(this) ⊔ obj_level(@metadataPath) ⊔ obj_level(conf) ⊔ obj_level(this);
}