org.apache.bookkeeper.bookie.ShortReadException (java.lang.String msg,
                                                 java.lang.Throwable t) {
  guard = tt;
  ret(obj_level(msg)) = obj_level(msg);
  ret(obj_level(t)) = pc ⊔ level(msg) ⊔ level(t) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(t);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ level(t) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(t);
}