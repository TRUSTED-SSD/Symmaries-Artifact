org.apache.bookkeeper.bookie.EntryLogMetadata org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLogger:readEntryLogIndex (
  long logId) {
  guard = tt;
  ret(level()) = pc ⊔ level(logId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(logId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(logId) ⊔ level(this) ⊔ obj_level(this);
}