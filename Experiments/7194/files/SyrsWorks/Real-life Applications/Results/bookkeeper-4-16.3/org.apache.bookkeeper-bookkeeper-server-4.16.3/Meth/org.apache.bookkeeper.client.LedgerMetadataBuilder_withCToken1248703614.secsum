org.apache.bookkeeper.client.LedgerMetadataBuilder org.apache.bookkeeper.client.LedgerMetadataBuilder:withCToken (
  long cToken) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(cToken) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cToken) ⊔ obj_level(this);
}