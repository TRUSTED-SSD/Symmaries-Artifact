org.apache.bookkeeper.proto.BookieNettyServer org.apache.bookkeeper.proto.BookieNettyServer:setRequestProcessor (
  org.apache.bookkeeper.processor.RequestProcessor processor) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(processor) ⊔ obj_level(processor) ⊔ obj_level(this);
  ret(obj_level(processor)) = pc ⊔ level(processor) ⊔ obj_level(processor);
  ret(obj_level(this)) = pc ⊔ level(processor) ⊔ obj_level(processor) ⊔ obj_level(this);
}