void org.apache.bookkeeper.proto.LongPollReadEntryProcessorV3:update (
  org.apache.bookkeeper.bookie.LastAddConfirmedUpdateNotification
    newLACNotification) {
  guard = pc ⊔ level(newLACNotification) ⊔ level(this) ⊔ obj_level(newLACNotification) ⊔ obj_level(this) = ⊥;
  ret(obj_level(newLACNotification)) = ⊥;
  ret(obj_level(this)) = ⊥;
}