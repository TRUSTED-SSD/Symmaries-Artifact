java.util.concurrent.CompletableFuture org.apache.bookkeeper.bookie.datainteg.DataIntegrityCheckImpl:processPreBoot (
  long ledgerId, org.apache.bookkeeper.client.api.LedgerMetadata metadata,
  java.lang.String @runId) {
  guard = pc ⊔ level(@runId) ⊔ level(ledgerId) ⊔ level(metadata) ⊔ level(this) ⊔ obj_level(@runId) ⊔ obj_level(metadata) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊤;
  ret(obj_level(@runId)) = ⊤;
  ret(obj_level(metadata)) = ⊤;
  ret(obj_level(this)) = ⊤;
}