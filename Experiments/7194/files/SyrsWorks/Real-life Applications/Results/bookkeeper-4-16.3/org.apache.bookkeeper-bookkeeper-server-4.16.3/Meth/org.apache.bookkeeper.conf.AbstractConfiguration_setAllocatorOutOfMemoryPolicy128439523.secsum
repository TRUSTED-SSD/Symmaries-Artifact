org.apache.bookkeeper.conf.AbstractConfiguration org.apache.bookkeeper.conf.AbstractConfiguration:setAllocatorOutOfMemoryPolicy (
  org.apache.bookkeeper.common.allocator.OutOfMemoryPolicy oomPolicy) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(oomPolicy) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ obj_level(oomPolicy) ⊔ obj_level(this);
  ret(obj_level(oomPolicy)) = obj_level(oomPolicy);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(oomPolicy) ⊔ obj_level(this);
}