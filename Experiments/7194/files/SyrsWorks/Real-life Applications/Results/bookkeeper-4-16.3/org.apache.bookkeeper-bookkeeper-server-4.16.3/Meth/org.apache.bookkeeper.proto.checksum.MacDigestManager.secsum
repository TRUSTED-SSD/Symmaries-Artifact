org.apache.bookkeeper.proto.checksum.MacDigestManager (long ledgerId,
                                                       byte[] @passwd,
                                                       boolean useV2Protocol,
                                                       io.netty.buffer.ByteBufAllocator
                                                         allocator) {
  guard = tt;
  ret(obj_level(@passwd)) = pc ⊔ level(@passwd) ⊔ level(allocator) ⊔ level(ledgerId) ⊔ level(this) ⊔ level(useV2Protocol) ⊔ obj_level(@passwd) ⊔ obj_level(allocator) ⊔ obj_level(this);
  ret(obj_level(allocator)) = pc ⊔ level(allocator) ⊔ level(ledgerId) ⊔ level(this) ⊔ level(useV2Protocol) ⊔ obj_level(allocator) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@passwd) ⊔ level(allocator) ⊔ level(ledgerId) ⊔ level(this) ⊔ level(useV2Protocol) ⊔ obj_level(@passwd) ⊔ obj_level(allocator) ⊔ obj_level(this);
}