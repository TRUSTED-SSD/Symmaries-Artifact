void org.apache.bookkeeper.meta.AbstractZkLedgerManager:cancelMetadataWatch (
  long ledgerId, org.apache.zookeeper.Watcher watcher) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(ledgerId) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(watcher);
  ret(obj_level(watcher)) = pc ⊔ level(ledgerId) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(watcher);
}