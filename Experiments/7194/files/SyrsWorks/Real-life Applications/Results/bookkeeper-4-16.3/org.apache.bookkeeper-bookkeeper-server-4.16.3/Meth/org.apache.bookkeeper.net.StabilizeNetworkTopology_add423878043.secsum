void org.apache.bookkeeper.net.StabilizeNetworkTopology:add (org.apache.bookkeeper.net.Node
                                                               node) {
  guard = pc ⊔ level(node) ⊔ level(this) ⊔ obj_level(node) ⊔ obj_level(this) = ⊥;
  ret(obj_level(node)) = ⊥;
  ret(obj_level(this)) = ⊥;
}