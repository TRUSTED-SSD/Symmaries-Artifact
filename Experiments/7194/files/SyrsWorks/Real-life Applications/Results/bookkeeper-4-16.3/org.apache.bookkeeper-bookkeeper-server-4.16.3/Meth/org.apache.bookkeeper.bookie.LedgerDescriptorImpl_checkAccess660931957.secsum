void org.apache.bookkeeper.bookie.LedgerDescriptorImpl:checkAccess (byte[]
                                                                    @masterKey) {
  guard = tt;
  ret(obj_level(@masterKey)) = pc ⊔ level(@masterKey) ⊔ level(this) ⊔ obj_level(@masterKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@masterKey) ⊔ level(this) ⊔ obj_level(@masterKey) ⊔ obj_level(this);
}