org.apache.bookkeeper.zookeeper.BoundExponentialBackoffRetryPolicy (long
                                                                    baseBackoffTime,
                                                                    long
                                                                    maxBackoffTime,
                                                                    int
                                                                    maxRetries) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(baseBackoffTime) ⊔ level(maxBackoffTime) ⊔ level(maxRetries) ⊔ level(this) ⊔ obj_level(this);
}