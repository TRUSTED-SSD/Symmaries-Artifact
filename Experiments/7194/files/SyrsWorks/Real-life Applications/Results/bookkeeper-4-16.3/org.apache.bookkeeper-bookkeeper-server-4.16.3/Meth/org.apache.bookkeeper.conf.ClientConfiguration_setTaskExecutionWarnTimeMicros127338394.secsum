org.apache.bookkeeper.conf.ClientConfiguration org.apache.bookkeeper.conf.ClientConfiguration:setTaskExecutionWarnTimeMicros (
  long warnTime) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(warnTime) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(warnTime) ⊔ obj_level(this);
}