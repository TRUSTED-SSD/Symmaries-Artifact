long org.apache.bookkeeper.bookie.storage.ldb.SingleDirectoryDbLedgerStorage:getLastAddConfirmed (
  long ledgerId) {
  p1: io.netty.buffer.ByteBuf () -> level;
  p2: java.util.concurrent.locks.StampedLock () -> level;
  guard = p2 ⊔ pc ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(this) = ⊥;
  ret(level()) = p1;
  ret(obj_level(this)) = p1;
}