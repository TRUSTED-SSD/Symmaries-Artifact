org.apache.bookkeeper.bookie.EntryKeyValue (long ledgerId, long entryId,
                                            byte[] bytes, int offset,
                                            int length) {
  guard = tt;
  ret(obj_level(bytes)) = pc ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(bytes) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bytes) ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(length) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(bytes) ⊔ obj_level(this);
}