void org.apache.bookkeeper.bookie.BookieShell:printLedgerMetadata (long
                                                                    ledgerId,
                                                                   org.apache.bookkeeper.client.api.LedgerMetadata
                                                                    md,
                                                                   boolean
                                                                    printMeta) {
  guard = pc ⊔ level(ledgerId) ⊔ level(md) ⊔ level(printMeta) ⊔ level(this) ⊔ obj_level(md) ⊔ obj_level(this) = ⊥;
  ret(obj_level(md)) = ⊥;
  ret(obj_level(this)) = ⊥;
}