int org.apache.bookkeeper.bookie.KeyComparator:compare (org.apache.bookkeeper.bookie.EntryKey
                                                          left,
                                                        org.apache.bookkeeper.bookie.EntryKey
                                                          right) {
  guard = tt;
  ret(level()) = pc ⊔ level(left) ⊔ level(right) ⊔ obj_level(left);
  ret(obj_level(left)) = obj_level(left);
  ret(obj_level(right)) = obj_level(left);
  ret(obj_level(this)) = obj_level(this);
}