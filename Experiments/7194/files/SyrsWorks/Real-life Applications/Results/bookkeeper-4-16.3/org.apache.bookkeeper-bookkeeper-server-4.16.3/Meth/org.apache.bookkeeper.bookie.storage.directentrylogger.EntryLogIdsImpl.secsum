org.apache.bookkeeper.bookie.storage.directentrylogger.EntryLogIdsImpl (
  org.apache.bookkeeper.bookie.LedgerDirsManager ledgerDirsManager,
  org.apache.bookkeeper.slogger.Slogger @slog) {
  guard = ff;
  ret(obj_level(@slog)) = ⊥;
  ret(obj_level(ledgerDirsManager)) = ⊥;
  ret(obj_level(this)) = ⊥;
}