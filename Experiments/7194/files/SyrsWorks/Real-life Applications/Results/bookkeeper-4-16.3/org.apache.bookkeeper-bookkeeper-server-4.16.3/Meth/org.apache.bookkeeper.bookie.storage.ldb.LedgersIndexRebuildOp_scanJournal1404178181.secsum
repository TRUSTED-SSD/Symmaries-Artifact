void org.apache.bookkeeper.bookie.storage.ldb.LedgersIndexRebuildOp:scanJournal (
  org.apache.bookkeeper.bookie.Journal journal, long journalId,
  java.util.Set ledgers) {
  guard = pc ⊔ level(journalId) = ⊥;
  ret(obj_level(journal)) = level(ledgers) ⊔ level(this) ⊔ obj_level(journal) ⊔ obj_level(ledgers) ⊔ obj_level(this);
  ret(obj_level(ledgers)) = level(ledgers) ⊔ level(this) ⊔ obj_level(ledgers) ⊔ obj_level(this);
  ret(obj_level(this)) = level(ledgers) ⊔ level(this) ⊔ obj_level(ledgers) ⊔ obj_level(this);
}