org.apache.bookkeeper.client.EnsemblePlacementPolicy$PlacementPolicyAdherence org.apache.bookkeeper.client.RackawareEnsemblePlacementPolicyImpl:isEnsembleAdheringToPlacementPolicy (
  java.util.List ensembleList, int writeQuorumSize, int ackQuorumSize) {
  guard = pc ⊔ level(ensembleList) ⊔ level(this) ⊔ level(writeQuorumSize) ⊔ obj_level(ensembleList) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
