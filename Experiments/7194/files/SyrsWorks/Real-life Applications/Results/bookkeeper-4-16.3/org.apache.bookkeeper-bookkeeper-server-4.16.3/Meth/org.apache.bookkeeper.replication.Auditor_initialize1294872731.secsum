void org.apache.bookkeeper.replication.Auditor:initialize (org.apache.bookkeeper.conf.ServerConfiguration
                                                             conf,
                                                           org.apache.bookkeeper.client.BookKeeper
                                                             bkc) {
  guard = pc ⊔ level(bkc) ⊔ level(conf) ⊔ level(this) ⊔ obj_level(bkc) ⊔ obj_level(conf) ⊔ obj_level(this) = ⊥;
  ret(obj_level(bkc)) = ⊥;
  ret(obj_level(conf)) = ⊥;
  ret(obj_level(this)) = ⊥;
}