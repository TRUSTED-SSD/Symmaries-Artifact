org.apache.bookkeeper.bookie.datainteg.DataIntegrityCookieValidation (
  org.apache.bookkeeper.conf.ServerConfiguration conf,
  org.apache.bookkeeper.discover.RegistrationManager registrationManager,
  org.apache.bookkeeper.bookie.datainteg.DataIntegrityCheck dataIntegCheck) {
  guard = tt;
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(dataIntegCheck)) = pc ⊔ level(conf) ⊔ level(dataIntegCheck) ⊔ level(registrationManager) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(dataIntegCheck) ⊔ obj_level(registrationManager) ⊔ obj_level(this);
  ret(obj_level(registrationManager)) = pc ⊔ level(conf) ⊔ level(dataIntegCheck) ⊔ level(registrationManager) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(dataIntegCheck) ⊔ obj_level(registrationManager) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(dataIntegCheck) ⊔ level(registrationManager) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(dataIntegCheck) ⊔ obj_level(registrationManager) ⊔ obj_level(this);
}