org.apache.bookkeeper.bookie.EntryKeyValue org.apache.bookkeeper.bookie.EntryMemTable:getEntry (
  long ledgerId, long entryId) {
  guard = tt;
  ret(level()) = pc ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entryId) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(this);
}