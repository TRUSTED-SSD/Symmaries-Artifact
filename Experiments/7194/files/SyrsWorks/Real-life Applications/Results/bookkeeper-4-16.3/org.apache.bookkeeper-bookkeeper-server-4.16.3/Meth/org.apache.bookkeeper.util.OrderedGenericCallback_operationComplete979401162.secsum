void org.apache.bookkeeper.util.OrderedGenericCallback:operationComplete (
  int rc, java.lang.Object result) {
  guard = tt;
  ret(obj_level(result)) = pc ⊔ level(rc) ⊔ level(result) ⊔ level(this) ⊔ obj_level(result);
  ret(obj_level(this)) = pc ⊔ level(rc) ⊔ level(result) ⊔ level(this) ⊔ obj_level(this);
}