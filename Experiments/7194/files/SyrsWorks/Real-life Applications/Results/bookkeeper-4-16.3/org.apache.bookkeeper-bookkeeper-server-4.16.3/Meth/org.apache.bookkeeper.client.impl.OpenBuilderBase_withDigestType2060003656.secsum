org.apache.bookkeeper.client.api.OpenBuilder org.apache.bookkeeper.client.impl.OpenBuilderBase:withDigestType (
  org.apache.bookkeeper.client.api.DigestType digestType) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(digestType) ⊔ obj_level(digestType) ⊔ obj_level(this);
  ret(obj_level(digestType)) = obj_level(digestType);
  ret(obj_level(this)) = pc ⊔ level(digestType) ⊔ obj_level(digestType) ⊔ obj_level(this);
}