int org.apache.bookkeeper.proto.checksum.CRC32CDigestManager:update (
  int digest, io.netty.buffer.ByteBuf data, int offset, int len) {
  guard = tt;
  ret(level()) = pc ⊔ level(data) ⊔ level(digest) ⊔ level(len) ⊔ level(offset) ⊔ obj_level(data);
  ret(obj_level(data)) = pc ⊔ level(data) ⊔ level(digest) ⊔ level(len) ⊔ level(offset) ⊔ obj_level(data);
  ret(obj_level(this)) = obj_level(this);
}