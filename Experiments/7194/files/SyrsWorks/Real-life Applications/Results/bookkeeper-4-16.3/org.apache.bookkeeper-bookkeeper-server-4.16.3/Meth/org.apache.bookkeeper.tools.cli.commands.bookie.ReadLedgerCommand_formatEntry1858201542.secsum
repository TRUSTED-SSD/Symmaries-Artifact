void org.apache.bookkeeper.tools.cli.commands.bookie.ReadLedgerCommand:formatEntry (
  org.apache.bookkeeper.client.LedgerEntry entry, boolean printMsg) {
  p0: '0 -> dummyClass ('0) -> level;
  p1: io.netty.buffer.ByteBuf () -> level;
  guard = p0 ⊔ p1 ⊔ pc ⊔ level(entry) ⊔ level(printMsg) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this) = ⊥;
  ret(obj_level(entry)) = ⊥;
  ret(obj_level(this)) = ⊥;
}