void org.apache.bookkeeper.util.LocalBookKeeper:setZooKeeperShim (org.apache.bookkeeper.shims.zk.ZooKeeperServerShim
                                                                    zks,
                                                                  java.io.File
                                                                    zkTmpDir) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(zkTmpDir) ⊔ level(zks) ⊔ obj_level(this) ⊔ obj_level(zkTmpDir) ⊔ obj_level(zks);
  ret(obj_level(zkTmpDir)) = pc ⊔ level(this) ⊔ level(zkTmpDir) ⊔ level(zks) ⊔ obj_level(this) ⊔ obj_level(zkTmpDir) ⊔ obj_level(zks);
  ret(obj_level(zks)) = pc ⊔ level(this) ⊔ level(zkTmpDir) ⊔ level(zks) ⊔ obj_level(this) ⊔ obj_level(zkTmpDir) ⊔ obj_level(zks);
}