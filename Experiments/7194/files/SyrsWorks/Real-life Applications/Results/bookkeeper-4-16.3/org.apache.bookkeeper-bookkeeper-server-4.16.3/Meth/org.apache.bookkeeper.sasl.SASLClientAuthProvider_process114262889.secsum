void org.apache.bookkeeper.sasl.SASLClientAuthProvider:process (org.apache.bookkeeper.auth.AuthToken
                                                                  @m,
                                                                org.apache.bookkeeper.auth.AuthCallbacks$GenericCallback
                                                                  @cb) {
  guard = pc ⊔ level(@cb) ⊔ level(@m) ⊔ level(this) ⊔ obj_level(@cb) ⊔ obj_level(@m) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@cb)) = ⊥;
  ret(obj_level(@m)) = ⊥;
  ret(obj_level(this)) = ⊥;
}