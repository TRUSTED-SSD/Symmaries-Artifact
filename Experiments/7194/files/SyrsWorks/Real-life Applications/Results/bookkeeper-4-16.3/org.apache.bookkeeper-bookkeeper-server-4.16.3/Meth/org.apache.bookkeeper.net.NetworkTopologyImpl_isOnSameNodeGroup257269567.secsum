boolean org.apache.bookkeeper.net.NetworkTopologyImpl:isOnSameNodeGroup (
  org.apache.bookkeeper.net.Node node1, org.apache.bookkeeper.net.Node node2) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level(node1)) = obj_level(node1);
  ret(obj_level(node2)) = obj_level(node2);
  ret(obj_level(this)) = obj_level(this);
}