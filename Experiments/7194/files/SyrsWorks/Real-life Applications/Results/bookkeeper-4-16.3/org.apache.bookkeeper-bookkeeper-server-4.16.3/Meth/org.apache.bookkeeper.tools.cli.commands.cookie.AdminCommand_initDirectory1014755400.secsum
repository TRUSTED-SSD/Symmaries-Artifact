void org.apache.bookkeeper.tools.cli.commands.cookie.AdminCommand:initDirectory (
  org.apache.bookkeeper.conf.ServerConfiguration bkConf) {
  guard = tt;
  ret(obj_level(bkConf)) = pc ⊔ level(bkConf) ⊔ obj_level(bkConf);
  ret(obj_level(this)) = pc ⊔ level(bkConf) ⊔ level(this) ⊔ obj_level(bkConf) ⊔ obj_level(this);
}