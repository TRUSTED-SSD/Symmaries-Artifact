org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setMinorCompactionMaxTimeMillis (
  long minorCompactionMaxTimeMillis) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(minorCompactionMaxTimeMillis) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(minorCompactionMaxTimeMillis) ⊔ level(this) ⊔ obj_level(this);
}