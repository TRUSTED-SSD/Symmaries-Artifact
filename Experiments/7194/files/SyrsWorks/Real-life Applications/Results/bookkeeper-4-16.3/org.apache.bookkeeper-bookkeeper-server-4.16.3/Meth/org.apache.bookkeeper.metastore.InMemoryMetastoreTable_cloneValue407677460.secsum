  org.apache.bookkeeper.metastore.Value @value,
  org.apache.bookkeeper.versioning.Version @version, java.util.Set @fields) {
  guard = ff;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(@fields)) = ⊥;
