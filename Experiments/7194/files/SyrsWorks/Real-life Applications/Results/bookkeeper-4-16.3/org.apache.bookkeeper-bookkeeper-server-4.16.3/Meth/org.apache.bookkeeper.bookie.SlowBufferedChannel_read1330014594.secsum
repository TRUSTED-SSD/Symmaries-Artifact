  ret(obj_level(dest)) = p0 ⊔ pc ⊔ level(dest) ⊔ level(pos) ⊔ level(this) ⊔ obj_level(dest) ⊔ obj_level(this);
  ret(obj_level(this)) = p0 ⊔ pc ⊔ level(dest) ⊔ level(pos) ⊔ level(this) ⊔ obj_level(dest) ⊔ obj_level(this);
}