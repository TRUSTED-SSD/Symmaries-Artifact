long org.apache.bookkeeper.bookie.EntryLogManagerForEntryLogPerLedger:addEntry (
  long ledger, io.netty.buffer.ByteBuf entry, boolean rollLog) {
  p0: io.netty.buffer.ByteBuf () -> level;
  guard = tt;
  ret(level()) = p0 ⊔ pc ⊔ level(entry) ⊔ level(ledger) ⊔ level(rollLog) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
  ret(obj_level(entry)) = p0 ⊔ pc ⊔ level(entry) ⊔ level(ledger) ⊔ level(rollLog) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
  ret(obj_level(this)) = p0 ⊔ pc ⊔ level(entry) ⊔ level(ledger) ⊔ level(rollLog) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
}