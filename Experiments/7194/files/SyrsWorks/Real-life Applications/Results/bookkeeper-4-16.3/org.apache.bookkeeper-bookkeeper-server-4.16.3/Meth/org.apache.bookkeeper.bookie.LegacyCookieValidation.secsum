org.apache.bookkeeper.bookie.LegacyCookieValidation (org.apache.bookkeeper.conf.ServerConfiguration
                                                       conf,
                                                     org.apache.bookkeeper.discover.RegistrationManager
                                                       registrationManager) {
  guard = tt;
  ret(obj_level(conf)) = pc ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(registrationManager)) = pc ⊔ level(conf) ⊔ level(registrationManager) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(registrationManager) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(registrationManager) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(registrationManager) ⊔ obj_level(this);
}