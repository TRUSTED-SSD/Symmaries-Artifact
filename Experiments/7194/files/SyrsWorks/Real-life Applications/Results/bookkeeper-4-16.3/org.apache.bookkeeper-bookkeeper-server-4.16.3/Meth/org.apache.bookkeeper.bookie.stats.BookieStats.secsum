org.apache.bookkeeper.bookie.stats.BookieStats (org.apache.bookkeeper.stats.StatsLogger
                                                  statsLogger,
                                                int numJournalDirs,
                                                int maxJournalQueueSize) {
  guard = tt;
  ret(obj_level(statsLogger)) = pc ⊔ level(maxJournalQueueSize) ⊔ level(numJournalDirs) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(maxJournalQueueSize) ⊔ level(numJournalDirs) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
}