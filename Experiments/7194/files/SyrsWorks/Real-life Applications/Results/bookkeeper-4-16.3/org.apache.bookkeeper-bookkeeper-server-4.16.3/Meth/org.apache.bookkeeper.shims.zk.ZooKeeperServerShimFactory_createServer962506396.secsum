static org.apache.bookkeeper.shims.zk.ZooKeeperServerShim org.apache.bookkeeper.shims.zk.ZooKeeperServerShimFactory:createServer (
  java.io.File snapDir, java.io.File logDir, int zkPort, int maxCC) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(logDir) ⊔ level(maxCC) ⊔ level(snapDir) ⊔ level(zkPort) ⊔ obj_level(logDir);
  ret(obj_level(logDir)) = pc ⊔ level(zkPort) ⊔ obj_level(snapDir);
  ret(obj_level(snapDir)) = pc ⊔ level(zkPort) ⊔ obj_level(snapDir);
}