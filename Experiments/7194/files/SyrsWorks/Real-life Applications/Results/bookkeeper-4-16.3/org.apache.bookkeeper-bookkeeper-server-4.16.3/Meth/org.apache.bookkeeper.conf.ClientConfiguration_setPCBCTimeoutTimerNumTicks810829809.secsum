org.apache.bookkeeper.conf.ClientConfiguration org.apache.bookkeeper.conf.ClientConfiguration:setPCBCTimeoutTimerNumTicks (
  int numTicks) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(numTicks) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(numTicks) ⊔ level(this) ⊔ obj_level(this);
}