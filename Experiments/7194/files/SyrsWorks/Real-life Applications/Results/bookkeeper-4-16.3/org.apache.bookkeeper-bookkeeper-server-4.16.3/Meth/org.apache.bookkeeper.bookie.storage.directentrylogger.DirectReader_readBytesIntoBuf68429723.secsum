int org.apache.bookkeeper.bookie.storage.directentrylogger.DirectReader:readBytesIntoBuf (
  io.netty.buffer.ByteBuf buf, long offset, int size) {
  guard = tt;
  ret(level()) = pc ⊔ level(offset) ⊔ level(size) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(buf)) = pc ⊔ level(buf) ⊔ level(offset) ⊔ level(size) ⊔ level(this) ⊔ obj_level(buf) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(buf) ⊔ level(offset) ⊔ level(size) ⊔ level(this) ⊔ obj_level(buf) ⊔ obj_level(this);
}