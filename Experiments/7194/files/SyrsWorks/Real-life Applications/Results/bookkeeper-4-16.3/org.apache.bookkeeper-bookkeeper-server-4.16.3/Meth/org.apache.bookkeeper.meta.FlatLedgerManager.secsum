org.apache.bookkeeper.meta.FlatLedgerManager (org.apache.bookkeeper.conf.AbstractConfiguration
                                                conf,
                                              org.apache.zookeeper.ZooKeeper
                                                zk) {
  guard = tt;
  ret(obj_level(conf)) = obj_level(conf);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(zk)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(zk);
}