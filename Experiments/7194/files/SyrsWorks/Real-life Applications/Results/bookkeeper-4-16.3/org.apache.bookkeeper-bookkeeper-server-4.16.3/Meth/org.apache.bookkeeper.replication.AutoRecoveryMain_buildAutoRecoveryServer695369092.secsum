static org.apache.bookkeeper.common.component.LifecycleComponentStack org.apache.bookkeeper.replication.AutoRecoveryMain:buildAutoRecoveryServer (
  org.apache.bookkeeper.server.conf.BookieConfiguration conf) {
  guard = pc ⊔ level(conf) ⊔ obj_level(conf) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(conf)) = ⊥;
}