void org.apache.bookkeeper.versioning.Versioned:setVersion (org.apache.bookkeeper.versioning.Version
                                                              version) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(version) ⊔ obj_level(this) ⊔ obj_level(version);
  ret(obj_level(version)) = obj_level(version);
}