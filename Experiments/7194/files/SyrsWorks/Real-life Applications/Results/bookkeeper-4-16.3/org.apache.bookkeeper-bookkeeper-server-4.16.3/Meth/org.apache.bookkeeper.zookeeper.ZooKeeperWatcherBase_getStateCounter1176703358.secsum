org.apache.bookkeeper.stats.Counter org.apache.bookkeeper.zookeeper.ZooKeeperWatcherBase:getStateCounter (
  org.apache.zookeeper.Watcher$Event$KeeperState state) {
  guard = tt;
  ret(level()) = pc ⊔ level(state) ⊔ level(this) ⊔ obj_level(state) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(state) ⊔ level(this) ⊔ obj_level(state) ⊔ obj_level(this);
  ret(obj_level(state)) = pc ⊔ level(state) ⊔ level(this) ⊔ obj_level(state) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(state) ⊔ level(this) ⊔ obj_level(state) ⊔ obj_level(this);
}