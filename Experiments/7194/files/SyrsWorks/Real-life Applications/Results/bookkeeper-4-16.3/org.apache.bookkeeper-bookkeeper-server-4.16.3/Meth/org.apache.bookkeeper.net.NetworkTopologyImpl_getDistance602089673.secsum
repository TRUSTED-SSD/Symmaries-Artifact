int org.apache.bookkeeper.net.NetworkTopologyImpl:getDistance (org.apache.bookkeeper.net.Node
                                                                 node1,
                                                               org.apache.bookkeeper.net.Node
                                                                 node2) {
  guard = pc ⊔ level(node1) ⊔ level(node2) ⊔ level(this) ⊔ obj_level(node1) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(node1)) = ⊥;
  ret(obj_level(node2)) = ⊥;
  ret(obj_level(this)) = ⊥;
}