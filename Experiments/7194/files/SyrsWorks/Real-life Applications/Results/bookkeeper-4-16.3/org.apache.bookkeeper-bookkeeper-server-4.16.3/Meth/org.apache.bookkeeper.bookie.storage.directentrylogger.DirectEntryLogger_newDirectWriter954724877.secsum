org.apache.bookkeeper.bookie.storage.directentrylogger.LogWriter org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLogger:newDirectWriter (
  int newId) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(newId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(newId) ⊔ level(this) ⊔ obj_level(this);
}