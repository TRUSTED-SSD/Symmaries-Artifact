org.apache.bookkeeper.sasl.SaslClientState (java.lang.String @serverHostname,
                                            javax.security.auth.Subject
                                              @subject) {
  guard = pc ⊔ level(@serverHostname) ⊔ level(@subject) ⊔ level(this) ⊔ obj_level(@serverHostname) ⊔ obj_level(@subject) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@serverHostname)) = ⊥;
  ret(obj_level(@subject)) = ⊥;
  ret(obj_level(this)) = ⊥;
}