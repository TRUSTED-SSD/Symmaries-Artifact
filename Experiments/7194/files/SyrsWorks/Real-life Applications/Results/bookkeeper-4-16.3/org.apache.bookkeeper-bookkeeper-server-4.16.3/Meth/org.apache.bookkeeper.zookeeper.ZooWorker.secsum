org.apache.bookkeeper.zookeeper.ZooWorker (org.apache.bookkeeper.zookeeper.RetryPolicy
                                             retryPolicy,
                                           org.apache.bookkeeper.stats.OpStatsLogger
                                             statsLogger) {
  guard = tt;
  ret(obj_level(retryPolicy)) = pc ⊔ level(this) ⊔ obj_level(retryPolicy) ⊔ obj_level(this);
  ret(obj_level(statsLogger)) = pc ⊔ level(this) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(retryPolicy) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(retryPolicy) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
}