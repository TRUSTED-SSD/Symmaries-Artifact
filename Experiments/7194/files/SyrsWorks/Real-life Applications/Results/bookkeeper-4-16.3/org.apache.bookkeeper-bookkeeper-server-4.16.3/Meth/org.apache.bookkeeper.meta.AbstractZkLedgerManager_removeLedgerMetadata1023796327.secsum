java.util.concurrent.CompletableFuture org.apache.bookkeeper.meta.AbstractZkLedgerManager:removeLedgerMetadata (
  long ledgerId, org.apache.bookkeeper.versioning.Version version) {
  guard = pc ⊔ level(version) ⊔ obj_level(version) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = level(ledgerId) ⊔ level(this) ⊔ obj_level(this);
