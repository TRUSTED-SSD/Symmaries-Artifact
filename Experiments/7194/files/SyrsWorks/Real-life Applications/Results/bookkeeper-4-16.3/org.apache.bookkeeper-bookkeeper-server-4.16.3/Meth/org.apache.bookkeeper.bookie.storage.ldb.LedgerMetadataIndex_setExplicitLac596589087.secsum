void org.apache.bookkeeper.bookie.storage.ldb.LedgerMetadataIndex:setExplicitLac (
  long ledgerId, io.netty.buffer.ByteBuf lac) {
  p0: java.util.concurrent.locks.StampedLock () -> level;
  guard = p0 ⊔ pc ⊔ level(lac) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(lac) ⊔ obj_level(this) = ⊥;
  ret(obj_level(lac)) = ⊥;
  ret(obj_level(this)) = ⊥;
}