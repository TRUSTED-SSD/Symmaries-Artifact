org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setCompactionRate (
  int rate) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(rate) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(rate) ⊔ level(this) ⊔ obj_level(this);
}