static org.apache.bookkeeper.client.ClientInternalConf org.apache.bookkeeper.client.ClientInternalConf:fromConfigAndFeatureProvider (
  org.apache.bookkeeper.conf.ClientConfiguration conf,
  org.apache.bookkeeper.feature.FeatureProvider featureProvider) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(conf) ⊔ level(featureProvider) ⊔ obj_level(conf) ⊔ obj_level(featureProvider);
  ret(obj_level(conf)) = pc ⊔ level(conf) ⊔ level(featureProvider) ⊔ obj_level(conf) ⊔ obj_level(featureProvider);
  ret(obj_level(featureProvider)) = pc ⊔ level(conf) ⊔ level(featureProvider) ⊔ obj_level(conf) ⊔ obj_level(featureProvider);
}