static void org.apache.bookkeeper.bookie.BookieStatus:writeToFile (java.io.File
                                                                    file,
                                                                   java.lang.String
                                                                    body) {
  guard = pc ⊔ level(body) ⊔ level(file) ⊔ obj_level(body) ⊔ obj_level(file) = ⊥;
  ret(obj_level(body)) = ⊥;
  ret(obj_level(file)) = ⊥;
}