io.netty.buffer.ByteBuf org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLogger:readEntry (
  long entryLocation) {
  guard = tt;
  ret(level()) = pc ⊔ level(entryLocation) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(entryLocation) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entryLocation) ⊔ level(this) ⊔ obj_level(this);
}