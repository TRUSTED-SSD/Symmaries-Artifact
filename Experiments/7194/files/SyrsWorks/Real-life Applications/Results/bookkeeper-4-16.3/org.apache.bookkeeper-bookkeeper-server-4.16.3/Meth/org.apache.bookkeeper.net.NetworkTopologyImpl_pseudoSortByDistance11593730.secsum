void org.apache.bookkeeper.net.NetworkTopologyImpl:pseudoSortByDistance (
  org.apache.bookkeeper.net.Node reader,
  org.apache.bookkeeper.net.Node[] nodes) {
  guard = tt;
  ret(obj_level(nodes)) = pc ⊔ level(nodes) ⊔ level(reader) ⊔ level(this) ⊔ obj_level(nodes) ⊔ obj_level(reader) ⊔ obj_level(this);
  ret(obj_level(reader)) = pc ⊔ level(nodes) ⊔ level(reader) ⊔ level(this) ⊔ obj_level(nodes) ⊔ obj_level(reader) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(nodes) ⊔ level(reader) ⊔ level(this) ⊔ obj_level(nodes) ⊔ obj_level(reader) ⊔ obj_level(this);
}