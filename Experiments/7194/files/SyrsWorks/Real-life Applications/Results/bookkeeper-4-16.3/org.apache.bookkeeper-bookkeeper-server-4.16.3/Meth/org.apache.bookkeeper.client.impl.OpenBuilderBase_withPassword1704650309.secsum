org.apache.bookkeeper.client.api.OpenBuilder org.apache.bookkeeper.client.impl.OpenBuilderBase:withPassword (
  byte[] @password) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(@password) ⊔ obj_level(@password) ⊔ obj_level(this);
  ret(obj_level(@password)) = pc ⊔ level(@password) ⊔ obj_level(@password);
  ret(obj_level(this)) = pc ⊔ level(@password) ⊔ obj_level(@password) ⊔ obj_level(this);
}