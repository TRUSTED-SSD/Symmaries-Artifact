org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setUseTransactionalCompaction (
  boolean useTransactionalCompaction) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(useTransactionalCompaction) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(useTransactionalCompaction) ⊔ obj_level(this);
}