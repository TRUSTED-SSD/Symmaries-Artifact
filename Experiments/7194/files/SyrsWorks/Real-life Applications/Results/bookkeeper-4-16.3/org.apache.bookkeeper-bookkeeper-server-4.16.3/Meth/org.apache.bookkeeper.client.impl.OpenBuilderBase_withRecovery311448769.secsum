org.apache.bookkeeper.client.api.OpenBuilder org.apache.bookkeeper.client.impl.OpenBuilderBase:withRecovery (
  boolean recovery) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(recovery) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(recovery) ⊔ obj_level(this);
}