static int org.apache.bookkeeper.bookie.Journal:fullRead (org.apache.bookkeeper.bookie.JournalChannel
                                                            fc,
                                                          java.nio.ByteBuffer
                                                            bb) {
  guard = tt;
  ret(level()) = pc ⊔ level(bb) ⊔ level(fc) ⊔ obj_level(bb) ⊔ obj_level(fc);
  ret(obj_level(bb)) = pc ⊔ level(bb) ⊔ level(fc) ⊔ obj_level(bb) ⊔ obj_level(fc);
  ret(obj_level(fc)) = pc ⊔ level(bb) ⊔ level(fc) ⊔ obj_level(bb) ⊔ obj_level(fc);
}