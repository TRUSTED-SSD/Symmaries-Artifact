long org.apache.bookkeeper.sasl.TGTRefreshThread:getRefreshTime (javax.security.auth.kerberos.KerberosTicket
                                                                   tgt) {
  p1: java.util.Random () -> level;
  guard = pc ⊔ obj_level(tgt) = ⊥;
  ret(level()) = p1;
  ret(obj_level(tgt)) = if p1 = ⊤ then obj_level(this) else ⊥;
  ret(obj_level(this)) = obj_level(this);
}