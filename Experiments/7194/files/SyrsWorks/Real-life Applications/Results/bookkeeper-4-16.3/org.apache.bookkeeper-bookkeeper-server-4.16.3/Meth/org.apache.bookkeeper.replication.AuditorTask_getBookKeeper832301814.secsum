org.apache.bookkeeper.client.BookKeeper org.apache.bookkeeper.replication.AuditorTask:getBookKeeper (
  org.apache.bookkeeper.conf.ServerConfiguration conf) {
  guard = tt;
  ret(level()) = pc ⊔ level(conf) ⊔ obj_level(conf);
  ret(obj_level()) = level(conf) ⊔ obj_level(conf);
  ret(obj_level(conf)) = obj_level(conf);
  ret(obj_level(this)) = obj_level(this);
}