org.apache.bookkeeper.bookie.DefaultFileChannel (java.io.File file,
                                                 org.apache.bookkeeper.conf.ServerConfiguration
                                                   serverConfiguration) {
  guard = tt;
  ret(obj_level(file)) = pc ⊔ level(this) ⊔ obj_level(file) ⊔ obj_level(this);
  ret(obj_level(serverConfiguration)) = pc ⊔ level(this) ⊔ obj_level(serverConfiguration) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(file) ⊔ level(serverConfiguration) ⊔ level(this) ⊔ obj_level(file) ⊔ obj_level(serverConfiguration) ⊔ obj_level(this);
}