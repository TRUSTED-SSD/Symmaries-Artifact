static byte[] org.apache.bookkeeper.proto.checksum.MacDigestManager:genDigest (
  java.lang.String pad, byte[] @passwd) {
  guard = tt;
  ret(level()) = pc ⊔ level(@passwd) ⊔ level(pad) ⊔ obj_level(@passwd) ⊔ obj_level(pad);
  ret(obj_level()) = pc ⊔ level(@passwd) ⊔ level(pad) ⊔ obj_level(@passwd) ⊔ obj_level(pad);
  ret(obj_level(@passwd)) = pc ⊔ level(@passwd) ⊔ level(pad) ⊔ obj_level(@passwd) ⊔ obj_level(pad);
  ret(obj_level(pad)) = pc ⊔ level(@passwd) ⊔ level(pad) ⊔ obj_level(@passwd) ⊔ obj_level(pad);
}