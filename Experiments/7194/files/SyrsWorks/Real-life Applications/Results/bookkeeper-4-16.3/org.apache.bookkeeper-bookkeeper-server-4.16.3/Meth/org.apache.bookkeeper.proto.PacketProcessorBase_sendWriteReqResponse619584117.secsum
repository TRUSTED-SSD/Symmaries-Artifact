void org.apache.bookkeeper.proto.PacketProcessorBase:sendWriteReqResponse (
  int rc, java.lang.Object response,
  org.apache.bookkeeper.stats.OpStatsLogger statsLogger) {
  guard = tt;
  ret(obj_level(response)) = pc ⊔ level(this) ⊔ obj_level(response);
  ret(obj_level(statsLogger)) = pc ⊔ level(this) ⊔ obj_level(statsLogger);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(this);
}