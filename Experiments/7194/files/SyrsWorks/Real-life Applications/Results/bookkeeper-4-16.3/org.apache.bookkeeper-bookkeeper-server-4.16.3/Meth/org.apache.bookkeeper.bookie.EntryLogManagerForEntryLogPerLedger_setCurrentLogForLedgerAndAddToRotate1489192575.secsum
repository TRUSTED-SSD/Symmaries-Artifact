void org.apache.bookkeeper.bookie.EntryLogManagerForEntryLogPerLedger:setCurrentLogForLedgerAndAddToRotate (
  long ledgerId,
  org.apache.bookkeeper.bookie.DefaultEntryLogger$BufferedLogChannel
    @logChannel) {
  guard = tt;
  ret(obj_level(@logChannel)) = pc ⊔ level(@logChannel) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(@logChannel) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@logChannel) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(@logChannel) ⊔ obj_level(this);
}