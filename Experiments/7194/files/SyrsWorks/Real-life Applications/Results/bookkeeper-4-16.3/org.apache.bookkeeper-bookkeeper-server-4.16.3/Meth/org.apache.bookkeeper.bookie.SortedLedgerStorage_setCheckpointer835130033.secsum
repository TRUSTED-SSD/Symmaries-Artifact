void org.apache.bookkeeper.bookie.SortedLedgerStorage:setCheckpointer (
  org.apache.bookkeeper.bookie.Checkpointer checkpointer) {
  guard = tt;
  ret(obj_level(checkpointer)) = pc ⊔ level(checkpointer) ⊔ obj_level(checkpointer) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(checkpointer) ⊔ obj_level(checkpointer) ⊔ obj_level(this);
}