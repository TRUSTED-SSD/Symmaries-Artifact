org.apache.bookkeeper.conf.ClientConfiguration org.apache.bookkeeper.conf.ClientConfiguration:setClientRole (
  java.lang.String @role) {
  guard = tt;
  ret(level()) = pc ⊔ level(@role) ⊔ level(this) ⊔ obj_level(@role);
  ret(obj_level()) = pc ⊔ level(@role) ⊔ level(this) ⊔ obj_level(@role) ⊔ obj_level(this);
  ret(obj_level(@role)) = ⊤;
  ret(obj_level(this)) = pc ⊔ level(@role) ⊔ level(this) ⊔ obj_level(@role) ⊔ obj_level(this);
