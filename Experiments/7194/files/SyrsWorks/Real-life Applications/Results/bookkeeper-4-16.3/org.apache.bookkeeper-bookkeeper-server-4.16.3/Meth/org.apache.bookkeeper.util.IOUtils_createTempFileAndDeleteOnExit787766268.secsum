static java.io.File org.apache.bookkeeper.util.IOUtils:createTempFileAndDeleteOnExit (
  java.lang.String prefix, java.lang.String suffix) {
  guard = tt;
  ret(level()) = pc ⊔ level(prefix) ⊔ level(suffix) ⊔ obj_level(prefix);
  ret(obj_level()) = pc ⊔ level(prefix) ⊔ level(suffix) ⊔ obj_level(prefix);
  ret(obj_level(prefix)) = pc ⊔ level(prefix) ⊔ level(suffix) ⊔ obj_level(prefix);
  ret(obj_level(suffix)) = pc ⊔ level(prefix) ⊔ level(suffix) ⊔ obj_level(prefix);
}