boolean org.apache.bookkeeper.net.NetworkTopologyImpl:isOnSameRack (org.apache.bookkeeper.net.Node
                                                                    node1,
                                                                    org.apache.bookkeeper.net.Node
                                                                    node2) {
  guard = tt;
  ret(level()) = pc ⊔ level(node1) ⊔ level(node2) ⊔ level(this) ⊔ obj_level(node1) ⊔ obj_level(this);
  ret(obj_level(node1)) = pc ⊔ level(node1) ⊔ level(node2) ⊔ level(this) ⊔ obj_level(node1) ⊔ obj_level(this);
  ret(obj_level(node2)) = pc ⊔ level(node1) ⊔ level(node2) ⊔ level(this) ⊔ obj_level(node1) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(node1) ⊔ level(node2) ⊔ level(this) ⊔ obj_level(node1) ⊔ obj_level(this);
}