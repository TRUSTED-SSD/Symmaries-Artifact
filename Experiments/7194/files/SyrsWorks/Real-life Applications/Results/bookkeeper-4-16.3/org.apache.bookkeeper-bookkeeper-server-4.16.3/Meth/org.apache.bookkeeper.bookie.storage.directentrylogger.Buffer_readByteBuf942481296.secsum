int org.apache.bookkeeper.bookie.storage.directentrylogger.Buffer:readByteBuf (
  io.netty.buffer.ByteBuf buffer, int offset, int size) {
  guard = tt;
  ret(level()) = pc ⊔ level(offset) ⊔ level(size) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(buffer)) = pc ⊔ level(buffer) ⊔ level(offset) ⊔ level(size) ⊔ level(this) ⊔ obj_level(buffer) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(buffer) ⊔ level(offset) ⊔ level(size) ⊔ level(this) ⊔ obj_level(buffer) ⊔ obj_level(this);
}