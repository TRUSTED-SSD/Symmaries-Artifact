void org.apache.bookkeeper.sasl.SASLBookieAuthProviderFactory:init (org.apache.bookkeeper.conf.ServerConfiguration
                                                                    @conf) {
  guard = pc ⊔ level(@conf) ⊔ level(this) ⊔ obj_level(@conf) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@conf)) = ⊥;
  ret(obj_level(this)) = ⊥;
}