org.apache.bookkeeper.client.LedgerMetadataBuilder org.apache.bookkeeper.client.LedgerMetadataBuilder:withEnsembleSize (
  int ensembleSize) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(ensembleSize) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ensembleSize) ⊔ level(this) ⊔ obj_level(this);
}