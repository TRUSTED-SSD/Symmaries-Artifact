static void org.apache.bookkeeper.net.NetworkTopologyImpl:swap (org.apache.bookkeeper.net.Node[]
                                                                  nodes,
                                                                int i, 
                                                                int j) {
  guard = tt;
  ret(obj_level(nodes)) = pc ⊔ level(i) ⊔ level(j) ⊔ level(nodes) ⊔ obj_level(nodes);
}