void org.apache.bookkeeper.bookie.Cookie:writeToDirectory (java.io.File
                                                             directory) {
  guard = pc ⊔ level(directory) ⊔ level(this) ⊔ obj_level(directory) ⊔ obj_level(this) = ⊥;
  ret(obj_level(directory)) = ⊥;
  ret(obj_level(this)) = ⊥;
}