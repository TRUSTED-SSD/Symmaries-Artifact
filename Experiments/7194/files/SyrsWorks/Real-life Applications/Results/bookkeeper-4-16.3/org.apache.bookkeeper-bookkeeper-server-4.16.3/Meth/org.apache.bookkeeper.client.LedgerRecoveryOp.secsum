org.apache.bookkeeper.client.LedgerRecoveryOp (org.apache.bookkeeper.client.LedgerHandle
                                                 lh,
                                               org.apache.bookkeeper.client.ClientContext
                                                 clientCtx) {
  guard = tt;
  ret(obj_level(clientCtx)) = pc ⊔ level(clientCtx) ⊔ level(lh) ⊔ level(this) ⊔ obj_level(clientCtx) ⊔ obj_level(lh) ⊔ obj_level(this);
  ret(obj_level(lh)) = pc ⊔ level(clientCtx) ⊔ level(lh) ⊔ level(this) ⊔ obj_level(clientCtx) ⊔ obj_level(lh) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(clientCtx) ⊔ level(lh) ⊔ level(this) ⊔ obj_level(clientCtx) ⊔ obj_level(lh) ⊔ obj_level(this);
}