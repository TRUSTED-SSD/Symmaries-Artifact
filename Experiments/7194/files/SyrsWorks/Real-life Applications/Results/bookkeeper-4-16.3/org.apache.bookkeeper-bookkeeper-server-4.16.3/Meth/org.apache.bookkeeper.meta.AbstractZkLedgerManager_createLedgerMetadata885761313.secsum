  long ledgerId,
  org.apache.bookkeeper.client.api.LedgerMetadata @inputMetadata) {
  guard = pc ⊔ level(@inputMetadata) ⊔ level(ledgerId) ⊔ level(this) ⊔ obj_level(@inputMetadata) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊤;
  ret(obj_level(@inputMetadata)) = ⊤;
  ret(obj_level(this)) = ⊤;
}