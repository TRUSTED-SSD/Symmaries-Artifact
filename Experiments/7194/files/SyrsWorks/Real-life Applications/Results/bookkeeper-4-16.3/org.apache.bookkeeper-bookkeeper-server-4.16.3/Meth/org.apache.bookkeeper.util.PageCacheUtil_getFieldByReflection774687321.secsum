static java.lang.reflect.Field org.apache.bookkeeper.util.PageCacheUtil:getFieldByReflection (
  java.lang.Class cls, java.lang.String fieldName) {
  guard = tt;
  ret(level()) = pc ⊔ level(cls) ⊔ level(fieldName) ⊔ obj_level(cls) ⊔ obj_level(fieldName);
  ret(obj_level()) = pc ⊔ level(cls) ⊔ level(fieldName) ⊔ obj_level(cls) ⊔ obj_level(fieldName);
  ret(obj_level(cls)) = pc ⊔ level(cls) ⊔ level(fieldName) ⊔ obj_level(cls) ⊔ obj_level(fieldName);
  ret(obj_level(fieldName)) = pc ⊔ level(cls) ⊔ level(fieldName) ⊔ obj_level(cls) ⊔ obj_level(fieldName);
}