java.util.concurrent.CompletableFuture org.apache.bookkeeper.meta.CleanupLedgerManager:writeLedgerMetadata (
  long ledgerId, org.apache.bookkeeper.client.api.LedgerMetadata metadata,
  org.apache.bookkeeper.versioning.Version currentVersion) {
  guard = pc ⊔ level(currentVersion) ⊔ level(metadata) ⊔ level(this) ⊔ obj_level(currentVersion) ⊔ obj_level(metadata) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊤;
  ret(obj_level(currentVersion)) = ⊤;
  ret(obj_level(metadata)) = ⊤;
  ret(obj_level(this)) = ⊤;
}