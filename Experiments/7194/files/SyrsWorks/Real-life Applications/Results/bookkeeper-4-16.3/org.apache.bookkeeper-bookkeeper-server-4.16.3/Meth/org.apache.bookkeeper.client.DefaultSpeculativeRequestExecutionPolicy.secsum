org.apache.bookkeeper.client.DefaultSpeculativeRequestExecutionPolicy (
  int firstSpeculativeRequestTimeout, int maxSpeculativeRequestTimeout,
  float backoffMultiplier) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(backoffMultiplier) ⊔ level(firstSpeculativeRequestTimeout) ⊔ level(maxSpeculativeRequestTimeout) ⊔ level(this) ⊔ obj_level(this);
}