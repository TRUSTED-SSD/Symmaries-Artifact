void org.apache.bookkeeper.shims.zk.ZooKeeperServerShimImpl:initialize (
  java.io.File snapDir, java.io.File logDir, int zkPort, int maxCC) {
  guard = tt;
  ret(obj_level(logDir)) = pc ⊔ level(zkPort) ⊔ obj_level(logDir);
  ret(obj_level(snapDir)) = pc ⊔ level(zkPort) ⊔ obj_level(snapDir);
  ret(obj_level(this)) = pc ⊔ level(logDir) ⊔ level(maxCC) ⊔ level(snapDir) ⊔ level(this) ⊔ level(zkPort) ⊔ obj_level(logDir) ⊔ obj_level(this);
}