void org.apache.bookkeeper.bookie.Cookie:verifyIsSuperSet (org.apache.bookkeeper.bookie.Cookie
                                                             c) {
  guard = tt;
  ret(obj_level(c)) = pc ⊔ level(c) ⊔ level(this) ⊔ obj_level(c);
  ret(obj_level(this)) = pc ⊔ level(c) ⊔ level(this) ⊔ obj_level(c);
}