org.apache.bookkeeper.http.service.HttpServiceResponse org.apache.bookkeeper.server.http.service.WhoIsAuditorService:handle (
  org.apache.bookkeeper.http.service.HttpServiceRequest request) {
  guard = pc ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(request)) = ⊥;
  ret(obj_level(this)) = ⊥;
}