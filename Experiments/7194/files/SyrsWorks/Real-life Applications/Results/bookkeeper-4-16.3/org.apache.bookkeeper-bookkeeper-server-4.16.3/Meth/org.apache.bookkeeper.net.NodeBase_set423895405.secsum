void org.apache.bookkeeper.net.NodeBase:set (java.lang.String @name,
                                             java.lang.String location) {
  guard = tt;
  ret(obj_level(@name)) = pc ⊔ level(@name) ⊔ obj_level(@name);
  ret(obj_level(location)) = pc ⊔ level(@name) ⊔ obj_level(@name);
  ret(obj_level(this)) = pc ⊔ level(@name) ⊔ level(location) ⊔ obj_level(@name) ⊔ obj_level(this);
}