  org.apache.zookeeper.ZooKeeper zk) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ level(zk) ⊔ obj_level(this) ⊔ obj_level(zk);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(zk) ⊔ obj_level(this) ⊔ obj_level(zk);
  ret(obj_level(zk)) = pc ⊔ level(this) ⊔ level(zk) ⊔ obj_level(this) ⊔ obj_level(zk);
}