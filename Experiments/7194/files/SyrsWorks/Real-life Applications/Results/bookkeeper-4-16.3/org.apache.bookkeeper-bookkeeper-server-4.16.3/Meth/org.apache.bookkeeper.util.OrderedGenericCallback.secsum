org.apache.bookkeeper.util.OrderedGenericCallback (org.apache.bookkeeper.common.util.OrderedExecutor
                                                     executor,
                                                   long orderingKey) {
  guard = tt;
  ret(obj_level(executor)) = pc ⊔ level(executor) ⊔ level(this) ⊔ obj_level(executor) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(executor) ⊔ level(orderingKey) ⊔ level(this) ⊔ obj_level(executor) ⊔ obj_level(this);
}