void org.apache.bookkeeper.proto.PacketProcessorBase:sendResponseAndWait (
  int rc, java.lang.Object response,
  org.apache.bookkeeper.stats.OpStatsLogger statsLogger) {
  guard = tt;
  ret(obj_level(response)) = pc ⊔ level(rc) ⊔ level(response) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(response);
  ret(obj_level(statsLogger)) = pc ⊔ level(rc) ⊔ level(response) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(response);
  ret(obj_level(this)) = pc ⊔ level(rc) ⊔ level(response) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(response);
}