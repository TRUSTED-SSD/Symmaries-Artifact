void org.apache.bookkeeper.proto.checksum.MacDigestManager:populateValueAndReset (
  int digest, io.netty.buffer.ByteBuf buffer) {
  guard = tt;
  ret(obj_level(buffer)) = pc ⊔ level(buffer) ⊔ obj_level(buffer) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(buffer) ⊔ obj_level(buffer) ⊔ obj_level(this);
}