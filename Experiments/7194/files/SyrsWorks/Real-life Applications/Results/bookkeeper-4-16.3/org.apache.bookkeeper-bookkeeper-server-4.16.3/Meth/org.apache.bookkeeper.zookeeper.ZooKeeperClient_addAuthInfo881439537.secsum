void org.apache.bookkeeper.zookeeper.ZooKeeperClient:addAuthInfo (java.lang.String
                                                                    scheme,
                                                                  byte[] auth) {
  guard = tt;
  ret(obj_level(auth)) = pc ⊔ level(auth) ⊔ level(scheme) ⊔ level(this) ⊔ obj_level(auth) ⊔ obj_level(scheme) ⊔ obj_level(this);
  ret(obj_level(scheme)) = pc ⊔ level(auth) ⊔ level(scheme) ⊔ level(this) ⊔ obj_level(auth) ⊔ obj_level(scheme) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(auth) ⊔ level(scheme) ⊔ level(this) ⊔ obj_level(auth) ⊔ obj_level(scheme) ⊔ obj_level(this);
}