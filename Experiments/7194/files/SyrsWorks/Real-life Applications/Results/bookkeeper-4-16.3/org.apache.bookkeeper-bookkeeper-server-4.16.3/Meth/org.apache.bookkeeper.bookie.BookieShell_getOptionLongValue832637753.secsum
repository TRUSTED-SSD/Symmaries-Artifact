static long org.apache.bookkeeper.bookie.BookieShell:getOptionLongValue (
  org.apache.commons.cli.CommandLine cmdLine, java.lang.String @option,
  long defaultVal) {
  guard = tt;
  ret(level()) = pc ⊔ level(@option) ⊔ level(cmdLine) ⊔ level(defaultVal) ⊔ obj_level(@option) ⊔ obj_level(cmdLine);
  ret(obj_level(@option)) = pc ⊔ level(@option) ⊔ level(cmdLine) ⊔ obj_level(@option) ⊔ obj_level(cmdLine);
  ret(obj_level(cmdLine)) = pc ⊔ level(@option) ⊔ level(cmdLine) ⊔ obj_level(@option) ⊔ obj_level(cmdLine);
}