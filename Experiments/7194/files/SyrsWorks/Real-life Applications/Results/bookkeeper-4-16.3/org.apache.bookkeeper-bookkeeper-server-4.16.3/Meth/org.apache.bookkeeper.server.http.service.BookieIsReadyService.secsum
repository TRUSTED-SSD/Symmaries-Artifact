org.apache.bookkeeper.server.http.service.BookieIsReadyService (org.apache.bookkeeper.bookie.Bookie
                                                                  @bookie) {
  guard = tt;
  ret(obj_level(@bookie)) = pc ⊔ level(@bookie) ⊔ level(this) ⊔ obj_level(@bookie) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@bookie) ⊔ level(this) ⊔ obj_level(@bookie) ⊔ obj_level(this);
}