org.apache.bookkeeper.bookie.storage.directentrylogger.LogReader org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLogger:newDirectReader (
  int logId) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(logId) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(logId) ⊔ level(this) ⊔ obj_level(this);
}