org.apache.bookkeeper.sasl.TGTRefreshThread (org.apache.bookkeeper.sasl.JAASCredentialsContainer
                                               container) {
  guard = tt;
  ret(obj_level(container)) = pc ⊔ level(container) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(container) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(this);
}