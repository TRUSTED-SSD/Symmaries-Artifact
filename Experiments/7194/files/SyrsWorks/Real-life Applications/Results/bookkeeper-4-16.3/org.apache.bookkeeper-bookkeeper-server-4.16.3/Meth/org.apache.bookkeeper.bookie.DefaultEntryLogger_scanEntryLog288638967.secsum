void org.apache.bookkeeper.bookie.DefaultEntryLogger:scanEntryLog (long
                                                                    entryLogId,
                                                                   org.apache.bookkeeper.bookie.storage.EntryLogScanner
                                                                    scanner) {
  guard = ff;
  ret(obj_level(scanner)) = ⊥;
  ret(obj_level(this)) = ⊥;
}