static java.lang.String org.apache.bookkeeper.bookie.storage.directentrylogger.DirectEntryLogger:logFilename (
  java.io.File @directory, int logId) {
  guard = tt;
  ret(level()) = pc ⊔ level(@directory) ⊔ level(logId) ⊔ obj_level(@directory);
  ret(obj_level()) = pc ⊔ level(@directory) ⊔ level(logId) ⊔ obj_level(@directory);
  ret(obj_level(@directory)) = pc ⊔ level(@directory) ⊔ level(logId) ⊔ obj_level(@directory);
}