java.util.concurrent.CompletableFuture org.apache.bookkeeper.bookie.datainteg.DataIntegrityCheckImpl:runPreBootCheck (
  java.lang.String reason) {
  guard = tt;
  ret(level()) = pc ⊔ level(reason) ⊔ level(this) ⊔ obj_level(reason) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(reason) ⊔ level(this) ⊔ obj_level(reason) ⊔ obj_level(this);
  ret(obj_level(reason)) = obj_level(reason);
