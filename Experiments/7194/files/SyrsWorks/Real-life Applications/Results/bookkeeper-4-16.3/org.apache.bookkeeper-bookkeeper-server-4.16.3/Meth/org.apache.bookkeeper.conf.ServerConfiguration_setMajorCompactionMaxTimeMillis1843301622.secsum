org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setMajorCompactionMaxTimeMillis (
  long majorCompactionMaxTimeMillis) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(majorCompactionMaxTimeMillis) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(majorCompactionMaxTimeMillis) ⊔ level(this) ⊔ obj_level(this);
}