void org.apache.bookkeeper.bookie.InterleavedLedgerStorage:setCheckpointSource (
  org.apache.bookkeeper.bookie.CheckpointSource checkpointSource) {
  guard = tt;
  ret(obj_level(checkpointSource)) = pc ⊔ level(checkpointSource) ⊔ obj_level(checkpointSource);
  ret(obj_level(this)) = pc ⊔ level(checkpointSource) ⊔ obj_level(checkpointSource) ⊔ obj_level(this);
}