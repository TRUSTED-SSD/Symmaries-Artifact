org.apache.bookkeeper.meta.HierarchicalLedgerManager (org.apache.bookkeeper.conf.AbstractConfiguration
                                                        conf,
                                                      org.apache.zookeeper.ZooKeeper
                                                        zk) {
  guard = tt;
  ret(obj_level(conf)) = obj_level(conf);
  ret(obj_level(this)) = pc ⊔ obj_level(this);
  ret(obj_level(zk)) = pc ⊔ obj_level(zk);
}