  org.apache.bookkeeper.net.BookieId bookieId, boolean readOnly,
  org.apache.bookkeeper.discover.BookieServiceInfo bookieServiceInfo) {
  guard = tt;
  ret(obj_level(bookieId)) = pc ⊔ level(readOnly) ⊔ level(this) ⊔ obj_level(bookieId) ⊔ obj_level(this);
  ret(obj_level(bookieServiceInfo)) = pc ⊔ level(bookieId) ⊔ level(readOnly) ⊔ level(this) ⊔ obj_level(bookieId) ⊔ obj_level(bookieServiceInfo) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bookieId) ⊔ level(readOnly) ⊔ level(this) ⊔ obj_level(bookieId) ⊔ obj_level(this);
}