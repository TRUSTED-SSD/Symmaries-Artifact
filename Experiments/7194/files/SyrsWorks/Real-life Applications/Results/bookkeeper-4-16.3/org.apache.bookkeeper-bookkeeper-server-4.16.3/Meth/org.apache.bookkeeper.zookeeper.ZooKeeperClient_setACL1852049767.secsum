org.apache.zookeeper.data.Stat org.apache.bookkeeper.zookeeper.ZooKeeperClient:setACL (
  java.lang.String path, java.util.List acl, int version) {
  guard = tt;
  ret(level()) = pc ⊔ level(acl) ⊔ level(path) ⊔ level(this) ⊔ level(version) ⊔ obj_level(acl) ⊔ obj_level(path) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(acl) ⊔ level(path) ⊔ level(this) ⊔ level(version) ⊔ obj_level(acl) ⊔ obj_level(path) ⊔ obj_level(this);
  ret(obj_level(acl)) = pc ⊔ level(acl) ⊔ level(path) ⊔ level(this) ⊔ level(version) ⊔ obj_level(acl) ⊔ obj_level(path) ⊔ obj_level(this);
  ret(obj_level(path)) = pc ⊔ level(acl) ⊔ level(path) ⊔ level(this) ⊔ level(version) ⊔ obj_level(acl) ⊔ obj_level(path) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(acl) ⊔ level(path) ⊔ level(this) ⊔ level(version) ⊔ obj_level(acl) ⊔ obj_level(path) ⊔ obj_level(this);
}