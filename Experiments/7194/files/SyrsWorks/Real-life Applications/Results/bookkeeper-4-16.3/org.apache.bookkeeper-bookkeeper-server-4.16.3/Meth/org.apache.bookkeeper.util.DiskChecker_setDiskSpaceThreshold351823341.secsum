void org.apache.bookkeeper.util.DiskChecker:setDiskSpaceThreshold (float
                                                                    diskSpaceThreshold,
                                                                   float
                                                                    diskUsageWarnThreshold) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(diskSpaceThreshold) ⊔ level(diskUsageWarnThreshold) ⊔ obj_level(this);
}