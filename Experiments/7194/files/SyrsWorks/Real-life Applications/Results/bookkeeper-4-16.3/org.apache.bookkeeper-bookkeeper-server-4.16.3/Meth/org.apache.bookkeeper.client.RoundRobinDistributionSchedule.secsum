org.apache.bookkeeper.client.RoundRobinDistributionSchedule (int
                                                               writeQuorumSize,
                                                             int
                                                               ackQuorumSize,
                                                             int ensembleSize) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(ackQuorumSize) ⊔ level(ensembleSize) ⊔ level(this) ⊔ level(writeQuorumSize) ⊔ obj_level(this);
}