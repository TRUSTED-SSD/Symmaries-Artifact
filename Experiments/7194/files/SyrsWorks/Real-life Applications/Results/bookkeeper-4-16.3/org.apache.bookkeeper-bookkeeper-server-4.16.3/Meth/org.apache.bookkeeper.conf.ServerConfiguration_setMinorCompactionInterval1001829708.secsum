org.apache.bookkeeper.conf.ServerConfiguration org.apache.bookkeeper.conf.ServerConfiguration:setMinorCompactionInterval (
  long interval) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(interval) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(interval) ⊔ level(this) ⊔ obj_level(this);
}