org.apache.bookkeeper.conf.AbstractConfiguration org.apache.bookkeeper.conf.AbstractConfiguration:setLimitStatsLogging (
  boolean limitStatsLogging) {
  guard = tt;
  ret(level()) = pc ⊔ level(limitStatsLogging) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(limitStatsLogging) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(limitStatsLogging) ⊔ level(this) ⊔ obj_level(this);
}