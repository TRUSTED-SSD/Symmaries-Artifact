org.apache.bookkeeper.replication.Auditor org.apache.bookkeeper.replication.AutoRecoveryMain:getAuditor()
{
org.apache.bookkeeper.replication.AuditorElector $stack1;
  org.apache.bookkeeper.replication.Auditor $stack2;
  $stack1=this.auditorElector;
 $stack2 = $stack1.getAuditor();
 return  $stack2;
 } 

