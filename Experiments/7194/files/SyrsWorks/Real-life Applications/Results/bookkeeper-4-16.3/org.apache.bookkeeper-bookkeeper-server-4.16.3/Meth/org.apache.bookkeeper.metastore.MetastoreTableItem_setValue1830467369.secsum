void org.apache.bookkeeper.metastore.MetastoreTableItem:setValue (org.apache.bookkeeper.versioning.Versioned
                                                                    value) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(value) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(value) ⊔ obj_level(value);
}