org.apache.bookkeeper.conf.UncheckedConfigurationException (java.lang.String
                                                              message,
                                                            org.apache.commons.configuration.ConfigurationException
                                                              cause) {
  guard = tt;
  ret(obj_level(cause)) = pc ⊔ level(cause) ⊔ obj_level(cause);
  ret(obj_level(message)) = obj_level(message);
  ret(obj_level(this)) = pc ⊔ level(cause) ⊔ level(message) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(message) ⊔ obj_level(this);
}