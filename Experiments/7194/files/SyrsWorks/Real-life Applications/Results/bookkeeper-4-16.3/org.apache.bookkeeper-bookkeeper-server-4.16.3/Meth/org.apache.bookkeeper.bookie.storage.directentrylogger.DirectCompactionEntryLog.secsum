org.apache.bookkeeper.bookie.storage.directentrylogger.DirectCompactionEntryLog (
  int srcLogId, int dstLogId, java.io.File @ledgerDir,
  org.apache.bookkeeper.slogger.Slogger @slog) {
  guard = tt;
  ret(obj_level(@ledgerDir)) = pc ⊔ level(@ledgerDir) ⊔ level(dstLogId) ⊔ level(srcLogId) ⊔ level(this) ⊔ obj_level(@ledgerDir) ⊔ obj_level(this);
  ret(obj_level(@slog)) = pc ⊔ level(@slog) ⊔ level(dstLogId) ⊔ level(srcLogId) ⊔ level(this) ⊔ obj_level(@slog) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@ledgerDir) ⊔ level(@slog) ⊔ level(dstLogId) ⊔ level(srcLogId) ⊔ level(this) ⊔ obj_level(@ledgerDir) ⊔ obj_level(@slog) ⊔ obj_level(this);
}