boolean org.apache.bookkeeper.client.LedgerHandle:setLedgerMetadata (
  org.apache.bookkeeper.versioning.Versioned @expected,
  org.apache.bookkeeper.versioning.Versioned newMetadata) {
  guard = tt;
  ret(level()) = pc ⊔ level(@expected) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(@expected)) = pc ⊔ level(@expected) ⊔ level(newMetadata) ⊔ level(this) ⊔ obj_level(@expected) ⊔ obj_level(this);
  ret(obj_level(newMetadata)) = pc ⊔ level(@expected) ⊔ level(newMetadata) ⊔ level(this) ⊔ obj_level(newMetadata) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@expected) ⊔ level(newMetadata) ⊔ level(this) ⊔ obj_level(newMetadata) ⊔ obj_level(this);
}