org.apache.bookkeeper.meta.LedgerManagerFactory org.apache.bookkeeper.meta.LegacyHierarchicalLedgerManagerFactory:initialize (
  org.apache.bookkeeper.conf.AbstractConfiguration conf,
  org.apache.bookkeeper.meta.LayoutManager lm, int factoryVersion) {
  guard = tt;
  ret(level()) = pc ⊔ level(factoryVersion) ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(conf) ⊔ level(factoryVersion) ⊔ level(lm) ⊔ obj_level(conf) ⊔ obj_level(lm) ⊔ obj_level(this);
  ret(obj_level(conf)) = pc ⊔ level(factoryVersion) ⊔ obj_level(conf);
  ret(obj_level(lm)) = pc ⊔ level(conf) ⊔ level(factoryVersion) ⊔ level(lm) ⊔ obj_level(conf) ⊔ obj_level(lm);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(factoryVersion) ⊔ level(lm) ⊔ obj_level(conf) ⊔ obj_level(lm) ⊔ obj_level(this);
}