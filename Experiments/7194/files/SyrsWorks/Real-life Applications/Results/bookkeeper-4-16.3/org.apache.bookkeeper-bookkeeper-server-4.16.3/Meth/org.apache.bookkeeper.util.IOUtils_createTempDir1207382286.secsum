static java.io.File org.apache.bookkeeper.util.IOUtils:createTempDir (
  java.lang.String prefix, java.lang.String suffix) {
  guard = tt;
  ret(level()) = pc ⊔ level(prefix) ⊔ level(suffix) ⊔ obj_level(prefix);
  ret(obj_level()) = level(prefix) ⊔ level(suffix) ⊔ obj_level(prefix);
