void org.apache.bookkeeper.net.StabilizeNetworkTopology:updateNode (org.apache.bookkeeper.net.Node
                                                                    node,
                                                                    boolean
                                                                    tentativeToRemove) {
  guard = tt;
  ret(obj_level(node)) = pc ⊔ level(node) ⊔ level(tentativeToRemove) ⊔ level(this) ⊔ obj_level(node) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(node) ⊔ level(tentativeToRemove) ⊔ level(this) ⊔ obj_level(node) ⊔ obj_level(this);
}