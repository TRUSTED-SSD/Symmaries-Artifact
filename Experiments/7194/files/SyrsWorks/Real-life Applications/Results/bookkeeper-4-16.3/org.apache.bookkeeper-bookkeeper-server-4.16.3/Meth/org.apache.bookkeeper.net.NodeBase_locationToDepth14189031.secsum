static int org.apache.bookkeeper.net.NodeBase:locationToDepth (java.lang.String
                                                                 @location) {
  guard = tt;
  ret(level()) = pc ⊔ level(@location) ⊔ obj_level(@location);
  ret(obj_level(@location)) = pc ⊔ level(@location) ⊔ obj_level(@location);
}