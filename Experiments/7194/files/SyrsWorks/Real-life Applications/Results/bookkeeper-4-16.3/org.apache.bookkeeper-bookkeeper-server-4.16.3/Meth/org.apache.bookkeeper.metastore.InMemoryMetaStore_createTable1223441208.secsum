org.apache.bookkeeper.metastore.MetastoreTable org.apache.bookkeeper.metastore.InMemoryMetaStore:createTable (
  java.lang.String name) {
  guard = tt;
  ret(level()) = pc ⊔ level(name) ⊔ obj_level(name);
  ret(obj_level()) = pc ⊔ level(name) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(name)) = pc ⊔ level(name) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(name) ⊔ obj_level(name) ⊔ obj_level(this);
}