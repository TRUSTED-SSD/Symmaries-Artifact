static org.apache.bookkeeper.client.BookKeeper org.apache.bookkeeper.replication.Auditor:createBookKeeperClient (
  org.apache.bookkeeper.conf.ServerConfiguration conf,
  org.apache.bookkeeper.stats.StatsLogger statsLogger) {
  guard = ff;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(conf)) = ⊥;
  ret(obj_level(statsLogger)) = ⊥;
}