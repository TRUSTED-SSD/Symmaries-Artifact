org.apache.bookkeeper.metastore.MetastoreTableItem (java.lang.String key,
                                                    org.apache.bookkeeper.versioning.Versioned
                                                      value) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(this) ⊔ obj_level(key) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key) ⊔ obj_level(this) ⊔ obj_level(value);
}