org.apache.bookkeeper.feature.SettableFeature (java.lang.String name,
                                               int initialAvailability) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(initialAvailability) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(initialAvailability) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
}