static io.netty.buffer.ByteBuf org.apache.bookkeeper.proto.BookieProtoEncoding:serializeProtobuf (
  com.google.protobuf.MessageLite msg,
  io.netty.buffer.ByteBufAllocator allocator) {
  guard = pc ⊔ level(allocator) ⊔ level(msg) ⊔ obj_level(allocator) ⊔ obj_level(msg) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(allocator)) = ⊥;
  ret(obj_level(msg)) = ⊥;
}