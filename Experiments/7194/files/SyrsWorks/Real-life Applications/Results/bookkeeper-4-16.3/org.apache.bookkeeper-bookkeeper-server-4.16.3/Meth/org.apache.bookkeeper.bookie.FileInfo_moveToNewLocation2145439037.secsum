void org.apache.bookkeeper.bookie.FileInfo:moveToNewLocation (java.io.File
                                                                @newFile,
                                                              long size) {
  guard = tt;
  ret(obj_level(@newFile)) = pc ⊔ level(@newFile) ⊔ level(size) ⊔ level(this) ⊔ obj_level(@newFile) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@newFile) ⊔ level(size) ⊔ level(this) ⊔ obj_level(@newFile) ⊔ obj_level(this);
}