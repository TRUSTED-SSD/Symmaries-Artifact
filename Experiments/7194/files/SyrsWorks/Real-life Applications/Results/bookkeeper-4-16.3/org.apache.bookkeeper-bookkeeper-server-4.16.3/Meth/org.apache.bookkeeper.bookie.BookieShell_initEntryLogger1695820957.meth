void org.apache.bookkeeper.bookie.BookieShell:initEntryLogger()
{
org.apache.bookkeeper.bookie.storage.EntryLogger $stack1;
  org.apache.bookkeeper.bookie.ReadOnlyDefaultEntryLogger $stack2;
  org.apache.bookkeeper.conf.ServerConfiguration $stack3;
  $stack1=this.entryLogger;
 if (null!=$stack1) goto label0;
 $stack2=new org.apache.bookkeeper.bookie.ReadOnlyDefaultEntryLogger;
 $stack3=this.bkConf;
 $stack2#org.apache.bookkeeper.bookie.ReadOnlyDefaultEntryLogger($stack3);
 this.entryLogger=$stack2;
 label0:return;
 } 

