org.apache.bookkeeper.client.LedgerMetadataBuilder org.apache.bookkeeper.client.LedgerMetadataBuilder:withMetadataFormatVersion (
  int version) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ level(version);
  ret(obj_level()) = pc ⊔ level(version) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(version) ⊔ obj_level(this);
}