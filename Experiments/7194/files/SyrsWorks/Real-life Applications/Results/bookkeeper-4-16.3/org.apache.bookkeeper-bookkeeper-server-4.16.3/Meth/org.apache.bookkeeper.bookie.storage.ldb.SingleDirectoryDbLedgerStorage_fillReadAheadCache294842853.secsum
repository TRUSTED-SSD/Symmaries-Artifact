void org.apache.bookkeeper.bookie.storage.ldb.SingleDirectoryDbLedgerStorage:fillReadAheadCache (
  long orginalLedgerId, long firstEntryId, long firstEntryLocation) {
  p1: io.netty.buffer.ByteBuf () -> level;
  guard = tt;
  ret(obj_level(this)) = p1 ⊔ pc ⊔ level(firstEntryId) ⊔ level(firstEntryLocation) ⊔ level(orginalLedgerId) ⊔ level(this) ⊔ obj_level(this);
}