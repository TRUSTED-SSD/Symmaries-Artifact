org.apache.bookkeeper.server.http.service.MetricsService (org.apache.bookkeeper.conf.ServerConfiguration
                                                            conf,
                                                          org.apache.bookkeeper.stats.StatsProvider
                                                            statsProvider) {
  guard = tt;
  ret(obj_level(conf)) = pc ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(this);
  ret(obj_level(statsProvider)) = pc ⊔ level(this) ⊔ obj_level(statsProvider) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(conf) ⊔ level(statsProvider) ⊔ level(this) ⊔ obj_level(conf) ⊔ obj_level(statsProvider) ⊔ obj_level(this);
}