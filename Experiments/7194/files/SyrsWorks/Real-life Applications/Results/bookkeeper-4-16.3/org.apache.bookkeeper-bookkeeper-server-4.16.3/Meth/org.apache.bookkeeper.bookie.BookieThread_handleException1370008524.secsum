void org.apache.bookkeeper.bookie.BookieThread:handleException (java.lang.Thread
                                                                  t,
                                                                java.lang.Throwable
                                                                  e) {
  guard = tt;
  ret(obj_level(e)) = pc ⊔ level(e) ⊔ obj_level(e) ⊔ obj_level(t);
  ret(obj_level(t)) = pc ⊔ level(e) ⊔ obj_level(e) ⊔ obj_level(t);
  ret(obj_level(this)) = pc ⊔ level(e) ⊔ obj_level(e) ⊔ obj_level(t) ⊔ obj_level(this);
}