java.util.BitSet org.apache.bookkeeper.client.RoundRobinDistributionSchedule:getEntriesStripedToTheBookie (
  int bookieIndex, long startEntryId, long lastEntryId) {
  guard = pc ⊔ level(bookieIndex) ⊔ level(lastEntryId) ⊔ level(startEntryId) ⊔ level(this) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(this)) = ⊥;
}