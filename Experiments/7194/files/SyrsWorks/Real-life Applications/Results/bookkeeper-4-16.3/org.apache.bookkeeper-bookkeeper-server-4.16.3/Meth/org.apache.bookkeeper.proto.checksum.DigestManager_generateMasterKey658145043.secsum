static byte[] org.apache.bookkeeper.proto.checksum.DigestManager:generateMasterKey (
  byte[] @password) {
  guard = tt;
  ret(level()) = pc ⊔ level(@password) ⊔ obj_level(@password);
  ret(obj_level()) = pc ⊔ level(@password) ⊔ obj_level(@password);
  ret(obj_level(@password)) = pc ⊔ level(@password) ⊔ obj_level(@password);
}