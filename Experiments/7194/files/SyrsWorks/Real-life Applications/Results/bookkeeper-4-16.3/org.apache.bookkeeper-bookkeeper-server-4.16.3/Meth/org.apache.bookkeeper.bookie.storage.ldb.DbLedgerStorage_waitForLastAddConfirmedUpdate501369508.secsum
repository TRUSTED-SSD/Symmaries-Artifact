boolean org.apache.bookkeeper.bookie.storage.ldb.DbLedgerStorage:waitForLastAddConfirmedUpdate (
  long ledgerId, long previousLAC,
  org.apache.bookkeeper.common.util.Watcher watcher) {
  guard = tt;
  ret(level()) = pc ⊔ level(ledgerId) ⊔ level(previousLAC) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ledgerId) ⊔ level(previousLAC) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this) ⊔ obj_level(watcher);
  ret(obj_level(watcher)) = pc ⊔ level(ledgerId) ⊔ level(previousLAC) ⊔ level(this) ⊔ level(watcher) ⊔ obj_level(this) ⊔ obj_level(watcher);
}