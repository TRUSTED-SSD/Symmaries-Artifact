void org.apache.bookkeeper.sasl.SASLClientAuthProvider:init (org.apache.bookkeeper.auth.AuthCallbacks$GenericCallback
                                                               @cb) {
  guard = pc ⊔ level(@cb) ⊔ level(this) ⊔ obj_level(@cb) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@cb)) = ⊥;
  ret(obj_level(this)) = ⊥;
}