static java.util.List org.apache.bookkeeper.clients.utils.NetUtils:parseEndpoints (
  java.lang.String @endpointStr) {
  guard = tt;
  ret(level()) = level(@endpointStr) ⊔ obj_level(@endpointStr);
  ret(obj_level()) = level(@endpointStr) ⊔ obj_level(@endpointStr);
  ret(obj_level(@endpointStr)) = level(@endpointStr) ⊔ obj_level(@endpointStr);
}