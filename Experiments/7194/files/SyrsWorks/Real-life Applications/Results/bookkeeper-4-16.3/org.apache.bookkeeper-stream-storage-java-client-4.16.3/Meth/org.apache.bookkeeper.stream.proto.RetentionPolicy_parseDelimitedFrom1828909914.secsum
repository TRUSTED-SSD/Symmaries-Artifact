static org.apache.bookkeeper.stream.proto.RetentionPolicy org.apache.bookkeeper.stream.proto.RetentionPolicy:parseDelimitedFrom (
  java.io.InputStream input) {
  guard = tt;
  ret(level()) = level(input) ⊔ obj_level(input);
  ret(obj_level()) = level(input) ⊔ obj_level(input);
  ret(obj_level(input)) = level(input) ⊔ obj_level(input);
}