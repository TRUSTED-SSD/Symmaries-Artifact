void org.apache.bookkeeper.common.grpc.stats.MonitoringClientCallListener:onClose (
  io.grpc.Status status, io.grpc.Metadata trailers) {
  guard = tt;
  ret(obj_level(status)) = level(status) ⊔ level(this) ⊔ level(trailers) ⊔ obj_level(status) ⊔ obj_level(this) ⊔ obj_level(trailers);
  ret(obj_level(this)) = level(status) ⊔ level(this) ⊔ level(trailers) ⊔ obj_level(status) ⊔ obj_level(this) ⊔ obj_level(trailers);
  ret(obj_level(trailers)) = level(status) ⊔ level(this) ⊔ level(trailers) ⊔ obj_level(status) ⊔ obj_level(this) ⊔ obj_level(trailers);
}