org.apache.bookkeeper.common.exceptions.ObjectClosedException (java.lang.String
                                                                 @name) {
  guard = tt;
  ret(obj_level(@name)) = level(@name) ⊔ obj_level(@name);
  ret(obj_level(this)) = level(@name) ⊔ level(this) ⊔ obj_level(@name) ⊔ obj_level(this);
}