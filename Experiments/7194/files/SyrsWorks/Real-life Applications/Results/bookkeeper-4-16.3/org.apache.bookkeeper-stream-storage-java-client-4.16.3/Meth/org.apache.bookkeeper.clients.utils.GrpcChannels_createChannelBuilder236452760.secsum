static io.grpc.ManagedChannelBuilder org.apache.bookkeeper.clients.utils.GrpcChannels:createChannelBuilder (
  java.lang.String @serviceUri,
  org.apache.bookkeeper.clients.config.StorageClientSettings settings) {
  guard = tt;
  ret(level()) = level(@serviceUri) ⊔ obj_level(@serviceUri);
  ret(obj_level()) = level(@serviceUri) ⊔ obj_level(@serviceUri);
  ret(obj_level(@serviceUri)) = level(@serviceUri) ⊔ obj_level(@serviceUri);
  ret(obj_level(settings)) = level(@serviceUri) ⊔ obj_level(@serviceUri) ⊔ obj_level(settings);
}