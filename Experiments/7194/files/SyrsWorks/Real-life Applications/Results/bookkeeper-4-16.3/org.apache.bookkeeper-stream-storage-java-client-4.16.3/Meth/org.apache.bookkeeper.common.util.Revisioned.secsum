org.apache.bookkeeper.common.util.Revisioned (java.lang.Object value,
                                              long revision) {
  guard = tt;
  ret(obj_level(this)) = level(revision) ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
  ret(obj_level(value)) = level(revision) ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
}