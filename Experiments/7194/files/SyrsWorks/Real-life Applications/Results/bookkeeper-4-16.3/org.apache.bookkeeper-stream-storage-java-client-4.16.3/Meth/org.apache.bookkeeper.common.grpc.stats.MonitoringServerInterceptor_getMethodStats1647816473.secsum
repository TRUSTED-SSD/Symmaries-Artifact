org.apache.bookkeeper.common.grpc.stats.ServerStats org.apache.bookkeeper.common.grpc.stats.MonitoringServerInterceptor:getMethodStats (
  io.grpc.MethodDescriptor method) {
  guard = tt;
  ret(level()) = level(this) ⊔ obj_level(method) ⊔ obj_level(this);
  ret(obj_level()) = level(this) ⊔ obj_level(method) ⊔ obj_level(this);
  ret(obj_level(method)) = level(this) ⊔ obj_level(method) ⊔ obj_level(this);
  ret(obj_level(this)) = level(this) ⊔ obj_level(method) ⊔ obj_level(this);
}