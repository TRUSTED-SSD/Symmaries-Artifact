org.apache.bookkeeper.clients.exceptions.InvalidNamespaceNameException (
  java.lang.String @colName) {
  guard = tt;
  ret(obj_level(@colName)) = level(@colName) ⊔ level(this) ⊔ obj_level(@colName) ⊔ obj_level(this);
  ret(obj_level(this)) = level(@colName) ⊔ level(this) ⊔ obj_level(@colName) ⊔ obj_level(this);
}