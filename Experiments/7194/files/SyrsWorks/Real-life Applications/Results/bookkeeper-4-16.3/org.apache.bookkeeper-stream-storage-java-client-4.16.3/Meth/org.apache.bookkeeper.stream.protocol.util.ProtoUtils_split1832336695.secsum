static java.util.List org.apache.bookkeeper.stream.protocol.util.ProtoUtils:split (
  long streamId, int numInitialRanges, long nextRangeId,
  org.apache.bookkeeper.stream.protocol.util.StorageContainerPlacementPolicy
    placementPolicy) {
  guard = tt;
  ret(level()) = level(numInitialRanges);
  ret(obj_level()) = level(nextRangeId) ⊔ level(numInitialRanges) ⊔ level(placementPolicy) ⊔ level(streamId) ⊔ obj_level(placementPolicy);
  ret(obj_level(placementPolicy)) = level(nextRangeId) ⊔ level(numInitialRanges) ⊔ level(placementPolicy) ⊔ level(streamId) ⊔ obj_level(placementPolicy);
}