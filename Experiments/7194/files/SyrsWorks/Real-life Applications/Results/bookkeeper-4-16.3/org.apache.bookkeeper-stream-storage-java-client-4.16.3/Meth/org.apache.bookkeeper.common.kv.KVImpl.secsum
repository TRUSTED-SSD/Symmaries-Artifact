org.apache.bookkeeper.common.kv.KVImpl (java.lang.Object key,
                                        java.lang.Object value) {
  guard = tt;
  ret(obj_level(key)) = level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key);
  ret(obj_level(this)) = level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key);
  ret(obj_level(value)) = level(key) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key);
}