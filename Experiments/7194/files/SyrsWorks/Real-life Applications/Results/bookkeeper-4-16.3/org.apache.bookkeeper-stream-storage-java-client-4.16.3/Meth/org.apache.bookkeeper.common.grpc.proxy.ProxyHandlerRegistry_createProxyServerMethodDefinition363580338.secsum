static io.grpc.ServerMethodDefinition org.apache.bookkeeper.common.grpc.proxy.ProxyHandlerRegistry:createProxyServerMethodDefinition (
  io.grpc.MethodDescriptor @methodDesc, io.grpc.ServerCallHandler handler) {
  guard = tt;
  ret(level()) = level(handler) ⊔ obj_level(@methodDesc) ⊔ obj_level(handler);
  ret(obj_level()) = level(handler) ⊔ obj_level(@methodDesc) ⊔ obj_level(handler);
  ret(obj_level(@methodDesc)) = level(handler) ⊔ obj_level(@methodDesc) ⊔ obj_level(handler);
  ret(obj_level(handler)) = level(handler) ⊔ obj_level(@methodDesc) ⊔ obj_level(handler);
}