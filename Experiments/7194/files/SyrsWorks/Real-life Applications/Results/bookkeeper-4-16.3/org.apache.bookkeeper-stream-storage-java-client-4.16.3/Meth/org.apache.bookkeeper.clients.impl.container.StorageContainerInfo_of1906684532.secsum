static org.apache.bookkeeper.clients.impl.container.StorageContainerInfo org.apache.bookkeeper.clients.impl.container.StorageContainerInfo:of (
  long groupId, long revision,
  org.apache.bookkeeper.stream.proto.common.Endpoint endpoint) {
  guard = tt;
  ret(level()) = level(endpoint) ⊔ level(groupId) ⊔ level(revision) ⊔ obj_level(endpoint);
  ret(obj_level()) = level(endpoint) ⊔ level(groupId) ⊔ level(revision) ⊔ obj_level(endpoint);
  ret(obj_level(endpoint)) = level(endpoint) ⊔ obj_level(endpoint);
