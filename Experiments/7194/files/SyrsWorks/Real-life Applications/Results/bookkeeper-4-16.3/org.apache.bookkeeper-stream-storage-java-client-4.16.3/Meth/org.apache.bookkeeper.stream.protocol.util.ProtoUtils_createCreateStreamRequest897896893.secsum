static org.apache.bookkeeper.stream.proto.storage.CreateStreamRequest org.apache.bookkeeper.stream.protocol.util.ProtoUtils:createCreateStreamRequest (
  java.lang.String nsName, java.lang.String streamName,
  org.apache.bookkeeper.stream.proto.StreamConfiguration streamConf) {
  guard = tt;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(nsName)) = level(nsName) ⊔ level(streamConf) ⊔ level(streamName) ⊔ obj_level(streamConf) ⊔ obj_level(streamName);
  ret(obj_level(streamConf)) = level(nsName) ⊔ level(streamConf) ⊔ level(streamName) ⊔ obj_level(streamConf) ⊔ obj_level(streamName);
  ret(obj_level(streamName)) = level(nsName) ⊔ level(streamConf) ⊔ level(streamName) ⊔ obj_level(streamConf) ⊔ obj_level(streamName);
}