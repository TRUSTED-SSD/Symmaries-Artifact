void org.apache.bookkeeper.common.grpc.stats.MonitoringServerCall:close (
  io.grpc.Status status, io.grpc.Metadata trailers) {
  guard = tt;
  ret(obj_level(status)) = level(this) ⊔ obj_level(status) ⊔ obj_level(this);
  ret(obj_level(this)) = level(this) ⊔ obj_level(this);
  ret(obj_level(trailers)) = level(this) ⊔ obj_level(this) ⊔ obj_level(trailers);
}