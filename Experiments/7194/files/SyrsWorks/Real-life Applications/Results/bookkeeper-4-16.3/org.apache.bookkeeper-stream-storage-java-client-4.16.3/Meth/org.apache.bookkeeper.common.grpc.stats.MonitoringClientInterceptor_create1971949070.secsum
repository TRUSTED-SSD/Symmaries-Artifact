static org.apache.bookkeeper.common.grpc.stats.MonitoringClientInterceptor org.apache.bookkeeper.common.grpc.stats.MonitoringClientInterceptor:create (
  org.apache.bookkeeper.stats.StatsLogger statsLogger,
  boolean includeLatencyHistograms) {
  guard = tt;
  ret(level()) = ⊥;
  ret(obj_level()) = level(includeLatencyHistograms) ⊔ level(statsLogger) ⊔ obj_level(statsLogger);
  ret(obj_level(statsLogger)) = level(includeLatencyHistograms) ⊔ level(statsLogger) ⊔ obj_level(statsLogger);
}