  org.apache.bookkeeper.common.grpc.stats.ClientStats$Factory statsFactory,
  org.apache.bookkeeper.stats.StatsLogger statsLogger) {
  guard = tt;
  ret(obj_level(statsFactory)) = level(this) ⊔ obj_level(statsFactory) ⊔ obj_level(this);
  ret(obj_level(statsLogger)) = level(this) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
  ret(obj_level(this)) = level(statsFactory) ⊔ level(statsLogger) ⊔ level(this) ⊔ obj_level(statsFactory) ⊔ obj_level(statsLogger) ⊔ obj_level(this);
}