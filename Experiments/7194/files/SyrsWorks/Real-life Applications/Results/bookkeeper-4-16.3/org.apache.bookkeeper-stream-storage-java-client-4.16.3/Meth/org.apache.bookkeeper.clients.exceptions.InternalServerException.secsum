org.apache.bookkeeper.clients.exceptions.InternalServerException (java.lang.String
                                                                    message) {
  guard = tt;
  ret(obj_level(message)) = level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
  ret(obj_level(this)) = level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
}