void org.apache.bookkeeper.common.coder.ByteArrayCoder:encode (byte[] value,
                                                               io.netty.buffer.ByteBuf
                                                                 @destBuf) {
  guard = tt;
  ret(obj_level(@destBuf)) = level(@destBuf) ⊔ level(value) ⊔ obj_level(@destBuf) ⊔ obj_level(value);
  ret(obj_level(this)) = obj_level(this);
  ret(obj_level(value)) = obj_level(value);
}