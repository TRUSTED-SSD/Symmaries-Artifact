boolean org.apache.bookkeeper.clients.impl.internal.StreamMetadataCache:putStreamProperties (
  long streamId, org.apache.bookkeeper.stream.proto.StreamProperties props) {
  guard = tt;
  ret(level()) = ⊥;
  ret(obj_level(props)) = level(props) ⊔ level(streamId) ⊔ level(this) ⊔ obj_level(props) ⊔ obj_level(this);
  ret(obj_level(this)) = level(props) ⊔ level(streamId) ⊔ level(this) ⊔ obj_level(props) ⊔ obj_level(this);
}