org.apache.bookkeeper.api.kv.Txn org.apache.bookkeeper.clients.impl.kv.PByteBufTableRangeImpl:txn (
  io.netty.buffer.ByteBuf pKey) {
  guard = tt;
  ret(level()) = ⊥;
  ret(obj_level()) = level(pKey) ⊔ level(this) ⊔ obj_level(pKey) ⊔ obj_level(this);
  ret(obj_level(pKey)) = level(pKey) ⊔ level(this) ⊔ obj_level(pKey) ⊔ obj_level(this);
  ret(obj_level(this)) = level(pKey) ⊔ level(this) ⊔ obj_level(pKey) ⊔ obj_level(this);
}