static void org.apache.bookkeeper.clients.utils.GrpcUtils:processRpcException (
  java.lang.Throwable rpcCause,
  java.util.concurrent.CompletableFuture future) {
  guard = tt;
  ret(obj_level(future)) = level(future) ⊔ level(rpcCause) ⊔ obj_level(future) ⊔ obj_level(rpcCause);
  ret(obj_level(rpcCause)) = level(future) ⊔ level(rpcCause) ⊔ obj_level(future) ⊔ obj_level(rpcCause);
}