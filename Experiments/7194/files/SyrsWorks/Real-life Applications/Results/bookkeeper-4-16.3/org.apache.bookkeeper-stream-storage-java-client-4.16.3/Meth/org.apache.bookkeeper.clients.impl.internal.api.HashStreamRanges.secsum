org.apache.bookkeeper.clients.impl.internal.api.HashStreamRanges (java.util.NavigableMap
                                                                    ranges,
                                                                  long
                                                                    maxRangeId) {
  guard = tt;
  ret(obj_level(ranges)) = level(maxRangeId) ⊔ level(ranges) ⊔ level(this) ⊔ obj_level(ranges) ⊔ obj_level(this);
  ret(obj_level(this)) = level(maxRangeId) ⊔ level(ranges) ⊔ level(this) ⊔ obj_level(ranges) ⊔ obj_level(this);
}