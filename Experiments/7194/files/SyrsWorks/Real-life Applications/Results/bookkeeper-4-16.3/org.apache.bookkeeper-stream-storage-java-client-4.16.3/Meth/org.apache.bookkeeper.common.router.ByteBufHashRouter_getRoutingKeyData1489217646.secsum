io.netty.buffer.ByteBuf org.apache.bookkeeper.common.router.ByteBufHashRouter:getRoutingKeyData (
  io.netty.buffer.ByteBuf @key) {
  guard = tt;
  ret(level()) = level(@key) ⊔ obj_level(@key);
  ret(obj_level()) = level(@key) ⊔ obj_level(@key);
  ret(obj_level(@key)) = level(@key) ⊔ obj_level(@key);
  ret(obj_level(this)) = obj_level(this);
}