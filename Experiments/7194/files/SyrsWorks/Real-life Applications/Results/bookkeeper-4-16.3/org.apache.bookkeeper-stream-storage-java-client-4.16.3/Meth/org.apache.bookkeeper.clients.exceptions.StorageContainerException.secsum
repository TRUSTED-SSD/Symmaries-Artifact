org.apache.bookkeeper.clients.exceptions.StorageContainerException (org.apache.bookkeeper.stream.proto.storage.StatusCode
                                                                    code,
                                                                    java.lang.String
                                                                    @message) {
  guard = tt;
  ret(obj_level(@message)) = level(@message) ⊔ level(code) ⊔ level(this) ⊔ obj_level(@message) ⊔ obj_level(code) ⊔ obj_level(this);
  ret(obj_level(code)) = level(@message) ⊔ level(code) ⊔ level(this) ⊔ obj_level(@message) ⊔ obj_level(code) ⊔ obj_level(this);
  ret(obj_level(this)) = level(@message) ⊔ level(code) ⊔ level(this) ⊔ obj_level(@message) ⊔ obj_level(code) ⊔ obj_level(this);
}