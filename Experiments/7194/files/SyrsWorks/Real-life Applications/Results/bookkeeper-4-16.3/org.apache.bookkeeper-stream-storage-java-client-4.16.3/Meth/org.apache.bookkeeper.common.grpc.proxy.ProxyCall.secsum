org.apache.bookkeeper.common.grpc.proxy.ProxyCall (io.grpc.ServerCall
                                                     serverCall,
                                                   io.grpc.ClientCall
                                                     clientCall) {
  guard = tt;
  ret(obj_level(clientCall)) = level(clientCall) ⊔ level(serverCall) ⊔ level(this) ⊔ obj_level(clientCall) ⊔ obj_level(serverCall) ⊔ obj_level(this);
  ret(obj_level(serverCall)) = level(clientCall) ⊔ level(serverCall) ⊔ level(this) ⊔ obj_level(clientCall) ⊔ obj_level(serverCall) ⊔ obj_level(this);
  ret(obj_level(this)) = level(clientCall) ⊔ level(serverCall) ⊔ level(this) ⊔ obj_level(clientCall) ⊔ obj_level(serverCall) ⊔ obj_level(this);
}