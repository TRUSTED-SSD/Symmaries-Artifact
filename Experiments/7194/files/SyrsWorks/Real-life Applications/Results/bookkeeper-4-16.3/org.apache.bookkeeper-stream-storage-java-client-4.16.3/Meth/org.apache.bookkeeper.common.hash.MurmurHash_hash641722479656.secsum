static long org.apache.bookkeeper.common.hash.MurmurHash:hash64 (io.netty.buffer.ByteBuf
                                                                   key,
                                                                 int offset,
                                                                 int length,
                                                                 long seed) {
  guard = tt;
  ret(level()) = level(key) ⊔ level(length) ⊔ level(offset) ⊔ level(seed) ⊔ obj_level(key);
  ret(obj_level(key)) = level(key) ⊔ level(length) ⊔ level(offset) ⊔ obj_level(key);
}