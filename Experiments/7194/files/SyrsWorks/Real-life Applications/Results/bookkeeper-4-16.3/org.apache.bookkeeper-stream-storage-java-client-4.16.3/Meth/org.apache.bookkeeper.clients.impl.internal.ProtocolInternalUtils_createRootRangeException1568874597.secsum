static java.lang.Throwable org.apache.bookkeeper.clients.impl.internal.ProtocolInternalUtils:createRootRangeException (
  java.lang.String @streamName,
  org.apache.bookkeeper.stream.proto.storage.StatusCode statusCode) {
  guard = tt;
  ret(level()) = ⊥;
  ret(obj_level()) = level(@streamName) ⊔ level(statusCode) ⊔ obj_level(@streamName) ⊔ obj_level(statusCode);
  ret(obj_level(@streamName)) = level(@streamName) ⊔ level(statusCode) ⊔ obj_level(@streamName) ⊔ obj_level(statusCode);
  ret(obj_level(statusCode)) = level(@streamName) ⊔ level(statusCode) ⊔ obj_level(@streamName) ⊔ obj_level(statusCode);
}