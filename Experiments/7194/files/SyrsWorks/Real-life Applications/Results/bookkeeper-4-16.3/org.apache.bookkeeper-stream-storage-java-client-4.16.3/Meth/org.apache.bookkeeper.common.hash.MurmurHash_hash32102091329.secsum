static int org.apache.bookkeeper.common.hash.MurmurHash:hash32 (io.netty.buffer.ByteBuf
                                                                  data,
                                                                int offset,
                                                                int length,
                                                                int seed) {
  guard = tt;
  ret(level()) = level(data) ⊔ level(length) ⊔ level(offset) ⊔ level(seed) ⊔ obj_level(data);
  ret(obj_level(data)) = level(data) ⊔ level(length) ⊔ level(offset) ⊔ obj_level(data);
}