org.apache.bookkeeper.clients.exceptions.InvalidStreamNameException (
  java.lang.String @streamName) {
  guard = tt;
  ret(obj_level(@streamName)) = level(@streamName) ⊔ level(this) ⊔ obj_level(@streamName) ⊔ obj_level(this);
  ret(obj_level(this)) = level(@streamName) ⊔ level(this) ⊔ obj_level(@streamName) ⊔ obj_level(this);
}