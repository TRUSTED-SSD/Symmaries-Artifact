io.grpc.ServerMethodDefinition org.apache.bookkeeper.common.grpc.proxy.ProxyHandlerRegistry:lookupMethod (
  java.lang.String methodName, java.lang.String authority) {
  guard = tt;
  ret(level()) = level(methodName) ⊔ level(this) ⊔ obj_level(methodName) ⊔ obj_level(this);
  ret(obj_level()) = level(methodName) ⊔ level(this) ⊔ obj_level(methodName) ⊔ obj_level(this);
  ret(obj_level(authority)) = level(methodName) ⊔ level(this) ⊔ obj_level(authority) ⊔ obj_level(this);
  ret(obj_level(methodName)) = level(methodName) ⊔ level(this) ⊔ obj_level(methodName) ⊔ obj_level(this);
  ret(obj_level(this)) = level(methodName) ⊔ level(this) ⊔ obj_level(methodName) ⊔ obj_level(this);
}