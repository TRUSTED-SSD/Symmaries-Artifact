org.apache.bookkeeper.http.service.HttpServiceResponse org.apache.bookkeeper.http.service.NullHttpService:handle (
  org.apache.bookkeeper.http.service.HttpServiceRequest request) {
  guard = tt;
  ret(level()) = pc ⊔ level(request) ⊔ obj_level(request);
  ret(obj_level()) = pc ⊔ level(request) ⊔ obj_level(request);
  ret(obj_level(request)) = pc ⊔ level(request) ⊔ obj_level(request);
  ret(obj_level(this)) = obj_level(this);
}