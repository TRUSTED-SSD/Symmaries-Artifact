static void org.apache.bookkeeper.tools.framework.CommandUtils:printDescription (
  java.io.PrintStream printer, int firstLineIndent, int indent,
  java.lang.String @description) {
  guard = pc ⊔ level(@description) ⊔ level(indent) ⊔ level(printer) ⊔ obj_level(@description) ⊔ obj_level(printer) = ⊥;
  ret(obj_level(@description)) = ⊥;
  ret(obj_level(printer)) = ⊥;
}