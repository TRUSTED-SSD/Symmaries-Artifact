static com.beust.jcommander.JCommander org.apache.bookkeeper.tools.framework.Cli:setupCli (
  java.lang.String @cmdPath,
  org.apache.bookkeeper.tools.framework.CliSpec spec,
  java.util.Map commandMap) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = ⊤;
  ret(obj_level(@cmdPath)) = ⊤;
  ret(obj_level(commandMap)) = ⊤;
  ret(obj_level(spec)) = ⊤;
}