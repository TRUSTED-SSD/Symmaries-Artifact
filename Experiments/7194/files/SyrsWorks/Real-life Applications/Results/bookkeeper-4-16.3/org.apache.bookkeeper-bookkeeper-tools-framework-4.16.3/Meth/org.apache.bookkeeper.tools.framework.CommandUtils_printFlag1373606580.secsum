static void org.apache.bookkeeper.tools.framework.CommandUtils:printFlag (
  com.beust.jcommander.ParameterDescription pd, int indent,
  java.io.PrintStream printer) {
  guard = pc ⊔ level(indent) ⊔ level(printer) ⊔ obj_level(pd) ⊔ obj_level(printer) = ⊥;
  ret(obj_level(pd)) = ⊥;
  ret(obj_level(printer)) = ⊥;
}