org.apache.bookkeeper.tools.framework.CliSpec org.apache.bookkeeper.tools.framework.Cli:updateSpecWithDefaultValues (
  org.apache.bookkeeper.tools.framework.CliSpec @spec) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc;
  ret(obj_level(@spec)) = pc ⊔ level(@spec) ⊔ obj_level(@spec);
  ret(obj_level(this)) = pc ⊔ level(@spec) ⊔ obj_level(@spec) ⊔ obj_level(this);
}