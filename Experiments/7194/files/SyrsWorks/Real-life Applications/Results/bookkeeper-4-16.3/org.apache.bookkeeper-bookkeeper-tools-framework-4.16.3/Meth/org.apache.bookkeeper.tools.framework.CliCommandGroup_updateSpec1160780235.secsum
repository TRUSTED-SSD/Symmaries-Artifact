static org.apache.bookkeeper.tools.framework.CliSpec org.apache.bookkeeper.tools.framework.CliCommandGroup:updateSpec (
  org.apache.bookkeeper.tools.framework.CliSpec @spec) {
  guard = tt;
  ret(level()) = pc ⊔ level(@spec) ⊔ obj_level(@spec);
  ret(obj_level()) = pc ⊔ level(@spec) ⊔ obj_level(@spec);
  ret(obj_level(@spec)) = pc ⊔ level(@spec) ⊔ obj_level(@spec);
}