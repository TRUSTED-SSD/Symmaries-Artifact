static void org.apache.bookkeeper.tools.framework.CommandUtils:printCommand (
  java.io.PrintStream printer, java.lang.String @name,
  org.apache.bookkeeper.tools.framework.Command command,
  int longestCommandName) {
  guard = pc ⊔ level(@name) ⊔ level(command) ⊔ level(longestCommandName) ⊔ level(printer) ⊔ obj_level(@name) ⊔ obj_level(command) ⊔ obj_level(printer) = ⊥;
  ret(obj_level(@name)) = ⊥;
  ret(obj_level(command)) = ⊥;
  ret(obj_level(printer)) = ⊥;
}