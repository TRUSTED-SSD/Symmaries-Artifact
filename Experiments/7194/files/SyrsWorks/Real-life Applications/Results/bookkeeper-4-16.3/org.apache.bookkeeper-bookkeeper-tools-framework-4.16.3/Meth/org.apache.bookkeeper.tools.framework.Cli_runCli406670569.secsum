static int org.apache.bookkeeper.tools.framework.Cli:runCli (org.apache.bookkeeper.tools.framework.CliSpec
                                                               spec,
                                                             java.lang.String[]
                                                               args) {
  guard = tt;
  ret(level()) = pc ⊔ level(args) ⊔ obj_level(args);
  ret(obj_level(args)) = obj_level(args);
  ret(obj_level(spec)) = if obj_level(spec) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(args) = ⊤ ∧ obj_level(spec) = ⊥ then ⊤ else ⊥;
}