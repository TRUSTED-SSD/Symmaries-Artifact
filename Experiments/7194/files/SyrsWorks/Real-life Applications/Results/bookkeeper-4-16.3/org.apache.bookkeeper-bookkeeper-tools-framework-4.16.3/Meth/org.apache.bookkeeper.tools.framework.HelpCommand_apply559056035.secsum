java.lang.Boolean org.apache.bookkeeper.tools.framework.HelpCommand:apply (
  org.apache.bookkeeper.tools.framework.CliFlags globalFlags,
  java.lang.String[] args) {
  guard = pc ⊔ level(args) ⊔ level(this) ⊔ obj_level(args) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(args)) = ⊥;
  ret(obj_level(globalFlags)) = obj_level(globalFlags);
  ret(obj_level(this)) = ⊥;
}