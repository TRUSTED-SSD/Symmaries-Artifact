static void org.apache.bookkeeper.tools.framework.CommandUtils:printCategoryHeader (
  java.io.PrintStream printer, java.lang.String @category) {
  guard = pc ⊔ level(@category) ⊔ level(printer) ⊔ obj_level(@category) ⊔ obj_level(printer) = ⊥;
  ret(obj_level(@category)) = ⊥;
  ret(obj_level(printer)) = ⊥;
}