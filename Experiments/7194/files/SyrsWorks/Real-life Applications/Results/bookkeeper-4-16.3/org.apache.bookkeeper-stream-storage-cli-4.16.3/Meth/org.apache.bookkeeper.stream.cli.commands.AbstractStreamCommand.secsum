org.apache.bookkeeper.stream.cli.commands.AbstractStreamCommand (org.apache.bookkeeper.tools.framework.CliSpec
                                                                   spec) {
  guard = tt;
  ret(obj_level(spec)) = pc ⊔ level(spec) ⊔ level(this) ⊔ obj_level(spec) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(spec) ⊔ level(this) ⊔ obj_level(spec) ⊔ obj_level(this);
}