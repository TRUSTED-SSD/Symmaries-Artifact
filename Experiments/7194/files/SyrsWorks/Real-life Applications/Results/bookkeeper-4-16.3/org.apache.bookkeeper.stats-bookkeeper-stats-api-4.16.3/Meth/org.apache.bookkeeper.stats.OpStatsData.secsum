org.apache.bookkeeper.stats.OpStatsData (long numSuccessfulEvents,
                                         long numFailedEvents,
                                         double avgLatencyMillis,
                                         long[] @percentileLatenciesMillis) {
  guard = tt;
  ret(obj_level(@percentileLatenciesMillis)) = pc ⊔ level(@percentileLatenciesMillis) ⊔ level(this) ⊔ obj_level(@percentileLatenciesMillis) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@percentileLatenciesMillis) ⊔ level(avgLatencyMillis) ⊔ level(numFailedEvents) ⊔ level(numSuccessfulEvents) ⊔ level(this) ⊔ obj_level(@percentileLatenciesMillis) ⊔ obj_level(this);
}