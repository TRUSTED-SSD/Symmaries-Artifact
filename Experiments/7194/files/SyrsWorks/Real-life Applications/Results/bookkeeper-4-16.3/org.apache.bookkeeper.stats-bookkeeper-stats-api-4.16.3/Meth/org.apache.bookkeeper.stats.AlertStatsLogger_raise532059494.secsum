void org.apache.bookkeeper.stats.AlertStatsLogger:raise (java.lang.String
                                                           @msg,
                                                         java.lang.Object[]
                                                           args) {
  guard = pc ⊔ level(@msg) ⊔ level(args) ⊔ level(this) ⊔ obj_level(@msg) ⊔ obj_level(args) ⊔ obj_level(this) = ⊥;
  ret(obj_level(@msg)) = ⊥;
  ret(obj_level(args)) = ⊥;
  ret(obj_level(this)) = ⊥;
}