void org.apache.bookkeeper.stats.prometheus.PrometheusTextFormat:writeType (
  java.io.Writer @w, java.lang.String name, java.lang.String type) {
  guard = tt;
  ret(obj_level(@w)) = pc ⊔ level(@w) ⊔ level(name) ⊔ level(this) ⊔ level(type) ⊔ obj_level(@w) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(name)) = pc ⊔ level(@w) ⊔ level(name) ⊔ level(this) ⊔ level(type) ⊔ obj_level(@w) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@w) ⊔ level(name) ⊔ level(this) ⊔ level(type) ⊔ obj_level(@w) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(type)) = pc ⊔ level(@w) ⊔ level(name) ⊔ level(this) ⊔ level(type) ⊔ obj_level(@w) ⊔ obj_level(name) ⊔ obj_level(this);
}