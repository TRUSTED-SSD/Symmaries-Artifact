void org.apache.bookkeeper.stats.prometheus.PrometheusMetricsProvider:registerMetrics (
  io.prometheus.client.Collector collector) {
  guard = tt;
  ret(obj_level(collector)) = pc ⊔ level(collector) ⊔ level(this) ⊔ obj_level(collector) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(collector) ⊔ level(this) ⊔ obj_level(collector) ⊔ obj_level(this);
}