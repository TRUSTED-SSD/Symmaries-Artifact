void org.apache.bookkeeper.stats.prometheus.PrometheusServlet:doGet (
  javax.servlet.http.HttpServletRequest req,
  javax.servlet.http.HttpServletResponse resp) {
  guard = tt;
  ret(obj_level(req)) = pc ⊔ level(resp) ⊔ obj_level(req) ⊔ obj_level(resp);
  ret(obj_level(resp)) = pc ⊔ level(resp) ⊔ obj_level(resp);
  ret(obj_level(this)) = pc ⊔ level(resp) ⊔ obj_level(resp) ⊔ obj_level(this);
}