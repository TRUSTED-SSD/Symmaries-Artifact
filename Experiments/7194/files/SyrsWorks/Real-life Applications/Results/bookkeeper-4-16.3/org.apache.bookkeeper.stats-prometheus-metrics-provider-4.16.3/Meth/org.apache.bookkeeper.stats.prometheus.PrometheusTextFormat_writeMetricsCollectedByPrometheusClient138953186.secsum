static void org.apache.bookkeeper.stats.prometheus.PrometheusTextFormat:writeMetricsCollectedByPrometheusClient (
  java.io.Writer w, io.prometheus.client.CollectorRegistry registry) {
  guard = pc ⊔ level(registry) ⊔ level(w) ⊔ obj_level(registry) ⊔ obj_level(w) = ⊥;
  ret(obj_level(registry)) = ⊥;
  ret(obj_level(w)) = ⊥;
}