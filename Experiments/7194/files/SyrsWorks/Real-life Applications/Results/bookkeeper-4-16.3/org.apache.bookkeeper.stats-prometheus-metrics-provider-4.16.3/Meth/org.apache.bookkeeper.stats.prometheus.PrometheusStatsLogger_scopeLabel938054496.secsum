org.apache.bookkeeper.stats.StatsLogger org.apache.bookkeeper.stats.prometheus.PrometheusStatsLogger:scopeLabel (
  java.lang.String @labelName, java.lang.String labelValue) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@labelName) ⊔ level(labelValue) ⊔ level(this) ⊔ obj_level(labelValue) ⊔ obj_level(this);
  ret(obj_level(@labelName)) = pc ⊔ level(@labelName) ⊔ level(labelValue) ⊔ level(this) ⊔ obj_level(labelValue) ⊔ obj_level(this);
  ret(obj_level(labelValue)) = pc ⊔ level(@labelName) ⊔ level(labelValue) ⊔ level(this) ⊔ obj_level(labelValue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@labelName) ⊔ level(labelValue) ⊔ level(this) ⊔ obj_level(labelValue) ⊔ obj_level(this);
}