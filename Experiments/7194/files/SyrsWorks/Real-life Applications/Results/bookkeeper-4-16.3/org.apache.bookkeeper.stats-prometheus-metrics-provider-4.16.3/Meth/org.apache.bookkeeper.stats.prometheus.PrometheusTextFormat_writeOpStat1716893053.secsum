void org.apache.bookkeeper.stats.prometheus.PrometheusTextFormat:writeOpStat (
  java.io.Writer w, java.lang.String name,
  org.apache.bookkeeper.stats.prometheus.DataSketchesOpStatsLogger opStat) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(name) ⊔ level(opStat) ⊔ level(this) ⊔ level(w) ⊔ obj_level(name) ⊔ obj_level(opStat) ⊔ obj_level(this) ⊔ obj_level(w);
  ret(obj_level(opStat)) = pc ⊔ level(name) ⊔ level(opStat) ⊔ level(this) ⊔ level(w) ⊔ obj_level(name) ⊔ obj_level(opStat) ⊔ obj_level(this) ⊔ obj_level(w);
  ret(obj_level(this)) = pc ⊔ level(name) ⊔ level(opStat) ⊔ level(this) ⊔ level(w) ⊔ obj_level(name) ⊔ obj_level(opStat) ⊔ obj_level(this) ⊔ obj_level(w);
