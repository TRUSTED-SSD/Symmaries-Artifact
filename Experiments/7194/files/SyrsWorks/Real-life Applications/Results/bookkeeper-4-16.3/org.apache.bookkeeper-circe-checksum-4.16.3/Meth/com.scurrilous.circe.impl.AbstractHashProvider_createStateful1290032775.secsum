com.scurrilous.circe.StatefulHash com.scurrilous.circe.impl.AbstractHashProvider:createStateful (
  com.scurrilous.circe.HashParameters params) {
  guard = tt;
  ret(level()) = pc ⊔ level(params) ⊔ level(this) ⊔ obj_level(params) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(params) ⊔ level(this) ⊔ obj_level(params) ⊔ obj_level(this);
  ret(obj_level(params)) = pc ⊔ level(params) ⊔ level(this) ⊔ obj_level(params) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(params) ⊔ level(this) ⊔ obj_level(params) ⊔ obj_level(this);
}