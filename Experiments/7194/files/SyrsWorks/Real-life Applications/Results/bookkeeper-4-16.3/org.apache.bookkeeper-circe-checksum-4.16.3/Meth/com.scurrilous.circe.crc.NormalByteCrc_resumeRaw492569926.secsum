int com.scurrilous.circe.crc.NormalByteCrc:resumeRaw (int crc, byte[] input,
                                                      int index, int length) {
  guard = tt;
  ret(level()) = pc ⊔ level(crc) ⊔ level(index) ⊔ level(input) ⊔ level(length) ⊔ level(this) ⊔ obj_level(input) ⊔ obj_level(this);
  ret(obj_level(input)) = if obj_level(input) = ⊤ ∨ pc ≠ ⊤ ∧ level(length) = ⊤ ∧ obj_level(input) = ⊥ ∧ obj_level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ level(length) = ⊤ ∧ obj_level(input) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}