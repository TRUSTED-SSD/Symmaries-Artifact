com.scurrilous.circe.crc.ReflectedLongCrc (java.lang.String algorithm,
                                           int width, long poly, long init,
                                           long xorOut) {
  guard = tt;
  ret(obj_level(algorithm)) = pc ⊔ level(algorithm) ⊔ level(init) ⊔ level(this) ⊔ level(width) ⊔ level(xorOut) ⊔ obj_level(algorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(algorithm) ⊔ level(init) ⊔ level(poly) ⊔ level(this) ⊔ level(width) ⊔ level(xorOut) ⊔ obj_level(algorithm) ⊔ obj_level(this);
}