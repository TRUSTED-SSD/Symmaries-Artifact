boolean com.scurrilous.circe.params.CrcParameters:match (int bitWidth,
                                                         long polynomial,
                                                         long initial,
                                                         long xorOut,
                                                         boolean reflected) {
  guard = tt;
  ret(level()) = pc ⊔ level(bitWidth) ⊔ level(initial) ⊔ level(polynomial) ⊔ level(reflected) ⊔ level(this) ⊔ level(xorOut) ⊔ obj_level(this);
  ret(obj_level(this)) = obj_level(this);
}