com.scurrilous.circe.crc.NormalByteCrc (java.lang.String algorithm,
                                        int bitWidth, int poly, int init,
                                        int xorOut) {
  guard = tt;
  ret(obj_level(algorithm)) = pc ⊔ level(algorithm) ⊔ level(bitWidth) ⊔ level(init) ⊔ level(this) ⊔ level(xorOut) ⊔ obj_level(algorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(algorithm) ⊔ level(bitWidth) ⊔ level(init) ⊔ level(poly) ⊔ level(this) ⊔ level(xorOut) ⊔ obj_level(algorithm) ⊔ obj_level(this);
}