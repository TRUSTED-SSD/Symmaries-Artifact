com.scurrilous.circe.params.CrcParameters (java.lang.String name,
                                           int bitWidth, long polynomial,
                                           long initial, long xorOut,
                                           boolean reflected) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bitWidth) ⊔ level(initial) ⊔ level(name) ⊔ level(polynomial) ⊔ level(reflected) ⊔ level(this) ⊔ level(xorOut) ⊔ obj_level(name) ⊔ obj_level(this);
}