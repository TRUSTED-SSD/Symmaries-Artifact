com.scurrilous.circe.crc.AbstractIntCrc (java.lang.String algorithm,
                                         int bitWidth, int initial,
                                         int xorOut) {
  guard = tt;
  ret(obj_level(algorithm)) = pc ⊔ level(this) ⊔ obj_level(algorithm) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(algorithm) ⊔ level(bitWidth) ⊔ level(initial) ⊔ level(this) ⊔ level(xorOut) ⊔ obj_level(algorithm) ⊔ obj_level(this);
}