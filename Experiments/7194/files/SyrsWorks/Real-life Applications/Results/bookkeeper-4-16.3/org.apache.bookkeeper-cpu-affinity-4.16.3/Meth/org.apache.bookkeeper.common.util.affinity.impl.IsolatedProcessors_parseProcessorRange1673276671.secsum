static java.util.SortedSet org.apache.bookkeeper.common.util.affinity.impl.IsolatedProcessors:parseProcessorRange (
  java.lang.String @range) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@range) ⊔ obj_level(@range);
  ret(obj_level(@range)) = pc ⊔ level(@range) ⊔ obj_level(@range);
}