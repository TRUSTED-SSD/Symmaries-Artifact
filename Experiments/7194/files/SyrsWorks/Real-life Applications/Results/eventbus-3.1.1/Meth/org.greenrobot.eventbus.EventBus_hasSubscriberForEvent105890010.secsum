boolean org.greenrobot.eventbus.EventBus:hasSubscriberForEvent (java.lang.Class
                                                                  @eventClass) {
  guard = tt;
  ret(level()) = pc ⊔ level(@eventClass) ⊔ level(this) ⊔ obj_level(@eventClass) ⊔ obj_level(this);
  ret(obj_level(@eventClass)) = pc ⊔ level(@eventClass) ⊔ level(this) ⊔ obj_level(@eventClass) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@eventClass) ⊔ level(this) ⊔ obj_level(@eventClass) ⊔ obj_level(this);
}