void org.greenrobot.eventbus.util.ThrowableFailureEvent:setExecutionScope (
  java.lang.Object executionContext) {
  guard = tt;
  ret(obj_level(executionContext)) = pc ⊔ level(executionContext) ⊔ obj_level(executionContext);
  ret(obj_level(this)) = pc ⊔ level(executionContext) ⊔ obj_level(executionContext);
}