org.greenrobot.eventbus.util.ThrowableFailureEvent (java.lang.Throwable
                                                      throwable) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(throwable) ⊔ obj_level(this) ⊔ obj_level(throwable);
  ret(obj_level(throwable)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(throwable);
}