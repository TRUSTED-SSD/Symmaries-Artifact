org.greenrobot.eventbus.PendingPost (java.lang.Object event,
                                     org.greenrobot.eventbus.Subscription
                                       subscription) {
  guard = tt;
  ret(obj_level(event)) = pc ⊔ level(event) ⊔ level(subscription) ⊔ level(this) ⊔ obj_level(event);
  ret(obj_level(subscription)) = pc ⊔ level(event) ⊔ level(subscription) ⊔ level(this) ⊔ obj_level(event);
  ret(obj_level(this)) = pc ⊔ level(event) ⊔ level(subscription) ⊔ level(this) ⊔ obj_level(event);
}