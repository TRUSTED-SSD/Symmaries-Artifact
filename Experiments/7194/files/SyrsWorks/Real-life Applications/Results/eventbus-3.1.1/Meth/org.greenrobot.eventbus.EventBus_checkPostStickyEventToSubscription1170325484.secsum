void org.greenrobot.eventbus.EventBus:checkPostStickyEventToSubscription (
  org.greenrobot.eventbus.Subscription newSubscription,
  java.lang.Object stickyEvent) {
  guard = tt;
  ret(obj_level(newSubscription)) = pc ⊔ level(newSubscription) ⊔ level(stickyEvent) ⊔ level(this) ⊔ obj_level(newSubscription);
  ret(obj_level(stickyEvent)) = pc ⊔ level(newSubscription) ⊔ level(stickyEvent) ⊔ level(this) ⊔ obj_level(stickyEvent);
  ret(obj_level(this)) = pc ⊔ level(newSubscription) ⊔ level(stickyEvent) ⊔ level(this) ⊔ obj_level(stickyEvent);
}