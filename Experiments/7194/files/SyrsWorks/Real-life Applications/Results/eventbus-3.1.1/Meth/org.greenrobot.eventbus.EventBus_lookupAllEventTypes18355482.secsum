static java.util.List org.greenrobot.eventbus.EventBus:lookupAllEventTypes (
  java.lang.Class eventClass) {
  guard = tt;
  ret(level()) = pc ⊔ level(eventClass) ⊔ obj_level(eventClass);
  ret(obj_level()) = pc ⊔ level(eventClass) ⊔ obj_level(eventClass);
  ret(obj_level(eventClass)) = pc ⊔ level(eventClass) ⊔ obj_level(eventClass);
}