void org.greenrobot.eventbus.HandlerPoster:handleMessage (android.os.Message
                                                            @msg) {
  guard = tt;
  ret(obj_level(@msg)) = pc ⊔ level(this) ⊔ obj_level(@msg) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(this);
}