static boolean org.greenrobot.eventbus.util.ErrorDialogManager:isInExecutionScope (
  java.lang.Object executionScope,
  org.greenrobot.eventbus.util.ThrowableFailureEvent event) {
  guard = tt;
  ret(level()) = pc ⊔ level(event) ⊔ level(executionScope) ⊔ obj_level(event);
  ret(obj_level(event)) = pc ⊔ level(event) ⊔ level(executionScope) ⊔ obj_level(event);
  ret(obj_level(executionScope)) = pc ⊔ level(event) ⊔ level(executionScope) ⊔ obj_level(event);
}