void org.apache.rocketmq.broker.BrokerController:doRegisterBrokerAll (
  boolean checkOrderConfig, boolean oneway,
  org.apache.rocketmq.remoting.protocol.body.TopicConfigSerializeWrapper
    topicConfigWrapper) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(checkOrderConfig) ⊔ level(oneway) ⊔ level(this) ⊔ level(topicConfigWrapper) ⊔ obj_level(this) ⊔ obj_level(topicConfigWrapper);
  ret(obj_level(topicConfigWrapper)) = pc ⊔ level(checkOrderConfig) ⊔ level(oneway) ⊔ level(this) ⊔ level(topicConfigWrapper) ⊔ obj_level(this) ⊔ obj_level(topicConfigWrapper);
}