org.apache.rocketmq.store.pop.PopCheckPoint org.apache.rocketmq.broker.processor.PopReviveService:createMockCkForAck (
  org.apache.rocketmq.store.pop.AckMsg ackMsg, long reviveOffset) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(ackMsg) ⊔ level(reviveOffset) ⊔ obj_level(ackMsg);
  ret(obj_level(ackMsg)) = pc ⊔ level(ackMsg) ⊔ level(reviveOffset) ⊔ obj_level(ackMsg);
  ret(obj_level(this)) = pc ⊔ level(ackMsg) ⊔ level(reviveOffset) ⊔ obj_level(ackMsg) ⊔ obj_level(this);
}