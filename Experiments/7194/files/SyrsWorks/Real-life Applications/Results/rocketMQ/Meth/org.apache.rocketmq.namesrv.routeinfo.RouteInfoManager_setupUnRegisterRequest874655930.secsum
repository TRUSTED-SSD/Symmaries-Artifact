boolean org.apache.rocketmq.namesrv.routeinfo.RouteInfoManager:setupUnRegisterRequest (
  org.apache.rocketmq.remoting.protocol.header.namesrv.UnRegisterBrokerRequestHeader
    unRegisterRequest,
  org.apache.rocketmq.common.BrokerAddrInfo brokerAddrInfo) {
  guard = tt;
  ret(level()) = pc ⊔ level(brokerAddrInfo) ⊔ level(this) ⊔ obj_level(brokerAddrInfo) ⊔ obj_level(this) ⊔ obj_level(unRegisterRequest);
  ret(obj_level(brokerAddrInfo)) = pc ⊔ level(brokerAddrInfo) ⊔ level(this) ⊔ obj_level(brokerAddrInfo) ⊔ obj_level(this) ⊔ obj_level(unRegisterRequest);
  ret(obj_level(this)) = pc ⊔ level(brokerAddrInfo) ⊔ level(this) ⊔ obj_level(brokerAddrInfo) ⊔ obj_level(this) ⊔ obj_level(unRegisterRequest);
  ret(obj_level(unRegisterRequest)) = pc ⊔ level(brokerAddrInfo) ⊔ level(this) ⊔ obj_level(brokerAddrInfo) ⊔ obj_level(this) ⊔ obj_level(unRegisterRequest);
