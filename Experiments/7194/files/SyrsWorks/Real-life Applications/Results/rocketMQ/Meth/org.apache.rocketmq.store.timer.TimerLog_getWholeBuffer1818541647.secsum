org.apache.rocketmq.store.SelectMappedBufferResult org.apache.rocketmq.store.timer.TimerLog:getWholeBuffer (
  long offsetPy) {
  guard = tt;
  ret(level()) = pc ⊔ level(offsetPy) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(offsetPy) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ level(offsetPy) ⊔ level(this) = ⊤ then ⊤ else ⊥;
}