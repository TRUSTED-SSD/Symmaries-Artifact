org.apache.rocketmq.client.trace.hook.ConsumeMessageOpenTracingHookImpl (
  io.opentracing.Tracer tracer) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(tracer) ⊔ obj_level(this) ⊔ obj_level(tracer);
  ret(obj_level(tracer)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(tracer);
}