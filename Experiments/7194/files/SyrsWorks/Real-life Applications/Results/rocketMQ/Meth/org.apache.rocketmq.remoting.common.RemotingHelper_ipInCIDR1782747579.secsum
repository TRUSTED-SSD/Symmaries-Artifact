static boolean org.apache.rocketmq.remoting.common.RemotingHelper:ipInCIDR (
  java.lang.String @ip, java.lang.String cidr) {
  guard = tt;
  ret(level()) = pc ⊔ level(@ip) ⊔ level(cidr) ⊔ obj_level(@ip);
  ret(obj_level(@ip)) = pc ⊔ level(@ip) ⊔ level(cidr) ⊔ obj_level(@ip);
  ret(obj_level(cidr)) = pc ⊔ level(@ip) ⊔ level(cidr) ⊔ obj_level(@ip);
}