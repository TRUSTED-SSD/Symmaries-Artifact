static byte[] org.apache.rocketmq.common.utils.BinaryUtil:calculateMd5 (
  byte[] @binaryData) {
  guard = tt;
  ret(level()) = pc ⊔ level(@binaryData) ⊔ obj_level(@binaryData);
  ret(obj_level()) = pc ⊔ level(@binaryData) ⊔ obj_level(@binaryData);
  ret(obj_level(@binaryData)) = pc ⊔ level(@binaryData) ⊔ obj_level(@binaryData);
}