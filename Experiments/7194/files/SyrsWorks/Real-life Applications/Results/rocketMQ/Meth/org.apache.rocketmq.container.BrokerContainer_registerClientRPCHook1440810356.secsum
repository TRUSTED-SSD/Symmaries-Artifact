void org.apache.rocketmq.container.BrokerContainer:registerClientRPCHook (
  org.apache.rocketmq.remoting.RPCHook rpcHook) {
  guard = tt;
  ret(obj_level(rpcHook)) = pc ⊔ level(rpcHook) ⊔ level(this) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(rpcHook) ⊔ level(this) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
}