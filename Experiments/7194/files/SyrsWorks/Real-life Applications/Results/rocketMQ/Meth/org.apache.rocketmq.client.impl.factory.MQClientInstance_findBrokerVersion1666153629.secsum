int org.apache.rocketmq.client.impl.factory.MQClientInstance:findBrokerVersion (
  java.lang.String brokerName, java.lang.String brokerAddr) {
  guard = tt;
  ret(level()) = pc ⊔ level(brokerAddr) ⊔ level(brokerName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(brokerAddr)) = pc ⊔ level(brokerAddr) ⊔ level(brokerName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(brokerName)) = pc ⊔ level(brokerAddr) ⊔ level(brokerName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerAddr) ⊔ level(brokerName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
}