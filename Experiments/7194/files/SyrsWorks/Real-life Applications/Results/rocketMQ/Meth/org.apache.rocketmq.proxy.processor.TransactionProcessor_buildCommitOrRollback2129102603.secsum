int org.apache.rocketmq.proxy.processor.TransactionProcessor:buildCommitOrRollback (
  org.apache.rocketmq.proxy.processor.TransactionStatus transactionStatus) {
  guard = tt;
  ret(level()) = pc ⊔ level(transactionStatus) ⊔ obj_level(transactionStatus);
  ret(obj_level(this)) = pc ⊔ level(transactionStatus) ⊔ obj_level(this) ⊔ obj_level(transactionStatus);
  ret(obj_level(transactionStatus)) = pc ⊔ level(transactionStatus) ⊔ obj_level(transactionStatus);
}