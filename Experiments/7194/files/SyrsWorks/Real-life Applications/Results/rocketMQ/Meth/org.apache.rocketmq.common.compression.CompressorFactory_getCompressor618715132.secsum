static org.apache.rocketmq.common.compression.Compressor org.apache.rocketmq.common.compression.CompressorFactory:getCompressor (
  org.apache.rocketmq.common.compression.CompressionType type) {
  guard = tt;
  ret(level()) = pc ⊔ level(type) ⊔ obj_level(type);
  ret(obj_level()) = pc ⊔ level(type) ⊔ obj_level(type);
  ret(obj_level(type)) = pc ⊔ level(type) ⊔ obj_level(type);
}