boolean org.apache.rocketmq.broker.transaction.queue.TransactionalMessageServiceImpl:needDiscard (
  org.apache.rocketmq.common.message.MessageExt msgExt,
  int transactionCheckMax) {
  guard = tt;
  ret(level()) = pc ⊔ level(msgExt) ⊔ level(transactionCheckMax) ⊔ obj_level(msgExt);
  ret(obj_level(msgExt)) = pc ⊔ level(msgExt) ⊔ level(transactionCheckMax) ⊔ obj_level(msgExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msgExt) ⊔ level(transactionCheckMax) ⊔ obj_level(msgExt) ⊔ obj_level(this);
}