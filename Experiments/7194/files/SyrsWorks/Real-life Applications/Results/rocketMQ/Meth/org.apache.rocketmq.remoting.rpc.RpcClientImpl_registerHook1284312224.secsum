void org.apache.rocketmq.remoting.rpc.RpcClientImpl:registerHook (org.apache.rocketmq.remoting.rpc.RpcClientHook
                                                                    hook) {
  guard = tt;
  ret(obj_level(hook)) = pc ⊔ level(hook) ⊔ level(this) ⊔ obj_level(hook) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(hook) ⊔ level(this) ⊔ obj_level(hook) ⊔ obj_level(this);
}