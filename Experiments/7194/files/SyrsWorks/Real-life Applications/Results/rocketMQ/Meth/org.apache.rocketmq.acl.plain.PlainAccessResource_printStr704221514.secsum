static java.lang.String org.apache.rocketmq.acl.plain.PlainAccessResource:printStr (
  java.lang.String @resource, boolean isGroup) {
  guard = tt;
  ret(level()) = pc ⊔ level(@resource) ⊔ level(isGroup) ⊔ obj_level(@resource);
  ret(obj_level()) = pc ⊔ level(@resource) ⊔ level(isGroup) ⊔ obj_level(@resource);
  ret(obj_level(@resource)) = pc ⊔ level(@resource) ⊔ level(isGroup) ⊔ obj_level(@resource);
}