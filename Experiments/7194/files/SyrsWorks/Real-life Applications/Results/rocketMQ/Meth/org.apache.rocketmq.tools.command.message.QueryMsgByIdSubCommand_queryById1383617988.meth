static void org.apache.rocketmq.tools.command.message.QueryMsgByIdSubCommand:queryById(org.apache.rocketmq.tools.admin.DefaultMQAdminExt admin,java.lang.String msgId,java.nio.charset.Charset msgBodyCharset)
{
org.apache.rocketmq.common.message.MessageExt msg;
  msg = admin.viewMessage(msgId);
 org.apache.rocketmq.tools.command.message.QueryMsgByIdSubCommand.printMsg(admin,msg,msgBodyCharset);
 return;
 } 

