org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.broker.processor.PullMessageProcessor:rewriteRequestForStaticTopic (
  org.apache.rocketmq.remoting.protocol.header.PullMessageRequestHeader
    requestHeader,
  org.apache.rocketmq.remoting.protocol.statictopic.TopicQueueMappingContext
    mappingContext) {
  guard = tt;
  ret(level()) = pc ⊔ level(mappingContext) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(mappingContext) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(mappingContext) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(mappingContext) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(mappingContext)) = pc ⊔ level(mappingContext) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(mappingContext) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(requestHeader)) = pc ⊔ level(mappingContext) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(mappingContext) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(mappingContext) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(mappingContext) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
}