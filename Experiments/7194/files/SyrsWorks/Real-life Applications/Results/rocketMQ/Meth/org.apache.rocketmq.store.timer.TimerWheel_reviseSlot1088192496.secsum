void org.apache.rocketmq.store.timer.TimerWheel:reviseSlot (long timeMs,
                                                            long firstPos,
                                                            long lastPos,
                                                            boolean force) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(firstPos) ⊔ level(force) ⊔ level(lastPos) ⊔ level(this) ⊔ level(timeMs) ⊔ obj_level(this);
}