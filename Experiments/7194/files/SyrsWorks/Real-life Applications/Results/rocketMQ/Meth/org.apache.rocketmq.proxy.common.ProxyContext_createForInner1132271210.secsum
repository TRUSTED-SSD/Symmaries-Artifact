static org.apache.rocketmq.proxy.common.ProxyContext org.apache.rocketmq.proxy.common.ProxyContext:createForInner (
  java.lang.String @actionName) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@actionName) ⊔ obj_level(@actionName);
  ret(obj_level(@actionName)) = pc ⊔ level(@actionName) ⊔ obj_level(@actionName);
}