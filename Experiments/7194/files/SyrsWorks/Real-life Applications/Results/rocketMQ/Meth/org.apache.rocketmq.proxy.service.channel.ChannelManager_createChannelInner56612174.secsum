org.apache.rocketmq.proxy.service.channel.SimpleChannel org.apache.rocketmq.proxy.service.channel.ChannelManager:createChannelInner (
  org.apache.rocketmq.proxy.common.ProxyContext context) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(context) ⊔ obj_level(context);
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ obj_level(context);
  ret(obj_level(this)) = pc ⊔ level(context) ⊔ obj_level(context) ⊔ obj_level(this);
}