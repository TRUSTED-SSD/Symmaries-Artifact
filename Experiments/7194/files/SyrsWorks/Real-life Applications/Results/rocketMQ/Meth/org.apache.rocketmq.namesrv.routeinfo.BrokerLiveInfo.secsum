org.apache.rocketmq.namesrv.routeinfo.BrokerLiveInfo (long
                                                        lastUpdateTimestamp,
                                                      long
                                                        heartbeatTimeoutMillis,
                                                      org.apache.rocketmq.remoting.protocol.DataVersion
                                                        dataVersion,
                                                      io.netty.channel.Channel
                                                        channel,
