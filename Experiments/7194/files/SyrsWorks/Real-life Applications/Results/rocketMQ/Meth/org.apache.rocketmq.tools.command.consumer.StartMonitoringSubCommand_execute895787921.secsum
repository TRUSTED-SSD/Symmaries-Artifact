void org.apache.rocketmq.tools.command.consumer.StartMonitoringSubCommand:execute (
  org.apache.commons.cli.CommandLine commandLine,
  org.apache.commons.cli.Options options,
  org.apache.rocketmq.remoting.RPCHook rpcHook) {
  guard = tt;
  ret(obj_level(commandLine)) = pc ⊔ level(rpcHook) ⊔ obj_level(commandLine) ⊔ obj_level(rpcHook);
  ret(obj_level(options)) = pc ⊔ level(rpcHook) ⊔ obj_level(options) ⊔ obj_level(rpcHook);
  ret(obj_level(rpcHook)) = pc ⊔ level(rpcHook) ⊔ obj_level(rpcHook);
  ret(obj_level(this)) = pc ⊔ level(rpcHook) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
}