long org.apache.rocketmq.client.consumer.DefaultMQPullConsumer:fetchConsumeOffset (
  org.apache.rocketmq.common.message.MessageQueue @mq, boolean fromStore) {
  guard = tt;
  ret(level()) = pc ⊔ level(@mq) ⊔ level(fromStore) ⊔ level(this) ⊔ obj_level(@mq) ⊔ obj_level(this);
  ret(obj_level(@mq)) = pc ⊔ level(@mq) ⊔ level(this) ⊔ obj_level(@mq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@mq) ⊔ level(this) ⊔ obj_level(@mq) ⊔ obj_level(this);
}