void org.apache.rocketmq.controller.ControllerManager:start()
{
org.apache.rocketmq.controller.BrokerHeartbeatManager $stack1;
  org.apache.rocketmq.controller.Controller $stack2;
  org.apache.rocketmq.remoting.RemotingClient $stack3;
  $stack1=this.heartbeatManager;
 $stack1.start();
 $stack2=this.controller;
 $stack2.startup();
 $stack3=this.remotingClient;
 $stack3.start();
 return;
 } 

