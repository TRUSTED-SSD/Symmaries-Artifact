org.apache.rocketmq.remoting.protocol.header.SendMessageRequestHeader org.apache.rocketmq.broker.processor.ReplyMessageProcessor:parseRequestHeader (
  org.apache.rocketmq.remoting.protocol.RemotingCommand request) {
  guard = tt;
  ret(level()) = pc ⊔ level(request) ⊔ obj_level(request);
  ret(obj_level()) = pc ⊔ level(request) ⊔ obj_level(request);
  ret(obj_level(request)) = pc ⊔ level(request) ⊔ obj_level(request);
  ret(obj_level(this)) = pc ⊔ level(request) ⊔ obj_level(request) ⊔ obj_level(this);
}