org.apache.rocketmq.common.message.MessageExtBrokerInner org.apache.rocketmq.broker.processor.PopMessageProcessor:buildCkMsg (
  org.apache.rocketmq.store.pop.PopCheckPoint ck, int reviveQid) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(ck) ⊔ level(reviveQid) ⊔ level(this) ⊔ obj_level(ck) ⊔ obj_level(this);
  ret(obj_level(ck)) = pc ⊔ level(ck) ⊔ level(reviveQid) ⊔ level(this) ⊔ obj_level(ck) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ck) ⊔ level(reviveQid) ⊔ level(this) ⊔ obj_level(ck) ⊔ obj_level(this);
}