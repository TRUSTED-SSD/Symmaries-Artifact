void org.apache.rocketmq.client.impl.consumer.ConsumeMessageOrderlyService:submitConsumeRequestLater (
  org.apache.rocketmq.client.impl.consumer.ProcessQueue processQueue,
  org.apache.rocketmq.common.message.MessageQueue messageQueue,
  long suspendTimeMillis) {
  guard = tt;
  ret(obj_level(messageQueue)) = pc ⊔ level(messageQueue) ⊔ level(processQueue) ⊔ level(suspendTimeMillis) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(processQueue) ⊔ obj_level(this);
  ret(obj_level(processQueue)) = pc ⊔ level(messageQueue) ⊔ level(processQueue) ⊔ level(suspendTimeMillis) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(processQueue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageQueue) ⊔ level(processQueue) ⊔ level(suspendTimeMillis) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(processQueue) ⊔ obj_level(this);
}