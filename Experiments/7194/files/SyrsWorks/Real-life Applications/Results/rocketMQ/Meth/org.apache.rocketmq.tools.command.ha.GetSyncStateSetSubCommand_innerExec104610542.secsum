void org.apache.rocketmq.tools.command.ha.GetSyncStateSetSubCommand:innerExec (
  org.apache.commons.cli.CommandLine commandLine,
  org.apache.commons.cli.Options options,
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt defaultMQAdminExt) {
  guard = pc ⊔ level(commandLine) ⊔ level(options) ⊔ obj_level(commandLine) ⊔ obj_level(options) = ⊥;
  ret(obj_level(commandLine)) = level(defaultMQAdminExt) ⊔ obj_level(defaultMQAdminExt);
  ret(obj_level(defaultMQAdminExt)) = level(defaultMQAdminExt) ⊔ obj_level(defaultMQAdminExt) ⊔ obj_level(this);
  ret(obj_level(options)) = level(defaultMQAdminExt) ⊔ obj_level(defaultMQAdminExt);
  ret(obj_level(this)) = level(defaultMQAdminExt) ⊔ obj_level(defaultMQAdminExt) ⊔ obj_level(this);
}