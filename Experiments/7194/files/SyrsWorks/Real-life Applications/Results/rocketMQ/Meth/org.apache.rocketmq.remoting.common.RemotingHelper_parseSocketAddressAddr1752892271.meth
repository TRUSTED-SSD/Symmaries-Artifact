static java.lang.String org.apache.rocketmq.remoting.common.RemotingHelper:parseSocketAddressAddr(java.net.SocketAddress socketAddress)
{
java.lang.String addr;
  int index;
  if (socketAddress==null) goto label0;
 addr = socketAddress.toString();
 index = addr.lastIndexOf("/");
 if (index==-1) goto label1;
 index=(index+1);
 addr = addr.substring(index);
 goto label1;
 label1:return  addr;
 label0:return  "";
 } 

