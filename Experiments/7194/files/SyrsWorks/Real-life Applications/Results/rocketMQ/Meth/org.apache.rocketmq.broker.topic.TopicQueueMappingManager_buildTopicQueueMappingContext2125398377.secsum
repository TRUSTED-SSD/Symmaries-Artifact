org.apache.rocketmq.remoting.protocol.statictopic.TopicQueueMappingContext org.apache.rocketmq.broker.topic.TopicQueueMappingManager:buildTopicQueueMappingContext (
  org.apache.rocketmq.remoting.rpc.TopicRequestHeader requestHeader,
  boolean selectOneWhenMiss) {
  guard = tt;
  ret(level()) = pc ⊔ level(requestHeader) ⊔ level(selectOneWhenMiss) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(requestHeader) ⊔ level(selectOneWhenMiss) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(requestHeader)) = pc ⊔ level(requestHeader) ⊔ level(selectOneWhenMiss) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(requestHeader) ⊔ level(selectOneWhenMiss) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
}