void org.apache.rocketmq.tools.command.broker.GetBrokerEpochSubCommand:printData (
  java.util.Set brokers,
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt defaultMQAdminExt) {
  guard = pc ⊔ level(brokers) ⊔ level(defaultMQAdminExt) ⊔ obj_level(brokers) ⊔ obj_level(defaultMQAdminExt) = ⊥;
  ret(obj_level(brokers)) = ⊥;
  ret(obj_level(defaultMQAdminExt)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}