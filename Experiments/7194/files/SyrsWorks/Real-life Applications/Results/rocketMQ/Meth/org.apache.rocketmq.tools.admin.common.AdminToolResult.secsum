org.apache.rocketmq.tools.admin.common.AdminToolResult (boolean success,
                                                        int code,
                                                        java.lang.String
                                                          errorMsg,
                                                        java.lang.Object data) {
  guard = tt;
  ret(obj_level(data)) = pc ⊔ level(code) ⊔ level(data) ⊔ level(errorMsg) ⊔ level(success) ⊔ level(this) ⊔ obj_level(data);
  ret(obj_level(errorMsg)) = pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(code) ⊔ level(data) ⊔ level(errorMsg) ⊔ level(success) ⊔ level(this) ⊔ obj_level(data);
}