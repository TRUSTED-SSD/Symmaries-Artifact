org.apache.rocketmq.common.message.MessageExtBrokerInner org.apache.rocketmq.broker.transaction.queue.TransactionalMessageBridge:parseHalfMessageInner (
  org.apache.rocketmq.common.message.MessageExtBrokerInner msgInner) {
  guard = tt;
  ret(level()) = pc ⊔ level(msgInner);
  ret(obj_level()) = pc ⊔ level(msgInner) ⊔ obj_level(msgInner);
  ret(obj_level(msgInner)) = pc ⊔ level(msgInner) ⊔ obj_level(msgInner);
  ret(obj_level(this)) = pc ⊔ level(msgInner) ⊔ obj_level(msgInner) ⊔ obj_level(this);
}