org.apache.rocketmq.store.SelectMappedBufferResult org.apache.rocketmq.store.dledger.DLedgerCommitLog:getData (
  long offset) {
  guard = tt;
  ret(level()) = pc ⊔ level(offset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(offset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ level(offset) ⊔ level(this) = ⊤ then ⊤ else ⊥;
}