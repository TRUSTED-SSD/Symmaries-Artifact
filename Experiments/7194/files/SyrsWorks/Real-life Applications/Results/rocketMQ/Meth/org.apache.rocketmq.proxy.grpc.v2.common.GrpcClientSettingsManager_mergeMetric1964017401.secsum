apache.rocketmq.v2.Settings org.apache.rocketmq.proxy.grpc.v2.common.GrpcClientSettingsManager:mergeMetric (
  apache.rocketmq.v2.Settings @settings) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(@settings);
  ret(obj_level()) = pc ⊔ obj_level(@settings);
  ret(obj_level(@settings)) = obj_level(@settings);
  ret(obj_level(this)) = pc ⊔ obj_level(@settings) ⊔ obj_level(this);
}