void org.apache.rocketmq.client.trace.AsyncTraceDispatcher:setHostConsumer (
  org.apache.rocketmq.client.impl.consumer.DefaultMQPushConsumerImpl
    hostConsumer) {
  guard = tt;
  ret(obj_level(hostConsumer)) = pc ⊔ level(hostConsumer) ⊔ obj_level(hostConsumer);
  ret(obj_level(this)) = pc ⊔ level(hostConsumer) ⊔ obj_level(hostConsumer) ⊔ obj_level(this);
}