org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.broker.processor.ConsumerManageProcessor:processRequest (
  io.netty.channel.ChannelHandlerContext ctx,
  org.apache.rocketmq.remoting.protocol.RemotingCommand @request) {
  guard = tt;
  ret(level()) = pc ⊔ level(@request) ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level()) = ⊤;
  ret(obj_level(@request)) = ⊤;
  ret(obj_level(ctx)) = ⊤;
  ret(obj_level(this)) = ⊤;
}