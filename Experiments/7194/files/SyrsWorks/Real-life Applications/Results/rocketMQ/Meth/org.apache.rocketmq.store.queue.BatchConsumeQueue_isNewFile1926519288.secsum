boolean org.apache.rocketmq.store.queue.BatchConsumeQueue:isNewFile (
  org.apache.rocketmq.store.logfile.MappedFile mappedFile) {
  guard = tt;
  ret(level()) = pc ⊔ level(mappedFile) ⊔ obj_level(mappedFile);
  ret(obj_level(mappedFile)) = pc ⊔ level(mappedFile) ⊔ obj_level(mappedFile);
  ret(obj_level(this)) = pc ⊔ level(mappedFile) ⊔ obj_level(mappedFile) ⊔ obj_level(this);
}