org.apache.rocketmq.container.InnerBrokerController org.apache.rocketmq.container.BrokerContainer:addMasterBroker (
  org.apache.rocketmq.common.BrokerConfig masterBrokerConfig,
  org.apache.rocketmq.store.config.MessageStoreConfig storeConfig) {
  guard = tt;
  ret(level()) = pc ⊔ level(storeConfig) ⊔ level(this) ⊔ obj_level(masterBrokerConfig) ⊔ obj_level(storeConfig) ⊔ obj_level(this);
  ret(obj_level()) = ⊤;
  ret(obj_level(masterBrokerConfig)) = ⊤;
  ret(obj_level(storeConfig)) = ⊤;
  ret(obj_level(this)) = ⊤;
}