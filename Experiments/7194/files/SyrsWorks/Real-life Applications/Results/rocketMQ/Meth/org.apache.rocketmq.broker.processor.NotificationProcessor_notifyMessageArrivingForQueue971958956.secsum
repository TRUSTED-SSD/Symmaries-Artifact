void org.apache.rocketmq.broker.processor.NotificationProcessor:notifyMessageArrivingForQueue (
  java.lang.String @topic, int queueId) {
  guard = tt;
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
}