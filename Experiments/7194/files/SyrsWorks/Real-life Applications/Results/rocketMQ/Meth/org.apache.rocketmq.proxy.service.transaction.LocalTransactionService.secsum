  org.apache.rocketmq.common.BrokerConfig brokerConfig) {
  guard = tt;
  ret(obj_level(brokerConfig)) = pc ⊔ level(this) ⊔ obj_level(brokerConfig) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerConfig) ⊔ level(this) ⊔ obj_level(brokerConfig) ⊔ obj_level(this);
}