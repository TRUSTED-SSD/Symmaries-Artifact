org.apache.rocketmq.store.PutMessageResult org.apache.rocketmq.store.DefaultMessageStore:putMessage (
  org.apache.rocketmq.common.message.MessageExtBrokerInner msg) {
  guard = tt;
  ret(level()) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(msg)) = obj_level(msg);
  ret(obj_level(this)) = obj_level(this);
}