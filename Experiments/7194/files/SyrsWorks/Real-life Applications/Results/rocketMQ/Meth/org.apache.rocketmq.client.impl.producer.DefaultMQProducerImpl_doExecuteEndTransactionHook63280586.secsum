  ret(obj_level(this)) = pc ⊔ level(@msgId) ⊔ level(brokerAddr) ⊔ level(fromTransactionCheck) ⊔ level(msg) ⊔ level(state) ⊔ level(this) ⊔ obj_level(@msgId) ⊔ obj_level(msg) ⊔ obj_level(state) ⊔ obj_level(this);
