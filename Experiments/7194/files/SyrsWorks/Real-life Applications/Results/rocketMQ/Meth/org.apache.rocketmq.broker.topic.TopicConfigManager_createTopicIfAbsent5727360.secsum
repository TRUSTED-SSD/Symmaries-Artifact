org.apache.rocketmq.common.TopicConfig org.apache.rocketmq.broker.topic.TopicConfigManager:createTopicIfAbsent (
  org.apache.rocketmq.common.TopicConfig @topicConfig) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topicConfig) ⊔ level(this) ⊔ obj_level(@topicConfig) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@topicConfig) ⊔ level(this) ⊔ obj_level(@topicConfig) ⊔ obj_level(this);
  ret(obj_level(@topicConfig)) = obj_level(@topicConfig);
  ret(obj_level(this)) = obj_level(this);
}