org.apache.rocketmq.common.Pair (java.lang.Object object1,
                                 java.lang.Object object2) {
  guard = tt;
  ret(obj_level(object1)) = pc ⊔ level(object1) ⊔ level(object2) ⊔ level(this) ⊔ obj_level(object1);
  ret(obj_level(object2)) = pc ⊔ level(object1) ⊔ level(object2) ⊔ level(this) ⊔ obj_level(object1);
  ret(obj_level(this)) = pc ⊔ level(object1) ⊔ level(object2) ⊔ level(this) ⊔ obj_level(object1);
}