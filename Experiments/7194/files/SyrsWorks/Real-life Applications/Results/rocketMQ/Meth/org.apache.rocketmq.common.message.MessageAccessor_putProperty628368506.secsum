static void org.apache.rocketmq.common.message.MessageAccessor:putProperty (
  org.apache.rocketmq.common.message.Message msg, java.lang.String name,
  java.lang.String value) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(name) ⊔ level(value) ⊔ obj_level(msg) ⊔ obj_level(name);
  ret(obj_level(name)) = pc ⊔ level(msg) ⊔ level(name) ⊔ level(value) ⊔ obj_level(msg) ⊔ obj_level(name);
  ret(obj_level(value)) = pc ⊔ level(msg) ⊔ level(name) ⊔ level(value) ⊔ obj_level(msg) ⊔ obj_level(name);
}