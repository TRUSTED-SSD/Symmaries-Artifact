org.apache.rocketmq.common.attribute.BooleanAttribute (java.lang.String name,
                                                       boolean changeable,
                                                       boolean defaultValue) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(changeable) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(changeable) ⊔ level(defaultValue) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
}