static org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.remoting.rpc.RpcClientUtils:createCommandForRpcRequest (
  org.apache.rocketmq.remoting.rpc.RpcRequest rpcRequest) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(rpcRequest) ⊔ obj_level(rpcRequest);
  ret(obj_level(rpcRequest)) = pc ⊔ level(rpcRequest) ⊔ obj_level(rpcRequest);
}