  ret(obj_level(processQueue)) = pc ⊔ level(messageQueue) ⊔ level(offset) ⊔ level(processQueue) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(processQueue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageQueue) ⊔ level(offset) ⊔ level(processQueue) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(this);
