  guard = tt;
  ret(obj_level(@path)) = pc ⊔ level(@path) ⊔ level(this) ⊔ obj_level(@path) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@path) ⊔ level(this) ⊔ obj_level(@path) ⊔ obj_level(this);
}