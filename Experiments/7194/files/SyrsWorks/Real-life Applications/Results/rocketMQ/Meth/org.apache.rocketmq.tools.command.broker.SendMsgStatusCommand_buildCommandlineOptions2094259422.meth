org.apache.commons.cli.Options org.apache.rocketmq.tools.command.broker.SendMsgStatusCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("b","brokerName",1,"Broker Name e.g. clusterName_brokerName as DefaultCluster_broker-a");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("s","messageSize",1,"Message Size, Default: 128");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("c","count",1,"send message count, Default: 50");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 return  options;
 } 

