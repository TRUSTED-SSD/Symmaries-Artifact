void org.apache.rocketmq.client.consumer.DefaultLitePullConsumer:setSubExpressionForAssign (
  java.lang.String @topic, java.lang.String subExpresion) {
  guard = tt;
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(subExpresion) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(subExpresion)) = pc ⊔ level(@topic) ⊔ level(subExpresion) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(subExpresion) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
}