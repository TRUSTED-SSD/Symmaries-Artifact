org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.proxy.service.mqclient.ProxyClientRemotingProcessor:checkTransactionState (
  io.netty.channel.ChannelHandlerContext ctx,
  org.apache.rocketmq.remoting.protocol.RemotingCommand request) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc;
  ret(obj_level(ctx)) = pc ⊔ level(ctx) ⊔ level(request) ⊔ level(this) ⊔ obj_level(ctx) ⊔ obj_level(request) ⊔ obj_level(this);
  ret(obj_level(request)) = pc ⊔ level(ctx) ⊔ level(request) ⊔ level(this) ⊔ obj_level(ctx) ⊔ obj_level(request) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ctx) ⊔ level(request) ⊔ level(this) ⊔ obj_level(ctx) ⊔ obj_level(request) ⊔ obj_level(this);
}