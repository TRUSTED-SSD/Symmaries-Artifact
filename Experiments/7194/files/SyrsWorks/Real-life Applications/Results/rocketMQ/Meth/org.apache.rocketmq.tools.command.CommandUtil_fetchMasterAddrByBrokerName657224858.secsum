static java.lang.String org.apache.rocketmq.tools.command.CommandUtil:fetchMasterAddrByBrokerName (
  org.apache.rocketmq.tools.admin.MQAdminExt adminExt,
  java.lang.String @brokerName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@brokerName) ⊔ level(adminExt) ⊔ obj_level(@brokerName) ⊔ obj_level(adminExt);
  ret(obj_level()) = pc ⊔ level(@brokerName) ⊔ level(adminExt) ⊔ obj_level(@brokerName) ⊔ obj_level(adminExt);
  ret(obj_level(@brokerName)) = pc ⊔ level(@brokerName) ⊔ level(adminExt) ⊔ obj_level(@brokerName) ⊔ obj_level(adminExt);
  ret(obj_level(adminExt)) = pc ⊔ level(@brokerName) ⊔ level(adminExt) ⊔ obj_level(@brokerName) ⊔ obj_level(adminExt);
}