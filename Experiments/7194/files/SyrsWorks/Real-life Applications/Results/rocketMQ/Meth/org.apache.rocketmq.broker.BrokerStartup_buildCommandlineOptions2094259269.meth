static org.apache.commons.cli.Options org.apache.rocketmq.broker.BrokerStartup:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("c","configFile",1,"Broker config properties file");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("p","printConfigItem",0,"Print all config item");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("m","printImportantConfig",0,"Print important config item");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 return  options;
 } 

