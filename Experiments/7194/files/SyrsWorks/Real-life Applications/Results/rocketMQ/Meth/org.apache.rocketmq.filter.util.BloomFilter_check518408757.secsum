void org.apache.rocketmq.filter.util.BloomFilter:check (org.apache.rocketmq.filter.util.BitsArray
                                                          bits) {
  guard = tt;
  ret(obj_level(bits)) = pc ⊔ level(bits) ⊔ level(this) ⊔ obj_level(bits) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bits) ⊔ level(this) ⊔ obj_level(bits) ⊔ obj_level(this);
}