static java.lang.String org.apache.rocketmq.acl.common.AclUtils:calSignature (
  byte[] data, java.lang.String @secretKey) {
  guard = tt;
  ret(level()) = pc ⊔ level(@secretKey) ⊔ level(data) ⊔ obj_level(@secretKey) ⊔ obj_level(data);
  ret(obj_level()) = pc ⊔ level(@secretKey) ⊔ level(data) ⊔ obj_level(@secretKey) ⊔ obj_level(data);
  ret(obj_level(@secretKey)) = obj_level(@secretKey);
  ret(obj_level(data)) = obj_level(data);
}