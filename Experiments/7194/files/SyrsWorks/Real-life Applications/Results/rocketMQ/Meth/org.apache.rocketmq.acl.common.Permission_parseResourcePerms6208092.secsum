static void org.apache.rocketmq.acl.common.Permission:parseResourcePerms (
  org.apache.rocketmq.acl.plain.PlainAccessResource plainAccessResource,
  java.lang.Boolean isTopic, java.util.List resources) {
  guard = tt;
  ret(obj_level(isTopic)) = pc ⊔ level(isTopic) ⊔ level(plainAccessResource) ⊔ level(resources) ⊔ obj_level(isTopic) ⊔ obj_level(plainAccessResource) ⊔ obj_level(resources);
  ret(obj_level(plainAccessResource)) = pc ⊔ level(isTopic) ⊔ level(plainAccessResource) ⊔ level(resources) ⊔ obj_level(isTopic) ⊔ obj_level(plainAccessResource) ⊔ obj_level(resources);
  ret(obj_level(resources)) = pc ⊔ level(isTopic) ⊔ level(plainAccessResource) ⊔ level(resources) ⊔ obj_level(isTopic) ⊔ obj_level(plainAccessResource) ⊔ obj_level(resources);
}