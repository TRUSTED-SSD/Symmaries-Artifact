org.apache.rocketmq.remoting.protocol.heartbeat.ConsumeType org.apache.rocketmq.proxy.grpc.v2.client.ClientActivity:buildConsumeType (
  apache.rocketmq.v2.ClientType clientType) {
  guard = tt;
  ret(level()) = pc ⊔ level(clientType) ⊔ obj_level(clientType);
  ret(obj_level()) = pc ⊔ level(clientType) ⊔ obj_level(clientType);
  ret(obj_level(clientType)) = pc ⊔ level(clientType) ⊔ obj_level(clientType);
  ret(obj_level(this)) = pc ⊔ level(clientType) ⊔ obj_level(clientType) ⊔ obj_level(this);
}