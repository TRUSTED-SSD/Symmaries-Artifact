org.apache.rocketmq.client.consumer.PullResult org.apache.rocketmq.broker.transaction.queue.TransactionalMessageServiceImpl:pullOpMsg (
  org.apache.rocketmq.common.message.MessageQueue mq, long offset, int nums) {
  guard = tt;
  ret(level()) = pc ⊔ level(mq) ⊔ level(nums) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
  ret(obj_level()) = ⊤;
  ret(obj_level(mq)) = ⊤;
  ret(obj_level(this)) = ⊤;
}