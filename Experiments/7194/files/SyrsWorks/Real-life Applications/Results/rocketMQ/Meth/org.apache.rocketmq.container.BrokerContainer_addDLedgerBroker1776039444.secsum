org.apache.rocketmq.container.InnerBrokerController org.apache.rocketmq.container.BrokerContainer:addDLedgerBroker (
  org.apache.rocketmq.common.BrokerConfig brokerConfig,
  org.apache.rocketmq.store.config.MessageStoreConfig storeConfig) {
  guard = tt;
  ret(level()) = pc ⊔ level(storeConfig) ⊔ level(this) ⊔ obj_level(brokerConfig) ⊔ obj_level(storeConfig) ⊔ obj_level(this);
  ret(obj_level()) = ⊤;
  ret(obj_level(brokerConfig)) = ⊤;
  ret(obj_level(storeConfig)) = ⊤;
  ret(obj_level(this)) = ⊤;
}