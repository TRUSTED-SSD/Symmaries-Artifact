void org.apache.rocketmq.broker.BrokerController:onMasterOnline (java.lang.String
                                                                   @masterAddr,
                                                                 java.lang.String
                                                                   masterHaAddr) {
  guard = tt;
  ret(obj_level(@masterAddr)) = pc ⊔ level(@masterAddr) ⊔ level(masterHaAddr) ⊔ level(this) ⊔ obj_level(@masterAddr) ⊔ obj_level(this);
  ret(obj_level(masterHaAddr)) = pc ⊔ level(@masterAddr) ⊔ level(masterHaAddr) ⊔ level(this) ⊔ obj_level(@masterAddr) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@masterAddr) ⊔ level(masterHaAddr) ⊔ level(this) ⊔ obj_level(@masterAddr) ⊔ obj_level(this);
}