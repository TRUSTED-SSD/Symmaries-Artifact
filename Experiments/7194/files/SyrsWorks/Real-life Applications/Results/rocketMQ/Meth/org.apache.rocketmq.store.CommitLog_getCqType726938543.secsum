org.apache.rocketmq.common.attribute.CQType org.apache.rocketmq.store.CommitLog:getCqType (
  org.apache.rocketmq.common.message.MessageExtBrokerInner msgInner) {
  guard = tt;
  ret(level()) = pc ⊔ level(msgInner) ⊔ level(this) ⊔ obj_level(msgInner) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(msgInner) ⊔ level(this) ⊔ obj_level(msgInner) ⊔ obj_level(this);
  ret(obj_level(msgInner)) = pc ⊔ level(msgInner) ⊔ level(this) ⊔ obj_level(msgInner) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msgInner) ⊔ level(this) ⊔ obj_level(msgInner) ⊔ obj_level(this);
}