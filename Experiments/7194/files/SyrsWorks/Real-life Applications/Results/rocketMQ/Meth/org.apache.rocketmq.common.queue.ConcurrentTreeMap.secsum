org.apache.rocketmq.common.queue.ConcurrentTreeMap (int capacity,
                                                    java.util.Comparator
                                                      comparator) {
  guard = tt;
  ret(obj_level(comparator)) = pc ⊔ level(capacity) ⊔ level(comparator) ⊔ level(this) ⊔ obj_level(comparator) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(capacity) ⊔ level(comparator) ⊔ level(this) ⊔ obj_level(comparator) ⊔ obj_level(this);
}