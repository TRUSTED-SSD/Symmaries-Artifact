long org.apache.rocketmq.broker.processor.NotificationProcessor:getPopOffset (
  java.lang.String topic, java.lang.String cid, int queueId) {
  guard = tt;
  ret(level()) = pc ⊔ level(cid) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(cid) ⊔ obj_level(this);
  ret(obj_level(cid)) = pc ⊔ level(cid) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(cid) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cid) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(cid) ⊔ obj_level(this);
  ret(obj_level(topic)) = pc ⊔ level(cid) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(cid) ⊔ obj_level(this);
}