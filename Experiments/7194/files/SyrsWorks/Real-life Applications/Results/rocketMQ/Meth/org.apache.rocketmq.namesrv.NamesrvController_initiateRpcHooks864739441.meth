void org.apache.rocketmq.namesrv.NamesrvController:initiateRpcHooks()
{
org.apache.rocketmq.namesrv.route.ZoneRouteRPCHook $stack1;
  org.apache.rocketmq.remoting.RemotingServer $stack2;
  $stack2=this.remotingServer;
 $stack1=new org.apache.rocketmq.namesrv.route.ZoneRouteRPCHook;
 $stack1#org.apache.rocketmq.namesrv.route.ZoneRouteRPCHook();
 $stack2.registerRPCHook((org.apache.rocketmq.remoting.RPCHook)$stack1);
 return;
 } 

