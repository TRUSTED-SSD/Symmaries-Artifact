org.apache.rocketmq.store.index.IndexService (org.apache.rocketmq.store.DefaultMessageStore
                                                @store) {
  guard = tt;
  ret(obj_level(@store)) = pc ⊔ level(@store) ⊔ level(this) ⊔ obj_level(@store) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@store) ⊔ level(this) ⊔ obj_level(@store) ⊔ obj_level(this);
}