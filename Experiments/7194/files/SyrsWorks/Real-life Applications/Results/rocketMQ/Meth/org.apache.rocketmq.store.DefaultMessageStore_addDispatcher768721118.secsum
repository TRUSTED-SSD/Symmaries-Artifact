void org.apache.rocketmq.store.DefaultMessageStore:addDispatcher (org.apache.rocketmq.store.CommitLogDispatcher
                                                                    dispatcher) {
  guard = tt;
  ret(obj_level(dispatcher)) = pc ⊔ level(dispatcher) ⊔ level(this) ⊔ obj_level(dispatcher) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(dispatcher) ⊔ level(this) ⊔ obj_level(dispatcher) ⊔ obj_level(this);
}