boolean org.apache.rocketmq.controller.impl.DefaultBrokerHeartbeatManager:isBrokerActive (
  java.lang.String clusterName, java.lang.String brokerAddr) {
  guard = tt;
  ret(level()) = pc ⊔ level(brokerAddr) ⊔ level(clusterName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(brokerAddr)) = pc ⊔ level(brokerAddr) ⊔ level(clusterName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(clusterName)) = pc ⊔ level(brokerAddr) ⊔ level(clusterName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerAddr) ⊔ level(clusterName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
}