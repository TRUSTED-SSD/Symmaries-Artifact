void org.apache.rocketmq.broker.dledger.DLedgerRoleChangeHandler:handleSlaveSynchronize (
  org.apache.rocketmq.store.config.BrokerRole role) {
  guard = tt;
  ret(obj_level(role)) = pc ⊔ level(role) ⊔ level(this) ⊔ obj_level(role) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(role) ⊔ level(this) ⊔ obj_level(this);
}