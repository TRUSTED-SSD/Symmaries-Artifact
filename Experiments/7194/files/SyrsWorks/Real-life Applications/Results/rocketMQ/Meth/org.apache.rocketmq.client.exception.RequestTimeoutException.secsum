org.apache.rocketmq.client.exception.RequestTimeoutException (int
                                                                responseCode,
                                                              java.lang.String
                                                                errorMessage) {
  guard = tt;
  ret(obj_level(errorMessage)) = pc ⊔ level(errorMessage) ⊔ level(responseCode) ⊔ level(this) ⊔ obj_level(errorMessage) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(errorMessage) ⊔ level(responseCode) ⊔ level(this) ⊔ obj_level(errorMessage) ⊔ obj_level(this);
}