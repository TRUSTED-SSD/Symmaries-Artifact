org.apache.rocketmq.controller.BrokerLiveInfo(java.lang.String brokerName,java.lang.String brokerAddr,long brokerId,long lastUpdateTimestamp,long heartbeatTimeoutMillis,io.netty.channel.Channel channel,int epoch,long maxOffset,java.lang.Integer electionPriority)
{
this#java.lang.Object();
 this.brokerName=brokerName;
