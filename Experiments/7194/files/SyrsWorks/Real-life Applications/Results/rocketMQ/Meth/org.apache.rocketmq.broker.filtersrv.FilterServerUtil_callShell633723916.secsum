static void org.apache.rocketmq.broker.filtersrv.FilterServerUtil:callShell (
  java.lang.String shellString,
  org.apache.rocketmq.logging.org.slf4j.Logger log) {
  guard = tt;
  ret(obj_level(log)) = pc ⊔ level(log) ⊔ level(shellString) ⊔ obj_level(log) ⊔ obj_level(shellString);
  ret(obj_level(shellString)) = pc ⊔ level(shellString) ⊔ obj_level(shellString);
}