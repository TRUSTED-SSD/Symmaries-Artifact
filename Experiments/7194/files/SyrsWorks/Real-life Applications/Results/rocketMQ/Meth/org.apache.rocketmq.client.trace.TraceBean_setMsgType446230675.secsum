void org.apache.rocketmq.client.trace.TraceBean:setMsgType (org.apache.rocketmq.common.message.MessageType
                                                              msgType) {
  guard = tt;
  ret(obj_level(msgType)) = obj_level(msgType);
  ret(obj_level(this)) = pc ⊔ level(msgType) ⊔ obj_level(msgType) ⊔ obj_level(this);
}