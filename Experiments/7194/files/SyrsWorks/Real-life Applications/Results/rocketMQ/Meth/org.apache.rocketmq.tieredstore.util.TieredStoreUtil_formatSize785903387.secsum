static java.lang.String org.apache.rocketmq.tieredstore.util.TieredStoreUtil:formatSize (
  long size, long divider, java.lang.String @unitName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@unitName) ⊔ level(divider) ⊔ level(size) ⊔ obj_level(@unitName);
  ret(obj_level()) = pc ⊔ level(@unitName) ⊔ level(divider) ⊔ level(size) ⊔ obj_level(@unitName);
  ret(obj_level(@unitName)) = pc ⊔ level(@unitName) ⊔ level(divider) ⊔ level(size) ⊔ obj_level(@unitName);
}