boolean org.apache.rocketmq.broker.processor.NotificationProcessor:hasMsgFromQueue (
  boolean isRetry,
  org.apache.rocketmq.remoting.protocol.header.NotificationRequestHeader
    requestHeader,
  int queueId) {
  guard = tt;
  ret(level()) = pc ⊔ level(isRetry) ⊔ level(queueId) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(requestHeader)) = pc ⊔ level(isRetry) ⊔ level(queueId) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(isRetry) ⊔ level(queueId) ⊔ level(requestHeader) ⊔ level(this) ⊔ obj_level(requestHeader) ⊔ obj_level(this);
}