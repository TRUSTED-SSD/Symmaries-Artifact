static boolean org.apache.rocketmq.proxy.ProxyMode:isLocalMode (java.lang.String
                                                                  @mode) {
  guard = tt;
  ret(level()) = pc ⊔ level(@mode) ⊔ obj_level(@mode);
  ret(obj_level(@mode)) = if obj_level(@mode) = ⊤ ∨ pc ≠ ⊤ ∧ level(@mode) = ⊤ ∧ obj_level(@mode) = ⊥ then ⊤ else ⊥;
}