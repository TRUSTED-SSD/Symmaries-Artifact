boolean org.apache.rocketmq.client.impl.consumer.DefaultMQPullConsumerImpl:isSubscribeTopicNeedUpdate (
  java.lang.String topic) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ obj_level(topic) = ⊤ then ⊤ else ⊥;
  ret(obj_level(topic)) = obj_level(topic);
}