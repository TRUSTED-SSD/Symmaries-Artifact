int org.apache.rocketmq.proxy.grpc.v2.producer.SendMessageActivity:buildSysFlag (
  apache.rocketmq.v2.Message protoMessage) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(protoMessage);
  ret(obj_level(protoMessage)) = obj_level(protoMessage);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(protoMessage) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}