static void org.apache.rocketmq.common.message.MessageAccessor:setTransferFlag (
  org.apache.rocketmq.common.message.Message msg, java.lang.String unit) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(unit) ⊔ obj_level(msg);
  ret(obj_level(unit)) = pc ⊔ level(msg) ⊔ level(unit) ⊔ obj_level(msg) ⊔ obj_level(unit);
}