  ret(obj_level(o)) = pc ⊔ level(o) ⊔ level(this) ⊔ obj_level(o);
  ret(obj_level(this)) = if obj_level(o) = ⊤ ∨ pc ≠ ⊤ ∧ (if level(this) = ⊥ then level(o) = ⊤ ∧ obj_level(o) = ⊥ else level(this) = ⊤ ∧ obj_level(o) = ⊥) then ⊤ else ⊥;
}