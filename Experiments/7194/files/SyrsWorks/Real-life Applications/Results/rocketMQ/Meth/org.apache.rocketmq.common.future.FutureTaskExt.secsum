org.apache.rocketmq.common.future.FutureTaskExt (java.lang.Runnable runnable,
                                                 java.lang.Object result) {
  guard = tt;
  ret(obj_level(result)) = pc ⊔ level(result) ⊔ level(runnable) ⊔ level(this) ⊔ obj_level(result);
  ret(obj_level(runnable)) = pc ⊔ level(result) ⊔ level(runnable) ⊔ level(this) ⊔ obj_level(result);
  ret(obj_level(this)) = pc ⊔ level(result) ⊔ level(runnable) ⊔ level(this) ⊔ obj_level(result);
}