org.apache.rocketmq.filter.expression.Expression org.apache.rocketmq.filter.SqlFilter:compile (
  java.lang.String expr) {
  guard = tt;
  ret(level()) = pc ⊔ level(expr) ⊔ obj_level(expr);
  ret(obj_level()) = pc ⊔ level(expr) ⊔ obj_level(expr);
  ret(obj_level(expr)) = pc ⊔ level(expr) ⊔ obj_level(expr);
  ret(obj_level(this)) = obj_level(this);
}