void org.apache.rocketmq.broker.processor.DefaultPullMessageResultHandler:generateOffsetMovedEvent (
  org.apache.rocketmq.remoting.protocol.topic.OffsetMovedEvent event) {
  guard = tt;
  ret(obj_level(event)) = pc ⊔ level(event) ⊔ level(this) ⊔ obj_level(event) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(event) ⊔ level(this) ⊔ obj_level(event) ⊔ obj_level(this);
}