static void org.apache.rocketmq.common.message.MessageAccessor:setReconsumeTime (
  org.apache.rocketmq.common.message.Message msg,
  java.lang.String reconsumeTimes) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(reconsumeTimes) ⊔ obj_level(msg);
  ret(obj_level(reconsumeTimes)) = pc ⊔ level(msg) ⊔ level(reconsumeTimes) ⊔ obj_level(msg) ⊔ obj_level(reconsumeTimes);
}