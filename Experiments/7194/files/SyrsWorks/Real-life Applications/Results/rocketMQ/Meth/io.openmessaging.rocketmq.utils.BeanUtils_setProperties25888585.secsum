static void io.openmessaging.rocketmq.utils.BeanUtils:setProperties (
  java.lang.Class @clazz, java.lang.Object obj, java.lang.String @methodName,
  java.lang.Object value) {
  guard = tt;
  ret(obj_level(@clazz)) = pc ⊔ level(@clazz) ⊔ level(@methodName) ⊔ level(obj) ⊔ level(value) ⊔ obj_level(@clazz);
  ret(obj_level(@methodName)) = pc ⊔ level(@clazz) ⊔ level(@methodName) ⊔ level(obj) ⊔ level(value) ⊔ obj_level(@clazz);
  ret(obj_level(obj)) = pc ⊔ level(@clazz) ⊔ level(@methodName) ⊔ level(obj) ⊔ level(value) ⊔ obj_level(@clazz);
  ret(obj_level(value)) = pc ⊔ level(@clazz) ⊔ level(@methodName) ⊔ level(obj) ⊔ level(value) ⊔ obj_level(@clazz);
}