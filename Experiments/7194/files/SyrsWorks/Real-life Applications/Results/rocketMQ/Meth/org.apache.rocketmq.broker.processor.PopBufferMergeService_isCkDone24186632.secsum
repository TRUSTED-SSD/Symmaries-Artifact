boolean org.apache.rocketmq.broker.processor.PopBufferMergeService:isCkDone (
  org.apache.rocketmq.broker.processor.PopBufferMergeService$PopCheckPointWrapper
    pointWrapper) {
  guard = tt;
  ret(level()) = pc ⊔ level(pointWrapper) ⊔ obj_level(pointWrapper);
  ret(obj_level(pointWrapper)) = if obj_level(pointWrapper) = ⊤ ∨ pc ≠ ⊤ ∧ level(pointWrapper) = ⊤ ∧ obj_level(pointWrapper) = ⊥ ∧ obj_level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(pointWrapper) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}