void org.apache.rocketmq.store.ha.DefaultHAService:addConnection (org.apache.rocketmq.store.ha.HAConnection
                                                                    conn) {
  guard = tt;
  ret(obj_level(conn)) = pc ⊔ level(conn) ⊔ level(this) ⊔ obj_level(conn) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(conn) ⊔ level(this) ⊔ obj_level(conn) ⊔ obj_level(this);
}