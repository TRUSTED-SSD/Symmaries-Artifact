org.apache.rocketmq.store.timer.TimerLog (java.lang.String storePath,
                                          int fileSize) {
  guard = tt;
  ret(obj_level(storePath)) = pc ⊔ level(fileSize) ⊔ level(storePath) ⊔ level(this) ⊔ obj_level(storePath) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fileSize) ⊔ level(storePath) ⊔ level(this) ⊔ obj_level(storePath) ⊔ obj_level(this);
}