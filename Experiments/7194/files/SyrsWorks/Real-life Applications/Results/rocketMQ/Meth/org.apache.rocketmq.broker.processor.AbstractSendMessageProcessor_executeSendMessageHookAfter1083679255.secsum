void org.apache.rocketmq.broker.processor.AbstractSendMessageProcessor:executeSendMessageHookAfter (
  org.apache.rocketmq.remoting.protocol.RemotingCommand response,
  org.apache.rocketmq.broker.mqtrace.SendMessageContext context) {
  guard = tt;
  ret(obj_level(context)) = pc ⊔ level(response) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(response) ⊔ obj_level(this);
  ret(obj_level(response)) = pc ⊔ level(response) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(response) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(response) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(response) ⊔ obj_level(this);
}