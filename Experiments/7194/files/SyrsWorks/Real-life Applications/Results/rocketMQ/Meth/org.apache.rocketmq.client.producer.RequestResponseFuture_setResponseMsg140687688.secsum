void org.apache.rocketmq.client.producer.RequestResponseFuture:setResponseMsg (
  org.apache.rocketmq.common.message.Message responseMsg) {
  guard = tt;
  ret(obj_level(responseMsg)) = pc ⊔ level(responseMsg) ⊔ obj_level(responseMsg);
  ret(obj_level(this)) = pc ⊔ level(responseMsg) ⊔ obj_level(responseMsg) ⊔ obj_level(this);
}