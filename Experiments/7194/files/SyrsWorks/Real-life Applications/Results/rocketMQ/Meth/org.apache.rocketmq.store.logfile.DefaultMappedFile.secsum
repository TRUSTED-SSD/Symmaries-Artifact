org.apache.rocketmq.store.logfile.DefaultMappedFile (java.lang.String
                                                       fileName,
                                                     int fileSize) {
  guard = tt;
  ret(obj_level(fileName)) = pc ⊔ level(fileName) ⊔ level(fileSize) ⊔ level(this) ⊔ obj_level(fileName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(fileName) ⊔ level(fileSize) ⊔ level(this) ⊔ obj_level(fileName) ⊔ obj_level(this);
}