long org.apache.rocketmq.store.timer.TimerWheel:checkPhyPos (long timeStartMs,
                                                             long maxOffset) {
  guard = tt;
  ret(level()) = pc ⊔ level(maxOffset) ⊔ level(this) ⊔ level(timeStartMs) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(timeStartMs) ⊔ obj_level(this);
}