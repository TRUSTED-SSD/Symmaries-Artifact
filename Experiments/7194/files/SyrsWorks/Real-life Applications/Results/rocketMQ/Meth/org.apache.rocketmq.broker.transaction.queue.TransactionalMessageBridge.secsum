org.apache.rocketmq.broker.transaction.queue.TransactionalMessageBridge (
  org.apache.rocketmq.broker.BrokerController brokerController,
  org.apache.rocketmq.store.MessageStore store) {
  guard = tt;
  ret(obj_level(brokerController)) = pc ⊔ level(brokerController) ⊔ level(store) ⊔ level(this) ⊔ obj_level(brokerController) ⊔ obj_level(store) ⊔ obj_level(this);
  ret(obj_level(store)) = pc ⊔ level(brokerController) ⊔ level(store) ⊔ level(this) ⊔ obj_level(brokerController) ⊔ obj_level(store) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerController) ⊔ level(store) ⊔ level(this) ⊔ obj_level(brokerController) ⊔ obj_level(store) ⊔ obj_level(this);
}