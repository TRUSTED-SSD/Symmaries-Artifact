void org.apache.rocketmq.tools.monitor.DefaultMonitorListener:reportUndoneMsgs (
  org.apache.rocketmq.tools.monitor.UndoneMsgs undoneMsgs) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(undoneMsgs) ⊔ obj_level(this) ⊔ obj_level(undoneMsgs);
  ret(obj_level(undoneMsgs)) = pc ⊔ level(undoneMsgs) ⊔ obj_level(undoneMsgs);
}