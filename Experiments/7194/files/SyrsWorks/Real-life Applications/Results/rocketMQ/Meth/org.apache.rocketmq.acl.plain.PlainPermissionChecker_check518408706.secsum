void org.apache.rocketmq.acl.plain.PlainPermissionChecker:check (org.apache.rocketmq.acl.AccessResource
                                                                   checkedAccess,
                                                                 org.apache.rocketmq.acl.AccessResource
                                                                   ownedAccess) {
  guard = tt;
  ret(obj_level(checkedAccess)) = pc ⊔ level(checkedAccess) ⊔ level(ownedAccess) ⊔ obj_level(checkedAccess);
  ret(obj_level(ownedAccess)) = pc ⊔ level(checkedAccess) ⊔ level(ownedAccess) ⊔ obj_level(checkedAccess);
  ret(obj_level(this)) = pc ⊔ level(checkedAccess) ⊔ level(ownedAccess) ⊔ obj_level(checkedAccess) ⊔ obj_level(this);
}