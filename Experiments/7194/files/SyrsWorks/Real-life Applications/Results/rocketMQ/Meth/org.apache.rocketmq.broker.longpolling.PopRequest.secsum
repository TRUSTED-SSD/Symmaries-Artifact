org.apache.rocketmq.broker.longpolling.PopRequest (org.apache.rocketmq.remoting.protocol.RemotingCommand
                                                     remotingCommand,
                                                   io.netty.channel.Channel
                                                     channel,
                                                   long expired) {
  guard = tt;
  ret(obj_level(channel)) = pc ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level(remotingCommand)) = pc ⊔ level(channel) ⊔ level(expired) ⊔ level(remotingCommand) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(remotingCommand) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(channel) ⊔ level(expired) ⊔ level(remotingCommand) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(remotingCommand) ⊔ obj_level(this);
}