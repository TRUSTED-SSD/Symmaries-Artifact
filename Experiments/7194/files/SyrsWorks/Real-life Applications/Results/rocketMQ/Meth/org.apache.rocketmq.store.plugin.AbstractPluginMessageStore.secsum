org.apache.rocketmq.store.plugin.AbstractPluginMessageStore (org.apache.rocketmq.store.plugin.MessageStorePluginContext
                                                               context,
                                                             org.apache.rocketmq.store.MessageStore
                                                               next) {
  guard = tt;
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ level(next) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(next);
  ret(obj_level(next)) = pc ⊔ level(context) ⊔ level(next) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(next);
  ret(obj_level(this)) = pc ⊔ level(context) ⊔ level(next) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(next);
}