void org.apache.rocketmq.proxy.grpc.v2.producer.SendMessageActivity:fillDelayMessageProperty (
  apache.rocketmq.v2.Message message,
  org.apache.rocketmq.common.message.Message messageWithHeader) {
  guard = tt;
  ret(obj_level(message)) = pc ⊔ level(messageWithHeader) ⊔ obj_level(message) ⊔ obj_level(messageWithHeader) ⊔ obj_level(this);
  ret(obj_level(messageWithHeader)) = pc ⊔ level(messageWithHeader) ⊔ obj_level(message) ⊔ obj_level(messageWithHeader) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageWithHeader) ⊔ obj_level(message) ⊔ obj_level(messageWithHeader) ⊔ obj_level(this);
}