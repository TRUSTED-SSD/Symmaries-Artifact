void org.apache.rocketmq.store.stats.BrokerStatsManager:incQueuePutNums (
  java.lang.String @topic, java.lang.Integer queueId, int num, int times) {
  guard = tt;
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(num) ⊔ level(queueId) ⊔ level(this) ⊔ level(times) ⊔ obj_level(@topic) ⊔ obj_level(queueId) ⊔ obj_level(this);
  ret(obj_level(queueId)) = pc ⊔ level(@topic) ⊔ level(num) ⊔ level(queueId) ⊔ level(this) ⊔ level(times) ⊔ obj_level(@topic) ⊔ obj_level(queueId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(num) ⊔ level(queueId) ⊔ level(this) ⊔ level(times) ⊔ obj_level(@topic) ⊔ obj_level(queueId) ⊔ obj_level(this);
}