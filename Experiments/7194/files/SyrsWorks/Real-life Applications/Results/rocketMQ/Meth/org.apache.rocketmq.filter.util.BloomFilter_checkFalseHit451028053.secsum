boolean org.apache.rocketmq.filter.util.BloomFilter:checkFalseHit (int[]
                                                                    bitPositions,
                                                                   org.apache.rocketmq.filter.util.BitsArray
                                                                    bits) {
  guard = tt;
  ret(level()) = pc ⊔ level(bitPositions) ⊔ level(bits) ⊔ obj_level(bitPositions) ⊔ obj_level(bits);
  ret(obj_level(bitPositions)) = obj_level(bitPositions);
  ret(obj_level(bits)) = obj_level(bits);
  ret(obj_level(this)) = obj_level(this);
}