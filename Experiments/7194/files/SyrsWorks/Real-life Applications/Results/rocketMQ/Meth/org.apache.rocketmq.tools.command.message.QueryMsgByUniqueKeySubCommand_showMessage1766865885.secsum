static void org.apache.rocketmq.tools.command.message.QueryMsgByUniqueKeySubCommand:showMessage (
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt admin,
  org.apache.rocketmq.common.message.MessageExt msg, int index) {
  guard = pc ⊔ level(index) ⊔ level(msg) ⊔ obj_level(msg) = ⊥;
  ret(obj_level(admin)) = level(admin) ⊔ obj_level(admin);
  ret(obj_level(msg)) = level(admin) ⊔ obj_level(admin);
}