org.apache.rocketmq.remoting.protocol.heartbeat.SubscriptionData org.apache.rocketmq.client.impl.consumer.DefaultMQPullConsumerImpl:getSubscriptionData (
  org.apache.rocketmq.common.message.MessageQueue mq,
  java.lang.String subExpression) {
  guard = tt;
  ret(level()) = pc ⊔ level(mq) ⊔ level(subExpression) ⊔ obj_level(mq);
  ret(obj_level()) = pc ⊔ level(mq) ⊔ level(subExpression) ⊔ obj_level(mq);
  ret(obj_level(mq)) = pc ⊔ level(mq) ⊔ level(subExpression) ⊔ obj_level(mq);
  ret(obj_level(subExpression)) = pc ⊔ level(mq) ⊔ level(subExpression) ⊔ obj_level(mq) ⊔ obj_level(subExpression);
  ret(obj_level(this)) = pc ⊔ level(mq) ⊔ level(subExpression) ⊔ obj_level(mq) ⊔ obj_level(this);
}