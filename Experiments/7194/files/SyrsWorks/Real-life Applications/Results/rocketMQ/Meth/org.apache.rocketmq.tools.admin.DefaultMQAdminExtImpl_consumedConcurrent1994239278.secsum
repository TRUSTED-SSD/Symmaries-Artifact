boolean org.apache.rocketmq.tools.admin.DefaultMQAdminExtImpl:consumedConcurrent (
  org.apache.rocketmq.common.message.MessageExt msg, java.lang.String @group) {
  guard = tt;
  ret(level()) = pc ⊔ level(@group) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(@group) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(@group)) = pc ⊔ level(@group) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(@group) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(msg)) = pc ⊔ level(@group) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(@group) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@group) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(@group) ⊔ obj_level(msg) ⊔ obj_level(this);
}