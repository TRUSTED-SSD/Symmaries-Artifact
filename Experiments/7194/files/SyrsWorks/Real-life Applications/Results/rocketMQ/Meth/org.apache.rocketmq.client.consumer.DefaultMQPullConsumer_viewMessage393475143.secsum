  ret(obj_level()) = pc ⊔ level(this) ⊔ level(uniqKey) ⊔ obj_level(this) ⊔ obj_level(uniqKey);
  ret(obj_level(@topic)) = pc ⊔ level(this) ⊔ level(uniqKey) ⊔ obj_level(@topic) ⊔ obj_level(this);
