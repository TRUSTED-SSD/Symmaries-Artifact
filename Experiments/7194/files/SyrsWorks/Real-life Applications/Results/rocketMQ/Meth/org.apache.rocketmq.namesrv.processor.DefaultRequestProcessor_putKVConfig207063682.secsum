org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.namesrv.processor.DefaultRequestProcessor:putKVConfig (
  io.netty.channel.ChannelHandlerContext ctx,
  org.apache.rocketmq.remoting.protocol.RemotingCommand request) {
  guard = pc ⊔ level(request) ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level()) = ⊥;
  ret(obj_level(ctx)) = obj_level(ctx);
  ret(obj_level(request)) = ⊥;
  ret(obj_level(this)) = ⊥;
}