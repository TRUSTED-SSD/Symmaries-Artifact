org.apache.rocketmq.store.logfile.MappedFile org.apache.rocketmq.store.MultiPathMappedFileQueue:tryCreateMappedFile (
  long createOffset) {
  guard = tt;
  ret(level()) = pc ⊔ level(createOffset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(createOffset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(createOffset) ⊔ level(this) ⊔ obj_level(this);
}