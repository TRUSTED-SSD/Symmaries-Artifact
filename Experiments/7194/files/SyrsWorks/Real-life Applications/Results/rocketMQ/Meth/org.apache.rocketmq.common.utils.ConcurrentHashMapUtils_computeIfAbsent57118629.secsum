static java.lang.Object org.apache.rocketmq.common.utils.ConcurrentHashMapUtils:computeIfAbsent (
  java.util.concurrent.ConcurrentMap map, java.lang.Object @key,
  java.util.function.Function func) {
  guard = tt;
  ret(level()) = pc ⊔ level(@key) ⊔ level(func) ⊔ level(map) ⊔ obj_level(@key);
  ret(obj_level()) = pc ⊔ level(@key) ⊔ level(func) ⊔ level(map) ⊔ obj_level(@key);
  ret(obj_level(@key)) = pc ⊔ level(@key) ⊔ level(func) ⊔ level(map) ⊔ obj_level(@key);
  ret(obj_level(func)) = pc ⊔ level(@key) ⊔ level(func) ⊔ level(map) ⊔ obj_level(@key);
  ret(obj_level(map)) = pc ⊔ level(@key) ⊔ level(func) ⊔ level(map) ⊔ obj_level(@key);
}