void org.apache.rocketmq.tools.admin.api.MessageTrack:setTrackType (org.apache.rocketmq.tools.admin.api.TrackType
                                                                    trackType) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(trackType) ⊔ obj_level(this) ⊔ obj_level(trackType);
  ret(obj_level(trackType)) = obj_level(trackType);
}