void io.openmessaging.rocketmq.consumer.LocalMessageCache:updatePullOffset (
  org.apache.rocketmq.common.message.MessageQueue remoteQueue,
  long nextPullOffset) {
  guard = tt;
  ret(obj_level(remoteQueue)) = pc ⊔ level(nextPullOffset) ⊔ level(remoteQueue) ⊔ level(this) ⊔ obj_level(remoteQueue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(nextPullOffset) ⊔ level(remoteQueue) ⊔ level(this) ⊔ obj_level(remoteQueue) ⊔ obj_level(this);
}