int org.apache.rocketmq.common.consistenthash.ConsistentHashRouter:getExistingReplicas (
  org.apache.rocketmq.common.consistenthash.Node pNode) {
  guard = tt;
  ret(level()) = pc ⊔ level(pNode) ⊔ level(this) ⊔ obj_level(pNode) ⊔ obj_level(this);
  ret(obj_level(pNode)) = pc ⊔ level(pNode) ⊔ level(this) ⊔ obj_level(pNode) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(pNode) ⊔ level(this) ⊔ obj_level(pNode) ⊔ obj_level(this);
}