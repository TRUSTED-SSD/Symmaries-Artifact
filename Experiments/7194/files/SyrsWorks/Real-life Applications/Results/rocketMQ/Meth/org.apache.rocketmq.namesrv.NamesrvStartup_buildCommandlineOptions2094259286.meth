static org.apache.commons.cli.Options org.apache.rocketmq.namesrv.NamesrvStartup:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("c","configFile",1,"Name server config properties file");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("p","printConfigItem",0,"Print all config items");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 return  options;
 } 

