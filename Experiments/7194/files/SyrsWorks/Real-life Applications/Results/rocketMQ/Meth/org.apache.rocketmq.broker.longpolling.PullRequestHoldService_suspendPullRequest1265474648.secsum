void org.apache.rocketmq.broker.longpolling.PullRequestHoldService:suspendPullRequest (
  java.lang.String @topic, int queueId,
  org.apache.rocketmq.broker.longpolling.PullRequest pullRequest) {
  guard = tt;
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(pullRequest) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(pullRequest) ⊔ obj_level(this);
  ret(obj_level(pullRequest)) = pc ⊔ level(@topic) ⊔ level(pullRequest) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(pullRequest) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(pullRequest) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(pullRequest) ⊔ obj_level(this);
}