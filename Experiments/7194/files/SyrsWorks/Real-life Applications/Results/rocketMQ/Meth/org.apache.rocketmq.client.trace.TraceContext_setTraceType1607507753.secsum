void org.apache.rocketmq.client.trace.TraceContext:setTraceType (org.apache.rocketmq.client.trace.TraceType
                                                                   traceType) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(traceType) ⊔ obj_level(this) ⊔ obj_level(traceType);
  ret(obj_level(traceType)) = obj_level(traceType);
}