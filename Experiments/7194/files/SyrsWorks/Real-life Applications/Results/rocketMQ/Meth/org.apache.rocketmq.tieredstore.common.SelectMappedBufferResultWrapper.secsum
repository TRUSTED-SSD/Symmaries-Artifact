org.apache.rocketmq.tieredstore.common.SelectMappedBufferResultWrapper (
  org.apache.rocketmq.store.SelectMappedBufferResult result, long curOffset,
  long minOffset, long maxOffset, long size) {
  guard = tt;
  ret(obj_level(result)) = pc ⊔ level(curOffset) ⊔ level(maxOffset) ⊔ level(minOffset) ⊔ level(result) ⊔ level(size) ⊔ level(this) ⊔ obj_level(result) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(curOffset) ⊔ level(maxOffset) ⊔ level(minOffset) ⊔ level(result) ⊔ level(size) ⊔ level(this) ⊔ obj_level(result) ⊔ obj_level(this);
}