org.apache.rocketmq.acl.common.SessionCredentials (java.lang.String accessKey,
                                                   java.lang.String secretKey) {
  guard = tt;
  ret(obj_level(accessKey)) = pc ⊔ level(this) ⊔ obj_level(accessKey) ⊔ obj_level(this);
  ret(obj_level(secretKey)) = pc ⊔ level(this) ⊔ obj_level(secretKey) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(accessKey) ⊔ level(secretKey) ⊔ level(this) ⊔ obj_level(accessKey) ⊔ obj_level(this);
}