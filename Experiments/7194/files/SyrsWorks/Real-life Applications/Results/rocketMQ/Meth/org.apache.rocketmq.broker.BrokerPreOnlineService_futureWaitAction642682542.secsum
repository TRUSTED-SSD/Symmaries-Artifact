boolean org.apache.rocketmq.broker.BrokerPreOnlineService:futureWaitAction (
  boolean result,
  org.apache.rocketmq.remoting.protocol.body.BrokerMemberGroup
    brokerMemberGroup) {
  guard = tt;
  ret(level()) = pc ⊔ level(result);
  ret(obj_level(brokerMemberGroup)) = pc ⊔ level(brokerMemberGroup) ⊔ level(result) ⊔ level(this) ⊔ obj_level(brokerMemberGroup) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerMemberGroup) ⊔ level(result) ⊔ level(this) ⊔ obj_level(brokerMemberGroup) ⊔ obj_level(this);
}