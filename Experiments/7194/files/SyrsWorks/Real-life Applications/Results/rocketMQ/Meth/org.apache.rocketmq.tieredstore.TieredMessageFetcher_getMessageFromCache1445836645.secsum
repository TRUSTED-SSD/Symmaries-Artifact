org.apache.rocketmq.tieredstore.common.SelectMappedBufferResultWrapper org.apache.rocketmq.tieredstore.TieredMessageFetcher:getMessageFromCache (
  org.apache.rocketmq.tieredstore.container.TieredMessageQueueContainer
    container,
  long queueOffset) {
  guard = tt;
  ret(level()) = pc ⊔ level(container) ⊔ level(queueOffset) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(container) ⊔ level(queueOffset) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(this);
  ret(obj_level(container)) = pc ⊔ level(container) ⊔ level(queueOffset) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(container) ⊔ level(queueOffset) ⊔ level(this) ⊔ obj_level(container) ⊔ obj_level(this);
}