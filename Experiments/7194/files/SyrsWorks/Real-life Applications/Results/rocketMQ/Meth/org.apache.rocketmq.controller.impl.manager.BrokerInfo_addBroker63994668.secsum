void org.apache.rocketmq.controller.impl.manager.BrokerInfo:addBroker (
  java.lang.String address, java.lang.Long brokerId) {
  guard = tt;
  ret(obj_level(address)) = pc ⊔ level(address) ⊔ level(brokerId) ⊔ level(this) ⊔ obj_level(address) ⊔ obj_level(brokerId) ⊔ obj_level(this);
  ret(obj_level(brokerId)) = pc ⊔ level(address) ⊔ level(brokerId) ⊔ level(this) ⊔ obj_level(address) ⊔ obj_level(brokerId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(address) ⊔ level(brokerId) ⊔ level(this) ⊔ obj_level(address) ⊔ obj_level(brokerId) ⊔ obj_level(this);
}