static byte[] org.apache.rocketmq.acl.common.AclUtils:combineRequestContent (
  org.apache.rocketmq.remoting.protocol.RemotingCommand request,
  java.util.SortedMap fieldsMap) {
  guard = tt;
  ret(level()) = pc ⊔ level(fieldsMap) ⊔ level(request) ⊔ obj_level(fieldsMap) ⊔ obj_level(request);
  ret(obj_level()) = pc ⊔ level(fieldsMap) ⊔ level(request) ⊔ obj_level(fieldsMap) ⊔ obj_level(request);
  ret(obj_level(fieldsMap)) = pc ⊔ level(fieldsMap) ⊔ obj_level(fieldsMap);
  ret(obj_level(request)) = pc ⊔ level(fieldsMap) ⊔ obj_level(fieldsMap) ⊔ obj_level(request);
}