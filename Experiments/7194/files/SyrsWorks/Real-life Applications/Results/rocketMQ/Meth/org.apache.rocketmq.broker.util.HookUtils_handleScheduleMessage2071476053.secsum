static org.apache.rocketmq.store.PutMessageResult org.apache.rocketmq.broker.util.HookUtils:handleScheduleMessage (
  org.apache.rocketmq.broker.BrokerController brokerController,
  org.apache.rocketmq.common.message.MessageExtBrokerInner msg) {
  guard = tt;
  ret(level()) = pc ⊔ level(brokerController) ⊔ level(msg) ⊔ obj_level(brokerController) ⊔ obj_level(msg);
  ret(obj_level()) = pc ⊔ level(brokerController) ⊔ level(msg) ⊔ obj_level(brokerController) ⊔ obj_level(msg);
  ret(obj_level(brokerController)) = pc ⊔ level(brokerController) ⊔ level(msg) ⊔ obj_level(brokerController) ⊔ obj_level(msg);
  ret(obj_level(msg)) = pc ⊔ level(brokerController) ⊔ level(msg) ⊔ obj_level(brokerController) ⊔ obj_level(msg);
}