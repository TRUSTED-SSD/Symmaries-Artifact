void org.apache.rocketmq.broker.dledger.DLedgerRoleChangeHandler:handle (
  long term, io.openmessaging.storage.dledger.MemberState$Role role) {
  guard = tt;
  ret(obj_level(role)) = pc ⊔ level(role) ⊔ level(term) ⊔ level(this) ⊔ obj_level(role) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(role) ⊔ level(term) ⊔ level(this) ⊔ obj_level(role) ⊔ obj_level(this);
}