static boolean org.apache.rocketmq.remoting.protocol.NamespaceUtil:isAlreadyWithNamespace (
  java.lang.String @resource, java.lang.String @namespace) {
  guard = tt;
  ret(level()) = pc ⊔ level(@namespace) ⊔ level(@resource) ⊔ obj_level(@namespace);
  ret(obj_level(@namespace)) = pc ⊔ level(@namespace) ⊔ level(@resource) ⊔ obj_level(@namespace);
  ret(obj_level(@resource)) = pc ⊔ level(@namespace) ⊔ level(@resource) ⊔ obj_level(@namespace);
}