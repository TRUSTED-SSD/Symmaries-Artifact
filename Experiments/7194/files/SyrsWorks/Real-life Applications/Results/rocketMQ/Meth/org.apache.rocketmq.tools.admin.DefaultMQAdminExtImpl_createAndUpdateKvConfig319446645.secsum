void org.apache.rocketmq.tools.admin.DefaultMQAdminExtImpl:createAndUpdateKvConfig (
  java.lang.String namespace, java.lang.String key, java.lang.String value) {
  guard = tt;
  ret(obj_level(key)) = pc ⊔ level(key) ⊔ level(namespace) ⊔ level(this) ⊔ level(value) ⊔ obj_level(key) ⊔ obj_level(this);
  ret(obj_level(namespace)) = pc ⊔ level(key) ⊔ level(namespace) ⊔ level(this) ⊔ level(value) ⊔ obj_level(namespace) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(key) ⊔ level(namespace) ⊔ level(this) ⊔ level(value) ⊔ obj_level(namespace) ⊔ obj_level(this);
  ret(obj_level(value)) = pc ⊔ level(key) ⊔ level(namespace) ⊔ level(this) ⊔ level(value) ⊔ obj_level(namespace) ⊔ obj_level(this);
}