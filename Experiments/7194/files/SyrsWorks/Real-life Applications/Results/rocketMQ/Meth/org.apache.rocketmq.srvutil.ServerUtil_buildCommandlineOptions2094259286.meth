static org.apache.commons.cli.Options org.apache.rocketmq.srvutil.ServerUtil:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("h","help",0,"Print help");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("n","namesrvAddr",1,"Name server address list, eg: \'192.168.0.1:9876;192.168.0.2:9876\'");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 return  options;
 } 

