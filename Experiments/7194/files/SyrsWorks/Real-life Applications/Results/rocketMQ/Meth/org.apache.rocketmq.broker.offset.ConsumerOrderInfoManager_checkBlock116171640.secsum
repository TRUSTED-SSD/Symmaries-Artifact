boolean org.apache.rocketmq.broker.offset.ConsumerOrderInfoManager:checkBlock (
  java.lang.String @topic, java.lang.String group, int queueId,
  long invisibleTime) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(group) ⊔ level(invisibleTime) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(group) ⊔ level(invisibleTime) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(group)) = pc ⊔ level(@topic) ⊔ level(group) ⊔ level(invisibleTime) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(group) ⊔ level(invisibleTime) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
