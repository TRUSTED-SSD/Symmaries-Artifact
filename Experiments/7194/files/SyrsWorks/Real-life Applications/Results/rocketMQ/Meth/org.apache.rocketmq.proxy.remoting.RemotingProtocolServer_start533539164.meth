void org.apache.rocketmq.proxy.remoting.RemotingProtocolServer:start()
{
org.apache.rocketmq.proxy.remoting.channel.RemotingChannelManager $stack1;
  org.apache.rocketmq.remoting.RemotingServer $stack2;
  $stack1=this.remotingChannelManager;
 $stack1.start();
 $stack2=this.defaultRemotingServer;
 $stack2.start();
 return;
 } 

