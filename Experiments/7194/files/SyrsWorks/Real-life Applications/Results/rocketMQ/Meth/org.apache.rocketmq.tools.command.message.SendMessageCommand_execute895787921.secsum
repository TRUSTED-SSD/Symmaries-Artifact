void org.apache.rocketmq.tools.command.message.SendMessageCommand:execute (
  org.apache.commons.cli.CommandLine commandLine,
  org.apache.commons.cli.Options options,
  org.apache.rocketmq.remoting.RPCHook rpcHook) {
  guard = pc ⊔ level(commandLine) ⊔ obj_level(commandLine) = ⊥;
  ret(obj_level(commandLine)) = level(this) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
  ret(obj_level(options)) = level(this) ⊔ obj_level(options) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
  ret(obj_level(rpcHook)) = level(this) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
  ret(obj_level(this)) = level(this) ⊔ obj_level(rpcHook) ⊔ obj_level(this);
}