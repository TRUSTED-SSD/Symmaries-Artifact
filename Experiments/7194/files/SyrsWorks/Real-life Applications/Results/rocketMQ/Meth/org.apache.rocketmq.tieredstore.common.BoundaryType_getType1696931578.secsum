static org.apache.rocketmq.tieredstore.common.BoundaryType org.apache.rocketmq.tieredstore.common.BoundaryType:getType (
  java.lang.String name) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(name);
  ret(obj_level()) = if pc ≠ ⊤ ∧ obj_level(name) = ⊤ then ⊤ else ⊥;
  ret(obj_level(name)) = obj_level(name);
}