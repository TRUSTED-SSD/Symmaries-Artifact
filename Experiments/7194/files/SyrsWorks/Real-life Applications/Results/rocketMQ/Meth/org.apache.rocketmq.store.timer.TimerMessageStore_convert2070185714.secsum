org.apache.rocketmq.common.message.MessageExtBrokerInner org.apache.rocketmq.store.timer.TimerMessageStore:convert (
  org.apache.rocketmq.common.message.MessageExt messageExt, long enqueueTime,
  boolean needRoll) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(enqueueTime) ⊔ level(messageExt) ⊔ level(needRoll) ⊔ obj_level(messageExt);
  ret(obj_level(messageExt)) = pc ⊔ level(enqueueTime) ⊔ level(messageExt) ⊔ level(needRoll) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(enqueueTime) ⊔ level(messageExt) ⊔ level(needRoll) ⊔ obj_level(messageExt) ⊔ obj_level(this);
}