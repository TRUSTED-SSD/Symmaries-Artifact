org.apache.rocketmq.remoting.protocol.heartbeat.MessageModel (java.lang.String
                                                                l1,
                                                              int l2,
                                                              java.lang.String
                                                                modeCN) {
  guard = tt;
  ret(obj_level(l1)) = pc ⊔ level(l1) ⊔ level(l2) ⊔ level(this) ⊔ obj_level(l1) ⊔ obj_level(this);
  ret(obj_level(modeCN)) = pc ⊔ level(l1) ⊔ level(l2) ⊔ level(this) ⊔ obj_level(modeCN) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(l1) ⊔ level(l2) ⊔ level(modeCN) ⊔ level(this) ⊔ obj_level(modeCN) ⊔ obj_level(this);
}