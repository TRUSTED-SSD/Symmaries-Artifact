void org.apache.rocketmq.client.impl.factory.MQClientInstance:unregisterClient (
  java.lang.String producerGroup, java.lang.String consumerGroup) {
  guard = tt;
  ret(obj_level(consumerGroup)) = pc ⊔ level(consumerGroup) ⊔ level(producerGroup) ⊔ level(this) ⊔ obj_level(consumerGroup) ⊔ obj_level(this);
  ret(obj_level(producerGroup)) = pc ⊔ level(consumerGroup) ⊔ level(producerGroup) ⊔ level(this) ⊔ obj_level(consumerGroup) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(consumerGroup) ⊔ level(producerGroup) ⊔ level(this) ⊔ obj_level(consumerGroup) ⊔ obj_level(this);
}