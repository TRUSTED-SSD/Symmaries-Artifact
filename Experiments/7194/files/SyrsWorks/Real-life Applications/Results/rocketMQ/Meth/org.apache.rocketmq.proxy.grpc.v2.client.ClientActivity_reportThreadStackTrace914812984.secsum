void org.apache.rocketmq.proxy.grpc.v2.client.ClientActivity:reportThreadStackTrace (
  org.apache.rocketmq.proxy.common.ProxyContext ctx,
  apache.rocketmq.v2.Status status,
  apache.rocketmq.v2.ThreadStackTrace request) {
  guard = tt;
  ret(obj_level(ctx)) = pc ⊔ level(this) ⊔ obj_level(ctx) ⊔ obj_level(request) ⊔ obj_level(status) ⊔ obj_level(this);
  ret(obj_level(request)) = pc ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(status) ⊔ obj_level(this);
  ret(obj_level(status)) = pc ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(status) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ obj_level(request) ⊔ obj_level(status) ⊔ obj_level(this);
}