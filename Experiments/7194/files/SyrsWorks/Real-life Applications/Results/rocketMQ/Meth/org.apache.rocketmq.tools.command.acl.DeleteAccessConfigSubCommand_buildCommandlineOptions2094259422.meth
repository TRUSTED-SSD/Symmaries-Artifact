org.apache.commons.cli.Options org.apache.rocketmq.tools.command.acl.DeleteAccessConfigSubCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.OptionGroup optionGroup;
  org.apache.commons.cli.Option opt;
  optionGroup=new org.apache.commons.cli.OptionGroup;
 optionGroup#org.apache.commons.cli.OptionGroup();
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("b","brokerAddr",1,"delete acl config account from which broker");
 optionGroup.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("c","clusterName",1,"delete acl config account from which cluster");
 optionGroup.addOption(opt);
 optionGroup.setRequired((boolean)1);
 options.addOptionGroup(optionGroup);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("a","accessKey",1,"set accessKey in acl config file for deleting which account");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 return  options;
 } 

