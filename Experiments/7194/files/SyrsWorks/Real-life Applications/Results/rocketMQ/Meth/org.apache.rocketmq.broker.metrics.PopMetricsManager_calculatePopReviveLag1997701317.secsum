static void org.apache.rocketmq.broker.metrics.PopMetricsManager:calculatePopReviveLag (
  org.apache.rocketmq.broker.BrokerController brokerController,
  io.opentelemetry.api.metrics.ObservableLongMeasurement measurement) {
  guard = tt;
  ret(obj_level(brokerController)) = pc ⊔ level(brokerController) ⊔ level(measurement) ⊔ obj_level(brokerController) ⊔ obj_level(measurement);
  ret(obj_level(measurement)) = pc ⊔ level(brokerController) ⊔ level(measurement) ⊔ obj_level(brokerController) ⊔ obj_level(measurement);
}