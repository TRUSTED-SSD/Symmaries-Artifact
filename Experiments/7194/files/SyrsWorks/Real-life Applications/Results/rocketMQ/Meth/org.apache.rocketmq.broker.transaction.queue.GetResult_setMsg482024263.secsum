void org.apache.rocketmq.broker.transaction.queue.GetResult:setMsg (org.apache.rocketmq.common.message.MessageExt
                                                                    msg) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ obj_level(msg);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ obj_level(msg) ⊔ obj_level(this);
}