 opt#org.apache.commons.cli.Option("a","controllerAddress",1,"the address of controller");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("c","clusterName",1,"which cluster");
