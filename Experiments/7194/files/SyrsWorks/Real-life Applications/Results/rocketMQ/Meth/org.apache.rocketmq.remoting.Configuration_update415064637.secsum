void org.apache.rocketmq.remoting.Configuration:update (java.util.Properties
                                                          properties) {
  guard = pc ⊔ level(properties) ⊔ level(this) ⊔ obj_level(properties) ⊔ obj_level(this) = ⊥;
  ret(obj_level(properties)) = ⊥;
  ret(obj_level(this)) = ⊥;
}