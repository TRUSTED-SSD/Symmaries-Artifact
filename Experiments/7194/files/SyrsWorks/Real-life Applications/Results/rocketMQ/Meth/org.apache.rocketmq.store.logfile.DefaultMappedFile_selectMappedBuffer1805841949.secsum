org.apache.rocketmq.store.SelectMappedBufferResult org.apache.rocketmq.store.logfile.DefaultMappedFile:selectMappedBuffer (
  int pos, int size) {
  guard = tt;
  ret(level()) = pc ⊔ level(pos) ⊔ level(size) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(pos) ⊔ level(size) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(pos) ⊔ level(size) ⊔ level(this) ⊔ obj_level(this);
}