org.apache.rocketmq.store.logfile.MappedFile org.apache.rocketmq.store.queue.SparseConsumeQueue:searchFileByOffsetOrRight (
  long msgOffset) {
  guard = tt;
  ret(level()) = pc ⊔ level(msgOffset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(msgOffset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msgOffset) ⊔ level(this) ⊔ obj_level(this);
}