apache.rocketmq.v2.MessageQueue org.apache.rocketmq.proxy.grpc.v2.common.GrpcConverter:buildMessageQueue (
  org.apache.rocketmq.common.message.MessageExt messageExt,
  java.lang.String @brokerName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@brokerName) ⊔ level(messageExt) ⊔ obj_level(@brokerName) ⊔ obj_level(messageExt);
  ret(obj_level()) = pc ⊔ level(@brokerName) ⊔ level(messageExt) ⊔ obj_level(@brokerName) ⊔ obj_level(messageExt);
  ret(obj_level(@brokerName)) = pc ⊔ level(@brokerName) ⊔ level(messageExt) ⊔ obj_level(@brokerName) ⊔ obj_level(messageExt);
  ret(obj_level(messageExt)) = pc ⊔ level(@brokerName) ⊔ level(messageExt) ⊔ obj_level(@brokerName) ⊔ obj_level(messageExt);
