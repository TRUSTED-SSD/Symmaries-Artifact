static void org.apache.rocketmq.common.message.MessageDecoder:decodeMessage (
  org.apache.rocketmq.common.message.MessageExt messageExt,
  java.util.List list) {
  guard = tt;
  ret(obj_level(list)) = pc ⊔ level(list) ⊔ level(messageExt) ⊔ obj_level(list) ⊔ obj_level(messageExt);
  ret(obj_level(messageExt)) = pc ⊔ level(list) ⊔ level(messageExt) ⊔ obj_level(list) ⊔ obj_level(messageExt);
}