static java.lang.String[] org.apache.rocketmq.acl.common.AclUtils:getAddresses (
  java.lang.String @netaddress, java.lang.String @partialAddress) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@netaddress) ⊔ level(@partialAddress) ⊔ obj_level(@netaddress);
  ret(obj_level(@netaddress)) = pc ⊔ level(@netaddress) ⊔ level(@partialAddress) ⊔ obj_level(@netaddress);
  ret(obj_level(@partialAddress)) = pc ⊔ level(@netaddress) ⊔ level(@partialAddress) ⊔ obj_level(@netaddress);
}