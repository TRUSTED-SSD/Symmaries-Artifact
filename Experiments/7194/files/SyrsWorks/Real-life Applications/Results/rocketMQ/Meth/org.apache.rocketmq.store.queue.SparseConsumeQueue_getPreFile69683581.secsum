org.apache.rocketmq.store.logfile.MappedFile org.apache.rocketmq.store.queue.SparseConsumeQueue:getPreFile (
  org.apache.rocketmq.store.logfile.MappedFile @file) {
  guard = tt;
  ret(level()) = pc ⊔ level(@file) ⊔ level(this) ⊔ obj_level(@file) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@file) ⊔ level(this) ⊔ obj_level(@file) ⊔ obj_level(this);
  ret(obj_level(@file)) = pc ⊔ level(@file) ⊔ level(this) ⊔ obj_level(@file) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@file) ⊔ level(this) ⊔ obj_level(@file) ⊔ obj_level(this);
}