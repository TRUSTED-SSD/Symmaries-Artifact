static void org.apache.rocketmq.common.message.MessageAccessor:setMQ2Flag (
  org.apache.rocketmq.common.message.Message msg, java.lang.String flag) {
  guard = tt;
  ret(obj_level(flag)) = pc ⊔ level(flag) ⊔ level(msg) ⊔ obj_level(flag) ⊔ obj_level(msg);
  ret(obj_level(msg)) = pc ⊔ level(flag) ⊔ level(msg) ⊔ obj_level(msg);
}