void org.apache.rocketmq.store.CommitLog$DefaultFlushManager:handleDiskFlush (
  org.apache.rocketmq.store.AppendMessageResult result,
  org.apache.rocketmq.store.PutMessageResult putMessageResult,
  org.apache.rocketmq.common.message.MessageExt messageExt) {
  guard = tt;
  ret(obj_level(messageExt)) = pc ⊔ level(messageExt) ⊔ level(result) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(putMessageResult) ⊔ obj_level(result) ⊔ obj_level(this);
  ret(obj_level(putMessageResult)) = pc ⊔ level(messageExt) ⊔ level(result) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(putMessageResult) ⊔ obj_level(result) ⊔ obj_level(this);
  ret(obj_level(result)) = pc ⊔ level(messageExt) ⊔ level(result) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(putMessageResult) ⊔ obj_level(result) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageExt) ⊔ level(result) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(putMessageResult) ⊔ obj_level(result) ⊔ obj_level(this);
}