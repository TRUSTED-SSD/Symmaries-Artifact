static void org.apache.rocketmq.acl.common.AclUtils:verify (java.lang.String
                                                              @netaddress,
                                                            int index) {
  guard = tt;
  ret(obj_level(@netaddress)) = pc ⊔ level(@netaddress) ⊔ level(index) ⊔ obj_level(@netaddress);
}