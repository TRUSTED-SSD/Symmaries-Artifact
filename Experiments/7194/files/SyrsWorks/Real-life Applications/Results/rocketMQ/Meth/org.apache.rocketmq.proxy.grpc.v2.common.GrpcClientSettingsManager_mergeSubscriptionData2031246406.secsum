static apache.rocketmq.v2.Settings org.apache.rocketmq.proxy.grpc.v2.common.GrpcClientSettingsManager:mergeSubscriptionData (
  apache.rocketmq.v2.Settings @settings,
  org.apache.rocketmq.remoting.protocol.subscription.SubscriptionGroupConfig
    groupConfig) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(@settings);
  ret(obj_level()) = pc ⊔ obj_level(@settings);
  ret(obj_level(@settings)) = obj_level(@settings);
  ret(obj_level(groupConfig)) = pc ⊔ level(groupConfig) ⊔ obj_level(groupConfig);
}