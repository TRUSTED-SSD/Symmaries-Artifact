void org.apache.rocketmq.tieredstore.container.TieredIndexFile:initIndexFileHeader (
  org.apache.rocketmq.store.logfile.MappedFile mappedFile) {
  guard = tt;
  ret(obj_level(mappedFile)) = pc ⊔ level(mappedFile) ⊔ level(this) ⊔ obj_level(mappedFile) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(mappedFile) ⊔ level(this) ⊔ obj_level(mappedFile) ⊔ obj_level(this);
}