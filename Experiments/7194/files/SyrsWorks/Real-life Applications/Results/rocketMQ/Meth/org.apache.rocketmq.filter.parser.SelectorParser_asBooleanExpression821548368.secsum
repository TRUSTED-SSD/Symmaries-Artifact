org.apache.rocketmq.filter.expression.BooleanExpression org.apache.rocketmq.filter.parser.SelectorParser:asBooleanExpression (
  org.apache.rocketmq.filter.expression.Expression value) {
  guard = tt;
  ret(level()) = pc ⊔ level(value) ⊔ obj_level(value);
  ret(obj_level()) = pc ⊔ level(value) ⊔ obj_level(value);
  ret(obj_level(this)) = pc ⊔ level(value) ⊔ obj_level(this) ⊔ obj_level(value);
  ret(obj_level(value)) = pc ⊔ level(value) ⊔ obj_level(value);
}