long org.apache.rocketmq.store.timer.TimerMetrics:updateDistPair (int period,
                                                                  int value) {
  guard = tt;
  ret(level()) = pc ⊔ level(period) ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(period) ⊔ level(this) ⊔ level(value) ⊔ obj_level(this);
}