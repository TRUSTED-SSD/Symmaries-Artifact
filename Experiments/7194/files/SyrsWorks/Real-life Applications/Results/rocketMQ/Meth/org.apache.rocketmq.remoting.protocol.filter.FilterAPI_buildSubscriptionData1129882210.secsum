static org.apache.rocketmq.remoting.protocol.heartbeat.SubscriptionData org.apache.rocketmq.remoting.protocol.filter.FilterAPI:buildSubscriptionData (
  java.lang.String @topic, java.lang.String subString) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(subString) ⊔ obj_level(@topic);
  ret(obj_level()) = pc ⊔ level(@topic) ⊔ level(subString) ⊔ obj_level(@topic);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(subString) ⊔ obj_level(@topic);
  ret(obj_level(subString)) = pc ⊔ level(@topic) ⊔ level(subString) ⊔ obj_level(@topic);
}