org.apache.rocketmq.proxy.common.ProxyContext org.apache.rocketmq.proxy.remoting.activity.AbstractRemotingActivity:createContext (
  io.netty.channel.ChannelHandlerContext ctx,
  org.apache.rocketmq.remoting.protocol.RemotingCommand request) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(ctx) ⊔ level(request) ⊔ obj_level(ctx) ⊔ obj_level(request);
  ret(obj_level(ctx)) = pc ⊔ level(ctx) ⊔ level(request) ⊔ obj_level(ctx) ⊔ obj_level(request);
  ret(obj_level(request)) = pc ⊔ level(ctx) ⊔ level(request) ⊔ obj_level(ctx) ⊔ obj_level(request);
  ret(obj_level(this)) = pc ⊔ level(ctx) ⊔ level(request) ⊔ obj_level(ctx) ⊔ obj_level(request) ⊔ obj_level(this);
}