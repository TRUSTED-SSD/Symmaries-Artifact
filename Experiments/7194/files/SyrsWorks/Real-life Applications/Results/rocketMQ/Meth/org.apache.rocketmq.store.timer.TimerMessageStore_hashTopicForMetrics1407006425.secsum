int org.apache.rocketmq.store.timer.TimerMessageStore:hashTopicForMetrics (
  java.lang.String topic) {
  guard = tt;
  ret(level()) = pc ⊔ level(topic) ⊔ obj_level(topic);
  ret(obj_level(this)) = pc ⊔ level(topic) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(topic)) = pc ⊔ level(topic) ⊔ obj_level(topic);
}