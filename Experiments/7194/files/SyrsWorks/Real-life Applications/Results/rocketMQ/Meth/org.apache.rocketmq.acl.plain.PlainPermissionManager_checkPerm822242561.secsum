void org.apache.rocketmq.acl.plain.PlainPermissionManager:checkPerm (
  org.apache.rocketmq.acl.plain.PlainAccessResource needCheckedAccess,
  org.apache.rocketmq.acl.plain.PlainAccessResource ownedAccess) {
  guard = tt;
  ret(obj_level(needCheckedAccess)) = pc ⊔ level(needCheckedAccess) ⊔ level(ownedAccess) ⊔ obj_level(needCheckedAccess) ⊔ obj_level(this);
  ret(obj_level(ownedAccess)) = pc ⊔ level(needCheckedAccess) ⊔ level(ownedAccess) ⊔ obj_level(needCheckedAccess) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(needCheckedAccess) ⊔ level(ownedAccess) ⊔ obj_level(needCheckedAccess) ⊔ obj_level(this);
}