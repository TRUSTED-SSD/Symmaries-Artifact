boolean org.apache.rocketmq.client.impl.consumer.ConsumeMessageConcurrentlyService:sendMessageBack (
  org.apache.rocketmq.common.message.MessageExt msg,
  org.apache.rocketmq.client.consumer.listener.ConsumeConcurrentlyContext
    context) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(msg)) = pc ⊔ level(context) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(context) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(msg) ⊔ obj_level(this);
}