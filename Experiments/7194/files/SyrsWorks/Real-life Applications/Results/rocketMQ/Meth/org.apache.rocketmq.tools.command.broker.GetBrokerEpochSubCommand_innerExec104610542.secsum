void org.apache.rocketmq.tools.command.broker.GetBrokerEpochSubCommand:innerExec (
  org.apache.commons.cli.CommandLine commandLine,
  org.apache.commons.cli.Options options,
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt defaultMQAdminExt) {
  guard = pc ⊔ level(commandLine) ⊔ level(defaultMQAdminExt) ⊔ level(options) ⊔ obj_level(commandLine) ⊔ obj_level(defaultMQAdminExt) ⊔ obj_level(options) = ⊥;
  ret(obj_level(commandLine)) = ⊥;
  ret(obj_level(defaultMQAdminExt)) = ⊥;
  ret(obj_level(options)) = ⊥;
  ret(obj_level(this)) = obj_level(this);
}