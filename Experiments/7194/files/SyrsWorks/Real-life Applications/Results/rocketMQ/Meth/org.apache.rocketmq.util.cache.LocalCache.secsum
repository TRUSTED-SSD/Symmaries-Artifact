org.apache.rocketmq.util.cache.LocalCache (int cacheSize, boolean isLru,
                                           org.apache.rocketmq.util.cache.CacheEvictHandler
                                             handler) {
  guard = tt;
  ret(obj_level(handler)) = pc ⊔ level(isLru) ⊔ level(this) ⊔ obj_level(handler) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(cacheSize) ⊔ level(handler) ⊔ level(isLru) ⊔ level(this) ⊔ obj_level(handler) ⊔ obj_level(this);
}