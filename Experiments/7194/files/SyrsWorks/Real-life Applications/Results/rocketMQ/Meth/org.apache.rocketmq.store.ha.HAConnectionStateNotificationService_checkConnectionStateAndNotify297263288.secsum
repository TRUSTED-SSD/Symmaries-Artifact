boolean org.apache.rocketmq.store.ha.HAConnectionStateNotificationService:checkConnectionStateAndNotify (
  org.apache.rocketmq.store.ha.HAConnection connection) {
  guard = tt;
  ret(level()) = pc ⊔ level(connection) ⊔ level(this) ⊔ obj_level(connection) ⊔ obj_level(this);
  ret(obj_level(connection)) = pc ⊔ level(connection) ⊔ level(this) ⊔ obj_level(connection) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(connection) ⊔ level(this) ⊔ obj_level(connection) ⊔ obj_level(this);
}