boolean org.apache.rocketmq.acl.plain.PlainPermissionManager:updateAccessConfig (
  org.apache.rocketmq.common.PlainAccessConfig plainAccessConfig) {
  guard = level(plainAccessConfig) ⊔ level(this) ⊔ obj_level(plainAccessConfig) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(plainAccessConfig)) = ⊥;
  ret(obj_level(this)) = ⊥;
}