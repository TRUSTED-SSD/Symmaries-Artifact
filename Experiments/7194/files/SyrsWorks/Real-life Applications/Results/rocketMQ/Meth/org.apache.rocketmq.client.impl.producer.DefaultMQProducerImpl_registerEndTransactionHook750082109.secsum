void org.apache.rocketmq.client.impl.producer.DefaultMQProducerImpl:registerEndTransactionHook (
  org.apache.rocketmq.client.hook.EndTransactionHook hook) {
  guard = tt;
  ret(obj_level(hook)) = pc ⊔ level(hook) ⊔ level(this) ⊔ obj_level(hook) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(hook) ⊔ level(this) ⊔ obj_level(hook) ⊔ obj_level(this);
}