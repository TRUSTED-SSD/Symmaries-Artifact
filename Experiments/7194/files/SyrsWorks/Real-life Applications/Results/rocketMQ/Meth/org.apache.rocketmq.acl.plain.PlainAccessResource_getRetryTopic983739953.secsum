static java.lang.String org.apache.rocketmq.acl.plain.PlainAccessResource:getRetryTopic (
  java.lang.String @group) {
  guard = tt;
  ret(level()) = pc ⊔ level(@group) ⊔ obj_level(@group);
  ret(obj_level()) = pc ⊔ level(@group) ⊔ obj_level(@group);
  ret(obj_level(@group)) = pc ⊔ level(@group) ⊔ obj_level(@group);
}