java.lang.String org.apache.rocketmq.common.stats.RTStatsItem:statPrintDetail (
  org.apache.rocketmq.common.stats.StatsSnapshot ss) {
  guard = tt;
  ret(level()) = pc ⊔ level(ss) ⊔ obj_level(ss);
  ret(obj_level()) = pc ⊔ level(ss) ⊔ obj_level(ss);
  ret(obj_level(ss)) = pc ⊔ level(ss) ⊔ obj_level(ss);
  ret(obj_level(this)) = pc ⊔ level(ss) ⊔ obj_level(ss) ⊔ obj_level(this);
}