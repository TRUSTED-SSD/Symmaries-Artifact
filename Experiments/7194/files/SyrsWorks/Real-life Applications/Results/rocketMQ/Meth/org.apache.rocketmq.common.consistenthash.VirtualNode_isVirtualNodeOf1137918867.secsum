boolean org.apache.rocketmq.common.consistenthash.VirtualNode:isVirtualNodeOf (
  org.apache.rocketmq.common.consistenthash.Node pNode) {
  guard = tt;
  ret(level()) = pc ⊔ level(pNode) ⊔ level(this) ⊔ obj_level(pNode);
  ret(obj_level(pNode)) = pc ⊔ level(pNode) ⊔ level(this) ⊔ obj_level(pNode);
  ret(obj_level(this)) = pc ⊔ level(pNode) ⊔ level(this) ⊔ obj_level(pNode);
}