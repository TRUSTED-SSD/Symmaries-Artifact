org.apache.rocketmq.common.message.MessageExt org.apache.rocketmq.store.plugin.AbstractPluginMessageStore:lookMessageByOffset (
  long commitLogOffset) {
  guard = tt;
  ret(level()) = pc ⊔ level(commitLogOffset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(commitLogOffset) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(commitLogOffset) ⊔ level(this) ⊔ obj_level(this);
}