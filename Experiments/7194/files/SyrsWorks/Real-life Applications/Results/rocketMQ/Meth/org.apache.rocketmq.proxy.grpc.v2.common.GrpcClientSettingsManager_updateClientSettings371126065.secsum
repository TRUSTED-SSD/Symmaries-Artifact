void org.apache.rocketmq.proxy.grpc.v2.common.GrpcClientSettingsManager:updateClientSettings (
  java.lang.String clientId, apache.rocketmq.v2.Settings @settings) {
  guard = tt;
  ret(obj_level(@settings)) = pc ⊔ level(@settings) ⊔ level(clientId) ⊔ obj_level(@settings) ⊔ obj_level(clientId) ⊔ obj_level(this);
  ret(obj_level(clientId)) = pc ⊔ level(@settings) ⊔ level(clientId) ⊔ obj_level(@settings) ⊔ obj_level(clientId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@settings) ⊔ level(clientId) ⊔ obj_level(@settings) ⊔ obj_level(clientId) ⊔ obj_level(this);
}