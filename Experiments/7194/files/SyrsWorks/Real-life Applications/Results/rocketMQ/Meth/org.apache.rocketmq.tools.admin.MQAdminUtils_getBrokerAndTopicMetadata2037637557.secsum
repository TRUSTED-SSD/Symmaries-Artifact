static org.apache.rocketmq.remoting.rpc.ClientMetadata org.apache.rocketmq.tools.admin.MQAdminUtils:getBrokerAndTopicMetadata (
  java.lang.String topic,
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt defaultMQAdminExt) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(defaultMQAdminExt) ⊔ level(topic) ⊔ obj_level(defaultMQAdminExt) ⊔ obj_level(topic);
  ret(obj_level(defaultMQAdminExt)) = pc ⊔ level(defaultMQAdminExt) ⊔ level(topic) ⊔ obj_level(defaultMQAdminExt) ⊔ obj_level(topic);
  ret(obj_level(topic)) = pc ⊔ level(defaultMQAdminExt) ⊔ level(topic) ⊔ obj_level(defaultMQAdminExt) ⊔ obj_level(topic);
}