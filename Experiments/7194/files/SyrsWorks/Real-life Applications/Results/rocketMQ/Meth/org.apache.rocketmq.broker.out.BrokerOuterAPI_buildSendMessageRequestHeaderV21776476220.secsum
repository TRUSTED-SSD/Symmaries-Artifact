static org.apache.rocketmq.remoting.protocol.header.SendMessageRequestHeaderV2 org.apache.rocketmq.broker.out.BrokerOuterAPI:buildSendMessageRequestHeaderV2 (
  org.apache.rocketmq.common.message.MessageExt msg, java.lang.String @group) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@group) ⊔ level(msg) ⊔ obj_level(@group) ⊔ obj_level(msg);
  ret(obj_level(@group)) = pc ⊔ level(@group) ⊔ level(msg) ⊔ obj_level(@group) ⊔ obj_level(msg);
  ret(obj_level(msg)) = pc ⊔ level(@group) ⊔ level(msg) ⊔ obj_level(@group) ⊔ obj_level(msg);
}