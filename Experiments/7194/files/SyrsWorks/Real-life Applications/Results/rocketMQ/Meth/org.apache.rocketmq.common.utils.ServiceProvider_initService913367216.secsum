static java.lang.Object org.apache.rocketmq.common.utils.ServiceProvider:initService (
  java.lang.ClassLoader classLoader, java.lang.String @serviceName,
  java.lang.Class clazz) {
  guard = tt;
  ret(level()) = pc ⊔ level(@serviceName) ⊔ level(classLoader) ⊔ obj_level(@serviceName) ⊔ obj_level(classLoader) ⊔ obj_level(clazz);
  ret(obj_level()) = pc ⊔ level(@serviceName) ⊔ level(classLoader) ⊔ obj_level(@serviceName) ⊔ obj_level(classLoader) ⊔ obj_level(clazz);
  ret(obj_level(@serviceName)) = pc ⊔ level(@serviceName) ⊔ level(classLoader) ⊔ obj_level(@serviceName) ⊔ obj_level(classLoader) ⊔ obj_level(clazz);
  ret(obj_level(classLoader)) = pc ⊔ level(@serviceName) ⊔ level(classLoader) ⊔ obj_level(@serviceName) ⊔ obj_level(classLoader) ⊔ obj_level(clazz);
  ret(obj_level(clazz)) = pc ⊔ level(@serviceName) ⊔ level(classLoader) ⊔ obj_level(@serviceName) ⊔ obj_level(classLoader) ⊔ obj_level(clazz);
}