void org.apache.rocketmq.client.trace.hook.SendMessageOpenTracingHookImpl:sendMessageAfter (
  org.apache.rocketmq.client.hook.SendMessageContext context) {
  guard = tt;
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ obj_level(context);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ (if level(context) = ⊤ then obj_level(this) = ⊥ else level(context) = ⊥ ∧ obj_level(context) = ⊤ ∧ obj_level(this) = ⊥) then ⊤ else ⊥;
}