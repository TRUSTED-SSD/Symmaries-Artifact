void org.apache.rocketmq.broker.topic.TopicConfigManager:duplicationCheck (
  java.util.Set keys, java.lang.String @key) {
  guard = tt;
  ret(obj_level(@key)) = pc ⊔ level(@key) ⊔ level(keys) ⊔ obj_level(@key) ⊔ obj_level(keys);
  ret(obj_level(keys)) = pc ⊔ level(@key) ⊔ level(keys) ⊔ obj_level(@key) ⊔ obj_level(keys);
  ret(obj_level(this)) = pc ⊔ level(@key) ⊔ level(keys) ⊔ obj_level(@key) ⊔ obj_level(keys) ⊔ obj_level(this);
}