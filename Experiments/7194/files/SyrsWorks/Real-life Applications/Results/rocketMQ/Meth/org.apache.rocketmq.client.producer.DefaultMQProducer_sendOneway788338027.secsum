void org.apache.rocketmq.client.producer.DefaultMQProducer:sendOneway (
  org.apache.rocketmq.common.message.Message msg) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
}