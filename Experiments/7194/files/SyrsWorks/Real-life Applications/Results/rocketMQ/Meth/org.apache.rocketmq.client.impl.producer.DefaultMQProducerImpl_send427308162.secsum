void org.apache.rocketmq.client.impl.producer.DefaultMQProducerImpl:send (
  org.apache.rocketmq.common.message.Message msg,
  org.apache.rocketmq.client.producer.SendCallback sendCallback) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(sendCallback) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(sendCallback) ⊔ obj_level(this);
  ret(obj_level(sendCallback)) = pc ⊔ level(msg) ⊔ level(sendCallback) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(sendCallback) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ level(sendCallback) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(sendCallback) ⊔ obj_level(this);
}