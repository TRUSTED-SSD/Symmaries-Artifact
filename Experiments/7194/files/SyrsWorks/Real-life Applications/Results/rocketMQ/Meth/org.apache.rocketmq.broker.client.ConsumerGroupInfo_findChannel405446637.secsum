org.apache.rocketmq.broker.client.ClientChannelInfo org.apache.rocketmq.broker.client.ConsumerGroupInfo:findChannel (
  io.netty.channel.Channel channel) {
  guard = tt;
  ret(level()) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level(channel)) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
}