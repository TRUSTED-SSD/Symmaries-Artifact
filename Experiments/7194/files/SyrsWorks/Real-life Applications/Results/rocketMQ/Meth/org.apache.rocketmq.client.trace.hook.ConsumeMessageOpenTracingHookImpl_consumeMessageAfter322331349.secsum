void org.apache.rocketmq.client.trace.hook.ConsumeMessageOpenTracingHookImpl:consumeMessageAfter (
  org.apache.rocketmq.client.hook.ConsumeMessageContext context) {
  guard = tt;
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ obj_level(context);
  ret(obj_level(this)) = pc ⊔ level(context) ⊔ obj_level(context) ⊔ obj_level(this);
}