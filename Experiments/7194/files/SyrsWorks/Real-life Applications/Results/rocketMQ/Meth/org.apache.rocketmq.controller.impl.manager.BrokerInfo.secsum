org.apache.rocketmq.controller.impl.manager.BrokerInfo (java.lang.String
                                                          clusterName,
                                                        java.lang.String
                                                          brokerName) {
  guard = tt;
  ret(obj_level(brokerName)) = pc ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level(clusterName)) = pc ⊔ level(this) ⊔ obj_level(clusterName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerName) ⊔ level(clusterName) ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
}