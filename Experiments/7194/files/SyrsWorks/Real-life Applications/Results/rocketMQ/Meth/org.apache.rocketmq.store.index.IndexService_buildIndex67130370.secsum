void org.apache.rocketmq.store.index.IndexService:buildIndex (org.apache.rocketmq.store.DispatchRequest
                                                                req) {
  guard = tt;
  ret(obj_level(req)) = pc ⊔ level(req) ⊔ level(this) ⊔ obj_level(req) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(req) ⊔ level(this) ⊔ obj_level(req) ⊔ obj_level(this);
}