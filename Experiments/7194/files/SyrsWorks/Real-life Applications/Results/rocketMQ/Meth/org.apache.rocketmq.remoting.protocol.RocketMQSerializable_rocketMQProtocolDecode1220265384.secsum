static org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.remoting.protocol.RocketMQSerializable:rocketMQProtocolDecode (
  io.netty.buffer.ByteBuf headerBuffer, int headerLen) {
  p0: '0 -> dummyClass ('0) -> level;
  p1: io.netty.buffer.ByteBuf () -> level;
  p2: '0, '1 -> io.netty.buffer.ByteBuf ('0, '1) -> level;
  guard = tt;
  ret(level()) = p1 ⊔ pc ⊔ level(headerLen);
  ret(obj_level()) = p0 ⊔ p1 ⊔ p2 ⊔ pc ⊔ level(headerLen) ⊔ obj_level(headerBuffer);
  ret(obj_level(headerBuffer)) = p0 ⊔ p1 ⊔ p2 ⊔ pc ⊔ level(headerLen) ⊔ obj_level(headerBuffer);
}