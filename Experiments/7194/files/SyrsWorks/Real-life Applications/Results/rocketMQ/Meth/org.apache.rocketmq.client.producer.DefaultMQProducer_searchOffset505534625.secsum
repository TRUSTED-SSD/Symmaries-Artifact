long org.apache.rocketmq.client.producer.DefaultMQProducer:searchOffset (
  org.apache.rocketmq.common.message.MessageQueue @mq, long timestamp) {
  guard = tt;
  ret(level()) = pc ⊔ level(@mq) ⊔ level(this) ⊔ level(timestamp) ⊔ obj_level(@mq) ⊔ obj_level(this);
  ret(obj_level(@mq)) = pc ⊔ level(@mq) ⊔ level(this) ⊔ level(timestamp) ⊔ obj_level(@mq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@mq) ⊔ level(this) ⊔ level(timestamp) ⊔ obj_level(@mq) ⊔ obj_level(this);
}