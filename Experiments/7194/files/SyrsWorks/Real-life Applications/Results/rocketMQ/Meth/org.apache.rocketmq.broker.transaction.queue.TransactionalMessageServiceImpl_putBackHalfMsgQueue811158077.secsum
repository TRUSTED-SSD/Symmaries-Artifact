boolean org.apache.rocketmq.broker.transaction.queue.TransactionalMessageServiceImpl:putBackHalfMsgQueue (
  org.apache.rocketmq.common.message.MessageExt msgExt, long offset) {
  guard = tt;
  ret(level()) = pc ⊔ level(msgExt) ⊔ level(this) ⊔ obj_level(msgExt) ⊔ obj_level(this);
  ret(obj_level(msgExt)) = pc ⊔ level(msgExt) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(msgExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msgExt) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(msgExt) ⊔ obj_level(this);
}