org.apache.rocketmq.common.statistics.StatisticsItemPrinter (org.apache.rocketmq.common.statistics.StatisticsItemFormatter
                                                               formatter,
                                                             org.apache.rocketmq.logging.org.slf4j.Logger
                                                               log) {
  guard = tt;
  ret(obj_level(formatter)) = pc ⊔ level(this) ⊔ obj_level(formatter) ⊔ obj_level(this);
  ret(obj_level(log)) = pc ⊔ level(this) ⊔ obj_level(log) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(formatter) ⊔ level(log) ⊔ level(this) ⊔ obj_level(formatter) ⊔ obj_level(log) ⊔ obj_level(this);
}