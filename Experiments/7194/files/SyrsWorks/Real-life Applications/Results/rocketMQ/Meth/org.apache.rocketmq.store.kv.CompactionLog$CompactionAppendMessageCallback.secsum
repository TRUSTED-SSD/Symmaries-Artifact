org.apache.rocketmq.store.kv.CompactionLog$CompactionAppendMessageCallback (
  org.apache.rocketmq.common.message.MessageExt msgExt,
  org.apache.rocketmq.store.queue.SparseConsumeQueue bcq) {
  guard = tt;
  ret(obj_level(bcq)) = pc ⊔ level(bcq) ⊔ level(msgExt) ⊔ level(this) ⊔ obj_level(bcq) ⊔ obj_level(msgExt) ⊔ obj_level(this);
  ret(obj_level(msgExt)) = pc ⊔ level(bcq) ⊔ level(msgExt) ⊔ level(this) ⊔ obj_level(bcq) ⊔ obj_level(msgExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bcq) ⊔ level(msgExt) ⊔ level(this) ⊔ obj_level(bcq) ⊔ obj_level(msgExt) ⊔ obj_level(this);
}