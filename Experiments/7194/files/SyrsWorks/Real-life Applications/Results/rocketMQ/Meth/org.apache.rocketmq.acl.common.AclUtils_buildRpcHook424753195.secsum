static org.apache.rocketmq.remoting.RPCHook org.apache.rocketmq.acl.common.AclUtils:buildRpcHook (
  com.alibaba.fastjson.JSONObject yamlDataObject) {
  guard = tt;
  ret(level()) = pc ⊔ level(yamlDataObject) ⊔ obj_level(yamlDataObject);
  ret(obj_level()) = pc ⊔ level(yamlDataObject) ⊔ obj_level(yamlDataObject);
  ret(obj_level(yamlDataObject)) = pc ⊔ level(yamlDataObject) ⊔ obj_level(yamlDataObject);
}