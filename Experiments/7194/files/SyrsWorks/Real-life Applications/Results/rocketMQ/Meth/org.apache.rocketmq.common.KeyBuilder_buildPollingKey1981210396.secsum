static java.lang.String org.apache.rocketmq.common.KeyBuilder:buildPollingKey (
  java.lang.String @topic, java.lang.String cid, int queueId) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(queueId) ⊔ obj_level(@topic);
  ret(obj_level()) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(queueId) ⊔ obj_level(@topic);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(queueId) ⊔ obj_level(@topic);
  ret(obj_level(cid)) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(queueId) ⊔ obj_level(@topic);
}