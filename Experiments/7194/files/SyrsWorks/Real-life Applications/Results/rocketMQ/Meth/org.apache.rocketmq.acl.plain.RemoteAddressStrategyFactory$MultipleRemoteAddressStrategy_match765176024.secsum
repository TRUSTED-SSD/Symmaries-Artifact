boolean org.apache.rocketmq.acl.plain.RemoteAddressStrategyFactory$MultipleRemoteAddressStrategy:match (
  org.apache.rocketmq.acl.plain.PlainAccessResource plainAccessResource) {
  guard = tt;
  ret(level()) = pc ⊔ level(plainAccessResource) ⊔ level(this) ⊔ obj_level(plainAccessResource) ⊔ obj_level(this);
  ret(obj_level(plainAccessResource)) = obj_level(plainAccessResource);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(plainAccessResource) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}