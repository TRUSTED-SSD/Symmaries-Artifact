org.apache.rocketmq.filter.expression.UnaryExpression (org.apache.rocketmq.filter.expression.Expression
                                                         left) {
  guard = tt;
  ret(obj_level(left)) = pc ⊔ level(left) ⊔ level(this) ⊔ obj_level(left);
  ret(obj_level(this)) = pc ⊔ level(left) ⊔ level(this) ⊔ obj_level(left);
}