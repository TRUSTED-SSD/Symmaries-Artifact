void org.apache.rocketmq.client.trace.TraceBean:setTransactionState (
  org.apache.rocketmq.client.producer.LocalTransactionState transactionState) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(transactionState) ⊔ obj_level(this) ⊔ obj_level(transactionState);
  ret(obj_level(transactionState)) = obj_level(transactionState);
}