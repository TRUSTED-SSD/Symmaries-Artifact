void org.apache.rocketmq.store.stats.LmqBrokerStatsManager:incGroupGetNums (
  java.lang.String group, java.lang.String topic, int incValue) {
  guard = tt;
  ret(obj_level(group)) = pc ⊔ level(group) ⊔ level(topic) ⊔ obj_level(group);
  ret(obj_level(this)) = pc ⊔ level(group) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(topic)) = pc ⊔ level(group) ⊔ level(topic) ⊔ obj_level(group);
}