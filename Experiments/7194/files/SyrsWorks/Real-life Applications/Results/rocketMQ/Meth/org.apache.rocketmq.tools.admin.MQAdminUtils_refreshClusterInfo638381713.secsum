static void org.apache.rocketmq.tools.admin.MQAdminUtils:refreshClusterInfo (
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt defaultMQAdminExt,
  org.apache.rocketmq.remoting.rpc.ClientMetadata clientMetadata) {
  guard = tt;
  ret(obj_level(clientMetadata)) = pc ⊔ level(clientMetadata) ⊔ level(defaultMQAdminExt) ⊔ obj_level(clientMetadata) ⊔ obj_level(defaultMQAdminExt);
  ret(obj_level(defaultMQAdminExt)) = pc ⊔ level(clientMetadata) ⊔ level(defaultMQAdminExt) ⊔ obj_level(clientMetadata) ⊔ obj_level(defaultMQAdminExt);
}