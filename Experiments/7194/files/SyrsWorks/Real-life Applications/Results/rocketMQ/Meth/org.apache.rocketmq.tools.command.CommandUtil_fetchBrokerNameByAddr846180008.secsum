static java.lang.String org.apache.rocketmq.tools.command.CommandUtil:fetchBrokerNameByAddr (
  org.apache.rocketmq.tools.admin.MQAdminExt adminExt,
  java.lang.String @addr) {
  guard = tt;
  ret(level()) = pc ⊔ level(adminExt) ⊔ obj_level(@addr) ⊔ obj_level(adminExt);
  ret(obj_level()) = pc ⊔ level(adminExt) ⊔ obj_level(@addr) ⊔ obj_level(adminExt);
  ret(obj_level(@addr)) = pc ⊔ level(adminExt) ⊔ obj_level(@addr) ⊔ obj_level(adminExt);
  ret(obj_level(adminExt)) = pc ⊔ level(adminExt) ⊔ obj_level(@addr) ⊔ obj_level(adminExt);
}