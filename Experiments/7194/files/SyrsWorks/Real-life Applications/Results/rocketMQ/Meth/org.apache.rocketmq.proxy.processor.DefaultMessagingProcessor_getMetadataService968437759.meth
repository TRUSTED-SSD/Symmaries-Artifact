org.apache.rocketmq.proxy.service.metadata.MetadataService org.apache.rocketmq.proxy.processor.DefaultMessagingProcessor:getMetadataService()
{
org.apache.rocketmq.proxy.service.ServiceManager $stack1;
  org.apache.rocketmq.proxy.service.metadata.MetadataService $stack2;
  $stack1=this.serviceManager;
 $stack2 = $stack1.getMetadataService();
 return  $stack2;
 } 

