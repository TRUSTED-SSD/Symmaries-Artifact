void org.apache.rocketmq.client.trace.AsyncTraceDispatcher:setHostProducer (
  org.apache.rocketmq.client.impl.producer.DefaultMQProducerImpl hostProducer) {
  guard = tt;
  ret(obj_level(hostProducer)) = pc ⊔ level(hostProducer) ⊔ obj_level(hostProducer);
  ret(obj_level(this)) = pc ⊔ level(hostProducer) ⊔ obj_level(hostProducer) ⊔ obj_level(this);
}