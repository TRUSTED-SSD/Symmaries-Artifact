long org.apache.rocketmq.broker.metrics.ConsumerLagCalculator:getAvailableMsgCount (
  java.lang.String group, java.lang.String topic, boolean isPop) {
  guard = tt;
  ret(level()) = pc ⊔ level(group) ⊔ level(isPop) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(group)) = pc ⊔ level(this) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(topic) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(topic)) = pc ⊔ level(this) ⊔ level(topic) ⊔ obj_level(this) ⊔ obj_level(topic);
}