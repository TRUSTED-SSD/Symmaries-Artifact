void org.apache.rocketmq.store.ConsumeQueue:fillPreBlank (org.apache.rocketmq.store.logfile.MappedFile
                                                            mappedFile,
                                                          long untilWhere) {
  guard = tt;
  ret(obj_level(mappedFile)) = pc ⊔ level(this) ⊔ level(untilWhere) ⊔ obj_level(mappedFile) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(untilWhere) ⊔ obj_level(this);
}