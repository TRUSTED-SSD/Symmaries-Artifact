static java.lang.String org.apache.rocketmq.common.message.MessageClientIDSetter:getIPStrFromID (
  java.lang.String @msgID) {
  guard = tt;
  ret(level()) = pc ⊔ level(@msgID) ⊔ obj_level(@msgID);
  ret(obj_level()) = pc ⊔ level(@msgID) ⊔ obj_level(@msgID);
  ret(obj_level(@msgID)) = if obj_level(@msgID) = ⊤ ∨ pc ≠ ⊤ ∧ level(@msgID) = ⊤ ∧ obj_level(@msgID) = ⊥ then ⊤ else ⊥;
}