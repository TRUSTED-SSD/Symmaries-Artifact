void org.apache.rocketmq.store.DefaultMessageStore:cleanFilesPeriodically()
{
org.apache.rocketmq.store.DefaultMessageStore$CleanCommitLogService $stack1;
  org.apache.rocketmq.store.DefaultMessageStore$CleanConsumeQueueService $stack2;
  org.apache.rocketmq.store.DefaultMessageStore$CorrectLogicOffsetService $stack3;
  $stack1=this.cleanCommitLogService;
 $stack1.run();
 $stack2=this.cleanConsumeQueueService;
 $stack2.run();
 $stack3=this.correctLogicOffsetService;
 $stack3.run();
 return;
 } 

