void org.apache.rocketmq.acl.plain.PlainPermissionManager:checkPlainAccessConfig (
  org.apache.rocketmq.common.PlainAccessConfig plainAccessConfig) {
  guard = tt;
  ret(obj_level(plainAccessConfig)) = pc ⊔ level(plainAccessConfig) ⊔ obj_level(plainAccessConfig);
  ret(obj_level(this)) = pc ⊔ level(plainAccessConfig) ⊔ obj_level(plainAccessConfig) ⊔ obj_level(this);
}