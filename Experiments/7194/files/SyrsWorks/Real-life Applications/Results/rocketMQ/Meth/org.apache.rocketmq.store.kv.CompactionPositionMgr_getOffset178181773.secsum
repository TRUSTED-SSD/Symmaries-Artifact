long org.apache.rocketmq.store.kv.CompactionPositionMgr:getOffset (java.lang.String
                                                                    @topic,
                                                                   int
                                                                    queueId) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
}