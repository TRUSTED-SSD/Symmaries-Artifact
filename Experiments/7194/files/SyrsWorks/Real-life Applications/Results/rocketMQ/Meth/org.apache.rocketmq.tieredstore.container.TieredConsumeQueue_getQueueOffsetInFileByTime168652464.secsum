org.apache.commons.lang3.tuple.Pair org.apache.rocketmq.tieredstore.container.TieredConsumeQueue:getQueueOffsetInFileByTime (
  long timestamp,
  org.apache.rocketmq.tieredstore.common.BoundaryType boundaryType) {
  guard = tt;
  ret(level()) = pc ⊔ level(boundaryType) ⊔ level(this) ⊔ level(timestamp) ⊔ obj_level(boundaryType) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(boundaryType) ⊔ level(this) ⊔ level(timestamp) ⊔ obj_level(boundaryType) ⊔ obj_level(this);
  ret(obj_level(boundaryType)) = obj_level(boundaryType);
  ret(obj_level(this)) = pc ⊔ level(boundaryType) ⊔ level(this) ⊔ level(timestamp) ⊔ obj_level(boundaryType) ⊔ obj_level(this);
}