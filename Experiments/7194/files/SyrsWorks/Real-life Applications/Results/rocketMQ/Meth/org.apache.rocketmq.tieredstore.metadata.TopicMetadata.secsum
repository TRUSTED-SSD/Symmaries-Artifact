org.apache.rocketmq.tieredstore.metadata.TopicMetadata (int topicId,
                                                        java.lang.String
                                                          topic,
                                                        long reserveTime) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(reserveTime) ⊔ level(this) ⊔ level(topic) ⊔ level(topicId) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(topic)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(topic);
}