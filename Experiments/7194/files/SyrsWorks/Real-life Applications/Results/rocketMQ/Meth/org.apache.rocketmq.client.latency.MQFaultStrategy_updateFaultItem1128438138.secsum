void org.apache.rocketmq.client.latency.MQFaultStrategy:updateFaultItem (
  java.lang.String brokerName, long currentLatency, boolean isolation) {
  guard = tt;
  ret(obj_level(brokerName)) = pc ⊔ level(brokerName) ⊔ level(currentLatency) ⊔ level(isolation) ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerName) ⊔ level(currentLatency) ⊔ level(isolation) ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
}