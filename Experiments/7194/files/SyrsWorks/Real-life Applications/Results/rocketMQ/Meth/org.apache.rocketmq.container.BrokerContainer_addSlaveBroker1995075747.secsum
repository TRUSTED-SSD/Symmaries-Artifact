org.apache.rocketmq.container.InnerSalveBrokerController org.apache.rocketmq.container.BrokerContainer:addSlaveBroker (
  org.apache.rocketmq.common.BrokerConfig slaveBrokerConfig,
  org.apache.rocketmq.store.config.MessageStoreConfig storeConfig) {
  guard = tt;
  ret(level()) = pc ⊔ level(storeConfig) ⊔ level(this) ⊔ obj_level(slaveBrokerConfig) ⊔ obj_level(storeConfig) ⊔ obj_level(this);
  ret(obj_level()) = ⊤;
  ret(obj_level(slaveBrokerConfig)) = ⊤;
  ret(obj_level(storeConfig)) = ⊤;
  ret(obj_level(this)) = ⊤;
}