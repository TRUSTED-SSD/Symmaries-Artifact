static void org.apache.rocketmq.common.message.MessageClientIDSetter:setStartTime(long millis)
{
java.util.Calendar cal;
  cal = java.util.Calendar.getInstance();
 cal.setTimeInMillis(millis);
 cal.set(5,1);
 cal.set(11,0);
 cal.set(12,0);
 cal.set(13,0);
 cal.set(14,0);
 millis = cal.getTimeInMillis();
 org.apache.rocketmq.common.message.MessageClientIDSetter.startTime=millis;
 cal.add(2,1);
 millis = cal.getTimeInMillis();
 org.apache.rocketmq.common.message.MessageClientIDSetter.nextStartTime=millis;
 return;
 } 

