org.apache.rocketmq.tieredstore.metadata.QueueMetadata (org.apache.rocketmq.common.message.MessageQueue
                                                          queue,
                                                        long minOffset,
                                                        long maxOffset) {
  guard = tt;
  ret(obj_level(queue)) = pc ⊔ level(this) ⊔ obj_level(queue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(maxOffset) ⊔ level(minOffset) ⊔ level(queue) ⊔ level(this) ⊔ obj_level(queue) ⊔ obj_level(this);
}