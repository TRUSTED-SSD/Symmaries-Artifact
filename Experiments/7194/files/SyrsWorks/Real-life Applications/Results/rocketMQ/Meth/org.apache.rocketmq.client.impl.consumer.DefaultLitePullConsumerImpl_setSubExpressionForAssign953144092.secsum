void org.apache.rocketmq.client.impl.consumer.DefaultLitePullConsumerImpl:setSubExpressionForAssign (
  java.lang.String topic, java.lang.String subExpression) {
  guard = tt;
  ret(obj_level(subExpression)) = pc ⊔ level(subExpression) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(subExpression) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(subExpression) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(subExpression) ⊔ obj_level(this);
  ret(obj_level(topic)) = pc ⊔ level(subExpression) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(subExpression) ⊔ obj_level(this);
}