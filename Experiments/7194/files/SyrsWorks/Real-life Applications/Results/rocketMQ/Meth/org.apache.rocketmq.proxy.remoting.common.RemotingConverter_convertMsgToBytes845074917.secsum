byte[] org.apache.rocketmq.proxy.remoting.common.RemotingConverter:convertMsgToBytes (
  org.apache.rocketmq.common.message.MessageExt msg) {
  guard = tt;
  ret(level()) = pc ⊔ level(msg) ⊔ obj_level(msg);
  ret(obj_level()) = pc ⊔ level(msg) ⊔ obj_level(msg);
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ obj_level(msg);
  ret(obj_level(this)) = pc ⊔ obj_level(msg) ⊔ obj_level(this);
}