boolean org.apache.rocketmq.client.impl.consumer.RebalancePushImpl:unlockDelay (
  org.apache.rocketmq.common.message.MessageQueue mq,
  org.apache.rocketmq.client.impl.consumer.ProcessQueue pq) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level(mq)) = pc ⊔ level(mq) ⊔ level(pq) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(pq) ⊔ obj_level(this);
  ret(obj_level(pq)) = pc ⊔ level(mq) ⊔ level(pq) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(pq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(mq) ⊔ level(pq) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(pq) ⊔ obj_level(this);
}