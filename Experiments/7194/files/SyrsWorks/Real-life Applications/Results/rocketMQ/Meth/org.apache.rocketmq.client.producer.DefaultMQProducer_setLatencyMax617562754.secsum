void org.apache.rocketmq.client.producer.DefaultMQProducer:setLatencyMax (
  long[] latencyMax) {
  guard = tt;
  ret(obj_level(latencyMax)) = pc ⊔ level(latencyMax) ⊔ obj_level(latencyMax) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(latencyMax) ⊔ obj_level(latencyMax) ⊔ obj_level(this);
}