boolean org.apache.rocketmq.client.impl.producer.DefaultMQProducerImpl:tryToCompressMessage (
  org.apache.rocketmq.common.message.Message msg) {
  guard = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this) = ⊥;
  ret(level()) = ⊥;
  ret(obj_level(msg)) = ⊥;
  ret(obj_level(this)) = ⊥;
}