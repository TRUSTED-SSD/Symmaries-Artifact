static boolean org.apache.rocketmq.remoting.protocol.statictopic.TopicQueueMappingUtils:checkIfLeader (
  java.util.List items,
  org.apache.rocketmq.remoting.protocol.statictopic.TopicQueueMappingDetail
    mappingDetail) {
  guard = tt;
  ret(level()) = pc ⊔ level(items) ⊔ level(mappingDetail) ⊔ obj_level(items) ⊔ obj_level(mappingDetail);
  ret(obj_level(items)) = pc ⊔ level(items) ⊔ level(mappingDetail) ⊔ obj_level(items);
  ret(obj_level(mappingDetail)) = pc ⊔ level(items) ⊔ level(mappingDetail) ⊔ obj_level(items) ⊔ obj_level(mappingDetail);
}