void org.apache.rocketmq.broker.transaction.queue.TransactionalMessageBridge:updateConsumeOffset (
  org.apache.rocketmq.common.message.MessageQueue mq, long offset) {
  guard = tt;
  ret(obj_level(mq)) = pc ⊔ level(mq) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(mq) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
}