org.apache.rocketmq.proxy.grpc.GrpcServerBuilder org.apache.rocketmq.proxy.grpc.GrpcServerBuilder:addService (
  io.grpc.BindableService service) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(service) ⊔ level(this) ⊔ obj_level(service) ⊔ obj_level(this);
  ret(obj_level(service)) = obj_level(service);
  ret(obj_level(this)) = pc ⊔ level(service) ⊔ level(this) ⊔ obj_level(service) ⊔ obj_level(this);
}