static org.apache.rocketmq.broker.BrokerController org.apache.rocketmq.container.BrokerContainerStartup:createAndInitializeBroker (
  org.apache.rocketmq.container.BrokerContainer brokerContainer,
  java.lang.String @filePath, java.util.Properties brokerProperties) {
  guard = tt;
  ret(level()) = pc ⊔ level(@filePath) ⊔ level(brokerContainer) ⊔ level(brokerProperties) ⊔ obj_level(@filePath) ⊔ obj_level(brokerContainer) ⊔ obj_level(brokerProperties);
  ret(obj_level()) = ⊤;
  ret(obj_level(@filePath)) = ⊤;
  ret(obj_level(brokerContainer)) = ⊤;
  ret(obj_level(brokerProperties)) = ⊤;
}