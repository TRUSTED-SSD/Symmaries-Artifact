static org.apache.rocketmq.store.MessageStore org.apache.rocketmq.store.plugin.MessageStoreFactory:build (
  org.apache.rocketmq.store.plugin.MessageStorePluginContext context,
  org.apache.rocketmq.store.MessageStore @messageStore) {
  guard = tt;
  ret(level()) = pc ⊔ level(@messageStore) ⊔ level(context) ⊔ obj_level(@messageStore) ⊔ obj_level(context);
  ret(obj_level()) = pc ⊔ level(@messageStore) ⊔ level(context) ⊔ obj_level(@messageStore) ⊔ obj_level(context);
  ret(obj_level(@messageStore)) = pc ⊔ level(@messageStore) ⊔ level(context) ⊔ obj_level(@messageStore) ⊔ obj_level(context);
  ret(obj_level(context)) = pc ⊔ level(@messageStore) ⊔ level(context) ⊔ obj_level(@messageStore) ⊔ obj_level(context);
}