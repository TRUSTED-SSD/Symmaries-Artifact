static java.lang.Throwable org.apache.rocketmq.proxy.common.utils.ExceptionUtils:getRealException (
  java.lang.Throwable @throwable) {
  guard = tt;
  ret(level()) = pc ⊔ level(@throwable) ⊔ obj_level(@throwable);
  ret(obj_level()) = pc ⊔ level(@throwable) ⊔ obj_level(@throwable);
  ret(obj_level(@throwable)) = if obj_level(@throwable) = ⊤ ∨ pc ≠ ⊤ ∧ level(@throwable) = ⊤ ∧ obj_level(@throwable) = ⊥ then ⊤ else ⊥;
}