boolean org.apache.rocketmq.store.kv.CompactionLog:shouldRetainMsg (org.apache.rocketmq.common.message.MessageExt
                                                                    msgExt,
                                                                    org.apache.rocketmq.store.kv.CompactionLog$OffsetMap
                                                                    map) {
  guard = tt;
  ret(level()) = pc ⊔ level(map) ⊔ level(msgExt) ⊔ obj_level(map) ⊔ obj_level(msgExt);
  ret(obj_level(map)) = pc ⊔ level(map) ⊔ level(msgExt) ⊔ obj_level(map) ⊔ obj_level(msgExt);
  ret(obj_level(msgExt)) = pc ⊔ level(map) ⊔ level(msgExt) ⊔ obj_level(map) ⊔ obj_level(msgExt);
  ret(obj_level(this)) = pc ⊔ level(map) ⊔ level(msgExt) ⊔ obj_level(map) ⊔ obj_level(msgExt) ⊔ obj_level(this);
}