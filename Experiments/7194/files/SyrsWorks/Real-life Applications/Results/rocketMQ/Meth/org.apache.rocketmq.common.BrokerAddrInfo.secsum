org.apache.rocketmq.common.BrokerAddrInfo (java.lang.String clusterName,
                                           java.lang.String brokerAddr) {
  guard = tt;
  ret(obj_level(brokerAddr)) = pc ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(clusterName)) = pc ⊔ level(this) ⊔ obj_level(clusterName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerAddr) ⊔ level(clusterName) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
}