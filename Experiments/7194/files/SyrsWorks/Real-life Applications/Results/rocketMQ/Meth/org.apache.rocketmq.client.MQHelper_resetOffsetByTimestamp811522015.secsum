static void org.apache.rocketmq.client.MQHelper:resetOffsetByTimestamp (
  org.apache.rocketmq.remoting.protocol.heartbeat.MessageModel messageModel,
  java.lang.String instanceName, java.lang.String consumerGroup,
  java.lang.String topic, long timestamp) {
  guard = pc ⊔ level(consumerGroup) ⊔ level(instanceName) ⊔ level(messageModel) ⊔ level(timestamp) ⊔ level(topic) ⊔ obj_level(consumerGroup) ⊔ obj_level(messageModel) = ⊥;
  ret(obj_level(consumerGroup)) = ⊥;
  ret(obj_level(instanceName)) = ⊥;
  ret(obj_level(messageModel)) = ⊥;
  ret(obj_level(topic)) = ⊥;
}