org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.broker.client.net.Broker2Client:callClient (
  io.netty.channel.Channel channel,
  org.apache.rocketmq.remoting.protocol.RemotingCommand @request) {
  guard = tt;
  ret(level()) = pc ⊔ level(@request) ⊔ level(channel) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@request) ⊔ level(channel) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level(@request)) = obj_level(@request);
  ret(obj_level(channel)) = obj_level(channel);
  ret(obj_level(this)) = obj_level(this);
}