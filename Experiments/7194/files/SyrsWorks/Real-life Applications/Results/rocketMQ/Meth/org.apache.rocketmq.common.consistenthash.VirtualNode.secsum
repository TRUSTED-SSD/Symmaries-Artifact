org.apache.rocketmq.common.consistenthash.VirtualNode (org.apache.rocketmq.common.consistenthash.Node
                                                         physicalNode,
                                                       int replicaIndex) {
  guard = tt;
  ret(obj_level(physicalNode)) = pc ⊔ level(physicalNode) ⊔ level(replicaIndex) ⊔ level(this) ⊔ obj_level(physicalNode);
  ret(obj_level(this)) = pc ⊔ level(physicalNode) ⊔ level(replicaIndex) ⊔ level(this) ⊔ obj_level(physicalNode);
}