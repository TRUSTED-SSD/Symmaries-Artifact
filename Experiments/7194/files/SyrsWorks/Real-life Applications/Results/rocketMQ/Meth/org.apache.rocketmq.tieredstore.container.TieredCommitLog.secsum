org.apache.rocketmq.tieredstore.container.TieredCommitLog (org.apache.rocketmq.common.message.MessageQueue
                                                             messageQueue,
                                                           org.apache.rocketmq.tieredstore.common.TieredMessageStoreConfig
                                                             storeConfig) {
  guard = tt;
  ret(obj_level(messageQueue)) = pc ⊔ level(messageQueue) ⊔ level(storeConfig) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(storeConfig) ⊔ obj_level(this);
  ret(obj_level(storeConfig)) = pc ⊔ level(messageQueue) ⊔ level(storeConfig) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(storeConfig) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageQueue) ⊔ level(storeConfig) ⊔ level(this) ⊔ obj_level(messageQueue) ⊔ obj_level(storeConfig) ⊔ obj_level(this);
}