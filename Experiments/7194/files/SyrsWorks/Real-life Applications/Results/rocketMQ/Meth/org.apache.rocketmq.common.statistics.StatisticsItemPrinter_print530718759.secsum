void org.apache.rocketmq.common.statistics.StatisticsItemPrinter:print (
  java.lang.String @prefix,
  org.apache.rocketmq.common.statistics.StatisticsItem statItem,
  java.lang.String[] suffixs) {
  guard = tt;
  ret(obj_level(@prefix)) = pc ⊔ level(statItem) ⊔ level(suffixs) ⊔ level(this) ⊔ obj_level(@prefix) ⊔ obj_level(statItem) ⊔ obj_level(suffixs) ⊔ obj_level(this);
  ret(obj_level(statItem)) = pc ⊔ level(statItem) ⊔ level(suffixs) ⊔ level(this) ⊔ obj_level(statItem) ⊔ obj_level(suffixs) ⊔ obj_level(this);
  ret(obj_level(suffixs)) = pc ⊔ level(statItem) ⊔ level(suffixs) ⊔ level(this) ⊔ obj_level(statItem) ⊔ obj_level(suffixs) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@prefix) ⊔ level(statItem) ⊔ level(suffixs) ⊔ level(this) ⊔ obj_level(@prefix) ⊔ obj_level(statItem) ⊔ obj_level(suffixs) ⊔ obj_level(this);
}