  org.apache.rocketmq.tools.admin.DefaultMQAdminExt defaultMQAdminExt) {
  guard = tt;
  ret(level()) = pc ⊔ level(defaultMQAdminExt) ⊔ level(topic) ⊔ obj_level(defaultMQAdminExt);
  ret(obj_level()) = pc ⊔ level(defaultMQAdminExt) ⊔ level(topic) ⊔ obj_level(defaultMQAdminExt);
  ret(obj_level(defaultMQAdminExt)) = pc ⊔ level(defaultMQAdminExt) ⊔ level(topic) ⊔ obj_level(defaultMQAdminExt);
