static java.lang.Class io.openmessaging.rocketmq.utils.BeanUtils:getMethodClass (
  java.lang.Class @clazz, java.lang.String methodName) {
  guard = tt;
  ret(level()) = pc ⊔ obj_level(@clazz) ⊔ obj_level(methodName);
  ret(obj_level()) = pc ⊔ obj_level(@clazz) ⊔ obj_level(methodName);
  ret(obj_level(@clazz)) = if obj_level(@clazz) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(@clazz) = ⊥ ∧ obj_level(methodName) = ⊤ then ⊤ else ⊥;
  ret(obj_level(methodName)) = if obj_level(methodName) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(@clazz) = ⊤ ∧ obj_level(methodName) = ⊥ then ⊤ else ⊥;
}