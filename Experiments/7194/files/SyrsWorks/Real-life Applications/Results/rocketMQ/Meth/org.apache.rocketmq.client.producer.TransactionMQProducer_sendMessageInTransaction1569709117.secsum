  ret(obj_level(arg)) = pc ⊔ level(arg) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(arg);
  ret(obj_level(msg)) = pc ⊔ level(arg) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(arg);
  ret(obj_level(this)) = pc ⊔ level(arg) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(arg);
