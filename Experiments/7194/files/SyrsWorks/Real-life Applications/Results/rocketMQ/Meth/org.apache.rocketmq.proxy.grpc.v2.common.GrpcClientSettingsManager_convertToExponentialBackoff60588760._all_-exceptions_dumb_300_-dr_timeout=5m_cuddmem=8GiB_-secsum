static apache.rocketmq.v2.ExponentialBackoff org.apache.rocketmq.proxy.grpc.v2.common.GrpcClientSettingsManager:convertToExponentialBackoff (
  org.apache.rocketmq.remoting.protocol.subscription.ExponentialRetryPolicy
    retryPolicy) {
  guard = tt;
  ret(level()) = level(retryPolicy) ⊔ obj_level(retryPolicy);
  ret(obj_level()) = level(retryPolicy) ⊔ obj_level(retryPolicy);
  ret(obj_level(retryPolicy)) = obj_level(retryPolicy);
}