org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.remoting.netty.ResponseFuture:waitResponse (
  long timeoutMillis) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ level(timeoutMillis) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(this) ⊔ level(timeoutMillis) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(this) ⊔ level(timeoutMillis) ⊔ obj_level(this);
}