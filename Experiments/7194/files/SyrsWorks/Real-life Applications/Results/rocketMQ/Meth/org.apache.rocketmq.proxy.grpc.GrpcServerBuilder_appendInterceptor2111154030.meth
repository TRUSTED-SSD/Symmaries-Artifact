org.apache.rocketmq.proxy.grpc.GrpcServerBuilder org.apache.rocketmq.proxy.grpc.GrpcServerBuilder:appendInterceptor(io.grpc.ServerInterceptor interceptor)
{
io.grpc.netty.shaded.io.grpc.netty.NettyServerBuilder $stack2;
  $stack2=this.serverBuilder;
 $stack2.intercept(interceptor);
 return  this;
 } 

