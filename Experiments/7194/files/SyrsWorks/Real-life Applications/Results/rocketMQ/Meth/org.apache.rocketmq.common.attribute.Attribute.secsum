org.apache.rocketmq.common.attribute.Attribute (java.lang.String name,
                                                boolean changeable) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(changeable) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
}