static byte[] org.apache.rocketmq.common.message.MessageDecoder:encodeUniquely (
  org.apache.rocketmq.common.message.MessageExt messageExt,
  boolean needCompress) {
  guard = pc ⊔ level(messageExt) ⊔ level(needCompress) ⊔ obj_level(messageExt) = ⊥;
  ret(level()) = ⊤;
  ret(obj_level()) = ⊤;
  ret(obj_level(messageExt)) = ⊤;
}