org.apache.rocketmq.common.filter.impl.Operator (java.lang.String symbol,
                                                 int priority,
                                                 boolean compareable) {
  guard = tt;
  ret(obj_level(symbol)) = pc ⊔ level(symbol) ⊔ level(this) ⊔ obj_level(symbol) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(compareable) ⊔ level(priority) ⊔ level(symbol) ⊔ level(this) ⊔ obj_level(symbol) ⊔ obj_level(this);
}