  guard = tt;
  ret(obj_level(addr)) = pc ⊔ level(addr) ⊔ level(globalWhiteAddrs) ⊔ level(this) ⊔ obj_level(addr) ⊔ obj_level(this);
  ret(obj_level(globalWhiteAddrs)) = pc ⊔ level(addr) ⊔ level(globalWhiteAddrs) ⊔ level(this) ⊔ obj_level(addr) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(addr) ⊔ level(globalWhiteAddrs) ⊔ level(this) ⊔ obj_level(addr) ⊔ obj_level(this);
