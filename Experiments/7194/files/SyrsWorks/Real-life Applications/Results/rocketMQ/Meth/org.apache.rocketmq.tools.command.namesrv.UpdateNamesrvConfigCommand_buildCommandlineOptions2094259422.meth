org.apache.commons.cli.Options org.apache.rocketmq.tools.command.namesrv.UpdateNamesrvConfigCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("k","key",1,"config key");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("v","value",1,"config value");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 return  options;
 } 

