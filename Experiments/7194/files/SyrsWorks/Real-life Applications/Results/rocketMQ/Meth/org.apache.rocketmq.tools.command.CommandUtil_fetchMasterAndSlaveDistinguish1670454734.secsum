static java.util.Map org.apache.rocketmq.tools.command.CommandUtil:fetchMasterAndSlaveDistinguish (
  org.apache.rocketmq.tools.admin.MQAdminExt adminExt,
  java.lang.String @clusterName) {
  guard = tt;
  ret(level()) = pc ⊔ level(@clusterName) ⊔ level(adminExt) ⊔ obj_level(@clusterName) ⊔ obj_level(adminExt);
  ret(obj_level()) = pc ⊔ level(@clusterName) ⊔ level(adminExt) ⊔ obj_level(@clusterName) ⊔ obj_level(adminExt);
  ret(obj_level(@clusterName)) = pc ⊔ level(@clusterName) ⊔ level(adminExt) ⊔ obj_level(@clusterName) ⊔ obj_level(adminExt);
  ret(obj_level(adminExt)) = pc ⊔ level(@clusterName) ⊔ level(adminExt) ⊔ obj_level(@clusterName) ⊔ obj_level(adminExt);
}