void org.apache.rocketmq.acl.plain.PlainAccessValidator:validate (org.apache.rocketmq.acl.AccessResource
                                                                    accessResource) {
  guard = tt;
  ret(obj_level(accessResource)) = pc ⊔ level(accessResource) ⊔ level(this) ⊔ obj_level(accessResource) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(accessResource) ⊔ level(this) ⊔ obj_level(accessResource) ⊔ obj_level(this);
}