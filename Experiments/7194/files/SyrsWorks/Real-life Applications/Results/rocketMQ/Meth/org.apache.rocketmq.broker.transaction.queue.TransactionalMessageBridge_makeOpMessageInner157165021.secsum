org.apache.rocketmq.common.message.MessageExtBrokerInner org.apache.rocketmq.broker.transaction.queue.TransactionalMessageBridge:makeOpMessageInner (
  org.apache.rocketmq.common.message.Message message,
  org.apache.rocketmq.common.message.MessageQueue messageQueue) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(message) ⊔ level(messageQueue) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(messageQueue) ⊔ obj_level(this);
  ret(obj_level(message)) = pc ⊔ level(message) ⊔ level(messageQueue) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(messageQueue) ⊔ obj_level(this);
  ret(obj_level(messageQueue)) = pc ⊔ level(message) ⊔ level(messageQueue) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(messageQueue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(message) ⊔ level(messageQueue) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(messageQueue) ⊔ obj_level(this);
}