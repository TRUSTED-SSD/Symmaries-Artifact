static java.lang.String org.apache.rocketmq.remoting.protocol.NamespaceUtil:wrapNamespace (
  java.lang.String @namespace, java.lang.String resourceWithOutNamespace) {
  guard = tt;
  ret(level()) = pc ⊔ level(@namespace) ⊔ level(resourceWithOutNamespace) ⊔ obj_level(@namespace);
  ret(obj_level()) = pc ⊔ level(@namespace) ⊔ level(resourceWithOutNamespace) ⊔ obj_level(@namespace);
  ret(obj_level(@namespace)) = pc ⊔ level(@namespace) ⊔ level(resourceWithOutNamespace) ⊔ obj_level(@namespace);
  ret(obj_level(resourceWithOutNamespace)) = pc ⊔ level(@namespace) ⊔ level(resourceWithOutNamespace) ⊔ obj_level(@namespace);
}