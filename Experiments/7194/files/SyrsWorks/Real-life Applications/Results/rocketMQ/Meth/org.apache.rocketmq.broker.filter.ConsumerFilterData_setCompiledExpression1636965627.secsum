void org.apache.rocketmq.broker.filter.ConsumerFilterData:setCompiledExpression (
  org.apache.rocketmq.filter.expression.Expression compiledExpression) {
  guard = tt;
  ret(obj_level(compiledExpression)) = pc ⊔ level(compiledExpression) ⊔ obj_level(compiledExpression);
  ret(obj_level(this)) = pc ⊔ level(compiledExpression) ⊔ obj_level(compiledExpression) ⊔ obj_level(this);
}