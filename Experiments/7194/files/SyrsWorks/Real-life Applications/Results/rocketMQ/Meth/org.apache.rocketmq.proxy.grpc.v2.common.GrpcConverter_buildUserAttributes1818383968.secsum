java.util.Map org.apache.rocketmq.proxy.grpc.v2.common.GrpcConverter:buildUserAttributes (
  org.apache.rocketmq.common.message.MessageExt messageExt) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(messageExt) ⊔ obj_level(messageExt);
  ret(obj_level(messageExt)) = pc ⊔ level(messageExt) ⊔ obj_level(messageExt);
  ret(obj_level(this)) = pc ⊔ level(messageExt) ⊔ obj_level(messageExt) ⊔ obj_level(this);
}