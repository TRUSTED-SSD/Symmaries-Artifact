boolean org.apache.rocketmq.store.ConsumeQueue:checkMultiDispatchQueue (
  org.apache.rocketmq.store.DispatchRequest dispatchRequest) {
  guard = tt;
  ret(level()) = pc ⊔ level(dispatchRequest) ⊔ level(this) ⊔ obj_level(dispatchRequest) ⊔ obj_level(this);
  ret(obj_level(dispatchRequest)) = pc ⊔ level(dispatchRequest) ⊔ level(this) ⊔ obj_level(dispatchRequest) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(dispatchRequest) ⊔ level(this) ⊔ obj_level(dispatchRequest) ⊔ obj_level(this);
}