org.apache.rocketmq.filter.expression.MQFilterException (java.lang.String
                                                           errorMessage,
                                                         java.lang.Throwable
                                                           cause) {
  guard = tt;
  ret(obj_level(cause)) = pc ⊔ level(cause) ⊔ level(errorMessage) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(errorMessage);
  ret(obj_level(errorMessage)) = pc ⊔ level(cause) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(errorMessage);
  ret(obj_level(this)) = pc ⊔ level(cause) ⊔ level(errorMessage) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(errorMessage);
}