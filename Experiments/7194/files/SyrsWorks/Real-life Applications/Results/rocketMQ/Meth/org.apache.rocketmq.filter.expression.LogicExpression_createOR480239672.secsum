static org.apache.rocketmq.filter.expression.BooleanExpression org.apache.rocketmq.filter.expression.LogicExpression:createOR (
  org.apache.rocketmq.filter.expression.BooleanExpression lvalue,
  org.apache.rocketmq.filter.expression.BooleanExpression rvalue) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(lvalue) ⊔ level(rvalue) ⊔ obj_level(lvalue);
  ret(obj_level(lvalue)) = pc ⊔ level(lvalue) ⊔ level(rvalue) ⊔ obj_level(lvalue);
  ret(obj_level(rvalue)) = pc ⊔ level(lvalue) ⊔ level(rvalue) ⊔ obj_level(lvalue);
}