org.apache.rocketmq.remoting.protocol.statictopic.TopicQueueMappingInfo (
  java.lang.String topic, int totalQueues, java.lang.String bname,
  long epoch) {
  guard = tt;
  ret(obj_level(bname)) = pc ⊔ level(this) ⊔ obj_level(bname) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(bname) ⊔ level(epoch) ⊔ level(this) ⊔ level(topic) ⊔ level(totalQueues) ⊔ obj_level(bname) ⊔ obj_level(this);
  ret(obj_level(topic)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(topic);
}