static java.lang.String org.apache.rocketmq.common.KeyBuilder:parseNormalTopic (
  java.lang.String @topic, java.lang.String @cid) {
  guard = tt;
  ret(level()) = pc ⊔ level(@cid) ⊔ level(@topic) ⊔ obj_level(@cid);
  ret(obj_level()) = pc ⊔ level(@cid) ⊔ level(@topic) ⊔ obj_level(@cid);
  ret(obj_level(@cid)) = pc ⊔ level(@cid) ⊔ level(@topic) ⊔ obj_level(@cid);
  ret(obj_level(@topic)) = pc ⊔ level(@cid) ⊔ level(@topic) ⊔ obj_level(@cid);
}