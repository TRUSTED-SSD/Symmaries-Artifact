void org.apache.rocketmq.client.consumer.store.RemoteBrokerOffsetStore:updateOffset (
  org.apache.rocketmq.common.message.MessageQueue mq, long offset,
  boolean increaseOnly) {
  guard = tt;
  ret(obj_level(mq)) = pc ⊔ level(increaseOnly) ⊔ level(mq) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(increaseOnly) ⊔ level(mq) ⊔ level(offset) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
}