boolean org.apache.rocketmq.broker.transaction.queue.TransactionalMessageServiceImpl:deletePrepareMessage (
  org.apache.rocketmq.common.message.MessageExt messageExt) {
  guard = tt;
  ret(level()) = pc ⊔ level(messageExt) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(messageExt)) = pc ⊔ level(messageExt) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageExt) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
}