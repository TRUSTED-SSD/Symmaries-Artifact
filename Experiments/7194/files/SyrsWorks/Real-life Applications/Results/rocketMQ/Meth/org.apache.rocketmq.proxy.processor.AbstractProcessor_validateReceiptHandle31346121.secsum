void org.apache.rocketmq.proxy.processor.AbstractProcessor:validateReceiptHandle (
  org.apache.rocketmq.common.consumer.ReceiptHandle handle) {
  guard = tt;
  ret(obj_level(handle)) = obj_level(handle);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ level(handle) ⊔ obj_level(handle) = ⊤ then ⊤ else ⊥;
}