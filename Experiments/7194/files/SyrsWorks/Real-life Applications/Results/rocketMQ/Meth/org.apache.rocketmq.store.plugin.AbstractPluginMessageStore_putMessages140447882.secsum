org.apache.rocketmq.store.PutMessageResult org.apache.rocketmq.store.plugin.AbstractPluginMessageStore:putMessages (
  org.apache.rocketmq.common.message.MessageExtBatch messageExtBatch) {
  guard = tt;
  ret(level()) = pc ⊔ level(messageExtBatch) ⊔ level(this) ⊔ obj_level(messageExtBatch) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(messageExtBatch) ⊔ level(this) ⊔ obj_level(messageExtBatch) ⊔ obj_level(this);
  ret(obj_level(messageExtBatch)) = obj_level(messageExtBatch);
  ret(obj_level(this)) = obj_level(this);
}