void org.apache.rocketmq.client.impl.consumer.PullAPIWrapper:updatePullFromWhichNode (
  org.apache.rocketmq.common.message.MessageQueue mq, long brokerId) {
  guard = tt;
  ret(obj_level(mq)) = pc ⊔ level(brokerId) ⊔ level(mq) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerId) ⊔ level(mq) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this);
}