static java.lang.String org.apache.rocketmq.tieredstore.container.TieredIndexFile:buildKey (
  java.lang.String @topic, java.lang.String key) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(key) ⊔ obj_level(@topic);
  ret(obj_level()) = pc ⊔ level(@topic) ⊔ level(key) ⊔ obj_level(@topic);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(key) ⊔ obj_level(@topic);
  ret(obj_level(key)) = pc ⊔ level(@topic) ⊔ obj_level(@topic);
}