boolean org.apache.rocketmq.broker.processor.PopBufferMergeService:addCk (
  org.apache.rocketmq.store.pop.PopCheckPoint point, int reviveQueueId,
  long reviveQueueOffset, long nextBeginOffset) {
  guard = tt;
  ret(level()) = pc ⊔ level(nextBeginOffset) ⊔ level(point) ⊔ level(reviveQueueId) ⊔ level(reviveQueueOffset) ⊔ level(this) ⊔ obj_level(point) ⊔ obj_level(this);
  ret(obj_level(point)) = pc ⊔ level(nextBeginOffset) ⊔ level(point) ⊔ level(reviveQueueId) ⊔ level(reviveQueueOffset) ⊔ level(this) ⊔ obj_level(point) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(nextBeginOffset) ⊔ level(point) ⊔ level(reviveQueueId) ⊔ level(reviveQueueOffset) ⊔ level(this) ⊔ obj_level(point) ⊔ obj_level(this);
}