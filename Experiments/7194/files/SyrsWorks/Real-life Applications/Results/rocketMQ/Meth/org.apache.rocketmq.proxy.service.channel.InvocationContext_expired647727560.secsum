boolean org.apache.rocketmq.proxy.service.channel.InvocationContext:expired (
  long expiredTimeSec) {
  guard = tt;
  ret(level()) = pc ⊔ level(expiredTimeSec) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ level(expiredTimeSec) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}