static org.apache.rocketmq.common.message.Message org.apache.rocketmq.client.utils.MessageUtil:createReplyMessage (
  org.apache.rocketmq.common.message.Message requestMessage, byte[] body) {
  guard = tt;
  ret(level()) = pc ⊔ level(requestMessage) ⊔ obj_level(requestMessage);
  ret(obj_level()) = pc ⊔ level(body) ⊔ level(requestMessage) ⊔ obj_level(body) ⊔ obj_level(requestMessage);
  ret(obj_level(body)) = pc ⊔ level(body) ⊔ level(requestMessage) ⊔ obj_level(body) ⊔ obj_level(requestMessage);
  ret(obj_level(requestMessage)) = pc ⊔ level(body) ⊔ level(requestMessage) ⊔ obj_level(body) ⊔ obj_level(requestMessage);
}