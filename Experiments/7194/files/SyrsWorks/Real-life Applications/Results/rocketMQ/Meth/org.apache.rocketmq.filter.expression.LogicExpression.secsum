org.apache.rocketmq.filter.expression.LogicExpression (org.apache.rocketmq.filter.expression.BooleanExpression
                                                         left,
                                                       org.apache.rocketmq.filter.expression.BooleanExpression
                                                         right) {
  guard = tt;
  ret(obj_level(left)) = pc ⊔ level(left) ⊔ level(right) ⊔ level(this) ⊔ obj_level(left);
  ret(obj_level(right)) = pc ⊔ level(left) ⊔ level(right) ⊔ level(this) ⊔ obj_level(left);
  ret(obj_level(this)) = pc ⊔ level(left) ⊔ level(right) ⊔ level(this) ⊔ obj_level(left);
}