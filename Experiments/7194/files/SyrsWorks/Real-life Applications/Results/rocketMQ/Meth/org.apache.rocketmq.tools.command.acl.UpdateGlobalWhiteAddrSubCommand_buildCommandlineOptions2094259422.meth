org.apache.commons.cli.Options org.apache.rocketmq.tools.command.acl.UpdateGlobalWhiteAddrSubCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.OptionGroup optionGroup;
  org.apache.commons.cli.Option opt;
  optionGroup=new org.apache.commons.cli.OptionGroup;
 optionGroup#org.apache.commons.cli.OptionGroup();
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("b","brokerAddr",1,"update global white address to which broker");
 optionGroup.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("c","clusterName",1,"update global white address to which cluster");
 optionGroup.addOption(opt);
 optionGroup.setRequired((boolean)1);
 options.addOptionGroup(optionGroup);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("g","globalWhiteRemoteAddresses",1,"set globalWhiteRemoteAddress list,eg: 10.10.103.*,192.168.0.*");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("p","aclFileFullPath",1,"update global white address of specified acl file,eg: /xxx/plain_test.yml");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 return  options;
 } 

