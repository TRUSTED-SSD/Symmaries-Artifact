void org.apache.rocketmq.tools.command.message.QueryMsgTraceByIdSubCommand:queryTraceByMsgId (
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt admin,
  java.lang.String traceTopic, java.lang.String msgId) {
  guard = tt;
  ret(obj_level(admin)) = pc ⊔ level(admin) ⊔ level(msgId) ⊔ level(traceTopic) ⊔ obj_level(admin) ⊔ obj_level(msgId) ⊔ obj_level(this);
  ret(obj_level(msgId)) = pc ⊔ level(admin) ⊔ level(msgId) ⊔ level(traceTopic) ⊔ obj_level(admin) ⊔ obj_level(msgId);
  ret(obj_level(this)) = pc ⊔ level(admin) ⊔ level(msgId) ⊔ level(traceTopic) ⊔ obj_level(admin) ⊔ obj_level(msgId) ⊔ obj_level(this);
  ret(obj_level(traceTopic)) = pc ⊔ level(admin) ⊔ level(msgId) ⊔ level(traceTopic) ⊔ obj_level(admin) ⊔ obj_level(msgId);
}