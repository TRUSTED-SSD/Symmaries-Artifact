org.apache.rocketmq.store.AllocateMappedFileService (org.apache.rocketmq.store.DefaultMessageStore
                                                       messageStore) {
  guard = tt;
  ret(obj_level(messageStore)) = pc ⊔ level(messageStore) ⊔ level(this) ⊔ obj_level(messageStore) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageStore) ⊔ level(this) ⊔ obj_level(messageStore) ⊔ obj_level(this);
}