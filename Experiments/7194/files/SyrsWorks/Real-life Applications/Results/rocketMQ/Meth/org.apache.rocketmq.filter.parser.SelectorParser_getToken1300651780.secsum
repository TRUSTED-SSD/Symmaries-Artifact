org.apache.rocketmq.filter.parser.Token org.apache.rocketmq.filter.parser.SelectorParser:getToken (
  int index) {
  guard = tt;
  ret(level()) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(index) ⊔ level(this) ⊔ obj_level(this);
}