void org.apache.rocketmq.filter.expression.UnaryExpression:setRight (
  org.apache.rocketmq.filter.expression.Expression expression) {
  guard = tt;
  ret(obj_level(expression)) = pc ⊔ level(expression) ⊔ obj_level(expression);
  ret(obj_level(this)) = pc ⊔ level(expression) ⊔ obj_level(expression);
}