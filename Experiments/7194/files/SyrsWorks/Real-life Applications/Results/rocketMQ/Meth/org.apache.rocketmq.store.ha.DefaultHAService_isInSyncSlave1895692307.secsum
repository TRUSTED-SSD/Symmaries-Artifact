boolean org.apache.rocketmq.store.ha.DefaultHAService:isInSyncSlave (
  long masterPutWhere, org.apache.rocketmq.store.ha.HAConnection conn) {
  guard = tt;
  ret(level()) = pc ⊔ level(conn) ⊔ level(masterPutWhere) ⊔ level(this) ⊔ obj_level(conn) ⊔ obj_level(this);
  ret(obj_level(conn)) = if obj_level(conn) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(conn) = ⊥ ∧ obj_level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(conn) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}