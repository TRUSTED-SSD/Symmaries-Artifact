org.apache.rocketmq.broker.BrokerController org.apache.rocketmq.container.BrokerContainer:getBroker (
  org.apache.rocketmq.common.BrokerIdentity brokerIdentity) {
  guard = tt;
  ret(level()) = pc ⊔ level(brokerIdentity) ⊔ level(this) ⊔ obj_level(brokerIdentity) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(brokerIdentity) ⊔ level(this) ⊔ obj_level(brokerIdentity) ⊔ obj_level(this);
  ret(obj_level(brokerIdentity)) = pc ⊔ level(brokerIdentity) ⊔ level(this) ⊔ obj_level(brokerIdentity) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerIdentity) ⊔ level(this) ⊔ obj_level(brokerIdentity) ⊔ obj_level(this);
}