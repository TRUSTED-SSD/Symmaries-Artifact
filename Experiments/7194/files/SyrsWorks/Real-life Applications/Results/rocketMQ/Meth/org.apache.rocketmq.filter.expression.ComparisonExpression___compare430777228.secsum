static int org.apache.rocketmq.filter.expression.ComparisonExpression:__compare (
  java.lang.Comparable @lv, java.lang.Comparable @rv,
  boolean convertStringExpressions) {
  guard = tt;
  ret(level()) = pc ⊔ level(@lv) ⊔ level(@rv) ⊔ level(convertStringExpressions) ⊔ obj_level(@lv);
  ret(obj_level(@lv)) = pc ⊔ level(@lv) ⊔ level(@rv) ⊔ level(convertStringExpressions) ⊔ obj_level(@lv);
  ret(obj_level(@rv)) = pc ⊔ level(@lv) ⊔ level(@rv) ⊔ level(convertStringExpressions) ⊔ obj_level(@lv);
}