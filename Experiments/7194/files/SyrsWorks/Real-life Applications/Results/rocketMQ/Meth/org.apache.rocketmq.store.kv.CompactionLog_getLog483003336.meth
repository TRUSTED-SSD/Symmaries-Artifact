org.apache.rocketmq.store.MappedFileQueue org.apache.rocketmq.store.kv.CompactionLog:getLog()
{
org.apache.rocketmq.store.kv.CompactionLog$TopicPartitionLog $stack1;
  org.apache.rocketmq.store.MappedFileQueue $stack2;
  $stack1=this.current;
 $stack2=$stack1.mappedFileQueue;
 return  $stack2;
 } 

