boolean org.apache.rocketmq.broker.transaction.queue.TransactionalMessageBridge:writeOp (
  java.lang.Integer queueId,
  org.apache.rocketmq.common.message.Message message) {
  guard = tt;
  ret(level()) = pc ⊔ level(message) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(queueId) ⊔ obj_level(this);
  ret(obj_level(message)) = pc ⊔ level(message) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(queueId) ⊔ obj_level(this);
  ret(obj_level(queueId)) = pc ⊔ level(message) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(queueId) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(message) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(queueId) ⊔ obj_level(this);
}