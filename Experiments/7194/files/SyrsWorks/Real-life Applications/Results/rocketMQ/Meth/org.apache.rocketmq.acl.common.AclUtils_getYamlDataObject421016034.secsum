static java.lang.Object org.apache.rocketmq.acl.common.AclUtils:getYamlDataObject (
  java.lang.String @path, java.lang.Class clazz) {
  guard = tt;
  ret(level()) = pc ⊔ level(@path) ⊔ level(clazz) ⊔ obj_level(@path) ⊔ obj_level(clazz);
  ret(obj_level()) = pc ⊔ level(@path) ⊔ level(clazz) ⊔ obj_level(@path) ⊔ obj_level(clazz);
  ret(obj_level(@path)) = pc ⊔ level(@path) ⊔ obj_level(@path);
  ret(obj_level(clazz)) = pc ⊔ level(@path) ⊔ obj_level(@path) ⊔ obj_level(clazz);
}