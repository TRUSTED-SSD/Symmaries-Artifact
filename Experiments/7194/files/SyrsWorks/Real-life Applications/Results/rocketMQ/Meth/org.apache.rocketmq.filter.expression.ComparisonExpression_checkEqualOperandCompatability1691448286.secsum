static void org.apache.rocketmq.filter.expression.ComparisonExpression:checkEqualOperandCompatability (
  org.apache.rocketmq.filter.expression.Expression left,
  org.apache.rocketmq.filter.expression.Expression right) {
  guard = tt;
  ret(obj_level(left)) = pc ⊔ level(left) ⊔ level(right) ⊔ obj_level(left);
  ret(obj_level(right)) = pc ⊔ level(left) ⊔ level(right) ⊔ obj_level(left);
}