org.apache.rocketmq.remoting.RemotingServer org.apache.rocketmq.remoting.netty.NettyRemotingServer:newRemotingServer (
  int port) {
  guard = tt;
  ret(level()) = pc ⊔ level(port) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(port) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(port) ⊔ level(this) ⊔ obj_level(this);
}