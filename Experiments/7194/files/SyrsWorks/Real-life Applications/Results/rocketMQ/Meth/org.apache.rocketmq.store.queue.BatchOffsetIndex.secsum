org.apache.rocketmq.store.queue.BatchOffsetIndex (org.apache.rocketmq.store.logfile.MappedFile
                                                    file,
                                                  int pos, long msgOffset,
                                                  short size,
                                                  long storeTimestamp) {
  guard = tt;
  ret(obj_level(file)) = pc ⊔ level(file) ⊔ level(msgOffset) ⊔ level(pos) ⊔ level(size) ⊔ level(storeTimestamp) ⊔ level(this) ⊔ obj_level(file) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(file) ⊔ level(msgOffset) ⊔ level(pos) ⊔ level(size) ⊔ level(storeTimestamp) ⊔ level(this) ⊔ obj_level(file) ⊔ obj_level(this);
}