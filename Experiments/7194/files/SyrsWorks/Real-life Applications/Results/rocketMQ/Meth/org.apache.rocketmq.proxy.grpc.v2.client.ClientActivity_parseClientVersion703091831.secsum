int org.apache.rocketmq.proxy.grpc.v2.client.ClientActivity:parseClientVersion (
  java.lang.String @clientVersionStr) {
  guard = tt;
  ret(level()) = pc ⊔ level(@clientVersionStr) ⊔ obj_level(@clientVersionStr);
  ret(obj_level(@clientVersionStr)) = pc ⊔ level(@clientVersionStr) ⊔ obj_level(@clientVersionStr);
  ret(obj_level(this)) = pc ⊔ level(@clientVersionStr) ⊔ obj_level(@clientVersionStr) ⊔ obj_level(this);
}