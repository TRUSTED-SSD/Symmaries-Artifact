  ret(obj_level(brokerName)) = pc ⊔ level(brokerName) ⊔ level(namesrvAddr) ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level(namesrvAddr)) = pc ⊔ level(brokerName) ⊔ level(namesrvAddr) ⊔ level(this) ⊔ obj_level(namesrvAddr) ⊔ obj_level(this);
