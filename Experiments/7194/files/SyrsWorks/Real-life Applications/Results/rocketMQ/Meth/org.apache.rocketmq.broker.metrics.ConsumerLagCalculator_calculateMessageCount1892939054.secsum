long org.apache.rocketmq.broker.metrics.ConsumerLagCalculator:calculateMessageCount (
  java.lang.String group, java.lang.String topic, int queueId, long from,
  long to) {
  guard = tt;
  ret(level()) = pc ⊔ level(from) ⊔ level(group) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(group)) = pc ⊔ level(from) ⊔ level(group) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(from) ⊔ level(group) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(topic)) = pc ⊔ level(from) ⊔ level(group) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
}