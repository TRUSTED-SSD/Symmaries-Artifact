void org.apache.rocketmq.proxy.processor.validator.DefaultTopicMessageTypeValidator:validate (
  org.apache.rocketmq.common.attribute.TopicMessageType topicMessageType,
  org.apache.rocketmq.common.attribute.TopicMessageType messageType) {
  guard = tt;
  ret(obj_level(messageType)) = pc ⊔ level(messageType) ⊔ level(topicMessageType) ⊔ obj_level(messageType);
  ret(obj_level(this)) = pc ⊔ level(messageType) ⊔ level(topicMessageType) ⊔ obj_level(messageType) ⊔ obj_level(this);
  ret(obj_level(topicMessageType)) = pc ⊔ level(messageType) ⊔ level(topicMessageType) ⊔ obj_level(messageType);
}