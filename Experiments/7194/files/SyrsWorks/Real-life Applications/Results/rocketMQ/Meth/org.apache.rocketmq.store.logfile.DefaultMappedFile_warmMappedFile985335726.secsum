void org.apache.rocketmq.store.logfile.DefaultMappedFile:warmMappedFile (
  org.apache.rocketmq.store.config.FlushDiskType type, int pages) {
  guard = tt;
  ret(obj_level(this)) = pc ⊔ level(pages) ⊔ level(this) ⊔ level(type) ⊔ obj_level(this);
  ret(obj_level(type)) = pc ⊔ level(pages) ⊔ level(this) ⊔ level(type) ⊔ obj_level(this) ⊔ obj_level(type);
}