void org.apache.rocketmq.broker.BrokerController:registerServerRPCHook(org.apache.rocketmq.remoting.RPCHook rpcHook)
{
org.apache.rocketmq.remoting.RemotingServer $stack2;
  $stack2 = this.getRemotingServer();
 $stack2.registerRPCHook(rpcHook);
 $stack2=this.fastRemotingServer;
 $stack2.registerRPCHook(rpcHook);
 return;
 } 

