void org.apache.rocketmq.broker.BrokerController:registerIncrementBrokerData (
  org.apache.rocketmq.common.TopicConfig topicConfig,
  org.apache.rocketmq.remoting.protocol.DataVersion dataVersion) {
  guard = tt;
  ret(obj_level(dataVersion)) = pc ⊔ level(topicConfig) ⊔ obj_level(dataVersion) ⊔ obj_level(topicConfig);
  ret(obj_level(this)) = pc ⊔ level(topicConfig) ⊔ obj_level(this) ⊔ obj_level(topicConfig);
  ret(obj_level(topicConfig)) = pc ⊔ level(topicConfig) ⊔ obj_level(topicConfig);
}