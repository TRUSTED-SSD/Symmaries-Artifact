void org.apache.rocketmq.common.statistics.StatisticsItem:incItems (long[]
                                                                    itemIncs) {
  guard = tt;
  ret(obj_level(itemIncs)) = pc ⊔ level(itemIncs) ⊔ level(this) ⊔ obj_level(itemIncs) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(itemIncs) ⊔ level(this) ⊔ obj_level(itemIncs) ⊔ obj_level(this);
}