static void org.apache.rocketmq.common.message.MessageAccessor:setOriginMessageId (
  org.apache.rocketmq.common.message.Message msg,
  java.lang.String originMessageId) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(originMessageId) ⊔ obj_level(msg);
  ret(obj_level(originMessageId)) = pc ⊔ level(msg) ⊔ level(originMessageId) ⊔ obj_level(msg) ⊔ obj_level(originMessageId);
}