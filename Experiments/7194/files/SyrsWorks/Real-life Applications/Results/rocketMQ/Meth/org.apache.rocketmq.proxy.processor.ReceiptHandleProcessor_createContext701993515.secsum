org.apache.rocketmq.proxy.common.ProxyContext org.apache.rocketmq.proxy.processor.ReceiptHandleProcessor:createContext (
  java.lang.String @actionName) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(@actionName) ⊔ obj_level(@actionName) ⊔ obj_level(this);
  ret(obj_level(@actionName)) = pc ⊔ level(@actionName) ⊔ obj_level(@actionName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@actionName) ⊔ obj_level(@actionName) ⊔ obj_level(this);
}