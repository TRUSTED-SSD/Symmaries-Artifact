void org.apache.rocketmq.client.impl.consumer.DefaultLitePullConsumerImpl:commit (
  java.util.Map messageQueues, boolean persist) {
  guard = pc ⊔ level(messageQueues) ⊔ level(persist) ⊔ level(this) ⊔ obj_level(messageQueues) ⊔ obj_level(this) = ⊥;
  ret(obj_level(messageQueues)) = ⊥;
  ret(obj_level(this)) = ⊥;
}