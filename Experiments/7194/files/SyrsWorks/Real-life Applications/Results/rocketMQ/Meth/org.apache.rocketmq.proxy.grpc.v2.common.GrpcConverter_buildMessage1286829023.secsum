apache.rocketmq.v2.Message org.apache.rocketmq.proxy.grpc.v2.common.GrpcConverter:buildMessage (
  org.apache.rocketmq.common.message.MessageExt messageExt) {
  guard = tt;
  ret(level()) = pc ⊔ level(messageExt) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(messageExt) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(messageExt)) = pc ⊔ level(messageExt) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(messageExt) ⊔ obj_level(messageExt) ⊔ obj_level(this);
}