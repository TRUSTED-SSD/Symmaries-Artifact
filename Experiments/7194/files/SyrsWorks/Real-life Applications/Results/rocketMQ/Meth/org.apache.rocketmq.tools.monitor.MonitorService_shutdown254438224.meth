void org.apache.rocketmq.tools.monitor.MonitorService:shutdown()
{
org.apache.rocketmq.client.consumer.DefaultMQPullConsumer $stack1;
  org.apache.rocketmq.tools.admin.DefaultMQAdminExt $stack2;
  org.apache.rocketmq.client.consumer.DefaultMQPushConsumer $stack3;
  $stack1=this.defaultMQPullConsumer;
 $stack1.shutdown();
 $stack2=this.defaultMQAdminExt;
 $stack2.shutdown();
 $stack3=this.defaultMQPushConsumer;
 $stack3.shutdown();
 return;
 } 

