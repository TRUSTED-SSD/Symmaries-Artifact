org.apache.commons.cli.Options org.apache.rocketmq.tools.command.consumer.ConsumerStatusSubCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("g","consumerGroup",1,"consumer group name");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("i","clientId",1,"The consumer\'s client id");
 opt.setRequired((boolean)0);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("b","brokerAddr",1,"broker address");
 opt.setRequired((boolean)0);
 options.addOption(opt);
