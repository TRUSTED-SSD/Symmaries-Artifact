org.apache.commons.cli.Options org.apache.rocketmq.tools.command.controller.ReElectMasterSubCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("a","controllerAddress",1,"The address of controller");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("b","brokerAddress",1,"The address of the broker which requires to become master");
 opt.setRequired((boolean)1);
 options.addOption(opt);
 opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("n","brokerName",1,"The broker name of the replicas that require to be manipulated");
 opt.setRequired((boolean)1);
