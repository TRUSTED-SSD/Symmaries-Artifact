static java.lang.String org.apache.rocketmq.remoting.protocol.header.ExtraInfoUtil:getRealTopic (
  java.lang.String[] extraInfoStrs, java.lang.String @topic,
  java.lang.String cid) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(extraInfoStrs) ⊔ obj_level(@topic) ⊔ obj_level(extraInfoStrs);
  ret(obj_level()) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(extraInfoStrs) ⊔ obj_level(@topic) ⊔ obj_level(extraInfoStrs);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(extraInfoStrs) ⊔ obj_level(@topic) ⊔ obj_level(extraInfoStrs);
  ret(obj_level(cid)) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(extraInfoStrs) ⊔ obj_level(@topic) ⊔ obj_level(extraInfoStrs);
  ret(obj_level(extraInfoStrs)) = pc ⊔ level(@topic) ⊔ level(cid) ⊔ level(extraInfoStrs) ⊔ obj_level(@topic) ⊔ obj_level(extraInfoStrs);
}