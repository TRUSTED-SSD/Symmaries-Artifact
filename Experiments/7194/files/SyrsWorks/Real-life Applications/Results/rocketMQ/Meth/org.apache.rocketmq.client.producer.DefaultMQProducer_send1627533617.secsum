org.apache.rocketmq.client.producer.SendResult org.apache.rocketmq.client.producer.DefaultMQProducer:send (
  org.apache.rocketmq.common.message.Message msg) {
  guard = tt;
  ret(level()) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ level(this) ⊔ obj_level(msg) ⊔ obj_level(this);
}