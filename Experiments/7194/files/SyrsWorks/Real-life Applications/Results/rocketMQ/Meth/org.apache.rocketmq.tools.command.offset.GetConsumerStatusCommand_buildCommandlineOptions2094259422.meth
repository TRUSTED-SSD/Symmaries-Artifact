org.apache.commons.cli.Options org.apache.rocketmq.tools.command.offset.GetConsumerStatusCommand:buildCommandlineOptions(org.apache.commons.cli.Options options)
{
org.apache.commons.cli.Option opt;
  opt=new org.apache.commons.cli.Option;
 opt#org.apache.commons.cli.Option("g","group",1,"set the consumer group");
 opt.setRequired((boolean)1);
