org.apache.rocketmq.broker.metrics.ProducerAttr (org.apache.rocketmq.remoting.protocol.LanguageCode
                                                   language,
                                                 int version) {
  guard = tt;
  ret(obj_level(language)) = pc ⊔ level(this) ⊔ obj_level(language) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(language) ⊔ level(this) ⊔ level(version) ⊔ obj_level(language) ⊔ obj_level(this);
}