void org.apache.rocketmq.store.ha.autoswitch.AutoSwitchHAConnection:changeTransferEpochToNext (
  org.apache.rocketmq.remoting.protocol.EpochEntry entry) {
  guard = tt;
  ret(obj_level(entry)) = pc ⊔ level(entry) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(entry) ⊔ level(this) ⊔ obj_level(entry) ⊔ obj_level(this);
}