void org.apache.rocketmq.client.consumer.MQPullConsumerScheduleService:setDefaultMQPullConsumer (
  org.apache.rocketmq.client.consumer.DefaultMQPullConsumer
    defaultMQPullConsumer) {
  guard = tt;
  ret(obj_level(defaultMQPullConsumer)) = pc ⊔ level(defaultMQPullConsumer) ⊔ obj_level(defaultMQPullConsumer);
  ret(obj_level(this)) = pc ⊔ level(defaultMQPullConsumer) ⊔ obj_level(defaultMQPullConsumer) ⊔ obj_level(this);
}