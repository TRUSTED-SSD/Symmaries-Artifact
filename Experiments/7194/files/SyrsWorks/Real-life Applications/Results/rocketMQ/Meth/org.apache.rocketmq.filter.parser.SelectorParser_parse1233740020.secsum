static org.apache.rocketmq.filter.expression.BooleanExpression org.apache.rocketmq.filter.parser.SelectorParser:parse (
  java.lang.String sql) {
  guard = tt;
  ret(level()) = pc ⊔ level(sql) ⊔ obj_level(sql);
  ret(obj_level()) = pc ⊔ level(sql) ⊔ obj_level(sql);
  ret(obj_level(sql)) = pc ⊔ level(sql) ⊔ obj_level(sql);
}