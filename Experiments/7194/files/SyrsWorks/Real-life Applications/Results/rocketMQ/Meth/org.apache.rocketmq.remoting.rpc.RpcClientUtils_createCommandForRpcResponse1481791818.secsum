static org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.remoting.rpc.RpcClientUtils:createCommandForRpcResponse (
  org.apache.rocketmq.remoting.rpc.RpcResponse rpcResponse) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(rpcResponse) ⊔ obj_level(rpcResponse);
  ret(obj_level(rpcResponse)) = pc ⊔ level(rpcResponse) ⊔ obj_level(rpcResponse);
}