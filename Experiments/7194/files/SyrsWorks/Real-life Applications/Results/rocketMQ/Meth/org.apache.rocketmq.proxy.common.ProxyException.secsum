org.apache.rocketmq.proxy.common.ProxyException (org.apache.rocketmq.proxy.common.ProxyExceptionCode
                                                   code,
                                                 java.lang.String message,
                                                 java.lang.Throwable cause) {
  guard = tt;
  ret(obj_level(cause)) = pc ⊔ level(cause) ⊔ level(code) ⊔ level(message) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(code) ⊔ obj_level(message);
  ret(obj_level(code)) = pc ⊔ level(cause) ⊔ level(message) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(code) ⊔ obj_level(message);
  ret(obj_level(message)) = pc ⊔ level(cause) ⊔ level(message) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(message);
  ret(obj_level(this)) = pc ⊔ level(cause) ⊔ level(code) ⊔ level(message) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(code) ⊔ obj_level(message);
}