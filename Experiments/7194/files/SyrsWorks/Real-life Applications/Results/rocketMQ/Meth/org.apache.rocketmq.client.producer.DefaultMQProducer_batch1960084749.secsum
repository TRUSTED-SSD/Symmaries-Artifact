  guard = tt;
  ret(level()) = pc ⊔ level(msgs) ⊔ obj_level(msgs);
  ret(obj_level()) = pc ⊔ level(msgs) ⊔ level(this) ⊔ obj_level(msgs) ⊔ obj_level(this);
  ret(obj_level(msgs)) = pc ⊔ level(msgs) ⊔ level(this) ⊔ obj_level(msgs) ⊔ obj_level(this);
