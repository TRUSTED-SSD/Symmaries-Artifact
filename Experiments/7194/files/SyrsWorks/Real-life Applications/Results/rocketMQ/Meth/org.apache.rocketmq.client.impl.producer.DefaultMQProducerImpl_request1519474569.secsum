void org.apache.rocketmq.client.impl.producer.DefaultMQProducerImpl:request (
  org.apache.rocketmq.common.message.Message msg,
  org.apache.rocketmq.client.producer.RequestCallback requestCallback,
  long timeout) {
  guard = tt;
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(requestCallback) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(msg) ⊔ obj_level(requestCallback) ⊔ obj_level(this);
  ret(obj_level(requestCallback)) = pc ⊔ level(msg) ⊔ level(requestCallback) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(msg) ⊔ obj_level(requestCallback) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ level(requestCallback) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(msg) ⊔ obj_level(requestCallback) ⊔ obj_level(this);
}