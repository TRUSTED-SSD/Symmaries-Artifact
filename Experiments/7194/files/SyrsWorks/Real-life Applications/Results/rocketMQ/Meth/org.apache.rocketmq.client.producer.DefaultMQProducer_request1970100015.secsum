org.apache.rocketmq.common.message.Message org.apache.rocketmq.client.producer.DefaultMQProducer:request (
  org.apache.rocketmq.common.message.Message @msg, long timeout) {
  guard = tt;
  ret(level()) = pc ⊔ level(@msg) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(@msg) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@msg) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(@msg) ⊔ obj_level(this);
  ret(obj_level(@msg)) = pc ⊔ level(@msg) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(@msg) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@msg) ⊔ level(this) ⊔ level(timeout) ⊔ obj_level(@msg) ⊔ obj_level(this);
}