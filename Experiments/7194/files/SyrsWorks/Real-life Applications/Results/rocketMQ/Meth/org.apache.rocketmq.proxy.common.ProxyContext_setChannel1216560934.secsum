org.apache.rocketmq.proxy.common.ProxyContext org.apache.rocketmq.proxy.common.ProxyContext:setChannel (
  io.netty.channel.Channel channel) {
  guard = tt;
  ret(level()) = pc ⊔ level(this);
  ret(obj_level()) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
  ret(obj_level(channel)) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel);
  ret(obj_level(this)) = pc ⊔ level(channel) ⊔ level(this) ⊔ obj_level(channel) ⊔ obj_level(this);
}