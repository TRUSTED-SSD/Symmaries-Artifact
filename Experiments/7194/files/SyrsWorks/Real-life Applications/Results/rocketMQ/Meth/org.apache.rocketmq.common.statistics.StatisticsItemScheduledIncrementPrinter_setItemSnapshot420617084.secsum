void org.apache.rocketmq.common.statistics.StatisticsItemScheduledIncrementPrinter:setItemSnapshot (
  java.util.concurrent.ConcurrentHashMap @snapshots,
  org.apache.rocketmq.common.statistics.StatisticsItem item) {
  guard = tt;
  ret(obj_level(@snapshots)) = pc ⊔ level(@snapshots) ⊔ level(item) ⊔ obj_level(@snapshots) ⊔ obj_level(item);
  ret(obj_level(item)) = pc ⊔ level(@snapshots) ⊔ level(item) ⊔ obj_level(@snapshots) ⊔ obj_level(item);
  ret(obj_level(this)) = pc ⊔ level(@snapshots) ⊔ level(item) ⊔ obj_level(@snapshots) ⊔ obj_level(item) ⊔ obj_level(this);
}