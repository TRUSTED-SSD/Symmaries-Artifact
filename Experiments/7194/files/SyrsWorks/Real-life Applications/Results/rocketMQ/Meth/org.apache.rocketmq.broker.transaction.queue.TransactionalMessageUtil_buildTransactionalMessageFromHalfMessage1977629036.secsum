static org.apache.rocketmq.common.message.MessageExtBrokerInner org.apache.rocketmq.broker.transaction.queue.TransactionalMessageUtil:buildTransactionalMessageFromHalfMessage (
  org.apache.rocketmq.common.message.MessageExt msgExt) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(msgExt) ⊔ obj_level(msgExt);
  ret(obj_level(msgExt)) = pc ⊔ level(msgExt) ⊔ obj_level(msgExt);
}