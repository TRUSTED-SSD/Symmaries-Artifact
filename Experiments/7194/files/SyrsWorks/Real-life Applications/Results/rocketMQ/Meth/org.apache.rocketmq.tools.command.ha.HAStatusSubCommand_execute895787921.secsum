void org.apache.rocketmq.tools.command.ha.HAStatusSubCommand:execute (
  org.apache.commons.cli.CommandLine commandLine,
  org.apache.commons.cli.Options options,
  org.apache.rocketmq.remoting.RPCHook rpcHook) {
  guard = pc ⊔ level(commandLine) ⊔ level(options) ⊔ level(rpcHook) ⊔ obj_level(commandLine) ⊔ obj_level(options) ⊔ obj_level(rpcHook) ⊔ obj_level(this) = ⊥;
  ret(obj_level(commandLine)) = ⊥;
  ret(obj_level(options)) = ⊥;
  ret(obj_level(rpcHook)) = ⊥;
  ret(obj_level(this)) = ⊥;
}