org.apache.rocketmq.client.exception.MQBrokerException (int responseCode,
                                                        java.lang.String
                                                          errorMessage,
                                                        java.lang.String
                                                          brokerAddr) {
  guard = tt;
  ret(obj_level(brokerAddr)) = pc ⊔ level(brokerAddr) ⊔ level(errorMessage) ⊔ level(responseCode) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(errorMessage)) = pc ⊔ level(brokerAddr) ⊔ level(errorMessage) ⊔ level(responseCode) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerAddr) ⊔ level(errorMessage) ⊔ level(responseCode) ⊔ level(this) ⊔ obj_level(brokerAddr) ⊔ obj_level(this);
}