long org.apache.rocketmq.store.DefaultMessageStore:estimateMessageCount (
  java.lang.String topic, int queueId, long from, long to,
  org.apache.rocketmq.store.MessageFilter filter) {
  guard = tt;
  ret(level()) = pc ⊔ level(filter) ⊔ level(from) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(filter) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(filter)) = pc ⊔ level(filter) ⊔ level(from) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(filter) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(this)) = pc ⊔ level(filter) ⊔ level(from) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(filter) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(topic)) = pc ⊔ level(filter) ⊔ level(from) ⊔ level(queueId) ⊔ level(this) ⊔ level(to) ⊔ level(topic) ⊔ obj_level(this) ⊔ obj_level(topic);
}