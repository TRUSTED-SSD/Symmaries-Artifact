org.apache.rocketmq.proxy.grpc.v2.common.GrpcProxyException (apache.rocketmq.v2.Code
                                                               code,
                                                             java.lang.String
                                                               message) {
  guard = tt;
  ret(obj_level(code)) = pc ⊔ level(message) ⊔ level(this) ⊔ obj_level(code) ⊔ obj_level(message) ⊔ obj_level(this);
  ret(obj_level(message)) = pc ⊔ level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(code) ⊔ level(message) ⊔ level(this) ⊔ obj_level(code) ⊔ obj_level(message) ⊔ obj_level(this);
}