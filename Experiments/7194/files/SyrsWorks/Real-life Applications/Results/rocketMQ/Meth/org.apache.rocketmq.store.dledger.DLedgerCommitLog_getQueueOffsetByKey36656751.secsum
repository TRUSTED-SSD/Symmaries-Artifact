long org.apache.rocketmq.store.dledger.DLedgerCommitLog:getQueueOffsetByKey (
  org.apache.rocketmq.common.message.MessageExtBrokerInner msg, int tranType) {
  guard = tt;
  ret(level()) = pc ⊔ level(msg) ⊔ level(tranType) ⊔ obj_level(msg);
  ret(obj_level(msg)) = pc ⊔ level(msg) ⊔ level(tranType) ⊔ obj_level(msg);
  ret(obj_level(this)) = pc ⊔ level(msg) ⊔ level(tranType) ⊔ obj_level(msg) ⊔ obj_level(this);
}