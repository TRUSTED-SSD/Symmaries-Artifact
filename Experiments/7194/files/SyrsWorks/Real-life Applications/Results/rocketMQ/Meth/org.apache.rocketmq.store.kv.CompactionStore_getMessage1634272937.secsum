org.apache.rocketmq.store.GetMessageResult org.apache.rocketmq.store.kv.CompactionStore:getMessage (
  java.lang.String group, java.lang.String topic, int queueId, long offset,
  int maxMsgNums, int maxTotalMsgSize) {
  guard = tt;
  ret(level()) = pc ⊔ level(group) ⊔ level(maxMsgNums) ⊔ level(maxTotalMsgSize) ⊔ level(offset) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(group) ⊔ level(maxMsgNums) ⊔ level(maxTotalMsgSize) ⊔ level(offset) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(group)) = pc ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(group) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(this) ⊔ obj_level(topic);
  ret(obj_level(topic)) = pc ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(this) ⊔ obj_level(topic);
}