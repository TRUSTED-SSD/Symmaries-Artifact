org.apache.rocketmq.tools.command.SubCommandException (java.lang.String msg,
                                                       java.lang.Throwable
                                                         cause) {
  guard = tt;
  ret(obj_level(cause)) = pc ⊔ level(cause) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(msg);
  ret(obj_level(msg)) = obj_level(msg);
  ret(obj_level(this)) = pc ⊔ level(cause) ⊔ level(msg) ⊔ level(this) ⊔ obj_level(cause) ⊔ obj_level(msg);
}