void org.apache.rocketmq.client.hook.SendMessageContext:setProducer (
  org.apache.rocketmq.client.impl.producer.DefaultMQProducerImpl producer) {
  guard = tt;
  ret(obj_level(producer)) = pc ⊔ level(producer) ⊔ obj_level(producer);
  ret(obj_level(this)) = pc ⊔ level(producer) ⊔ obj_level(producer) ⊔ obj_level(this);
}