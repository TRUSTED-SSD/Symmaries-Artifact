org.apache.rocketmq.remoting.protocol.RemotingCommand org.apache.rocketmq.broker.processor.QueryMessageProcessor:processRequest (
  io.netty.channel.ChannelHandlerContext ctx,
  org.apache.rocketmq.remoting.protocol.RemotingCommand @request) {
  guard = tt;
  ret(level()) = pc ⊔ level(@request) ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(@request) ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level(@request)) = if obj_level(@request) = ⊤ ∨ pc ≠ ⊤ ∧ level(@request) = ⊤ ∧ obj_level(@request) = ⊥ then ⊤ else ⊥;
  ret(obj_level(ctx)) = obj_level(ctx);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ level(@request) ⊔ obj_level(@request) = ⊤ then ⊤ else ⊥;
}