boolean org.apache.rocketmq.filter.expression.UnaryInExpression:matches (
  org.apache.rocketmq.filter.expression.EvaluationContext context) {
  guard = tt;
  ret(level()) = pc ⊔ level(context) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(this);
  ret(obj_level(context)) = pc ⊔ level(context) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(context) ⊔ level(this) ⊔ obj_level(context) ⊔ obj_level(this);
}