org.apache.rocketmq.store.ConsumeQueueExt (java.lang.String @topic,
                                           int queueId,
                                           java.lang.String @storePath,
                                           int mappedFileSize,
                                           int bitMapLength) {
  guard = tt;
  ret(obj_level(@storePath)) = pc ⊔ level(@storePath) ⊔ level(@topic) ⊔ level(mappedFileSize) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@storePath) ⊔ obj_level(this);
  ret(obj_level(@topic)) = pc ⊔ level(@storePath) ⊔ level(@topic) ⊔ level(mappedFileSize) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@storePath) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@storePath) ⊔ level(@topic) ⊔ level(bitMapLength) ⊔ level(mappedFileSize) ⊔ level(queueId) ⊔ level(this) ⊔ obj_level(@storePath) ⊔ obj_level(this);
}