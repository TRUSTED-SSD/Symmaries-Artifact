org.apache.rocketmq.proxy.service.route.LocalTopicRouteService (org.apache.rocketmq.broker.BrokerController
                                                                  @brokerController,
                                                                org.apache.rocketmq.proxy.service.mqclient.MQClientAPIFactory
                                                                  mqClientAPIFactory) {
  guard = tt;
  ret(obj_level(@brokerController)) = pc ⊔ level(@brokerController) ⊔ level(mqClientAPIFactory) ⊔ level(this) ⊔ obj_level(@brokerController) ⊔ obj_level(mqClientAPIFactory) ⊔ obj_level(this);
  ret(obj_level(mqClientAPIFactory)) = pc ⊔ level(@brokerController) ⊔ level(mqClientAPIFactory) ⊔ level(this) ⊔ obj_level(@brokerController) ⊔ obj_level(mqClientAPIFactory) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@brokerController) ⊔ level(mqClientAPIFactory) ⊔ level(this) ⊔ obj_level(@brokerController) ⊔ obj_level(mqClientAPIFactory) ⊔ obj_level(this);
}