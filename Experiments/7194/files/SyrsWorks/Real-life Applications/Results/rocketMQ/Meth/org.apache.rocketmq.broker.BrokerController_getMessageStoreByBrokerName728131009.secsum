org.apache.rocketmq.store.MessageStore org.apache.rocketmq.broker.BrokerController:getMessageStoreByBrokerName (
  java.lang.String brokerName) {
  guard = tt;
  ret(level()) = pc ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level(brokerName)) = if obj_level(brokerName) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(brokerName) = ⊥ ∧ obj_level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(brokerName) = ⊤ ∧ obj_level(this) = ⊥ then ⊤ else ⊥;
}