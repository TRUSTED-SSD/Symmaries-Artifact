static org.apache.rocketmq.store.FileQueueSnapshot org.apache.rocketmq.store.StoreUtil:getFileQueueSnapshot (
  org.apache.rocketmq.store.MappedFileQueue mappedFileQueue) {
  guard = tt;
  ret(level()) = pc ⊔ level(mappedFileQueue) ⊔ obj_level(mappedFileQueue);
  ret(obj_level()) = pc ⊔ level(mappedFileQueue) ⊔ obj_level(mappedFileQueue);
  ret(obj_level(mappedFileQueue)) = obj_level(mappedFileQueue);
}