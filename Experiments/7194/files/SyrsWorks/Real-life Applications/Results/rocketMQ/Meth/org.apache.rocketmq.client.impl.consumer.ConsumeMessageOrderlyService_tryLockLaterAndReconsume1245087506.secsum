void org.apache.rocketmq.client.impl.consumer.ConsumeMessageOrderlyService:tryLockLaterAndReconsume (
  org.apache.rocketmq.common.message.MessageQueue mq,
  org.apache.rocketmq.client.impl.consumer.ProcessQueue processQueue,
  long delayMills) {
  guard = tt;
  ret(obj_level(mq)) = pc ⊔ level(delayMills) ⊔ level(mq) ⊔ level(processQueue) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(processQueue) ⊔ obj_level(this);
  ret(obj_level(processQueue)) = pc ⊔ level(delayMills) ⊔ level(mq) ⊔ level(processQueue) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(processQueue) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(delayMills) ⊔ level(mq) ⊔ level(processQueue) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(processQueue) ⊔ obj_level(this);
}