io.openmessaging.producer.SendResult io.openmessaging.rocketmq.producer.ProducerImpl:send (
  io.openmessaging.Message message) {
  guard = tt;
  ret(level()) = pc ⊔ level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(message) ⊔ level(this) ⊔ obj_level(message) ⊔ obj_level(this);
  ret(obj_level(message)) = obj_level(message);
  ret(obj_level(this)) = obj_level(this);
}