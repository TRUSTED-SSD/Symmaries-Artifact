  ret(level()) = pc ⊔ level(bufferTotal) ⊔ level(isInMem) ⊔ level(maxMsgNums) ⊔ level(maxMsgSize) ⊔ level(messageTotal) ⊔ level(sizePy) ⊔ level(this) ⊔ level(unitBatchNum) ⊔ obj_level(this);
  ret(obj_level(this)) = obj_level(this);
}