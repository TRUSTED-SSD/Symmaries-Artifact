org.apache.rocketmq.common.attribute.LongRangeAttribute (java.lang.String
                                                           name,
                                                         boolean changeable,
                                                         long min, long max,
                                                         long defaultValue) {
  guard = tt;
  ret(obj_level(name)) = pc ⊔ level(changeable) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(changeable) ⊔ level(defaultValue) ⊔ level(max) ⊔ level(min) ⊔ level(name) ⊔ level(this) ⊔ obj_level(name) ⊔ obj_level(this);
}