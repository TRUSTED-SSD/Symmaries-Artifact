static java.lang.String org.apache.rocketmq.remoting.protocol.header.ExtraInfoUtil:buildExtraInfo (
  long ckQueueOffset, long popTime, long invisibleTime, int reviveQid,
  java.lang.String @topic, java.lang.String brokerName, int queueId) {
  guard = tt;
  ret(level()) = pc ⊔ level(@topic) ⊔ level(brokerName) ⊔ level(ckQueueOffset) ⊔ level(invisibleTime) ⊔ level(popTime) ⊔ level(queueId) ⊔ level(reviveQid) ⊔ obj_level(@topic);
  ret(obj_level()) = pc ⊔ level(@topic) ⊔ level(brokerName) ⊔ level(ckQueueOffset) ⊔ level(invisibleTime) ⊔ level(popTime) ⊔ level(queueId) ⊔ level(reviveQid) ⊔ obj_level(@topic);
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(brokerName) ⊔ level(ckQueueOffset) ⊔ level(invisibleTime) ⊔ level(popTime) ⊔ level(queueId) ⊔ level(reviveQid) ⊔ obj_level(@topic);
  ret(obj_level(brokerName)) = pc ⊔ level(@topic) ⊔ level(brokerName) ⊔ level(ckQueueOffset) ⊔ level(invisibleTime) ⊔ level(popTime) ⊔ level(queueId) ⊔ level(reviveQid) ⊔ obj_level(@topic);
}