void org.apache.rocketmq.client.consumer.DefaultMQPushConsumer:subscribe (
  java.lang.String @topic, java.lang.String subExpression) {
  guard = tt;
  ret(obj_level(@topic)) = pc ⊔ level(@topic) ⊔ level(subExpression) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(subExpression)) = pc ⊔ level(@topic) ⊔ level(subExpression) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@topic) ⊔ level(subExpression) ⊔ level(this) ⊔ obj_level(@topic) ⊔ obj_level(this);
}