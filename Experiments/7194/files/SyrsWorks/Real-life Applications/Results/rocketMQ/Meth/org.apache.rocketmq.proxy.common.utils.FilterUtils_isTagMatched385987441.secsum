static boolean org.apache.rocketmq.proxy.common.utils.FilterUtils:isTagMatched (
  java.util.Set tagsSet, java.lang.String tags) {
  guard = tt;
  ret(level()) = pc ⊔ level(tags) ⊔ level(tagsSet) ⊔ obj_level(tags) ⊔ obj_level(tagsSet);
  ret(obj_level(tags)) = obj_level(tags);
  ret(obj_level(tagsSet)) = if obj_level(tagsSet) = ⊤ ∨ pc ≠ ⊤ ∧ (if level(tags) = ⊤ then obj_level(tags) = ⊤ ∧ obj_level(tagsSet) = ⊥ else level(tags) = ⊥ ∧ obj_level(tagsSet) = ⊥ ∧ level(tagsSet) ⊓ obj_level(tags) = ⊤) then ⊤ else ⊥;
}