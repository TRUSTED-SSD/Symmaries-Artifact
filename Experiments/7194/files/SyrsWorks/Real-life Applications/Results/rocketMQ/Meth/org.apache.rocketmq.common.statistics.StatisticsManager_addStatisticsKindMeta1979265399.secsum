void org.apache.rocketmq.common.statistics.StatisticsManager:addStatisticsKindMeta (
  org.apache.rocketmq.common.statistics.StatisticsKindMeta kindMeta) {
  guard = tt;
  ret(obj_level(kindMeta)) = pc ⊔ level(kindMeta) ⊔ level(this) ⊔ obj_level(kindMeta) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(kindMeta) ⊔ level(this) ⊔ obj_level(kindMeta) ⊔ obj_level(this);
}