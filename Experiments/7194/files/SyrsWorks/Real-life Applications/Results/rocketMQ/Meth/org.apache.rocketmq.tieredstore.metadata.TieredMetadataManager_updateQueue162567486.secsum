void org.apache.rocketmq.tieredstore.metadata.TieredMetadataManager:updateQueue (
  org.apache.rocketmq.tieredstore.metadata.QueueMetadata metadata) {
  guard = tt;
  ret(obj_level(metadata)) = pc ⊔ level(metadata) ⊔ level(this) ⊔ obj_level(metadata) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(metadata) ⊔ level(this) ⊔ obj_level(metadata) ⊔ obj_level(this);
}