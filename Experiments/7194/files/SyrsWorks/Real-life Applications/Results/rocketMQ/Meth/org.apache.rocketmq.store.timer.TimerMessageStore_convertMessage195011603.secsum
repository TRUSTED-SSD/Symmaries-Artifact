org.apache.rocketmq.common.message.MessageExtBrokerInner org.apache.rocketmq.store.timer.TimerMessageStore:convertMessage (
  org.apache.rocketmq.common.message.MessageExt msgExt, boolean needRoll) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(msgExt) ⊔ level(needRoll) ⊔ obj_level(msgExt);
  ret(obj_level(msgExt)) = pc ⊔ level(msgExt) ⊔ level(needRoll) ⊔ obj_level(msgExt);
  ret(obj_level(this)) = pc ⊔ level(msgExt) ⊔ level(needRoll) ⊔ obj_level(msgExt) ⊔ obj_level(this);
}