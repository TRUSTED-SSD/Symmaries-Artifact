org.apache.rocketmq.store.SelectMappedBufferResult org.apache.rocketmq.store.ConsumeQueue:getIndexBuffer (
  long startIndex) {
  guard = tt;
  ret(level()) = pc ⊔ level(startIndex) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(startIndex) ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = if obj_level(this) = ⊤ ∨ pc ≠ ⊤ ∧ obj_level(this) = ⊥ ∧ level(startIndex) ⊔ level(this) = ⊤ then ⊤ else ⊥;
}