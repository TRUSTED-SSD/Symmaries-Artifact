static org.apache.rocketmq.filter.parser.Token org.apache.rocketmq.filter.parser.Token:newToken (
  int ofKind, java.lang.String image) {
  guard = tt;
  ret(level()) = pc;
  ret(obj_level()) = pc ⊔ level(image) ⊔ level(ofKind) ⊔ obj_level(image);
  ret(obj_level(image)) = pc ⊔ level(image) ⊔ level(ofKind) ⊔ obj_level(image);
}