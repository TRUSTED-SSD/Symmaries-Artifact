void org.apache.rocketmq.tools.command.message.ConsumeMessageCommand:pullMessageByQueue (
  org.apache.rocketmq.common.message.MessageQueue mq, long minOffset,
  long maxOffset) {
  guard = pc ⊔ level(maxOffset) ⊔ level(minOffset) ⊔ level(mq) ⊔ level(this) ⊔ obj_level(mq) ⊔ obj_level(this) = ⊥;
  ret(obj_level(mq)) = ⊥;
  ret(obj_level(this)) = ⊥;
}