void org.apache.rocketmq.broker.transaction.AbstractTransactionalMessageCheckListener:sendCheckMessage (
  org.apache.rocketmq.common.message.MessageExt msgExt) {
  guard = tt;
  ret(obj_level(msgExt)) = pc ⊔ level(msgExt) ⊔ level(this) ⊔ obj_level(msgExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(msgExt) ⊔ level(this) ⊔ obj_level(msgExt) ⊔ obj_level(this);
}