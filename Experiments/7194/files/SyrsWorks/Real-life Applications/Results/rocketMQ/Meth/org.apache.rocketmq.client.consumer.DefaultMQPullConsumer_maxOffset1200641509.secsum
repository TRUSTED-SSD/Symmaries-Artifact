long org.apache.rocketmq.client.consumer.DefaultMQPullConsumer:maxOffset (
  org.apache.rocketmq.common.message.MessageQueue @mq) {
  guard = tt;
  ret(level()) = pc ⊔ level(@mq) ⊔ level(this) ⊔ obj_level(@mq) ⊔ obj_level(this);
  ret(obj_level(@mq)) = pc ⊔ level(@mq) ⊔ level(this) ⊔ obj_level(@mq) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@mq) ⊔ level(this) ⊔ obj_level(@mq) ⊔ obj_level(this);
}