boolean org.apache.rocketmq.store.timer.TimerMessageStore:doEnqueue (
  long offsetPy, int sizePy, long delayedTime,
  org.apache.rocketmq.common.message.MessageExt messageExt) {
  guard = tt;
  ret(level()) = pc ⊔ level(delayedTime) ⊔ level(messageExt) ⊔ level(offsetPy) ⊔ level(sizePy) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(messageExt)) = pc ⊔ level(delayedTime) ⊔ level(messageExt) ⊔ level(offsetPy) ⊔ level(sizePy) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(delayedTime) ⊔ level(messageExt) ⊔ level(offsetPy) ⊔ level(sizePy) ⊔ level(this) ⊔ obj_level(messageExt) ⊔ obj_level(this);
}