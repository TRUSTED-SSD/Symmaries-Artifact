static org.apache.commons.cli.Options org.apache.rocketmq.namesrv.NamesrvStartup:buildCommandlineOptions (
  org.apache.commons.cli.Options options) {
  guard = tt;
  ret(level()) = pc ⊔ level(options);
  ret(obj_level()) = pc ⊔ level(options) ⊔ obj_level(options);
  ret(obj_level(options)) = pc ⊔ level(options) ⊔ obj_level(options);
}