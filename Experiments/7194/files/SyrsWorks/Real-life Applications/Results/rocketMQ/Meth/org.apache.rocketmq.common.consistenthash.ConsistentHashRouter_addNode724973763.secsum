void org.apache.rocketmq.common.consistenthash.ConsistentHashRouter:addNode (
  org.apache.rocketmq.common.consistenthash.Node pNode, int vNodeCount) {
  guard = tt;
  ret(obj_level(pNode)) = pc ⊔ level(pNode) ⊔ level(this) ⊔ level(vNodeCount) ⊔ obj_level(pNode) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(pNode) ⊔ level(this) ⊔ level(vNodeCount) ⊔ obj_level(pNode) ⊔ obj_level(this);
}