java.lang.String org.apache.rocketmq.acl.common.AuthorizationHeader:hexToBase64(java.lang.String @input)
{
byte[] bytes;
  java.lang.String input;
input=@input;
bytes = org.apache.commons.codec.binary.Hex.decodeHex(input);
 input = org.apache.commons.codec.binary.Base64.encodeBase64String(bytes);
 return  input;
 } 

