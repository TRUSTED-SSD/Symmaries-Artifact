org.apache.rocketmq.broker.transaction.queue.TransactionalMessageServiceImpl (
  org.apache.rocketmq.broker.transaction.queue.TransactionalMessageBridge
    @transactionBridge) {
  guard = tt;
  ret(obj_level(@transactionBridge)) = pc ⊔ level(@transactionBridge) ⊔ level(this) ⊔ obj_level(@transactionBridge) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(@transactionBridge) ⊔ level(this) ⊔ obj_level(@transactionBridge) ⊔ obj_level(this);
}