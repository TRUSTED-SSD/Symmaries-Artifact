char org.apache.rocketmq.filter.parser.SimpleCharStream:BeginToken () {
  p0: '0 -> dummyClass ('0) -> level;
  p1: '0, '1, '2 -> java.io.Reader ('0, '1, '2) -> level;
  guard = tt;
  ret(level()) = p0 ⊔ p1 ⊔ pc ⊔ level(this) ⊔ obj_level(this);
  ret(obj_level(this)) = p0 ⊔ p1 ⊔ pc ⊔ level(this) ⊔ obj_level(this);
}