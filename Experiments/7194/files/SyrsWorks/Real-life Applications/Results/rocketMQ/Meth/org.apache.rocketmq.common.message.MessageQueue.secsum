org.apache.rocketmq.common.message.MessageQueue (java.lang.String topic,
                                                 java.lang.String brokerName,
                                                 int queueId) {
  guard = tt;
  ret(obj_level(brokerName)) = pc ⊔ level(this) ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(brokerName) ⊔ level(queueId) ⊔ level(this) ⊔ level(topic) ⊔ obj_level(brokerName) ⊔ obj_level(this);
  ret(obj_level(topic)) = pc ⊔ level(this) ⊔ obj_level(this) ⊔ obj_level(topic);
}