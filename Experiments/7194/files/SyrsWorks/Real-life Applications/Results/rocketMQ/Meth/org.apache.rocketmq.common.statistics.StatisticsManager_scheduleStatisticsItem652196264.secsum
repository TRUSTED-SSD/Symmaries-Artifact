void org.apache.rocketmq.common.statistics.StatisticsManager:scheduleStatisticsItem (
  org.apache.rocketmq.common.statistics.StatisticsItem item) {
  guard = tt;
  ret(obj_level(item)) = pc ⊔ level(item) ⊔ level(this) ⊔ obj_level(item) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(item) ⊔ level(this) ⊔ obj_level(item) ⊔ obj_level(this);
}