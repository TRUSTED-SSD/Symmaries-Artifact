apache.rocketmq.v2.TelemetryCommand org.apache.rocketmq.proxy.grpc.v2.client.ClientActivity:processClientSettings (
  org.apache.rocketmq.proxy.common.ProxyContext ctx,
  apache.rocketmq.v2.TelemetryCommand @request) {
  guard = tt;
  ret(level()) = pc ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level()) = pc ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level(@request)) = pc ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level(ctx)) = pc ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(ctx) ⊔ level(this) ⊔ obj_level(@request) ⊔ obj_level(ctx) ⊔ obj_level(this);
}