void org.apache.rocketmq.broker.processor.PopReviveService:rePutCK (org.apache.rocketmq.store.pop.PopCheckPoint
                                                                    oldCK,
                                                                    org.apache.rocketmq.common.Pair
                                                                    pair) {
  guard = tt;
  ret(obj_level(oldCK)) = pc ⊔ level(oldCK) ⊔ level(pair) ⊔ level(this) ⊔ obj_level(oldCK) ⊔ obj_level(pair) ⊔ obj_level(this);
  ret(obj_level(pair)) = pc ⊔ level(oldCK) ⊔ level(pair) ⊔ level(this) ⊔ obj_level(oldCK) ⊔ obj_level(pair) ⊔ obj_level(this);
  ret(obj_level(this)) = pc ⊔ level(oldCK) ⊔ level(pair) ⊔ level(this) ⊔ obj_level(oldCK) ⊔ obj_level(pair) ⊔ obj_level(this);
}