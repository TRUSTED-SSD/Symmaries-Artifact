AccountOwner (Account l1) {
  guard = tt;
  ret(obj_level(l1)) = if l1><this ∧ obj_level(l1) = ⊥ ∧ level(l1) ⊔ level(this) = ⊥ then pc else if obj_level(l1) = ⊤ ∨ l1><this ∧ level(l1) ⊔ level(this) = ⊤ then ⊤ else ⊥;
  ret(obj_level(this)) = pc ⊔ level(l1) ⊔ level(this) ⊔ obj_level(l1) ⊔ obj_level(this);
  ret(l1><this) = tt;
  exc(level()) = ⊥;
  exc(obj_level()) = ⊥;
  exc(obj_level(l1)) = if l1><this ∧ obj_level(l1) = ⊥ ∧ level(l1) ⊔ level(this) = ⊥ then pc else if obj_level(l1) = ⊤ ∨ l1><this ∧ level(l1) ⊔ level(this) = ⊤ then ⊤ else ⊥;
  exc(obj_level(this)) = pc ⊔ level(l1) ⊔ level(this) ⊔ obj_level(l1) ⊔ obj_level(this);
  exc(l1><this) = tt;
}