static junit.runner.BaseTestRunner
{
int $stack0;
  junit.runner.BaseTestRunner.fgMaxMessageLength=500;
 junit.runner.BaseTestRunner.fgFilterStack=1;
 $stack0=junit.runner.BaseTestRunner.fgMaxMessageLength;
 $stack0 = junit.runner.BaseTestRunner.getPreference("maxmessage",$stack0);
 junit.runner.BaseTestRunner.fgMaxMessageLength=$stack0;
 return;
 } 

