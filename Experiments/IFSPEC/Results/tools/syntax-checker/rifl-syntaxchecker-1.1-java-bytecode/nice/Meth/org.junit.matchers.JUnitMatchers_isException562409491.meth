static org.hamcrest.Matcher org.junit.matchers.JUnitMatchers:isException(org.hamcrest.Matcher @exceptionMatcher)
{
org.hamcrest.Matcher exceptionMatcher;
exceptionMatcher=@exceptionMatcher;
exceptionMatcher = org.junit.internal.matchers.StacktracePrintingMatcher.isException(exceptionMatcher);
 return  exceptionMatcher;
 } 

