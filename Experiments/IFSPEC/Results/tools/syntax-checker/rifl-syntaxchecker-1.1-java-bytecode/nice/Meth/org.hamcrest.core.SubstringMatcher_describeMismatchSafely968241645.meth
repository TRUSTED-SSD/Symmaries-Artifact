void org.hamcrest.core.SubstringMatcher:describeMismatchSafely(java.lang.String item,org.hamcrest.Description @mismatchDescription)
{
org.hamcrest.Description mismatchDescription;
mismatchDescription=@mismatchDescription;
mismatchDescription = mismatchDescription.appendText("was \"");
 mismatchDescription = mismatchDescription.appendText(item);
 mismatchDescription = mismatchDescription.appendText("\"");
 return;
 } 

